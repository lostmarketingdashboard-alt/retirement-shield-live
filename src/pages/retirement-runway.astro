<script is:inline>
const STATE_OPTIONS = [
  ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],['CA','California'],
  ['CO','Colorado'],['CT','Connecticut'],['DE','Delaware'],['FL','Florida'],['GA','Georgia'],
  ['HI','Hawaii'],['ID','Idaho'],['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],
  ['KY','Kentucky'],['LA','Louisiana'],['ME','Maine'],['MD','Maryland'],['MA','Massachusetts'],
  ['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],['MO','Missouri'],['MT','Montana'],
  ['NE','Nebraska'],['NV','Nevada'],['NH','New Hampshire'],['NJ','New Jersey'],['NM','New Mexico'],
  ['NY','New York'],['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
  ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],['SD','South Dakota'],
  ['TN','Tennessee'],['TX','Texas'],['UT','Utah'],['VT','Vermont'],['VA','Virginia'],['WA','Washington'],
  ['WV','West Virginia'],['WI','Wisconsin'],['WY','Wyoming']
];

const STATE_LONGEVITY = {
  CA: 84.0, FL: 83.2, NY: 83.4, NJ: 83.8, WA: 83.2, MA: 84.1, MD: 82.8, CO: 82.6,
  OR: 82.7, AZ: 82.1, TX: 80.9, NC: 80.7, GA: 80.1, PA: 81.3, OH: 79.8, MI: 79.9,
  TN: 78.9, SC: 79.4, AL: 77.9, LA: 76.8
};

const REGIONAL_COST_FACTOR = {
  below: 0.94,
  average: 1,
  above: 1.08
};

let latestRunwayPayload = null;

const stateSelect = document.getElementById('stateSelect');
const placeholderOption = document.createElement('option');
placeholderOption.value = '';
placeholderOption.textContent = 'Select your state...';
placeholderOption.disabled = true;
placeholderOption.selected = true;
stateSelect.appendChild(placeholderOption);

STATE_OPTIONS.forEach(([code, name]) => {
  const option = document.createElement('option');
  option.value = code;
  option.textContent = name;
  stateSelect.appendChild(option);
});

function formatMoney(value) {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(value || 0);
}

function parseMoney(value) {
  const parsed = Number(String(value || '').replace(/[^0-9.]/g, ''));
  return Number.isFinite(parsed) ? parsed : 0;
}

function parsePercent(value, fallback = 0) {
  const parsed = Number(String(value || '').replace(/[^0-9.-]/g, ''));
  return Number.isFinite(parsed) ? parsed : fallback;
}

function stateName(code) {
  return STATE_OPTIONS.find(([v]) => v === code)?.[1] ?? code;
}

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach((panel) => panel.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');
  document.querySelectorAll('[data-step-indicator]').forEach((item, index) => {
    const num = index + 1;
    item.classList.toggle('active', num === step);
    item.classList.toggle('done', num < step);
  });
  document.getElementById('progressText').textContent = `Step ${step} of 3`;
  document.getElementById('progressFill').style.width = `${(step / 3) * 100}%`;
  window.scrollTo({ top: document.getElementById('wizardSection').offsetTop - 76, behavior: 'smooth' });
}

function getLongevityTarget(stateCode, age) {
  const target = STATE_LONGEVITY[stateCode] || 81.5;
  return Math.max(target, age + 8);
}

function simulateRunway({ balance, netMonthlyDraw, annualReturnPct, inflationPct, maxMonths = 480 }) {
  let assets = balance;
  let currentMonthlyDraw = netMonthlyDraw;
  const annualReturn = annualReturnPct / 100;
  const monthlyReturn = Math.pow(1 + annualReturn, 1 / 12) - 1;
  const monthlyInflation = Math.pow(1 + (inflationPct / 100), 1 / 12) - 1;
  const checkpoints = [];

  for (let month = 1; month <= maxMonths; month += 1) {
    assets = assets * (1 + monthlyReturn) - currentMonthlyDraw;
    currentMonthlyDraw = currentMonthlyDraw * (1 + monthlyInflation);

    if ([12, 60, 120, 180].includes(month)) {
      checkpoints.push({ month, assets: Math.max(assets, 0) });
    }

    if (assets <= 0) {
      return { months: month, finalAssets: 0, depleted: true, checkpoints };
    }
  }

  return { months: maxMonths, finalAssets: assets, depleted: false, checkpoints };
}

function addMonthsToToday(months) {
  const date = new Date();
  date.setMonth(date.getMonth() + months);
  return date;
}

function formatMonthYear(date) {
  return date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}

function monthsToYearsText(months) {
  const years = months / 12;
  if (years >= 10) return `${years.toFixed(1)} years`;
  return `${years.toFixed(1)} years`;
}

function buildRunwayPayload() {
  const fullName = document.getElementById('fullName').value.trim();
  const stateCode = document.getElementById('stateSelect').value;
  const stateFullName = stateName(stateCode);
  const countyName = document.getElementById('countyName').value.trim();
  const currentAge = Number(document.getElementById('currentAge').value || 0);
  const savingsBalance = parseMoney(document.getElementById('savingsBalance').value);
  const monthlyWithdrawal = parseMoney(document.getElementById('monthlyWithdrawal').value);
  const monthlyGuaranteedIncome = parseMoney(document.getElementById('monthlyGuaranteedIncome').value);
  const expectedReturn = parsePercent(document.getElementById('expectedReturn').value, 5.5);
  const portfolioMix = document.getElementById('portfolioMix').value.trim();
  const inflationRate = parsePercent(document.getElementById('inflationRate').value, 2.8);
  const stressInflationRate = parsePercent(document.getElementById('stressInflationRate').value, 5.2);
  const regionalCostTier = document.getElementById('regionalCostTier').value;
  const runwayPriority = document.getElementById('runwayPriority').value;

  const regionalFactor = REGIONAL_COST_FACTOR[regionalCostTier] || 1;
  const netMonthlyDraw = Math.max(0, (monthlyWithdrawal * regionalFactor) - monthlyGuaranteedIncome);
  const longevityAge = getLongevityTarget(stateCode, currentAge);
  const yearsToLongevity = Math.max(0, longevityAge - currentAge);
  const monthsToLongevity = Math.round(yearsToLongevity * 12);

  const optimistic = simulateRunway({
    balance: savingsBalance,
    netMonthlyDraw,
    annualReturnPct: expectedReturn + 1.5,
    inflationPct: Math.max(1, inflationRate - 0.9),
    maxMonths: 600
  });

  const baseline = simulateRunway({
    balance: savingsBalance,
    netMonthlyDraw,
    annualReturnPct: expectedReturn,
    inflationPct: inflationRate,
    maxMonths: 600
  });

  const stress = simulateRunway({
    balance: savingsBalance,
    netMonthlyDraw,
    annualReturnPct: Math.max(-1, expectedReturn - 3.5),
    inflationPct: stressInflationRate,
    maxMonths: 600
  });

  const scenarioPayload = [
    {
      key: 'optimistic',
      name: 'Optimistic',
      tone: optimistic.depleted ? 'watch' : 'safe',
      annualReturnPct: expectedReturn + 1.5,
      inflationPct: Math.max(1, inflationRate - 0.9),
      result: optimistic
    },
    {
      key: 'baseline',
      name: 'Baseline',
      tone: baseline.months >= monthsToLongevity ? 'safe' : baseline.months >= monthsToLongevity * 0.75 ? 'watch' : 'risk',
      annualReturnPct: expectedReturn,
      inflationPct: inflationRate,
      result: baseline
    },
    {
      key: 'stress',
      name: 'Stress-Tested',
      tone: stress.months >= monthsToLongevity ? 'watch' : 'risk',
      annualReturnPct: Math.max(-1, expectedReturn - 3.5),
      inflationPct: stressInflationRate,
      result: stress
    }
  ];

  const baselineEndDate = addMonthsToToday(baseline.months);
  const longevityGapMonths = baseline.months - monthsToLongevity;
  const priorityText = {
    outliving: 'outliving assets',
    inflation: 'inflation pressure',
    market: 'market drawdowns'
  }[runwayPriority] || 'runway durability';

  const narrative = baseline.depleted
    ? `At the current withdrawal pattern, the baseline runway projects depletion around ${formatMonthYear(baselineEndDate)}. The main pressure points are ${priorityText}, a net monthly draw of about ${formatMoney(netMonthlyDraw)}, and inflation compounding the withdrawals over time.`
    : `Under the current assumptions, the baseline runway still has assets remaining after ${monthsToYearsText(baseline.months)}. The biggest variables are ${priorityText}, inflation, and whether portfolio returns stay close to the plan.`;

  return {
    fullName,
    stateCode,
    stateName: stateFullName,
    countyName,
    currentAge,
    savingsBalance,
    monthlyWithdrawal,
    monthlyGuaranteedIncome,
    expectedReturn,
    portfolioMix,
    inflationRate,
    stressInflationRate,
    regionalCostTier,
    regionalFactor,
    runwayPriority,
    netMonthlyDraw,
    longevityAge,
    yearsToLongevity,
    monthsToLongevity,
    scenarios: scenarioPayload,
    baselineMonths: baseline.months,
    baselineEndDate: baselineEndDate.toISOString(),
    narrative
  };
}

function renderRunwayReport(payload) {
  latestRunwayPayload = payload;
  const baselineScenario = payload.scenarios.find((s) => s.key === 'baseline');
  const baselineDate = new Date(payload.baselineEndDate);
  const longevityGapMonths = baselineScenario.result.months - payload.monthsToLongevity;

  document.getElementById('reportTitle').textContent = `The Retirement Runway for ${payload.fullName || 'Your Plan'}`;
  document.getElementById('reportSubtitle').textContent = `A saved money-lasts-until projection for ${payload.countyName || 'your county'}${payload.stateName ? `, ${payload.stateName}` : ''}, updated from your current retirement assumptions.`;
  document.getElementById('metaName').textContent = `Prepared for ${payload.fullName || '—'}`;
  document.getElementById('metaLocation').textContent = `${payload.countyName || 'County not entered'} · ${payload.stateName || 'State not entered'} longevity framing`;
  document.getElementById('metaDate').textContent = `Generated ${new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;

  document.getElementById('summaryCopy').textContent = payload.portfolioMix || payload.narrative;
  document.getElementById('benchmarkHeadline').textContent = `Local longevity benchmark: roughly age ${payload.longevityAge.toFixed(1)}`;
  document.getElementById('benchmarkCopy').textContent = `For planning purposes, this report is comparing the runway against a ${payload.stateName} longevity target near age ${payload.longevityAge.toFixed(1)}. That gives the user a clear sense of whether the plan runs short, lands near target, or extends beyond it.`;
  document.getElementById('baselineDateValue').textContent = formatMonthYear(baselineDate);
  document.getElementById('netDrawValue').textContent = formatMoney(payload.netMonthlyDraw);
  document.getElementById('longevityGapValue').textContent = `${Math.abs(longevityGapMonths / 12).toFixed(1)} yrs`;
  document.getElementById('baselineDateSub').textContent = `About ${monthsToYearsText(baselineScenario.result.months)} from today`;
  document.getElementById('netDrawSub').textContent = `${formatMoney(payload.monthlyWithdrawal)} spending less ${formatMoney(payload.monthlyGuaranteedIncome)} guaranteed income`;
  document.getElementById('longevityGapSub').textContent = longevityGapMonths >= 0 ? 'Runway extends beyond longevity target' : 'Runway ends before longevity target';
  document.getElementById('scenarioPill').textContent = `Regional cost factor ${payload.regionalFactor.toFixed(2)}x`;

  const scenarioGrid = document.getElementById('scenarioGrid');
  scenarioGrid.innerHTML = payload.scenarios.map((scenario) => {
    const endDate = addMonthsToToday(scenario.result.months);
    return `
      <div class="scenario-card ${scenario.tone}">
        <div class="scenario-name">${scenario.name}</div>
        <div class="scenario-date">${formatMonthYear(endDate)}</div>
        <div class="scenario-sub">${scenario.result.depleted ? `Assets project to run out in about ${monthsToYearsText(scenario.result.months)}.` : `Assets remain after ${monthsToYearsText(scenario.result.months)}.`}</div>
        <div class="scenario-list">
          <div class="scenario-list-item"><span>Return assumption</span><span>${scenario.annualReturnPct.toFixed(1)}%</span></div>
          <div class="scenario-list-item"><span>Inflation assumption</span><span>${scenario.inflationPct.toFixed(1)}%</span></div>
          <div class="scenario-list-item"><span>Months from today</span><span>${scenario.result.months}</span></div>
        </div>
      </div>
    `;
  }).join('');

  const timelineGrid = document.getElementById('timelineGrid');
  const checkpoints = baselineScenario.result.checkpoints.length
    ? baselineScenario.result.checkpoints
    : [{ month: 12, assets: payload.savingsBalance }, { month: 60, assets: payload.savingsBalance }, { month: 120, assets: payload.savingsBalance }, { month: 180, assets: payload.savingsBalance }];
  timelineGrid.innerHTML = checkpoints.map((checkpoint) => `
    <div class="timeline-card">
      <div class="year">${checkpoint.month / 12} years</div>
      <div class="value">${formatMoney(checkpoint.assets)}</div>
      <div class="sub">Estimated remaining balance if the baseline path holds</div>
    </div>
  `).join('');

  const signalGrid = document.getElementById('signalGrid');
  const signals = [
    {
      tone: payload.netMonthlyDraw <= payload.savingsBalance * 0.0035 ? 'good' : payload.netMonthlyDraw <= payload.savingsBalance * 0.005 ? 'warn' : 'bad',
      title: 'Current withdrawal pressure',
      text: `The plan is pulling about ${formatMoney(payload.netMonthlyDraw)} per month from assets after guaranteed income is counted.`
    },
    {
      tone: payload.inflationRate <= 3 ? 'good' : payload.inflationRate <= 4.5 ? 'warn' : 'bad',
      title: 'Inflation drag',
      text: `Baseline inflation is modeled at ${payload.inflationRate.toFixed(1)}%, with a stress case of ${payload.stressInflationRate.toFixed(1)}%.`
    },
    {
      tone: payload.expectedReturn >= 5 ? 'good' : payload.expectedReturn >= 3.5 ? 'warn' : 'bad',
      title: 'Return support',
      text: `The baseline expected return is ${payload.expectedReturn.toFixed(1)}%, which can materially alter the runway if missed for several years.`
    }
  ];
  signalGrid.innerHTML = signals.map((signal) => `
    <div class="signal-card">
      <div class="signal-badge ${signal.tone}">${signal.tone === 'good' ? 'Supportive' : signal.tone === 'warn' ? 'Watch closely' : 'Pressure point'}</div>
      <strong>${signal.title}</strong>
      <span>${signal.text}</span>
    </div>
  `).join('');

  const compareGrid = document.getElementById('compareGrid');
  compareGrid.innerHTML = [
    {
      label: 'Current Assets',
      value: formatMoney(payload.savingsBalance),
      sub: 'Starting investable balance entered into the tracker'
    },
    {
      label: 'Annual Net Draw',
      value: formatMoney(payload.netMonthlyDraw * 12),
      sub: 'Year-one draw after guaranteed income offsets'
    },
    {
      label: 'Longevity Planning Horizon',
      value: `${payload.longevityAge.toFixed(1)}`,
      sub: `Approximate local planning age from current age ${payload.currentAge}`
    }
  ].map((item) => `
    <div class="compare-card">
      <div class="label">${item.label}</div>
      <div class="value">${item.value}</div>
      <div class="sub">${item.sub}</div>
    </div>
  `).join('');

  document.getElementById('runwayCallout').textContent = payload.narrative;
}

function runAnalysisAnimation(payload) {
  document.getElementById('analysisSub').textContent = `Running runway scenarios for ${payload.fullName || 'your plan'} in ${payload.stateName || 'your state'}.`;
  ['analysisStep1','analysisStep2','analysisStep3','analysisStep4'].forEach((id, index) => {
    const el = document.getElementById(id);
    el.classList.remove('done');
    setTimeout(() => el.classList.add('done'), (index + 1) * 360);
  });
}

async function saveRunwayReport(payload) {
  const supabase = window.retirementRunwaySupabase;
  if (!supabase) return null;
  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const insertPayload = {
    user_id: userId,
    full_name: payload.fullName || null,
    state_code: payload.stateCode || null,
    state_name: payload.stateName || null,
    county_name: payload.countyName || null,
    current_age: payload.currentAge || null,
    savings_balance: payload.savingsBalance,
    monthly_withdrawal: payload.monthlyWithdrawal,
    monthly_guaranteed_income: payload.monthlyGuaranteedIncome,
    net_monthly_draw: payload.netMonthlyDraw,
    expected_return_pct: payload.expectedReturn,
    inflation_rate_pct: payload.inflationRate,
    stress_inflation_rate_pct: payload.stressInflationRate,
    regional_cost_tier: payload.regionalCostTier || null,
    baseline_runway_months: payload.baselineMonths,
    baseline_runway_end_date: payload.baselineEndDate,
    longevity_target_age: payload.longevityAge,
    report_title: `The Retirement Runway for ${payload.fullName || 'Your Plan'}`,
    report_payload: payload
  };

  const { error } = await supabase
    .from('retirement_runway_reports')
    .insert(insertPayload);

  if (error) {
    console.error('Failed to save Retirement Runway report:', error);
  }
}

function showGeneratedRunwayReport(payload) {
  renderRunwayReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  runAnalysisAnimation(payload);

  setTimeout(() => {
    document.getElementById('analysisSection').classList.remove('active');
    document.getElementById('reportSection').classList.add('active');
    document.getElementById('reportShell').classList.add('visible');
    document.getElementById('reportShell').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 1800);
}

function showHydratedRunwayReport(payload) {
  renderRunwayReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('reportSection').classList.add('active');
  document.getElementById('reportShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedRunwayReport(report) {
  const payload = report?.report_payload;
  if (!payload) return false;

  const fieldMap = {
    fullName: payload.fullName,
    countyName: payload.countyName,
    currentAge: payload.currentAge,
    savingsBalance: payload.savingsBalance ? String(payload.savingsBalance) : '',
    monthlyWithdrawal: payload.monthlyWithdrawal ? String(payload.monthlyWithdrawal) : '',
    monthlyGuaranteedIncome: payload.monthlyGuaranteedIncome ? String(payload.monthlyGuaranteedIncome) : '',
    expectedReturn: payload.expectedReturn ? String(payload.expectedReturn) : '',
    portfolioMix: payload.portfolioMix,
    inflationRate: payload.inflationRate ? String(payload.inflationRate) : '',
    stressInflationRate: payload.stressInflationRate ? String(payload.stressInflationRate) : ''
  };

  Object.entries(fieldMap).forEach(([id, value]) => {
    const input = document.getElementById(id);
    if (input && value !== undefined && value !== null) input.value = value;
  });

  if (payload.stateCode) document.getElementById('stateSelect').value = payload.stateCode;
  if (payload.regionalCostTier) document.getElementById('regionalCostTier').value = payload.regionalCostTier;
  if (payload.runwayPriority) document.getElementById('runwayPriority').value = payload.runwayPriority;

  showHydratedRunwayReport(payload);
  return true;
}

async function generateRunwayReport() {
  const payload = buildRunwayPayload();
  await saveRunwayReport(payload);
  showGeneratedRunwayReport(payload);
}

function editRunwayReport() {
  document.getElementById('reportSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(3);
}

window.nextStep = nextStep;
window.generateRunwayReport = generateRunwayReport;
window.editRunwayReport = editRunwayReport;
window.hydrateRetirementRunwayReport = hydrateSavedRunwayReport;
</script>
