---
export const prerender = false;
export const ssr = false;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Client Portal</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
  <div id="app"></div>

  <script type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'

    const supabase = createClient(
      "https://nyiturqeotdxucfdurzu.supabase.co",
      "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im55aXR1cnFlb3RkeHVjZmR1cnp1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIxMzI0ODgsImV4cCI6MjA4NzcwODQ4OH0.CvYju6UTaCGD_Zd-8FVTcB-yW9YVG_jQtwkd0l7mIV0",
      {
        auth: {
          persistSession: true,
          autoRefreshToken: true,
          detectSessionInUrl: true,
          flowType: 'pkce'
        }
      }
    )

    document.addEventListener('DOMContentLoaded', async () => {
      const { data: { session } } = await supabase.auth.getSession()

      if (!session || !session.user) {
        window.location.href = '/login'
        return
      }

      const user = session.user

      const { data: profile, error } = await supabase
        .from('profiles')
        .select('*')
        .eq('id', user.id)
        .single()

      if (error || !profile) {
        window.location.href = '/login'
        return
      }

      initializePortal(user, profile)
    })

    function initializePortal(user, profile) {
      const initials = profile.full_name
        ? profile.full_name.split(' ').map(n => n[0]).join('').slice(0,2).toUpperCase()
        : 'RS'

      const app = document.getElementById('app')

      app.innerHTML = `
        <div class="portal-root">

          <nav class="portal-nav">
            <div class="nav-left" onclick="window.location.href='/'">
              <div class="shield-icon"></div>
              <span class="brand">Retirement <span>Shield</span></span>
            </div>

            <div class="nav-right">
              <span class="badge">${profile.role.toUpperCase()} PORTAL</span>

              <div class="user-menu">
                <div class="avatar">${initials}</div>
                <div class="user-info">
                  <span class="user-name">${profile.full_name}</span>
                  <span class="user-role">${profile.role}</span>
                </div>
                <button id="logoutBtn" class="logout-btn">Sign Out</button>
              </div>
            </div>
          </nav>
 ${profile.role === 'user' ? `
          <section class="hero">
            <div class="hero-inner">
              <div class="hero-label">
                <span class="line"></span>
                Your Retirement Action Plan
              </div>

              <div class="hero-card">
                <div class="progress-wrap">
                  <div class="progress-ring">
                    <div class="progress-value">65%</div>
                    <div class="progress-label">Complete</div>
                  </div>
                </div>
  
                <div class="hero-main">
                  <h1>${profile.full_name ? profile.full_name.split(' ').slice(-1)[0] + ' Family Plan' : 'Your Family Plan'}</h1>
                  <p class="subtext">Prepared following your consultation with Lewis on February 18, 2026</p>

               
                  <div class="status-badges">
                    <span class="badge-complete">1 Completed</span>
                    <span class="badge-progress">2 In Progress</span>
                    <span class="badge-queued">2 Queued</span>
                  </div>
              
                </div>

                <div class="review-box">
                  <div class="review-label">Next Plan Review</div>
                  <div class="review-date">August 2026</div>
                  <div class="review-sub">6-month check-in</div>
                </div>
              </div>
            </div>
          </section>
    ` : ''}
          <div class="tabs-wrap">
            <div class="tabs">
              ${profile.role === 'admin' ? `
  <button class="tab active" data-tab="users">Users</button>
  <button class="tab" data-tab="tasks">Action Tasks</button>
  <button class="tab" data-tab="add-users">Add Users</button>
  <button class="tab" data-tab="assign-referrals">Assign Referral Members</button>
  <button class="tab" data-tab="team-members">Team Members</button>
  <button class="tab" data-tab="articles">Articles</button>
` : profile.role === 'referral' ? `
  <button class="tab active" data-tab="assigned-members">Assigned Members</button>
` : `
  <button class="tab active" data-tab="action">Action Plan</button>
  <button class="tab" data-tab="team">Your Team</button>
  <button class="tab" data-tab="timeline">Timeline</button>
  <button class="tab" data-tab="documents">Documents</button>
`}
            </div>
            <div class="tab-underline"></div>
          </div>

          <div class="content-wrap">
            <div id="portalContent"></div>
          </div>

          <footer class="portal-footer">
            © 2026 <strong>Retirement Shield</strong> · Educational use only
          </footer>

        </div>
      `

      document.getElementById('logoutBtn').addEventListener('click', async () => {
        await supabase.auth.signOut()
        window.location.href = '/'
      })

      const contentDiv = document.getElementById('portalContent')

      if (profile.role === 'user') {

        let actionPlan = [];

        async function loadActionPlan() {

          // 1. Load global templates
          const { data: templates } = await supabase
            .from('action_plan_templates')
            .select('*')
            .order('created_at', { ascending: true });

          if (!templates) {
            actionPlan = [];
            return;
          }

          const enrichedPlans = [];

          for (const template of templates) {

            // 2. Load template subtasks
            const { data: subtasks } = await supabase
              .from('action_plan_template_subtasks')
              .select('*')
              .eq('template_id', template.id)
              .order('created_at', { ascending: true });

            // 3. Load user progress for those subtasks
            const { data: progress } = await supabase
              .from('user_subtask_progress')
              .select('*')
              .eq('user_id', user.id);

            const mergedSubtasks = (subtasks || []).map(st => {
              const match = progress?.find(p => p.subtask_id === st.id);
              return {
                id: st.id,
                label: st.label,
                done: match ? match.done : false
              };
            });

            // 4. Auto-calc status from subtasks
            let status = 'queued';
            if (mergedSubtasks.length) {
              if (mergedSubtasks.every(s => s.done)) status = 'complete';
              else if (mergedSubtasks.some(s => s.done)) status = 'progress';
            }

            enrichedPlans.push({
              id: template.id,
              title: template.title,
              category: template.category,
              details: template.details,
              status,
              subtasks: mergedSubtasks
            });
          }

          actionPlan = enrichedPlans;
        }

        function calculateStats() {
          const completed = actionPlan.filter(a => a.status === 'complete').length
          const inProgress = actionPlan.filter(a => a.status === 'progress').length
          const queued = actionPlan.filter(a => a.status === 'queued').length
          return { completed, inProgress, queued }
        }

        async function renderPlan() {
          const stats = calculateStats()

          document.querySelector('.badge-complete').innerText = `${stats.completed} Completed`
          document.querySelector('.badge-progress').innerText = `${stats.inProgress} In Progress`
          document.querySelector('.badge-queued').innerText = `${stats.queued} Queued`

          // Preserve which card is open
          const openCard = document.querySelector('.plan-card.open')
          const openId = openCard ? openCard.dataset.id : null

          contentDiv.innerHTML = actionPlan.map(item => `
            <div class="plan-card ${item.status}" data-id="${item.id}">
              <div class="plan-header">
                <div class="plan-left">
                  <div class="plan-number"></div>
                  <div>
                    <h3>${item.title}</h3>
                    <div class="plan-category">${item.category ?? ''}</div>
                  </div>
                </div>
                <div class="plan-status">${item.status.replace('_',' ')}</div>
              </div>
              <div class="plan-body">
                <p>${item.details ?? ''}</p>
                ${item.subtasks.length > 0 ? `
                  <div class="subtasks">
                    ${item.subtasks.map((s, i) => `
                      <label class="subtask ${s.done ? 'done' : ''}">
                        <input type="checkbox" data-parent="${item.id}" data-index="${i}" ${s.done ? 'checked' : ''}>
                        <span class="custom-check"></span>
                        <span class="task-label">${s.label}</span>
                      </label>
                    `).join('')}
                  </div>
                ` : ''}
              </div>
            </div>
          `).join('')

          attachEvents()

          if (openId) {
            const restored = document.querySelector(`.plan-card[data-id="${openId}"]`)
            if (restored) restored.classList.add('open')
          }
        }

        // --- DOCUMENTS TAB FUNCTIONALITY ---
        function renderDocuments() {
          contentDiv.innerHTML = `
            <div class="doc-card">
              <div class="doc-header">
                <div class="doc-icon">📄</div>
                <div>
                  <h3>Estate Planning Assessment</h3>
                  <div class="doc-meta">Generated March 4, 2026 · Personalized Strategy Report</div>
                </div>
              </div>

              <div class="doc-body">
                <p>
                  This comprehensive estate planning report outlines your trust structure,
                  beneficiary designations, asset protection positioning, and retirement
                  income coordination strategy.
                </p>
              </div>

              <div class="doc-actions">
                <button class="view-pdf-btn" id="viewPdfBtn">View My PDF</button>
              </div>
            </div>
          `
          const pdfBtn = document.getElementById('viewPdfBtn')
          if (pdfBtn) {
            pdfBtn.addEventListener('click', () => {
              window.location.href = `/EstatePlanningAssessmentpdf/${user.id}`
            })
          }
        }

        async function renderTeam() {

          // Load ALL referral assignments for this user
          const { data: assignments } = await supabase
            .from('referral_assignments')
            .select('referral_id')
            .eq('user_id', user.id);

          if (!assignments || assignments.length === 0) {
            contentDiv.innerHTML = `
              <div class="doc-card">
                <div class="doc-header">
                  <div class="doc-icon">👥</div>
                  <div>
                    <h3>Your Consultant</h3>
                    <div class="doc-meta">Primary point of contact</div>
                  </div>
                </div>
                <div class="doc-body">
                  <p>
                    No consultant has been assigned to your plan yet.
                    Once a consultant is formally connected to your strategy,
                    their details will appear here.
                  </p>
                </div>
              </div>
            `;
            return;
          }

          const referralIds = assignments.map(a => a.referral_id);

          // Load all consultants linked to this user
          const { data: consultants } = await supabase
            .from('profiles')
            .select('id, full_name, email')
            .in('id', referralIds);

          const consultantCards = (consultants || []).map(c => `
            <div style="margin-top:14px;padding:16px;border:1px solid var(--rule-light);border-radius:12px;">
              <strong>${c.full_name ?? 'Your Consultant'}</strong>
              <div style="font-size:13px;color:var(--text-muted);margin-top:4px;">
                ${c.email ?? ''}
              </div>
            </div>
          `).join('');

          contentDiv.innerHTML = `
            <div class="doc-card">
              <div class="doc-header">
                <div class="doc-icon">👥</div>
                <div>
                  <h3>Your Consultant${consultants && consultants.length > 1 ? 's' : ''}</h3>
                  <div class="doc-meta">Primary point${consultants && consultants.length > 1 ? 's' : ''} of contact</div>
                </div>
              </div>
              <div class="doc-body">
                ${consultantCards}
              </div>
            </div>
          `;
        }

        function renderTimeline() {
          contentDiv.innerHTML = `
            <div class="doc-card">
              <div class="doc-header">
                <div class="doc-icon">🗓️</div>
                <div>
                  <h3>Implementation Timeline</h3>
                  <div class="doc-meta">Execution milestones & review schedule</div>
                </div>
              </div>

              <div class="doc-body">
                <p>
                  No implementation timeline has been generated yet.
                  Once your retirement action steps are formally scheduled,
                  milestone tracking and progress deadlines will appear here.
                </p>
              </div>
            </div>
          `
        }

        function attachEvents() {
          document.querySelectorAll('.plan-header').forEach(h => {
            h.onclick = () => {
              const card = h.parentElement
              const isOpen = card.classList.contains('open')

              // Close all cards first
              document.querySelectorAll('.plan-card').forEach(c => c.classList.remove('open'))

              // If it was not open before, open it
              if (!isOpen) {
                card.classList.add('open')
              }
            }
          })

          document.querySelectorAll('.subtask input').forEach(cb => {
            cb.onchange = async (e) => {
              const parentId = e.target.dataset.parent;
              const index = Number(e.target.dataset.index);

              const planItem = actionPlan.find(a => a.id === parentId);
              const subtask = planItem.subtasks[index];

              subtask.done = e.target.checked;

              await supabase
                .from('user_subtask_progress')
                .upsert({
                  user_id: user.id,
                  subtask_id: subtask.id,
                  done: subtask.done
                }, { onConflict: 'user_id,subtask_id' });

              renderPlan();
            }
          })
        }

        (async () => {
          await loadActionPlan();
          renderPlan();
        })();

        const tabs = document.querySelectorAll('.tab')

        tabs.forEach(tab => {
          tab.addEventListener('click', async () => {
            tabs.forEach(t => t.classList.remove('active'))
            tab.classList.add('active')

            const type = tab.dataset.tab

            if (type === 'action') {
              await loadActionPlan();
              renderPlan();
            }
            if (type === 'documents') renderDocuments()
            if (type === 'team') renderTeam()
            if (type === 'timeline') renderTimeline()
          })
        })
      }

      // --- ADMIN USERS TAB LOGIC ---
      if (profile.role === 'admin' || profile.role === 'referral') {

        async function renderUsers() {
          const { data: users } = await supabase
            .from('profiles')
            .select('*')
            .neq('role', 'referral')
            .order('created_at', { ascending: false })

          contentDiv.innerHTML = `
            <div class="doc-card">
              <div class="doc-header">
                <div class="doc-icon">👥</div>
                <div>
                  <h3>All Registered Users</h3>
                  <div class="doc-meta">Manage roles and permissions</div>
                </div>
              </div>

              <div class="doc-body">
                ${users.map(u => `
                  <div class="card user-card" data-user="${u.id}" style="margin-bottom:14px;">
                    <div class="user-row" style="display:flex; justify-content:space-between; align-items:center; cursor:pointer;">
                      <div>
                        <strong>${u.full_name ?? 'No Name'}</strong>
                        <div style="font-size:13px; color:var(--text-muted);">
                          ${u.email ?? ''}
                        </div>
                      </div>

                      <div style="display:flex; align-items:center; gap:10px;">
                        <select data-user="${u.id}" class="role-select" style="padding:6px 12px; border-radius:8px;">
                          <option value="user" ${u.role === 'user' ? 'selected' : ''}>User</option>
                          <option value="admin" ${u.role === 'admin' ? 'selected' : ''}>Admin</option>
                          <option value="referral" ${u.role === 'referral' ? 'selected' : ''}>Referral</option>
                        </select>

                        <button 
                          data-delete="${u.id}" 
                          class="delete-user-btn"
                          style="
                            background:#b84040;
                            color:white;
                            border:none;
                            padding:6px 14px;
                            border-radius:8px;
                            cursor:pointer;
                            font-size:12px;
                          ">
                          Delete
                        </button>
                      </div>
                    </div>
                    <div class="user-answers" style="display:none; margin-top:18px;"></div>
                  </div>
                `).join('')}
              </div>
            </div>
          `

          document.querySelectorAll('.role-select').forEach(select => {
            select.addEventListener('change', async (e) => {
              const userId = e.target.dataset.user
              const newRole = e.target.value

              await supabase
                .from('profiles')
                .update({ role: newRole })
                .eq('id', userId)

              renderUsers()
            })
          })

          document.querySelectorAll('.delete-user-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {
              const userId = e.target.dataset.delete

              const confirmed = confirm("Are you sure you want to permanently delete this user? This action cannot be undone.")

              if (!confirmed) return

              const { error } = await supabase
                .from('profiles')
                .delete()
                .eq('id', userId)

              if (error) {
                alert("Error deleting user.")
                console.error(error)
                return
              }

              renderUsers()
            })
          })

          // User row expand/collapse and show quiz answers
          document.querySelectorAll('.user-card').forEach(card => {
            card.querySelector('.user-row').addEventListener('click', async (e) => {

              // Prevent click from firing when clicking buttons/select
              if (e.target.closest('select') || e.target.closest('button')) return

              const userId = card.dataset.user
              const answersContainer = card.querySelector('.user-answers')

              // Toggle close if already open
              if (answersContainer.style.display === 'block') {
                answersContainer.style.display = 'none'
                answersContainer.innerHTML = ''
                return
              }

              // Close other open cards
              document.querySelectorAll('.user-answers').forEach(a => {
                a.style.display = 'none'
                a.innerHTML = ''
              })

              const { data, error } = await supabase
                .from('quiz_submissions')
                .select('answers')
                .eq('user_id', userId)
                .order('created_at', { ascending: false })
                .limit(1)
                .single()

              if (error || !data) {
                answersContainer.innerHTML = '<p style="color:red;">No quiz submission found.</p>'
                answersContainer.style.display = 'block'
                return
              }

              const answers = data.answers || {}

              answersContainer.innerHTML = `
                <table style="
                  width:100%;
                  border-collapse:collapse;
                  margin-top:10px;
                  font-size:14px;
                ">
                  ${Object.entries(answers).map(([key, value]) => `
                    <tr>
                      <td style="padding:8px; border:1px solid var(--rule-light); font-weight:600;">
                        ${key}
                      </td>
                      <td style="padding:8px; border:1px solid var(--rule-light);">
                        ${value}
                      </td>
                    </tr>
                  `).join('')}
                </table>
              `

              answersContainer.style.display = 'block'
            })
          })
        }

        async function renderActionTasks() {
          // --- Step 1: Add edit mode state ---
          let editingTemplateId = null;

          // Load existing templates
          const { data: templates } = await supabase
            .from('action_plan_templates')
            .select('*')
            .order('created_at', { ascending: true });

          contentDiv.innerHTML = `
            <div class="doc-card">
              <h3>Create Global Action Plan Template</h3>

              <input id="newTitle" placeholder="Title"
                style="width:100%;margin-bottom:10px;padding:10px;border-radius:8px;border:1px solid #ddd;">

              <input id="newCategory" placeholder="Category"
                style="width:100%;margin-bottom:14px;padding:10px;border-radius:8px;border:1px solid #ddd;">

              <div id="subtaskContainer"></div>

              <button id="addSubtaskBtn"
                style="margin-bottom:14px;background:#eee;border:none;padding:8px 14px;border-radius:6px;cursor:pointer;">
                + Add Checklist Item
              </button>

              <button id="createPlanBtn" class="view-pdf-btn">
                Create Template
              </button>
            </div>

            <div class="doc-card" style="margin-top:30px;">
              <h3>Existing Action Plan Templates</h3>

              <table style="width:100%;border-collapse:collapse;font-size:14px;">
                <thead>
                  <tr>
                    <th style="text-align:left;padding:8px;border-bottom:1px solid var(--rule-light);">Title</th>
                    <th style="text-align:left;padding:8px;border-bottom:1px solid var(--rule-light);">Category</th>
                    <th style="text-align:right;padding:8px;border-bottom:1px solid var(--rule-light);">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  ${(templates || []).map(t => `
                    <tr>
                      <td style="padding:8px;border-bottom:1px solid var(--rule-light);">${t.title}</td>
                      <td style="padding:8px;border-bottom:1px solid var(--rule-light);">${t.category ?? ''}</td>
                      <td style="padding:8px;border-bottom:1px solid var(--rule-light);text-align:right;">
                        <button data-edit="${t.id}" class="edit-template-btn" style="margin-right:8px;">Edit</button>
                        <button data-delete="${t.id}" style="background:#b84040;color:white;border:none;padding:6px 12px;border-radius:6px;">Delete</button>
                      </td>
                    </tr>
                  `).join('')}
                </tbody>
              </table>
            </div>
          `;

          // -------- Checklist logic --------
          const subtaskContainer = document.getElementById('subtaskContainer');
          const addSubtaskBtn = document.getElementById('addSubtaskBtn');

          function addSubtaskInput(value = '') {
            const wrapper = document.createElement('div');
            wrapper.style.display = 'flex';
            wrapper.style.gap = '8px';
            wrapper.style.marginBottom = '8px';

            wrapper.innerHTML = `
              <input type="text"
                class="subtask-input"
                placeholder="Checklist item"
                value="${value}"
                style="flex:1;padding:8px;border-radius:6px;border:1px solid #ddd;">
              <button class="remove-subtask"
                style="background:#b84040;color:white;border:none;padding:6px 10px;border-radius:6px;cursor:pointer;">
                ✕
              </button>
            `;

            wrapper.querySelector('.remove-subtask').addEventListener('click', () => {
              wrapper.remove();
            });

            subtaskContainer.appendChild(wrapper);
          }

          addSubtaskBtn.addEventListener('click', () => addSubtaskInput());

          // --- Step 3: Unified create/edit handler ---
          const createBtn = document.getElementById('createPlanBtn');
          createBtn.addEventListener('click', async () => {

            const title = document.getElementById('newTitle').value.trim();
            const category = document.getElementById('newCategory').value.trim();

            if (!title) return alert("Title required.");

            // --- EDIT MODE ---
            if (editingTemplateId) {

              await supabase
                .from('action_plan_templates')
                .update({ title, category })
                .eq('id', editingTemplateId);

              await supabase
                .from('action_plan_template_subtasks')
                .delete()
                .eq('template_id', editingTemplateId);

              const subtaskInputs = document.querySelectorAll('.subtask-input');
              const subtasks = [];

              subtaskInputs.forEach(input => {
                if (input.value.trim()) {
                  subtasks.push({
                    template_id: editingTemplateId,
                    label: input.value.trim()
                  });
                }
              });

              if (subtasks.length) {
                await supabase.from('action_plan_template_subtasks').insert(subtasks);
              }

              editingTemplateId = null;
              createBtn.innerText = "Create Template";
            }

            // --- CREATE MODE ---
            else {

              const { data: template, error } = await supabase
                .from('action_plan_templates')
                .insert({ title, category })
                .select()
                .single();

              if (error) return alert("Error creating template.");

              const subtaskInputs = document.querySelectorAll('.subtask-input');
              const subtasks = [];

              subtaskInputs.forEach(input => {
                if (input.value.trim()) {
                  subtasks.push({
                    template_id: template.id,
                    label: input.value.trim()
                  });
                }
              });

              if (subtasks.length) {
                await supabase.from('action_plan_template_subtasks').insert(subtasks);
              }
            }

            // Reset form
            document.getElementById('newTitle').value = '';
            document.getElementById('newCategory').value = '';
            subtaskContainer.innerHTML = '';

            renderActionTasks();
          });

          // -------- DELETE TEMPLATE --------
          document.querySelectorAll('[data-delete]').forEach(btn => {
            btn.addEventListener('click', async (e) => {

              const id = e.target.dataset.delete;
              if (!confirm("Delete this template?")) return;

              await supabase.from('action_plan_template_subtasks').delete().eq('template_id', id);
