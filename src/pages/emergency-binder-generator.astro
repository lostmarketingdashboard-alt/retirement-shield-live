@media (max-width: 768px) {
  .site-header { padding: 14px 16px; }
  .hero { padding: 54px 20px 72px; }
  .wizard-section,
  .analysis-section,
  .binder-section { padding-left: 16px; padding-right: 16px; }
  .sidebar-card,
