---
import { supabase } from '../../lib/supabase'

export async function getStaticPaths() {
  const { data } = await supabase
    .from('state_guides')
    .select('state_slug')

  return data.map(row => ({
    params: { state: row.state_slug }
  }))
}

const { state } = Astro.params

const { data: guide } = await supabase
  .from('state_guides')
  .select('*')
  .eq('state_slug', state)
  .single()

if (!guide) {
  throw new Error(`State guide not found: ${state}`)
}

const stateName = guide.state_name

const clean = (str) => {
  if (typeof str !== 'string') return str;

  try {
    // Attempt to properly re-decode broken UTF-8 (mojibake fix)
    str = decodeURIComponent(escape(str));
  } catch (e) {
    // If it fails, continue with original string
  }

  return str
    .replace(/â€”/g, '—')
    .replace(/â€“/g, '–')
    .replace(/â€™/g, '’')
    .replace(/â€œ/g, '“')
    .replace(/â€/g, '”')
    .replace(/Â§/g, '§')
    .replace(/Â/g, '');
};
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<style>
  :root {
    --navy: #0f1f3d;
    --navy-mid: #1a3260;
    --gold: #c9973a;
    --gold-light: #e8b84b;
    --slate: #4a5568;
    --light-bg: #f7f8fc;
    --white: #ffffff;
    --green: #2d7a4f;
    --orange: #c05c1a;
    --border: #e2e8f0;
    --text: #1a202c;
    --text-muted: #718096;
  }

  :global(html), :global(body) {
    margin: 0;
    padding: 0;
    width: 100vw;
    max-width: 100%;
    height: 100%;
    background: var(--light-bg);
    overflow-x: hidden;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  h1, h2, h3, h4 {
    font-family: 'Playfair Display', serif;
  }
  body {
    font-family: 'DM Sans', sans-serif;
    color: var(--text);
    min-height: 100vh;
  }

  /* ── HEADER ── */
  .site-header {
    background: var(--navy);
    padding: 16px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 20px rgba(0,0,0,0.3);
    width: 100%;
    max-width: 100%;
    margin: 0;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .logo-shield {
    width: 36px;
    height: 36px;
  }
  .logo-text {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    color: var(--white);
    font-weight: 600;
    letter-spacing: 0.3px;
  }
  .logo-text span { color: var(--gold); }
  .header-badge {
    background: rgba(201,151,58,0.15);
    border: 1px solid var(--gold);
    color: var(--gold-light);
    font-size: 12px;
    font-weight: 500;
    padding: 4px 12px;
    border-radius: 20px;
    letter-spacing: 0.5px;
  }

  /* ── HERO BANNER ── */
  .hero {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 60%, #1d3a6e 100%);
    padding: 60px 40px 50px;
    position: relative;
    overflow: hidden;
    width: 100%;
    max-width: 100%;
    margin: 0;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(201,151,58,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--gold);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .hero-eyebrow::before {
    content: '';
    width: 24px; height: 2px;
    background: var(--gold);
    display: block;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 5vw, 52px);
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 16px;
    font-weight: 700;
  }
  .hero h1 em {
    color: var(--gold-light);
    font-style: normal;
  }
  .hero-sub {
    color: rgba(255,255,255,0.72);
    font-size: 17px;
    line-height: 1.6;
    max-width: 560px;
    margin-bottom: 32px;
  }
  .hero-stats {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
    align-items: flex-start;
  }
  .hero-stat {
    border-left: 2px solid var(--gold);
    padding-left: 16px;
    min-width: 160px;
    max-width: 280px;
  }
  .hero-stat-val {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    color: var(--white);
    font-weight: 700;
    line-height: 1.2;
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  .hero-stat-label {
    font-size: 12px;
    color: rgba(255,255,255,0.55);
    margin-top: 4px;
    font-weight: 400;
    letter-spacing: 0.3px;
  }

  /* ── MAIN LAYOUT ── */
  .page-body {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
    padding: 48px 24px 80px;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 36px;
    align-items: start;
  }

  /* ── KEY FACTS CARD (sidebar) ── */
  .sidebar {
    position: sticky;
    top: 80px;
  }
  .facts-card {
    background: var(--white);
    border-radius: 16px;
    box-shadow: 0 4px 30px rgba(0,0,0,0.08);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .facts-header {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    padding: 22px 24px;
  }
  .facts-header-eyebrow {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 6px;
  }
  .facts-header h3 {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    color: var(--white);
    font-weight: 600;
  }
  .facts-header p {
    font-size: 12px;
    color: rgba(255,255,255,0.55);
    margin-top: 4px;
  }
  .facts-list {
    padding: 0 24px;
  }
  .fact-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    gap: 12px;
  }
  .fact-row:last-child { border-bottom: none; }
  .fact-label {
    font-size: 14px;
    color: var(--slate);
    font-weight: 400;
    flex: 1;
  }
  .fact-val {
    font-size: 14px;
    font-weight: 600;
    white-space: nowrap;
  }
  .val-green { color: var(--green); }
  .val-orange { color: var(--orange); }
  .val-navy { color: var(--navy); }
  .val-check::before { content: '✓ '; }

  .cta-box {
    margin: 0 24px 24px;
    background: linear-gradient(135deg, #fff8ec 0%, #fef3d8 100%);
    border: 1px solid #e8c97a;
    border-radius: 12px;
    padding: 20px;
    text-align: center;
  }
  .cta-box h4 {
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .cta-box p {
    font-size: 12px;
    color: var(--slate);
    margin-bottom: 14px;
    line-height: 1.5;
  }
  .cta-btn {
    display: block;
    background: var(--navy);
    color: var(--white);
    text-decoration: none;
    padding: 11px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    transition: background 0.2s;
    cursor: pointer;
    border: none;
    width: 100%;
  }
  .cta-btn:hover { background: var(--gold); color: var(--navy); }

  /* ── MAIN CONTENT ── */
  .main-content {}

  .section {
    background: var(--white);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 24px;
    border: 1px solid var(--border);
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
  }

  .section-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
  }
  .section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    color: var(--navy);
    margin-bottom: 14px;
    font-weight: 700;
    line-height: 1.25;
  }
  .section p {
    font-size: 15px;
    color: var(--slate);
    line-height: 1.75;
    margin-bottom: 14px;
  }
  .section p:last-child { margin-bottom: 0; }

  /* Alert boxes */
  .alert {
    border-radius: 10px;
    padding: 16px 20px;
    margin: 20px 0;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .alert-icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }
  .alert-body { flex: 1; }
  .alert-title { font-weight: 600; font-size: 14px; margin-bottom: 4px; }
  .alert-text { font-size: 13px; line-height: 1.6; }
  .alert-green { background: #edfaf4; border-left: 3px solid var(--green); }
  .alert-green .alert-title { color: var(--green); }
  .alert-green .alert-text { color: #2d4a3e; }
  .alert-orange { background: #fff5ec; border-left: 3px solid var(--orange); }
  .alert-orange .alert-title { color: var(--orange); }
  .alert-orange .alert-text { color: #5a3010; }
  .alert-navy { background: #eef2fa; border-left: 3px solid var(--navy); }
  .alert-navy .alert-title { color: var(--navy); }
  .alert-navy .alert-text { color: #2a3a5c; }

  /* Data table */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 14px;
  }
  .data-table th {
    text-align: left;
    padding: 10px 14px;
    background: #f0f4fb;
    color: var(--navy);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.5px;
    border-bottom: 2px solid var(--border);
  }
  .data-table td {
    padding: 12px 14px;
    border-bottom: 1px solid var(--border);
    color: var(--slate);
    vertical-align: top;
  }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:nth-child(even) td { background: #fbfcff; }
  .badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
  }
  .badge-green { background: #d4f5e5; color: var(--green); }
  .badge-orange { background: #fde8d2; color: var(--orange); }
  .badge-navy { background: #dde6f5; color: var(--navy); }

  /* Checklist */
  .checklist { list-style: none; margin: 16px 0; }
  .checklist li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 8px 0;
    font-size: 15px;
    color: var(--slate);
    border-bottom: 1px solid #f0f0f0;
    line-height: 1.5;
  }
  .checklist li:last-child { border-bottom: none; }
  .check-icon {
    width: 22px; height: 22px;
    background: var(--navy);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: white;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .check-label { font-weight: 600; color: var(--navy); display: block; margin-bottom: 2px; font-size: 14px; }
  .check-detail { font-size: 13px; color: var(--slate); }

  /* Blurred / gated section */
  .gated-wrapper {
    position: relative;
    margin-bottom: 24px;
  }
  .gated-content {
    filter: blur(2px);
    user-select: none;
    pointer-events: none;
    background: var(--white);
    border-radius: 16px;
    padding: 32px;
    border: 1px solid var(--border);
  }
  .gate-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-start; /* move box to top */
    justify-content: center;
    padding-top: 40px; /* space from top of blurred section */
    z-index: 10;
    border-radius: 16px;
    background: linear-gradient(
      180deg,
      rgba(247,248,252,0.6) 0%,
      rgba(247,248,252,0.45) 40%,
      rgba(247,248,252,0.35) 100%
    );
  }
  .gate-box {
    background: var(--white);
    border-radius: 16px;
    padding: 36px 40px;
    text-align: center;
    box-shadow: 0 8px 40px rgba(0,0,0,0.14);
    border: 1px solid var(--border);
    max-width: 420px;
    width: 90%;
  }
  .gate-icon { font-size: 40px; margin-bottom: 14px; display: block; }
  .gate-box h3 {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .gate-box p {
    font-size: 14px;
    color: var(--slate);
    line-height: 1.6;
    margin-bottom: 22px;
  }
  .gate-form { display: flex; flex-direction: column; gap: 12px; }
  .gate-form input {
    padding: 13px 16px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }
  .gate-form input:focus { border-color: var(--navy); }
  .gate-submit {
    background: var(--navy);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 14px 20px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
  }
  .gate-submit:hover { background: #1a3a6e; transform: translateY(-1px); }
  .gate-fine-print {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 8px;
  }

  /* Progress bar */
  .progress-section {
    background: var(--white);
    border-radius: 16px;
    padding: 28px 32px;
    margin-bottom: 24px;
    border: 1px solid var(--border);
  }
  .progress-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 18px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .risk-meter {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .risk-row {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .risk-label {
    font-size: 13px;
    color: var(--slate);
    width: 160px;
    flex-shrink: 0;
  }
  .risk-bar-bg {
    flex: 1;
    height: 8px;
    background: #e8edf5;
    border-radius: 4px;
    overflow: hidden;
  }
  .risk-bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 1s ease;
  }
  .risk-value {
    font-size: 13px;
    font-weight: 600;
    width: 48px;
    text-align: right;
    flex-shrink: 0;
  }

  /* Disclaimer */
  .disclaimer {
    background: #f5f6fa;
    border: 1px solid #dde3f0;
    border-radius: 10px;
    padding: 16px 20px;
    margin-top: 32px;
    font-size: 11.5px;
    color: #8896b3;
    line-height: 1.7;
  }
  .disclaimer strong { color: var(--slate); }

  /* Footer */
  footer {
    background: var(--navy);
    color: rgba(255,255,255,0.5);
    text-align: center;
    padding: 28px;
    font-size: 12px;
    margin-top: 40px;
    width: 100%;
    max-width: 100%;
  }
  footer strong { color: rgba(255,255,255,0.8); }

  @media (max-width: 768px) {
    :global(body) {
      overflow-x: hidden;
    }


.main-content {
      width: 50%;
      max-width: 100%;
      margin-left: -1%;
      grid-template-columns: 1fr;
      padding: 32px 16px 60px;
    }

    .sidebar {
      position: static;
    }


    .header-badge {
      font-size: 10px;
      padding: 4px 8px;
    }

    .site-header {
      padding: 14px 16px;
    }
    .hero {
      padding: 36px 16px 32px;
      border-radius: 0;
    }
    footer {
      padding: 24px 16px;
    }


    /* --- Mobile hero adjustments --- */
    .hero-inner {
      max-width: 100%;
    }

    .hero h1 {
      font-size: 28px;
      line-height: 1.2;
    }

    .hero-sub {
      font-size: 14px;
      max-width: 100%;
    }

    .hero-stats {
      flex-direction: column;
      gap: 18px;
      width: 100%;
    }

    .hero-stat {
      border-left: none;
      border-top: 2px solid var(--gold);
      padding-left: 0;
      padding-top: 10px;
      width: 100%;
      min-width: 0;
      max-width: 100%;
    }

    .hero-stat-val {
      font-size: 20px;
    }
    /* --- End mobile hero adjustments --- */

    .section {
      padding: 24px 18px;
    }

    .data-table {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
      -webkit-overflow-scrolling: touch;
    }

    .data-table th,
    .data-table td {
      padding: 10px 12px;
      font-size: 13px;
    }

    .checklist li {
      padding: 10px 0;
    }

    .risk-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
    }

    .risk-label {
      width: 100%;
    }

    .risk-value {
      text-align: left;
      width: auto;
    }

    .facts-card {
      margin-top: 20px;
    }

    .cta-box {
      padding: 18px;
    }

    .gate-box {
      padding: 24px 18px;
    }

    .section,
    .progress-section,
    .gated-content,
    .facts-card,
    .cta-box {
      width: 100%;
      max-width: 100%;
    }
  }
</style>

<!-- HEADER -->
<header class="site-header">
  <a class="logo" href="#" onclick="if(document.referrer){history.back()}else{window.location.href='/'}">
 
    <span class="logo-text">Retirement <span>Shield</span></span>
  </a>
  <div class="header-badge">Free State Guide</div>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-eyebrow">{clean(guide.hero_eyebrow)}</div>
    <h1>{clean(guide.hero_h1_line1)}<br><em>{clean(guide.hero_h1_line2)}</em></h1>
    <p class="hero-sub">{clean(guide.hero_sub)}</p>
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-val">{clean(guide.hero_stat1_val)}</div>
        <div class="hero-stat-label">{guide.hero_stat1_label}</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-val">{clean(guide.hero_stat2_val)}</div>
        <div class="hero-stat-label">{guide.hero_stat2_label}</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-val">{clean(guide.hero_stat3_val)}</div>
        <div class="hero-stat-label">{guide.hero_stat3_label}</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-val">{clean(guide.hero_stat4_val)}</div>
        <div class="hero-stat-label">{guide.hero_stat4_label}</div>
      </div>
    </div>
  </div>
</section>

<!-- PAGE BODY -->
<div class="page-body">


  <!-- MAIN CONTENT -->
  <main class="main-content">

    <!-- SECTION 1: Overview -->
    <div class="section">
      <div class="section-eyebrow">Why This Matters</div>
      <h2>{stateName} Estate Planning — What Retirees Need to Know in 2026</h2>

      <p>{clean(guide.overview_intro_paragraph)}</p>

      <div class="alert alert-green">
        <div class="alert-icon">✅</div>
        <div class="alert-body">
          <div class="alert-title">{clean(guide.alert_good_news_title)}</div>
          <div class="alert-text">{clean(guide.alert_good_news_body)}</div>
        </div>
      </div>

      <div class="alert alert-orange">
        <div class="alert-icon">⚠️</div>
        <div class="alert-body">
          <div class="alert-title">{clean(guide.alert_watch_out_title)}</div>
          <div class="alert-text">{clean(guide.alert_watch_out_body)}</div>
        </div>
      </div>
    </div>

    <div class="gated-wrapper" id="gated-section">
      <div class="gated-content">
    <!-- SECTION 2: Key Facts Table -->
    <div class="section">
      <div class="section-eyebrow">At a Glance</div>
      <h2>Key {stateName} Estate Planning Facts for 2026</h2>

      <table class="data-table">
        <thead>
          <tr>
            <th>Topic</th>
            <th>{stateName} Rule</th>
            <th>Risk Level</th>
          </tr>
        </thead>
        <tbody>

          <tr>
            <td><strong>State Estate Tax</strong></td>
            <td>{guide.state_estate_tax}</td>
