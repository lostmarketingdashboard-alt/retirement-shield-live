<script is:inline>
const CURRENT_DATE = new Date('2026-04-15T12:00:00');
const CURRENT_YEAR = 2026;
const STATE_OPTIONS = [
  ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],['CA','California'],
  ['CO','Colorado'],['CT','Connecticut'],['DE','Delaware'],['FL','Florida'],['GA','Georgia'],
  ['HI','Hawaii'],['ID','Idaho'],['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],
  ['KY','Kentucky'],['LA','Louisiana'],['ME','Maine'],['MD','Maryland'],['MA','Massachusetts'],
  ['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],['MO','Missouri'],['MT','Montana'],
  ['NE','Nebraska'],['NV','Nevada'],['NH','New Hampshire'],['NJ','New Jersey'],['NM','New Mexico'],
  ['NY','New York'],['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
  ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],['SD','South Dakota'],
  ['TN','Tennessee'],['TX','Texas'],['UT','Utah'],['VT','Vermont'],['VA','Virginia'],['WA','Washington'],
  ['WV','West Virginia'],['WI','Wisconsin'],['WY','Wyoming']
];
const STATE_LONGEVITY = {
  CA: 84.0, FL: 83.2, NY: 83.4, NJ: 83.8, WA: 83.2, MA: 84.1, MD: 82.8, CO: 82.6,
  OR: 82.7, AZ: 82.1, TX: 80.9, NC: 80.7, GA: 80.1, PA: 81.3, OH: 79.8, MI: 79.9,
  TN: 78.9, SC: 79.4, AL: 77.9, LA: 76.8
};
const UNIFORM_LIFETIME_DIVISORS = {
  72:27.4,73:26.5,74:25.5,75:24.6,76:23.7,77:22.9,78:22.0,79:21.1,80:20.2,81:19.4,
  82:18.5,83:17.7,84:16.8,85:16.0,86:15.2,87:14.4,88:13.7,89:12.9,90:12.2,91:11.5,
  92:10.8,93:10.1,94:9.5,95:8.9,96:8.4,97:7.8,98:7.3,99:6.8,100:6.4,101:6.0,
  102:5.6,103:5.2,104:4.9,105:4.6,106:4.3,107:4.1,108:3.9,109:3.7,110:3.5,111:3.4,
  112:3.3,113:3.1,114:3.0,115:2.9,116:2.8,117:2.7,118:2.5,119:2.3,120:2.0
};

let latestRmdPayload = null;

const stateSelect = document.getElementById('stateSelect');
const placeholderOption = document.createElement('option');
placeholderOption.value = '';
placeholderOption.textContent = 'Select your state...';
placeholderOption.disabled = true;
placeholderOption.selected = true;
stateSelect.appendChild(placeholderOption);

STATE_OPTIONS.forEach(([code, name]) => {
  const option = document.createElement('option');
  option.value = code;
  option.textContent = name;
  stateSelect.appendChild(option);
});

function formatMoney(value) {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(value || 0);
}

function formatPercent(value) {
  return `${Number(value || 0).toFixed(1)}%`;
}

function parseMoney(value) {
  const parsed = Number(String(value || '').replace(/[^0-9.]/g, ''));
  return Number.isFinite(parsed) ? parsed : 0;
}

function parsePercent(value, fallback = 0) {
  const parsed = Number(String(value || '').replace(/[^0-9.-]/g, ''));
  return Number.isFinite(parsed) ? parsed : fallback;
}

function stateName(code) {
  return STATE_OPTIONS.find(([v]) => v === code)?.[1] ?? code;
}

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach((panel) => panel.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');
  document.querySelectorAll('[data-step-indicator]').forEach((item, index) => {
    const num = index + 1;
    item.classList.toggle('active', num === step);
    item.classList.toggle('done', num < step);
  });
  document.getElementById('progressText').textContent = `Step ${step} of 3`;
  document.getElementById('progressFill').style.width = `${(step / 3) * 100}%`;
  window.scrollTo({ top: document.getElementById('wizardSection').offsetTop - 76, behavior: 'smooth' });
}

function getGeoScalar(zip) {
  const z = parseInt(zip, 10) || 33101;
  if ((z >= 33101 && z <= 33299) || (z >= 80400 && z <= 80699) || (z >= 96700 && z <= 96899) || (z >= 10001 && z <= 10099)) return 0.92;
  if ((z >= 38600 && z <= 39999) || (z >= 24700 && z <= 26899)) return 1.12;
  return 1.0;
}

function getRequiredBeginningAge(birthYear) {
  if (birthYear <= 1950) return 72;
  if (birthYear <= 1959) return 73;
  return 75;
}

function getLongevityAge(stateCode, currentAge, zipCode) {
  const base = STATE_LONGEVITY[stateCode] || 81.5;
  const geoScalar = getGeoScalar(zipCode);
  const yearsAdjustment = (1 - geoScalar) * 10;
  return Math.max(currentAge + 6, base + yearsAdjustment);
}

function getDivisor(age) {
  if (UNIFORM_LIFETIME_DIVISORS[age]) return UNIFORM_LIFETIME_DIVISORS[age];
  if (age < 72) return UNIFORM_LIFETIME_DIVISORS[72];
  return UNIFORM_LIFETIME_DIVISORS[120];
}

function formatDate(date) {
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

function addDays(date, days) {
  const copy = new Date(date);
  copy.setDate(copy.getDate() + days);
  return copy;
}

function determineDeadline(stage) {
  if (stage === 'first_year') return new Date('2027-04-01T12:00:00');
  if (stage === 'ongoing') return new Date('2026-12-31T12:00:00');
  return null;
}

async function resolveZipLocation(zip) {
  const supabase = window.rmdCalendarSupabase;
  if (!supabase || !zip || zip.length !== 5) return null;
  const { data, error } = await supabase
    .from('zip_county_lookup')
    .select('county_name, state_name')
    .eq('zip', zip)
    .maybeSingle();
  if (error || !data) return null;
  return data;
}

document.getElementById('zipCode').addEventListener('blur', async () => {
  const zip = document.getElementById('zipCode').value.trim();
  const location = await resolveZipLocation(zip);
  if (!location) return;
  if (!document.getElementById('countyName').value.trim()) {
    document.getElementById('countyName').value = `${location.county_name} County`;
  }
  const stateCode = STATE_OPTIONS.find(([, name]) => name === location.state_name)?.[0];
  if (stateCode && !document.getElementById('stateSelect').value) {
    document.getElementById('stateSelect').value = stateCode;
  }
});

function buildProjection(balance, startAge, startYear, years, growthRate, federalTaxRate, stateTaxRate, otherIncome) {
  const rows = [];
  let startingBalance = balance;

  for (let offset = 0; offset < years; offset += 1) {
    const age = startAge + offset;
    const divisor = getDivisor(age);
    const rmd = divisor > 0 ? startingBalance / divisor : 0;
    const federalTax = rmd * (federalTaxRate / 100);
    const stateTax = rmd * (stateTaxRate / 100);
    const totalTax = federalTax + stateTax;
    const afterTax = rmd - totalTax;
    const endingBalance = Math.max(0, (startingBalance - rmd) * (1 + growthRate / 100));
    const combinedIncome = otherIncome + rmd;

    rows.push({
      year: startYear + offset,
      age,
      divisor,
      startingBalance,
      rmd,
      federalTax,
      stateTax,
      totalTax,
      afterTax,
      endingBalance,
      combinedIncome
    });

    startingBalance = endingBalance;
  }

  return rows;
}

function buildReminderDates(deadline) {
  if (!deadline) return [];
  return [
    { label: '90 days before', date: addDays(deadline, -90), type: 'ninety_day' },
    { label: '30 days before', date: addDays(deadline, -30), type: 'thirty_day' },
    { label: '7 days before', date: addDays(deadline, -7), type: 'seven_day' }
  ]
    .filter((item) => item.date >= CURRENT_DATE)
    .map((item) => ({ ...item, date: item.date.toISOString() }));
}

function buildNarrative(payload) {
  const nextRow = payload.projectionRows[0];
  const lastRow = payload.projectionRows[payload.projectionRows.length - 1];
  return `The current estimate shows an RMD of about ${formatMoney(nextRow.rmd)} due by ${formatDate(payload.nextDeadline)}. At the entered tax rates, that year's distribution may create roughly ${formatMoney(nextRow.totalTax)} of tax drag. If the account grows near ${formatPercent(payload.growthRate)}, the projected annual RMD rises to about ${formatMoney(lastRow.rmd)} by age ${lastRow.age}. ${payload.notes ? payload.notes : 'That is why this should be treated like an annual operating calendar item, not a one-time tax task.'}`;
}

function buildRmdPayload() {
  const fullName = document.getElementById('fullName').value.trim();
  const currentAge = Number(document.getElementById('currentAge').value || 0);
  const stateCode = document.getElementById('stateSelect').value;
  const stateFullName = stateName(stateCode);
  const zipCode = document.getElementById('zipCode').value.trim();
  const countyName = document.getElementById('countyName').value.trim();
  const filingStatus = document.getElementById('filingStatus').value;
  const rmdStage = document.getElementById('rmdStage').value;
  const priorYearEndBalance = parseMoney(document.getElementById('priorYearEndBalance').value);
  const otherTaxableIncome = parseMoney(document.getElementById('otherTaxableIncome').value);
  const growthRate = parsePercent(document.getElementById('growthRate').value, 5);
  const federalTaxRate = parsePercent(document.getElementById('federalTaxRate').value, 22);
  const stateTaxRate = parsePercent(document.getElementById('stateTaxRate').value, 0);
  const projectionYears = Number(document.getElementById('projectionYears').value || 10);
  const reminderPreference = document.getElementById('reminderPreference').value;
  const distributionIntent = document.getElementById('distributionIntent').value;
  const notes = document.getElementById('notes').value.trim();

  const birthYear = CURRENT_YEAR - currentAge;
  const requiredBeginningAge = getRequiredBeginningAge(birthYear);
  const firstRmdYear = birthYear + requiredBeginningAge;
  const isRmdEligible = CURRENT_YEAR >= firstRmdYear;
  const inferredStage = !isRmdEligible ? 'not_yet' : (rmdStage || 'ongoing');
  const nextDeadline = determineDeadline(inferredStage) || new Date(`${firstRmdYear}-12-31T12:00:00`);
  const projectionStartAge = Math.max(requiredBeginningAge, currentAge);
  const projectionStartYear = Math.max(CURRENT_YEAR, firstRmdYear);
  const longevityAge = getLongevityAge(stateCode, currentAge, zipCode);
  const projectionLimit = Math.max(1, Math.min(projectionYears, Math.ceil(longevityAge - projectionStartAge + 1)));
  const projectionRows = buildProjection(
    priorYearEndBalance,
    projectionStartAge,
    projectionStartYear,
    projectionLimit,
    growthRate,
    federalTaxRate,
    stateTaxRate,
    otherTaxableIncome
  );
  const reminderDates = buildReminderDates(nextDeadline);
  const nextRow = projectionRows[0];
  const planningYears = Math.max(0, longevityAge - projectionStartAge);
  const narrative = buildNarrative({
    projectionRows,
    nextDeadline,
    growthRate,
    notes
  });

  return {
    fullName,
    currentAge,
    birthYear,
    stateCode,
    stateName: stateFullName,
    zipCode,
    countyName,
    filingStatus,
    rmdStage: inferredStage,
    requiredBeginningAge,
    firstRmdYear,
    priorYearEndBalance,
    otherTaxableIncome,
    growthRate,
    federalTaxRate,
    stateTaxRate,
    projectionYears: projectionLimit,
    reminderPreference,
    distributionIntent,
    notes,
    nextDeadline: nextDeadline.toISOString(),
    longevityAge,
    planningYears,
    projectionRows,
    reminderDates,
    narrative,
    headlineRmd: nextRow ? nextRow.rmd : 0,
    headlineTax: nextRow ? nextRow.totalTax : 0,
    headlineAge: projectionStartAge
  };
}

function renderReminderGrid(reminders, deadline) {
  const items = reminders.length ? reminders.map((item) => ({
    label: item.label,
    value: formatDate(item.date),
    sub: `Relative to ${formatDate(deadline)}`
  })) : [{
    label: 'Next reminder',
    value: 'Deadline soon',
    sub: `The next deadline is ${formatDate(deadline)} and some earlier reminder windows have already passed.`
  }];

  document.getElementById('reminderGrid').innerHTML = items.map((item) => `
    <div class="compare-card">
      <div class="label">${item.label}</div>
      <div class="value" style="font-size:24px;">${item.value}</div>
      <div class="sub">${item.sub}</div>
    </div>
  `).join('');
}

function renderTimeline(rows) {
  document.getElementById('timelineGrid').innerHTML = rows.map((row) => `
    <div class="timeline-card">
      <div>
        <div class="timeline-label">Age ${row.age}</div>
        <div class="timeline-age">${row.year}</div>
      </div>
      <div class="timeline-meta">
        <div><strong>Divisor:</strong> ${row.divisor.toFixed(1)}</div>
        <div><strong>Start balance:</strong> ${formatMoney(row.startingBalance)}</div>
      </div>
      <div>
        <div class="timeline-label">RMD</div>
        <div class="timeline-value">${formatMoney(row.rmd)}</div>
      </div>
      <div>
        <div class="timeline-label">Est. Tax</div>
        <div class="timeline-value">${formatMoney(row.totalTax)}</div>
      </div>
      <div>
        <div class="timeline-label">End Balance</div>
        <div class="timeline-value">${formatMoney(row.endingBalance)}</div>
      </div>
    </div>
  `).join('');
}

function renderRmdReport(payload) {
  latestRmdPayload = payload;
  const nextRow = payload.projectionRows[0];

  document.getElementById('reportTitle').textContent = `RMD Calendar + Tax Impact Estimator for ${payload.fullName || 'Your Plan'}`;
  document.getElementById('reportSubtitle').textContent = `A saved RMD schedule for ${payload.countyName || 'your local area'}${payload.stateName ? `, ${payload.stateName}` : ''}, built from IRS Publication 590-B tables and your tax assumptions.`;
  document.getElementById('metaName').textContent = `Prepared for ${payload.fullName || '—'}`;
  document.getElementById('metaLocation').textContent = `${payload.countyName || 'County not entered'} · ${payload.stateName || 'State not entered'} longevity overlay`;
  document.getElementById('metaDate').textContent = `Generated ${formatDate(CURRENT_DATE)}`;

  document.getElementById('summaryTitle').innerHTML = `Your next estimated <em>RMD</em> is ${formatMoney(nextRow.rmd)}.`;
  document.getElementById('summaryCopy').textContent = payload.narrative;
  document.getElementById('benchmarkHeadline').textContent = `${payload.planningYears.toFixed(1)} expected RMD planning years from age ${payload.headlineAge}`;
  document.getElementById('benchmarkCopy').textContent = `Using a ${payload.zipCode ? 'ZIP-adjusted' : 'state-based'} longevity overlay for ${payload.countyName || payload.stateName || 'your area'}, this plan is framing roughly ${payload.planningYears.toFixed(1)} years of RMD decisions through about age ${payload.longevityAge.toFixed(1)}.`;

  document.getElementById('nextRmdValue').textContent = formatMoney(nextRow.rmd);
  document.getElementById('nextRmdSub').textContent = `Age ${nextRow.age} divisor ${nextRow.divisor.toFixed(1)}`;
  document.getElementById('nextDeadlineValue').textContent = formatDate(new Date(payload.nextDeadline));
  document.getElementById('nextDeadlineSub').textContent = payload.rmdStage === 'first_year' ? 'First-year RMD may be delayed to April 1, 2027' : 'Normal annual deadline cadence';
  document.getElementById('nextTaxValue').textContent = formatMoney(nextRow.totalTax);
  document.getElementById('nextTaxSub').textContent = `${formatPercent(payload.federalTaxRate)} federal + ${formatPercent(payload.stateTaxRate)} state estimate`;

  document.getElementById('statusPill').textContent = payload.rmdStage === 'not_yet' ? `First RMD year: ${payload.firstRmdYear}` : `Required beginning age: ${payload.requiredBeginningAge}`;
  document.getElementById('projectionPill').textContent = `${payload.projectionRows.length} projected RMD years`;
  document.getElementById('reminderPill').textContent = payload.reminderPreference.replaceAll('_', ' ');

  document.getElementById('compareGrid').innerHTML = [
    {
      label: 'Required Beginning Age',
      value: `${payload.requiredBeginningAge}`,
      sub: `Based on birth year ${payload.birthYear}`
    },
    {
      label: 'Projected Taxable Income',
      value: formatMoney(nextRow.combinedIncome),
      sub: `${formatMoney(payload.otherTaxableIncome)} other income plus next RMD`
    },
    {
      label: 'After-Tax RMD',
      value: formatMoney(nextRow.afterTax),
      sub: 'Estimated spendable amount after projected taxes'
    }
  ].map((item) => `
    <div class="compare-card">
      <div class="label">${item.label}</div>
      <div class="value">${item.value}</div>
      <div class="sub">${item.sub}</div>
    </div>
  `).join('');

  renderTimeline(payload.projectionRows);
  renderReminderGrid(payload.reminderDates.map((item) => ({ ...item, date: new Date(item.date) })), new Date(payload.nextDeadline));
  document.getElementById('rmdCallout').textContent = payload.distributionIntent === 'reinvest'
    ? `${payload.narrative} Because the intent is to reinvest excess distributions, the key planning friction is not cash flow. It is avoiding a last-minute taxable event with no withholding plan.`
    : payload.distributionIntent === 'cash_buffer'
      ? `${payload.narrative} Because part of the distribution may be held in cash, the planning conversation should pair the RMD calendar with near-term spending and withholding decisions.`
      : payload.narrative;
}

function runAnalysisAnimation(payload) {
  document.getElementById('analysisSub').textContent = `Calculating the RMD schedule for ${payload.fullName || 'your plan'} in ${payload.stateName || 'your state'}.`;
  ['analysisStep1','analysisStep2','analysisStep3','analysisStep4'].forEach((id, index) => {
    const el = document.getElementById(id);
    el.classList.remove('done');
    setTimeout(() => el.classList.add('done'), (index + 1) * 360);
  });
}

async function saveRmdReminders(reportId, payload) {
  const supabase = window.rmdCalendarSupabase;
  if (!supabase) return;
  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId || !payload.reminderDates.length) return;

  const rows = payload.reminderDates.map((item) => ({
    user_id: userId,
    report_id: reportId,
    tool_slug: 'rmd-calendar-tax-estimator',
    reminder_type: item.type,
    target_deadline_date: payload.nextDeadline.slice(0, 10),
    scheduled_for: item.date.slice(0, 10),
    delivery_channel: payload.reminderPreference,
    status: 'pending',
    payload: {
      fullName: payload.fullName,
      nextDeadline: payload.nextDeadline,
      headlineRmd: payload.headlineRmd
    }
  }));

  const { error } = await supabase
    .from('rmd_deadline_reminders')
    .upsert(rows, { onConflict: 'user_id,tool_slug,reminder_type,target_deadline_date' });

  if (error) {
    console.error('Failed to save RMD reminder rows:', error);
  }
}

async function saveRmdReport(payload) {
  const supabase = window.rmdCalendarSupabase;
  if (!supabase) return null;
  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const insertPayload = {
    user_id: userId,
    full_name: payload.fullName || null,
    state_code: payload.stateCode || null,
    state_name: payload.stateName || null,
    county_name: payload.countyName || null,
    zip_code: payload.zipCode || null,
    filing_status: payload.filingStatus || null,
    current_age: payload.currentAge || null,
    birth_year: payload.birthYear || null,
    required_beginning_age: payload.requiredBeginningAge,
    first_rmd_year: payload.firstRmdYear,
    rmd_stage: payload.rmdStage,
    prior_year_end_balance: payload.priorYearEndBalance,
    projected_growth_rate_pct: payload.growthRate,
    marginal_federal_tax_rate_pct: payload.federalTaxRate,
    state_tax_rate_pct: payload.stateTaxRate,
    other_taxable_income: payload.otherTaxableIncome,
    next_rmd_amount: payload.headlineRmd,
    next_rmd_deadline: payload.nextDeadline.slice(0, 10),
    next_rmd_estimated_tax: payload.headlineTax,
    longevity_target_age: payload.longevityAge,
    projected_rmd_years: payload.planningYears,
    reminder_preference: payload.reminderPreference,
    report_title: `RMD Calendar + Tax Impact Estimator for ${payload.fullName || 'Your Plan'}`,
    report_payload: payload
  };

  const { data: inserted, error } = await supabase
    .from('rmd_calendar_reports')
    .insert(insertPayload)
    .select('id')
    .single();

  if (error) {
    console.error('Failed to save RMD report:', error);
    return null;
  }

  if (inserted?.id) {
    await saveRmdReminders(inserted.id, payload);
  }

  return inserted;
}

function showGeneratedRmdReport(payload) {
  renderRmdReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  runAnalysisAnimation(payload);

  setTimeout(() => {
    document.getElementById('analysisSection').classList.remove('active');
    document.getElementById('reportSection').classList.add('active');
    document.getElementById('reportShell').classList.add('visible');
    document.getElementById('reportShell').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 1800);
}

function showHydratedRmdReport(payload) {
  renderRmdReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('reportSection').classList.add('active');
  document.getElementById('reportShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedRmdReport(report) {
  const payload = report?.report_payload;
  if (!payload) return false;

  const fields = {
    fullName: payload.fullName,
    currentAge: payload.currentAge,
    zipCode: payload.zipCode,
    countyName: payload.countyName,
    priorYearEndBalance: payload.priorYearEndBalance,
    otherTaxableIncome: payload.otherTaxableIncome,
    growthRate: payload.growthRate,
    federalTaxRate: payload.federalTaxRate,
    stateTaxRate: payload.stateTaxRate,
    notes: payload.notes
  };

  Object.entries(fields).forEach(([id, value]) => {
    const input = document.getElementById(id);
    if (input && value !== undefined && value !== null) input.value = String(value);
  });

  if (payload.stateCode) document.getElementById('stateSelect').value = payload.stateCode;
  if (payload.filingStatus) document.getElementById('filingStatus').value = payload.filingStatus;
  if (payload.rmdStage) document.getElementById('rmdStage').value = payload.rmdStage;
  if (payload.projectionYears) document.getElementById('projectionYears').value = String(Math.max(10, Math.min(20, Math.ceil(payload.projectionYears / 5) * 5)));
  if (payload.reminderPreference) document.getElementById('reminderPreference').value = payload.reminderPreference;
  if (payload.distributionIntent) document.getElementById('distributionIntent').value = payload.distributionIntent;

  showHydratedRmdReport(payload);
  return true;
}

async function generateRmdReport() {
  const payload = buildRmdPayload();
  await saveRmdReport(payload);
  showGeneratedRmdReport(payload);
}

function editRmdReport() {
  document.getElementById('reportSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(3);
}

window.nextStep = nextStep;
window.generateRmdReport = generateRmdReport;
window.editRmdReport = editRmdReport;
window.hydrateRmdCalendarReport = hydrateSavedRmdReport;
</script>

