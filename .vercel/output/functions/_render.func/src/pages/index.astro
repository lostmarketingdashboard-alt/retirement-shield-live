---
import { supabase } from '../lib/supabase';

const { data, error } = await supabase
  .from('articles')
  .select('slug, headline, lede, pillar, published_at')
  .order('published_at', { ascending: false })
  .limit(6);

if (error) {
  console.error('Supabase fetch error:', error);
}

const recentArticles = data ?? [];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Retirement Shield — Know What Your Advisor Knows</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,300;1,8..60,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />

    <style>


.check-input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.checklist-item {
  position: relative;
  cursor: pointer;
}

.check-state {
  width: 22px;
  height: 22px;
  border: 2px solid var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  transition: all 0.2s ease;
}

.check-input:checked + .check-state {
  background: var(--amber);
  border-color: var(--amber);
}

.check-input:checked + .check-state::after {
  content: "✓";
  color: white;
  font-weight: bold;
  font-size: 14px;
}

.check-input:checked ~ .check-text {
  opacity: 0.9;
}
/* ══════════════════════════════════════════════════
   DESIGN TOKENS
══════════════════════════════════════════════════ */
:root {
  --navy: #0d1b2a;
  --navy-mid: #1a2e45;
  --navy-light: #243b55;
  --cream: #f5f0e8;
  --cream-dark: #ede6d6;
  --amber: #c8821a;
  --amber-light: #e8a840;
  --text-primary: #1a1208;
  --text-secondary: #4a3f32;
  --text-muted: #7a6e62;
  --white: #ffffff;
  --rule: #c8b89a;
  --rule-light: rgba(200,184,154,0.35);
  --tap-min: 48px; /* WCAG minimum tap target */
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

body {
  background: var(--cream);
  color: var(--text-primary);
  font-family: 'Source Serif 4', Georgia, serif;
  font-size: 17px; /* 16px minimum for aging eyes; 17 gives breathing room */
  line-height: 1.68;
  overflow-x: hidden;
}

img, svg { max-width: 100%; display: block; }

/* ══════════════════════════════════════════════════
   MASTHEAD — DESKTOP
══════════════════════════════════════════════════ */
.masthead {
  background: var(--navy);
  padding: 0 48px;
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  border-bottom: 3px solid var(--amber);
  position: sticky;
  top: 0;
  z-index: 200;
}
.masthead-brand {
  display: flex; align-items: center; gap: 14px; padding: 16px 0; text-decoration: none;
}
.shield-mark { width: 34px; height: 40px; flex-shrink: 0; }
.brand-name {
  font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1.28rem;
  color: var(--cream); letter-spacing: 0.02em; line-height: 1.1;
}
.brand-tagline {
  font-family: 'DM Mono', monospace; font-size: 0.55rem; color: var(--amber-light);
  text-transform: uppercase; letter-spacing: 0.14em; margin-top: 2px; display: block; opacity: 0.85;
}
nav.desktop-nav { display: flex; align-items: center; gap: 28px; }
nav.desktop-nav a {
  font-family: 'DM Mono', monospace; font-size: 0.68rem; text-transform: uppercase;
  letter-spacing: 0.11em; color: var(--cream-dark); text-decoration: none;
  opacity: 0.75; transition: opacity 0.2s, color 0.2s; border-bottom: 1px solid transparent;
  padding: 4px 0;
}
nav.desktop-nav a:hover { opacity: 1; color: var(--amber-light); border-bottom-color: var(--amber-light); }
.nav-cta {
  background: var(--amber); color: var(--navy) !important; opacity: 1 !important;
  padding: 10px 20px !important; border-bottom: none !important; transition: background 0.2s !important;
}
.nav-cta:hover { background: var(--amber-light) !important; }

/* Hamburger — hidden on desktop */
.hamburger {
  display: none; background: none; border: none; cursor: pointer;
  padding: 16px 0; flex-direction: column; gap: 5px; align-items: center; justify-content: center;
}
.hamburger span {
  display: block; width: 22px; height: 2px; background: var(--cream);
  transition: transform 0.25s, opacity 0.25s;
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile nav drawer */
.mobile-nav {
  display: none;
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: var(--navy); z-index: 199;
  flex-direction: column; align-items: flex-start;
  padding: 90px 32px 40px;
  gap: 0;
  overflow-y: auto;
}
.mobile-nav.open { display: flex; }
.mobile-nav a {
  font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700;
  color: var(--cream); text-decoration: none; opacity: 0.8;
  padding: 16px 0; border-bottom: 1px solid rgba(200,184,154,0.12);
  width: 100%; transition: opacity 0.2s, color 0.2s;
  min-height: var(--tap-min); display: flex; align-items: center;
}
.mobile-nav a:hover, .mobile-nav a:active { opacity: 1; color: var(--amber-light); }
.mobile-nav .mobile-nav-cta {
  background: var(--amber); color: var(--navy) !important; opacity: 1 !important;
  padding: 18px 28px; margin-top: 24px; border-bottom: none;
  font-size: 0.8rem; font-family: 'DM Mono', monospace; font-weight: 400;
  text-transform: uppercase; letter-spacing: 0.12em; width: 100%; justify-content: center;
}

/* ══════════════════════════════════════════════════
   TICKER
══════════════════════════════════════════════════ */
.ticker-bar {
  background: var(--cream-dark); border-bottom: 1px solid var(--rule);
  overflow: hidden; padding: 9px 0; position: relative;
}
.ticker-bar::before, .ticker-bar::after {
  content: ''; position: absolute; top: 0; bottom: 0; width: 40px; z-index: 2;
}
.ticker-bar::before { left: 0; background: linear-gradient(90deg, var(--cream-dark), transparent); }
.ticker-bar::after  { right: 0; background: linear-gradient(-90deg, var(--cream-dark), transparent); }
.ticker-track {
  display: flex; gap: 0; animation: tickerScroll 50s linear infinite; width: max-content;
}
.ticker-track:hover { animation-play-state: paused; }
@keyframes tickerScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
.ticker-item { display: flex; align-items: center; gap: 10px; padding: 0 36px 0 0; white-space: nowrap; }
.ticker-label { font-family: 'DM Mono', monospace; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--amber); }
.ticker-fact { font-size: 0.78rem; color: var(--text-secondary); font-style: italic; }
.ticker-sep { color: var(--rule); margin-left: 36px; }

/* ══════════════════════════════════════════════════
   HERO
══════════════════════════════════════════════════ */
.hero {
  background: var(--navy); color: var(--cream);
  padding: 72px 48px 0;
  display: grid; grid-template-columns: 1fr 380px; gap: 64px;
  align-items: end; overflow: hidden; position: relative;
}
.hero::before {
  content: ''; position: absolute; top: -100px; right: -100px;
  width: 560px; height: 560px;
  background: radial-gradient(circle, rgba(200,130,26,0.1) 0%, transparent 65%);
  pointer-events: none;
}
.hero-eyebrow {
  font-family: 'DM Mono', monospace; font-size: 0.65rem; text-transform: uppercase;
  letter-spacing: 0.18em; color: var(--amber-light); margin-bottom: 20px;
  display: flex; align-items: center; gap: 12px;
  opacity: 0; animation: fadeUp 0.7s ease 0.1s forwards;
}
.hero-eyebrow::before {
  content: ''; display: block; width: 28px; height: 1px; background: var(--amber); flex-shrink: 0;
}
.hero-headline {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.4rem, 4vw, 3.7rem); font-weight: 900;
  line-height: 1.07; letter-spacing: -0.015em; color: var(--cream); margin-bottom: 26px;
  opacity: 0; animation: fadeUp 0.7s ease 0.25s forwards;
}
.hero-headline em { font-style: italic; color: var(--amber-light); }
.hero-body {
  font-size: 1rem; color: rgba(245,240,232,0.76); line-height: 1.78; max-width: 520px;
  margin-bottom: 28px; opacity: 0; animation: fadeUp 0.7s ease 0.4s forwards;
}
.hero-body strong { color: rgba(245,240,232,0.95); font-weight: 600; }
.hero-actions {
  display: flex; gap: 16px; align-items: center; flex-wrap: wrap;
  opacity: 0; animation: fadeUp 0.7s ease 0.52s forwards; padding-bottom: 60px;
}
.hero-aside {
  border-left: 1px solid rgba(200,184,154,0.2);
  padding-left: 44px; padding-bottom: 60px;
  opacity: 0; animation: fadeUp 0.7s ease 0.45s forwards;
}
.stat-card {
  background: rgba(255,255,255,0.04); border: 1px solid rgba(200,184,154,0.18);
  padding: 24px 24px 20px; margin-bottom: 14px;
}
.stat-card:last-child { margin-bottom: 0; }
.stat-number {
  font-family: 'Playfair Display', serif; font-size: 2.6rem; font-weight: 900;
  color: var(--amber-light); line-height: 1; margin-bottom: 8px;
}
.stat-description { font-size: 0.82rem; color: rgba(245,240,232,0.62); line-height: 1.55; }
.stat-source {
  font-family: 'DM Mono', monospace; font-size: 0.52rem; color: rgba(245,240,232,0.3);
  text-transform: uppercase; letter-spacing: 0.1em; margin-top: 10px; display: block;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ══════════════════════════════════════════════════
   BUTTONS
══════════════════════════════════════════════════ */
.btn-primary {
  background: var(--amber); color: var(--navy);
  font-family: 'DM Mono', monospace; font-size: 0.7rem;
  text-transform: uppercase; letter-spacing: 0.12em;
  padding: 15px 28px; text-decoration: none; border: none; cursor: pointer;
  transition: background 0.2s, transform 0.15s; display: inline-block;
  min-height: var(--tap-min); display: inline-flex; align-items: center; justify-content: center;
}
.btn-primary:hover { background: var(--amber-light); transform: translateY(-1px); }
.btn-ghost {
  color: var(--cream); font-family: 'DM Mono', monospace; font-size: 0.7rem;
  text-transform: uppercase; letter-spacing: 0.12em; text-decoration: none;
  padding: 15px 4px; border-bottom: 1px solid rgba(245,240,232,0.28);
  transition: border-color 0.2s, color 0.2s; min-height: var(--tap-min);
  display: inline-flex; align-items: center;
}
.btn-ghost:hover { border-color: var(--amber-light); color: var(--amber-light); }

/* ══════════════════════════════════════════════════
   ESTATE GATEWAY
══════════════════════════════════════════════════ */
.estate-gateway {
  background: var(--white); border-bottom: 3px solid var(--amber);
  padding: 64px 48px; position: relative; overflow: hidden;
}
.estate-gateway::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
  background: linear-gradient(90deg, var(--amber) 0%, var(--amber-light) 40%, transparent 100%);
}
.estate-gateway-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
.estate-gateway-label {
  font-family: 'DM Mono', monospace; font-size: 0.62rem; text-transform: uppercase;
  letter-spacing: 0.18em; color: var(--amber); margin-bottom: 18px;
  display: flex; align-items: center; gap: 10px;
}
.estate-gateway-label::before {
  content: 'START HERE'; background: var(--amber); color: var(--white);
  padding: 3px 8px; font-size: 0.55rem; letter-spacing: 0.14em;
}
.estate-gateway h2 {
  font-family: 'Playfair Display', serif; font-size: clamp(1.7rem, 2.8vw, 2.4rem);
  font-weight: 900; line-height: 1.12; color: var(--navy); margin-bottom: 18px;
}
.estate-gateway h2 em { font-style: italic; color: var(--amber); }
.estate-gateway p { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.75; margin-bottom: 28px; }
.estate-checklist {
  display: flex; flex-direction: column; gap: 0;
  border: 1px solid var(--rule); background: var(--cream);
}
.checklist-item {
  display: grid; grid-template-columns: 44px 1fr; align-items: start;
  padding: 18px 20px; border-bottom: 1px solid var(--rule); cursor: pointer;
  transition: background 0.2s; min-height: var(--tap-min); gap: 0;
  -webkit-tap-highlight-color: rgba(200,130,26,0.08);
}
.checklist-item:last-child { border-bottom: none; }
.checklist-item:hover, .checklist-item:active { background: var(--cream-dark); }
.check-state {
  font-family: 'DM Mono', monospace; font-size: 1rem;
  color: var(--text-muted); user-select: none; transition: color 0.2s; padding-top: 1px;
}
.check-state.checked { color: var(--amber); }
.check-text { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.5; }
.check-text strong { color: var(--text-primary); font-weight: 600; display: block; margin-bottom: 2px; }
.check-text span { font-size: 0.78rem; color: var(--text-muted); }
.estate-cta-row { display: flex; align-items: center; gap: 20px; margin-top: 28px; flex-wrap: wrap; }
.estate-stat-inline {
  font-family: 'DM Mono', monospace; font-size: 0.68rem; color: var(--text-muted);
  text-transform: uppercase; letter-spacing: 0.1em; line-height: 1.5;
}
.estate-stat-inline strong {
  display: block; font-family: 'Playfair Display', serif; font-size: 1.9rem;
  color: var(--amber); font-weight: 900; letter-spacing: 0; text-transform: none;
}

/* ══════════════════════════════════════════════════
   SECTION RULES
══════════════════════════════════════════════════ */
.section-rule { display: flex; align-items: center; gap: 16px; margin-bottom: 44px; }
.section-label {
  font-family: 'DM Mono', monospace; font-size: 0.6rem; text-transform: uppercase;
  letter-spacing: 0.18em; color: var(--amber); white-space: nowrap;
}
.section-line { flex: 1; height: 1px; background: var(--rule); }

/* ══════════════════════════════════════════════════
   QUIZ BANNER
══════════════════════════════════════════════════ */
.quiz-banner {
  background: var(--navy-mid); padding: 72px 48px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
  align-items: center; position: relative; overflow: hidden;
}
.quiz-banner::before {
  content: '?'; position: absolute; font-family: 'Playfair Display', serif;
  font-size: 36rem; color: rgba(200,130,26,0.04); line-height: 1;
  top: -80px; right: -20px; pointer-events: none; user-select: none;
}
.quiz-content h2 {
  font-family: 'Playfair Display', serif; font-size: clamp(1.7rem, 2.6vw, 2.4rem);
  font-weight: 900; line-height: 1.12; color: var(--cream); margin-bottom: 18px;
}
.quiz-content h2 em { font-style: italic; color: var(--amber-light); }
.quiz-content p { font-size: 0.93rem; color: rgba(245,240,232,0.68); margin-bottom: 32px; line-height: 1.72; }
.quiz-preview {
  background: rgba(255,255,255,0.04); border: 1px solid rgba(200,184,154,0.2); padding: 32px;
}
.quiz-q {
  font-family: 'Playfair Display', serif; font-size: 1rem; color: var(--cream);
  margin-bottom: 22px; font-style: italic; line-height: 1.5;
}
.quiz-options { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
.quiz-option {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(200,184,154,0.2);
  color: rgba(245,240,232,0.7);
  font-size: 0.9rem;
  padding: 14px 16px;
  cursor: pointer;
  text-align: left;
  font-family: 'Source Serif 4', serif;
  transition: background 0.2s, border-color 0.2s, color 0.2s;
  min-height: var(--tap-min);
  display: flex;
  align-items: center;
}

.quiz-option.correct {
  background: rgba(40, 160, 90, 0.18);
  border-color: #28a05a;
  color: #9ff3c4;
}

.quiz-option.wrong {
  background: rgba(200, 60, 60, 0.18);
  border-color: #c83c3c;
  color: #ffb3b3;
}
.quiz-reveal {
  display: none; background: rgba(200,130,26,0.1); border-left: 3px solid var(--amber);
  padding: 16px; font-size: 0.84rem; color: rgba(245,240,232,0.82); margin-bottom: 14px; line-height: 1.65;
}
.quiz-reveal.active { display: block; }
.quiz-note {
  font-family: 'DM Mono', monospace; font-size: 0.58rem;
  color: rgba(245,240,232,0.28); text-transform: uppercase; letter-spacing: 0.1em;
}

/* ══════════════════════════════════════════════════
   GAP SECTION
══════════════════════════════════════════════════ */
.gap-section { padding: 80px 48px; background: var(--cream); }
.gap-intro { max-width: 640px; margin-bottom: 52px; }
.gap-intro h2 {
  font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 2.8vw, 2.5rem);
  font-weight: 700; line-height: 1.15; margin-bottom: 16px; color: var(--navy);
}
.gap-intro h2 em { font-style: italic; color: var(--amber); }
.gap-intro p { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.75; }
.gap-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; background: var(--rule); border: 1px solid var(--rule);
}
.gap-card { background: var(--cream); padding: 32px 28px 28px; transition: background 0.25s; }
.gap-card:hover { background: var(--white); }
.gap-card-bucket {
  font-family: 'DM Mono', monospace; font-size: 0.57rem; text-transform: uppercase;
  letter-spacing: 0.14em; color: var(--amber); margin-bottom: 12px;
  display: flex; align-items: center; gap: 7px;
}
.gap-card-bucket::before { content: '▪'; font-size: 0.9em; }
.gap-card h3 {
  font-family: 'Playfair Display', serif; font-size: 1.12rem; font-weight: 700;
  line-height: 1.25; margin-bottom: 12px; color: var(--navy);
}
.gap-card p { font-size: 0.86rem; color: var(--text-secondary); line-height: 1.65; margin-bottom: 16px; }
.gap-card-fact {
  background: var(--navy); color: var(--cream); padding: 14px 16px;
  font-size: 0.79rem; line-height: 1.58; font-style: italic; border-left: 3px solid var(--amber);
}
.gap-card-fact span {
  display: block; font-family: 'DM Mono', monospace; font-style: normal; font-size: 0.55rem;
  text-transform: uppercase; letter-spacing: 0.1em; color: var(--amber-light); margin-top: 8px;
}

/* ══════════════════════════════════════════════════
   CONTENT BUCKETS
══════════════════════════════════════════════════ */
.buckets-section { padding: 72px 48px; background: var(--cream-dark); }
.buckets-grid {
  display: grid; grid-template-columns: repeat(5, 1fr);
  gap: 1px; background: var(--rule); border: 1px solid var(--rule);
}
.bucket-card {
  background: var(--cream-dark); padding: 28px 20px 24px;
  text-decoration: none; display: flex; flex-direction: column; transition: background 0.22s;
}
.bucket-card:hover { background: var(--white); }
.bucket-card.featured { background: var(--navy); border: 2px solid var(--amber); margin: -1px; }
.bucket-card.featured:hover { background: var(--navy-light); }
.bucket-icon { font-size: 1.4rem; margin-bottom: 12px; display: block; }
.bucket-name {
  font-family: 'Playfair Display', serif; font-size: 0.9rem; font-weight: 700;
  color: var(--navy); line-height: 1.25; margin-bottom: 8px;
}
.bucket-card.featured .bucket-name { color: var(--cream); }
.bucket-desc { font-size: 0.75rem; color: var(--text-muted); line-height: 1.6; flex: 1; margin-bottom: 12px; }
.bucket-card.featured .bucket-desc { color: rgba(245,240,232,0.55); }
.bucket-count { font-family: 'DM Mono', monospace; font-size: 0.55rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--amber); }
.bucket-card.featured .bucket-count { color: var(--amber-light); }

/* ══════════════════════════════════════════════════
   ARTICLES
══════════════════════════════════════════════════ */
.articles-section { padding: 80px 48px; background: var(--cream); }
.articles-layout { display: grid; grid-template-columns: 2fr 1fr; gap: 48px; }
.article-featured { border-bottom: 1px solid var(--rule); padding-bottom: 34px; margin-bottom: 34px; }
.article-featured:last-child { border-bottom: none; margin-bottom: 0; }
.article-bucket-tag {
  font-family: 'DM Mono', monospace; font-size: 0.58rem; text-transform: uppercase;
  letter-spacing: 0.14em; color: var(--amber); margin-bottom: 8px; display: block;
}
.article-featured h3 {
  font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700;
  line-height: 1.2; color: var(--navy); margin-bottom: 10px; cursor: pointer; transition: color 0.2s;
}
.article-featured h3:hover { color: var(--amber); }
.article-featured p { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.7; margin-bottom: 12px; }
.article-meta { font-family: 'DM Mono', monospace; font-size: 0.57rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; }
.articles-sidebar { border-left: 1px solid var(--rule); padding-left: 36px; }
.sidebar-article { padding-bottom: 20px; margin-bottom: 20px; border-bottom: 1px solid var(--rule); }
.sidebar-article:last-child { border-bottom: none; }
.sidebar-article h4 {
  font-family: 'Playfair Display', serif; font-size: 0.96rem; font-weight: 700;
