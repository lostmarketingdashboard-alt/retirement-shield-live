---
import { createClient } from '@supabase/supabase-js'

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
)

let allRows = []
let from = 0
const pageSize = 1000

while (true) {
  const { data, error } = await supabase
    .from('counties')
    .select('State')
    .range(from, from + pageSize - 1)

  if (error) {
    console.error(error)
    break
  }

  if (!data || data.length === 0) break

  allRows = allRows.concat(data)

  if (data.length < pageSize) break

  from += pageSize
}

const states = [...new Set(allRows.map(r => r.State))]
  .filter(Boolean)
  .sort()
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Browse Counties — Retirement Shield</title>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

<style>
:root{
  --navy:#0d1b2a;
  --gold:#c9a84c;
  --cream:#faf7f0;
  --border:#d4c9a8;
  --text:#1a1a1a;
}

*{margin:0;padding:0;box-sizing:border-box}

body{
  font-family:'DM Sans',sans-serif;
  background:var(--cream);
  color:var(--text);
}

/* NAV */
nav{
  background: var(--navy);
  border-bottom:1px solid var(--border);
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:18px 32px;
}

.nav-logo{
  font-family:'Playfair Display',serif;
  font-size:20px;
  font-weight:600;
  color:white;
  text-decoration:none !important;
  display:inline-block;
}

.nav-logo:hover{
  opacity:.9;
}

.nav-logo span{
  color:var(--gold);
  text-decoration:none !important;
}

.nav-links{
  list-style:none;
  display:flex;
  gap:28px;
  align-items:center;
}

.nav-links a{
  text-decoration:none;
  color: white;
  font-size:14px;
}

.nav-links a:hover{
  color:var(--gold);
}

.nav-cta{
  padding:10px 18px;
  background:var(--gold);
  color:white !important;
  border-radius:4px;
}

.nav-cta:hover{
  opacity:.9;
}

/* HEADER */
.header{
  background:var(--navy);
  color:white;
  padding:64px 32px;
}

.header h1{
  font-family:'Playfair Display',serif;
  font-size:38px;
  margin-bottom:12px;
}

/* New mode switch button style */
.mode-switch-btn{
  appearance:none;
  -webkit-appearance:none;
  border:1px solid var(--border);
  padding:14px 22px;
  background:var(--navy);
  color:white;
  font-size:14px;
  letter-spacing:.5px;
  cursor:pointer;
  transition:.25s ease;
  border-radius:4px;
  display:inline-block;
  font-family:'DM Sans',sans-serif;
}

.mode-switch-btn:hover{
  background:var(--gold);
  border-color:var(--gold);
  color:white;
}

.header p{
  opacity:.75;
  max-width:600px;
  line-height:1.6;
}

/* BODY */
.container{
  padding:64px 32px;
  max-width:1100px;
  margin:0 auto;
}

.section-title{
  font-family:'Playfair Display',serif;
  font-size:24px;
  margin-bottom:24px;
}

.states-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(180px,1fr));
  gap:16px;
}

.state-btn,
.county-link{
  padding:16px;
  border:1px solid var(--border);
  background:white;
  cursor:pointer;
  font-size:14px;
  transition:.2s;
  text-align:center;
  text-decoration:none;
  color:var(--text);
}

.state-btn:hover,
.county-link:hover{
  border-color:var(--gold);
  background:#fffdf6;
}

.guide-toggle{
  padding:12px 18px;
  border:1px solid var(--border);
  background:white;
  cursor:pointer;
  font-size:14px;
  transition:.2s;
}

.guide-toggle:hover{
  border-color:var(--gold);
}

.active-toggle{
  background:var(--gold);
  color:white;
  border-color:var(--gold);
}

@media (max-width: 768px) {
  .nav-links {
    display: none;
  }

  nav {
    justify-content: center;
    padding: 18px 16px;
  }

  .nav-logo {
    font-size: 18px;
  }
}
</style>

</head>

<body>

 <!-- NEWSLETTER MODAL -->
  <div id="newsletterModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:9999; align-items:center; justify-content:center; padding:20px; overflow:auto;">
    <div style="background:#1A2E4A; width:min(95%,700px); padding:32px; border-radius:12px; position:relative; box-shadow:0 20px 60px rgba(0,0,0,0.4);">
      <button onclick="closeNewsletterModal()" 
        style="position:absolute; top:14px; right:16px; background:none; border:none; color:white; font-size:22px; cursor:pointer;">
        ×
      </button>
      
      <div style="margin-bottom:20px;">
        <div style="font-size:11px; letter-spacing:1px; text-transform:uppercase; color:var(--gold); font-weight:600; margin-bottom:6px;">Free Newsletter</div>
        <h2 style="font-family:'Playfair Display',serif; color:white; font-size:22px; margin:0;">Join the Retirement Intelligence Report</h2>
      </div>

      <iframe 
        src="https://api.leadconnectorhq.com/widget/form/1fEKSAEG00dBmEd1y8gn" 
        style="width:100%; height:350px; border:none; border-radius:8px; background:transparent;">
      </iframe>
    </div>
  </div>

<!-- NAV -->
<nav>
  <a href="/" class="nav-logo">Retirement<span>Shield</span></a>
  <ul class="nav-links">
    <li><a href="/lifeexpectancycalculator">Life Expectancy</a></li>
    <li><a href="/quiz">Estate Planning</a></li>
    <!-- <li><a href="#">Calculators</a></li> -->
    <li><a href="#" onclick="openNewsletterModal(event)">Newsletter</a></li>
    <li><a href="/quiz" class="nav-cta">Free Assessment</a></li>
  </ul>
</nav>

<div class="header">

  <h1 id="pageTitle">Browse State Estate Planning Guides</h1>
  <p id="pageDescription">
    Select your state to access your complete 2026 Estate Planning Guide — including probate rules, Medicaid planning insights, tax exposure, and retirement protection strategies tailored to your state.
  </p>

</div>

<div class="container">

  <div style="margin-bottom:32px;">
    <button id="modeSwitchBtn" class="mode-switch-btn"></button>
  </div>

  <div class="section-title">Select a State</div>

  <div class="states-grid">
    {states.map(state => (
      <a 
        class="state-btn state-link" 
        data-state={state.toLowerCase().replace(/\s+/g,'-')}
        href={`/guide/${state.toLowerCase().replace(/\s+/g,'-')}`}
      >
        {state}
      </a>
    ))}
  </div>

</div>

<script is:inline>

window.openNewsletterModal = function(e) {
  if (e) e.preventDefault();
  const modal = document.getElementById('newsletterModal');
  if (modal) modal.style.display = 'flex';
}

window.closeNewsletterModal = function() {
  const modal = document.getElementById('newsletterModal');
  if (modal) modal.style.display = 'none';
}

document.addEventListener('click', function(e){
  const newsletter = document.getElementById('newsletterModal');
  if(newsletter && e.target === newsletter){
    window.closeNewsletterModal();
  }
});

const switchBtn = document.getElementById('modeSwitchBtn');
const pageTitle = document.getElementById('pageTitle');
const pageDescription = document.getElementById('pageDescription');
const stateLinks = document.querySelectorAll('.state-link');

let currentMode = 'estate';

function updateUI(){
  stateLinks.forEach(link => {
    const slug = link.dataset.state;
    link.href = currentMode === 'probate'
      ? `/probate/${slug}`
      : `/guide/${slug}`;
  });

  if(currentMode === 'probate'){
    pageTitle.textContent = 'Browse State Probate Guides';
    pageDescription.textContent = 'Select your state to explore detailed 2026 Probate Guides — including court timelines, probate costs, small estate thresholds, and strategies to reduce administrative burden in your state.';
    switchBtn.textContent = 'Browse Estate Planning Guides →';
  } else {
    pageTitle.textContent = 'Browse State Estate Planning Guides';
    pageDescription.textContent = 'Select your state to access your complete 2026 Estate Planning Guide — including probate rules, Medicaid planning insights, tax exposure, and retirement protection strategies tailored to your state.';
    switchBtn.textContent = 'Browse Probate Guides →';
  }
}

switchBtn.addEventListener('click', () => {
  currentMode = currentMode === 'estate' ? 'probate' : 'estate';
  updateUI();
});

updateUI();

</script>

</body>
</html>