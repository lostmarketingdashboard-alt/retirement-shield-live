---
export const prerender = false;
export const ssr = false;
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dividend Watch — Retirement Income Portfolio Monitor</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --navy:#0F1F3D;--navy-light:#1A2D52;--navy-mid:#152847;--gold:#C9A84C;--gold-light:#D4B96A;
  --gold-glow:rgba(201,168,76,0.12);--cream:#FAF7F0;--cream-dark:#F0EBE0;--white:#FFFFFF;
  --text-dark:#1A1A1A;--text-mid:#4A4A4A;--text-light:#7A7A7A;--green:#2E8B57;--amber:#D97706;--red:#B73E2E;
  --border:#E8E3D8;--shadow:0 2px 20px rgba(15,31,61,0.08)
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text-dark);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
.site-header{background:var(--navy);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;border-bottom:2px solid var(--gold)}
.logo{text-decoration:none}.logo-text{font-family:'Playfair Display',serif;color:var(--white);font-size:18px;font-weight:600}.logo-text span{color:var(--gold)}
.hero{background:var(--navy);padding:78px 24px 94px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 25% 18%, rgba(201,168,76,0.08) 0%, transparent 48%),radial-gradient(ellipse at 76% 74%, rgba(201,168,76,0.05) 0%, transparent 54%);pointer-events:none}
.hero-inner{position:relative;z-index:1;max-width:980px;margin:0 auto}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.22);border-radius:999px;padding:8px 18px;margin-bottom:28px;font-size:11px;font-weight:700;color:var(--gold);letter-spacing:1.2px;text-transform:uppercase}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,54px);font-weight:700;color:var(--white);line-height:1.12;margin-bottom:18px}
.hero h1 em{color:var(--gold);font-style:normal}
.hero-sub{font-size:18px;color:rgba(255,255,255,0.66);line-height:1.7;max-width:840px;margin:0 auto 38px;font-weight:300}
.hero-points{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
.hero-point{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.84);border-radius:999px;padding:10px 16px;font-size:13px}
.wizard-section,.analysis-section,.report-section{padding:52px 24px 30px}
.wizard-grid{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:340px minmax(0,1fr);gap:28px;align-items:start}
.sticky-sidebar{position:sticky;top:94px}
.sidebar-card,.form-card,.analysis-card,.report-shell,.disclaimer{background:var(--white);border:1px solid var(--border);border-radius:16px;box-shadow:var(--shadow)}
.sidebar-card{padding:28px}
.sidebar-label,.step-label,.section-kicker,.report-kicker{font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--gold)}
.sidebar-title{font-family:'Playfair Display',serif;font-size:28px;line-height:1.15;color:var(--navy);margin:8px 0 14px}
.sidebar-copy{font-size:14px;color:var(--text-mid);margin-bottom:22px}
.step-list{display:flex;flex-direction:column;gap:12px;margin-bottom:22px}
.step-item{display:grid;grid-template-columns:34px 1fr;gap:12px;align-items:start;padding:12px 14px;border-radius:12px;background:var(--cream);border:1px solid transparent}
.step-item.active{border-color:rgba(201,168,76,0.4);background:var(--gold-glow)}
.step-item.done .step-num{background:var(--gold);color:var(--navy)}
.step-num{width:34px;height:34px;border-radius:50%;background:var(--cream-dark);color:var(--navy);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700}
.step-title{font-size:14px;font-weight:700;color:var(--navy);line-height:1.35}.step-sub{font-size:12px;color:var(--text-light);margin-top:2px}
.sidebar-note{border-radius:14px;background:var(--navy);color:rgba(255,255,255,0.78);padding:18px;font-size:13px}.sidebar-note strong{color:var(--white);display:block;margin-bottom:6px}
.form-card{overflow:hidden}.form-header{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-light) 100%);padding:28px 30px}
.form-header-top{display:flex;justify-content:space-between;gap:16px;align-items:center;margin-bottom:18px}
.form-badge{display:inline-flex;align-items:center;gap:8px;padding:7px 14px;background:rgba(201,168,76,0.12);border:1px solid rgba(201,168,76,0.24);color:var(--gold);border-radius:999px;font-size:11px;font-weight:700;letter-spacing:1.1px;text-transform:uppercase}
.progress-inline{color:rgba(255,255,255,0.62);font-size:12px;font-weight:600}
.form-title{font-family:'Playfair Display',serif;color:var(--white);font-size:34px;line-height:1.1;margin-bottom:10px}
.form-sub{color:rgba(255,255,255,0.64);font-size:15px;max-width:760px}
.progress-bar{height:5px;background:rgba(255,255,255,0.1);border-radius:999px;margin-top:18px;overflow:hidden}
.progress-fill{height:100%;width:50%;background:linear-gradient(90deg,var(--gold),var(--gold-light));border-radius:999px;transition:width .35s ease}
.form-body{padding:30px}.form-step{display:none}.form-step.active{display:block}
.step-question{font-family:'Playfair Display',serif;font-size:28px;line-height:1.18;color:var(--navy);margin:8px 0}
.step-help{font-size:14px;color:var(--text-light);margin-bottom:24px;max-width:760px}
.field-grid,.metric-grid,.alert-grid,.calendar-grid,.table-grid{display:grid;gap:18px}
.field-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
.metric-grid,.alert-grid,.calendar-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
.field-group{margin-bottom:18px}.field-group.full{grid-column:1/-1}
.field-label{display:block;font-size:11px;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.9px;margin-bottom:8px}
.field-input,.field-select,.field-textarea{width:100%;border:1.5px solid var(--border);border-radius:10px;background:var(--cream);color:var(--text-dark);font-size:15px;font-family:'DM Sans',sans-serif;padding:14px 16px;outline:none;transition:border-color .2s,box-shadow .2s,background .2s}
.field-input:focus,.field-select:focus,.field-textarea:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,168,76,0.12);background:var(--white)}
.field-textarea{min-height:110px;resize:vertical}
.btn-row{display:flex;justify-content:space-between;gap:12px;margin-top:26px}
.btn-back,.btn-next,.btn-print,.btn-secondary,.btn-add{border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s ease}
.btn-back,.btn-secondary,.btn-add{background:transparent;border:1.5px solid var(--border);color:var(--text-mid);padding:13px 18px}
.btn-next,.btn-print{background:var(--gold);color:var(--navy);padding:13px 20px}.btn-next:hover,.btn-print:hover{background:var(--gold-light)}
.holdings-shell{display:flex;flex-direction:column;gap:12px}
.holding-row{display:grid;grid-template-columns:1fr 1fr auto;gap:12px;align-items:end}
.insight-band{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin-top:8px}
.insight-chip{border:1px solid var(--border);border-radius:14px;background:var(--cream);padding:16px}
.insight-chip strong{display:block;font-size:13px;color:var(--navy);margin-bottom:6px}.insight-chip span{font-size:13px;color:var(--text-light)}
.analysis-section,.report-section{display:none}.analysis-section.active,.report-section.active{display:block}
.analysis-card{max-width:920px;margin:0 auto;padding:42px 28px;text-align:center}
.analysis-orb{width:96px;height:96px;margin:0 auto 20px;border-radius:50%;background:radial-gradient(circle at 35% 35%,var(--gold-light),var(--gold));position:relative;box-shadow:0 0 0 16px rgba(201,168,76,0.08),0 0 0 32px rgba(201,168,76,0.04)}
.analysis-orb::after{content:'';position:absolute;inset:24px;border-radius:50%;background:var(--navy);opacity:.16}
.analysis-title{font-family:'Playfair Display',serif;font-size:34px;color:var(--navy);margin-bottom:8px}
.analysis-sub{font-size:15px;color:var(--text-light);margin-bottom:28px}
.analysis-steps{max-width:560px;margin:0 auto;display:flex;flex-direction:column;gap:12px}
.analysis-step{display:grid;grid-template-columns:38px 1fr;gap:14px;align-items:center;text-align:left;padding:14px 16px;border-radius:12px;background:var(--cream);border:1px solid var(--border)}
.analysis-indicator{width:38px;height:38px;border-radius:50%;background:var(--gold-glow);color:var(--gold);display:flex;align-items:center;justify-content:center;font-weight:700}
.analysis-step.done .analysis-indicator{background:var(--gold);color:var(--navy)}.analysis-text{font-size:14px;color:var(--text-mid)}
.report-shell{max-width:1080px;margin:0 auto;overflow:hidden}
.report-header{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-mid) 100%);padding:36px 32px 30px;color:var(--white)}
.report-title{font-family:'Playfair Display',serif;font-size:clamp(30px,4vw,44px);line-height:1.1;margin:10px 0 12px}
.report-subtitle{color:rgba(255,255,255,0.72);font-size:15px;max-width:800px}
.report-meta{margin-top:20px;display:flex;flex-wrap:wrap;gap:12px}
.report-meta-item,.pill{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:999px;padding:8px 14px;font-size:12px;color:rgba(255,255,255,0.8)}
.report-body{padding:28px;display:grid;gap:22px}
.hero-summary,.section-card{background:var(--white);border:1px solid var(--border);border-radius:16px}
.hero-summary{padding:28px;background:linear-gradient(135deg,rgba(15,31,61,0.03),rgba(201,168,76,0.08)),var(--white)}
.summary-lead{display:grid;grid-template-columns:1.05fr .95fr;gap:22px}
.summary-title{font-family:'Playfair Display',serif;font-size:34px;color:var(--navy);line-height:1.08;margin-bottom:10px}.summary-title em{color:var(--gold);font-style:normal}
.summary-copy{font-size:15px;color:var(--text-mid)}
.summary-benchmark{background:var(--navy);color:rgba(255,255,255,0.82);border-radius:16px;padding:22px}
.summary-benchmark .headline{font-family:'Playfair Display',serif;font-size:24px;color:var(--white);line-height:1.14;margin:8px 0 10px}
.metric-card,.alert-card,.calendar-card{background:var(--cream);border:1px solid var(--border);border-radius:14px;padding:16px}
.metric-label,.alert-label,.calendar-label{font-size:11px;text-transform:uppercase;letter-spacing:.9px;color:var(--text-light);font-weight:700;margin-bottom:6px}
.metric-value{font-family:'Playfair Display',serif;font-size:30px;color:var(--navy);line-height:1;margin-bottom:6px}
.metric-sub,.alert-copy,.calendar-copy{font-size:12px;color:var(--text-light)}
.section-card{padding:24px}
.section-head{display:flex;justify-content:space-between;align-items:end;gap:16px;margin-bottom:18px}
.section-title{font-family:'Playfair Display',serif;font-size:26px;color:var(--navy);line-height:1.15;margin-top:4px}
.section-copy{font-size:13px;color:var(--text-light);max-width:700px}
.pill{background:var(--cream);border-color:var(--border);color:var(--navy)}
.alert-card.risk{border-left:4px solid var(--red)}.alert-card.watch{border-left:4px solid var(--amber)}.alert-card.good{border-left:4px solid var(--green)}
.calendar-grid{grid-template-columns:repeat(4,minmax(0,1fr))}
.calendar-card .value{font-family:'Playfair Display',serif;font-size:24px;color:var(--navy);margin-bottom:6px}
.calendar-card .sub{font-size:12px;color:var(--text-mid)}
.holdings-table{width:100%;border-collapse:collapse}
.holdings-table th,.holdings-table td{padding:12px 14px;border-bottom:1px solid var(--border);text-align:left;font-size:14px}
.holdings-table th{font-size:11px;text-transform:uppercase;letter-spacing:.8px;color:var(--text-light)}
.holdings-table tr:last-child td{border-bottom:none}
.warning-banner{display:none;margin-top:16px;background:rgba(217,119,6,0.1);border:1px solid rgba(217,119,6,0.24);border-radius:14px;padding:14px 16px;color:#8A5200;font-size:13px}
.warning-banner.active{display:block}
.report-actions{display:flex;justify-content:space-between;gap:12px;align-items:center;padding:0 28px 28px}
.report-note{font-size:12px;color:var(--text-light)}
.disclaimer{max-width:1080px;margin:0 auto 64px;padding:24px 28px 32px}.disclaimer p{font-size:11px;color:var(--text-light);line-height:1.7}.disclaimer strong{color:var(--text-mid)}
.fade-up{opacity:0;transform:translateY(16px);transition:opacity .45s ease,transform .45s ease}.fade-up.visible{opacity:1;transform:translateY(0)}
@media (max-width:980px){.wizard-grid,.field-grid,.metric-grid,.alert-grid,.calendar-grid,.summary-lead,.holding-row,.insight-band{grid-template-columns:1fr}.sticky-sidebar{position:static}}
@media (max-width:768px){.site-header{padding:14px 16px}.hero{padding:54px 20px 72px}.wizard-section,.analysis-section,.report-section{padding-left:16px;padding-right:16px}.sidebar-card,.form-body,.report-body,.section-card,.hero-summary,.analysis-card,.disclaimer{padding-left:20px;padding-right:20px}.form-header,.report-header{padding:28px 20px}.step-question,.section-title{font-size:23px}.summary-title{font-size:28px}.btn-row,.section-head,.report-actions{flex-direction:column;align-items:stretch}.holdings-table,.holdings-table tbody,.holdings-table tr,.holdings-table td{display:block;width:100%}.holdings-table thead{display:none}.holdings-table tr{padding:12px 0;border-bottom:1px solid var(--border)}.holdings-table td{padding:4px 0;border:none}.holdings-table td::before{content:attr(data-label);display:block;font-size:11px;text-transform:uppercase;letter-spacing:.8px;color:var(--text-light);font-weight:700;margin-bottom:2px}}
@media print{body{background:#fff}.site-header,.hero,.wizard-section,.analysis-section,.disclaimer,.report-actions{display:none!important}.report-section{display:block!important;padding:0!important}.report-shell,.section-card,.hero-summary,.metric-card,.alert-card,.calendar-card{box-shadow:none!important;border-color:#ddd!important}.report-shell{max-width:none!important;border:none!important}}
</style>
</head>
<body>
<header class="site-header"><a href="/portal" class="logo"><div class="logo-text">Retirement <span>Shield</span></div></a></header>
<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge">Dividend Monitoring Tool</div>
    <h1>Dividend <em>Watch</em></h1>
    <p class="hero-sub">Track a retiree’s dividend-paying holdings like an income system, not a brokerage list. This report flags upcoming ex-dividend dates, change warnings, payout-ratio stress, and a month-by-month retirement paycheck calendar.</p>
    <div class="hero-points">
      <div class="hero-point">Upcoming ex-dividend alerts</div>
      <div class="hero-point">Dividend health score</div>
      <div class="hero-point">Monthly paycheck calendar</div>
    </div>
  </div>
</section>

<section class="wizard-section" id="wizardSection">
  <div class="wizard-grid">
    <aside class="sticky-sidebar">
      <div class="sidebar-card">
        <div class="sidebar-label">Monitor Builder</div>
        <div class="sidebar-title">Dividend investors do not just want yield. They want to know whether next month’s paycheck is still credible.</div>
        <div class="sidebar-copy">This tool watches the holdings list for dividend timing, change signals, payout-ratio stress, and concentration risk so the retiree can see the income stream as a living system.</div>
        <div class="step-list">
          <div class="step-item active" data-step-indicator="1"><div class="step-num">1</div><div><div class="step-title">Holdings</div><div class="step-sub">Ticker symbols and share counts</div></div></div>
          <div class="step-item" data-step-indicator="2"><div class="step-num">2</div><div><div class="step-title">Monitoring Notes</div><div class="step-sub">What matters most in the income stream</div></div></div>
        </div>
        <div class="sidebar-note"><strong>Live-market version</strong>This one uses live FMP-backed holding analysis instead of the bundled prototype dividend dataset used in the older paycheck tool.</div>
      </div>
    </aside>

    <div class="form-card">
      <div class="form-header">
        <div class="form-header-top"><div class="form-badge">Retirement Shield Tool</div><div class="progress-inline" id="progressText">Step 1 of 2</div></div>
        <div class="form-title">Watch the retirement income stream, not just the ticker tape.</div>
        <div class="form-sub">Enter up to 15 dividend holdings with share counts. We’ll build a live alert summary, monthly paycheck calendar, and dividend health score report you can save into the portal.</div>
        <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
      </div>
      <div class="form-body">
        <div class="form-step active" id="step1">
          <div class="step-label">Step 1 of 2</div>
          <div class="step-question">Which holdings should we monitor?</div>
          <div class="step-help">Use common stock or ETF ticker symbols and approximate share counts. The report is built for live dividend and payout-ratio monitoring, not just static yield math.</div>
          <div class="field-grid">
            <div class="field-group">
              <label class="field-label" for="fullName">Prepared For</label>
              <input class="field-input" id="fullName" type="text" placeholder="e.g. Margaret Thomas">
            </div>
            <div class="field-group">
              <label class="field-label" for="householdLabel">Portfolio Label</label>
              <input class="field-input" id="householdLabel" type="text" placeholder="e.g. Core Dividend Income Sleeve">
            </div>
            <div class="field-group full">
              <label class="field-label">Holdings</label>
              <div class="holdings-shell" id="holdingsRows"></div>
              <button class="btn-add" type="button" onclick="addHoldingRow()">+ Add Another Holding</button>
            </div>
          </div>
          <div class="insight-band">
            <div class="insight-chip"><strong>What this includes</strong><span>Ex-dividend timing, dividend change signals, payout-ratio warnings, and expected paycheck timing by month.</span></div>
            <div class="insight-chip"><strong>What this is not</strong><span>Not a buy/sell engine and not a replacement for reading company filings or fund notices.</span></div>
            <div class="insight-chip"><strong>Best use case</strong><span>Use it to see where the income stream is getting thin before a cut actually lands.</span></div>
          </div>
          <div class="btn-row"><div></div><button class="btn-next" type="button" onclick="nextStep(2)">Continue →</button></div>
        </div>

        <div class="form-step" id="step2">
          <div class="step-label">Step 2 of 2</div>
          <div class="step-question">What monitoring angle matters most?</div>
          <div class="step-help">This note helps frame the summary narrative, but the tool still runs the full alert stack.</div>
          <div class="field-grid">
            <div class="field-group">
              <label class="field-label" for="monitorPreference">Primary Concern</label>
              <select class="field-select" id="monitorPreference">
                <option value="alerts">I care most about dividend cuts and warning signs</option>
                <option value="calendar">I care most about paycheck timing</option>
                <option value="sustainability">I care most about long-term dividend sustainability</option>
              </select>
            </div>
            <div class="field-group full">
              <label class="field-label" for="portfolioNotes">Portfolio Notes</label>
              <textarea class="field-textarea" id="portfolioNotes" placeholder="e.g. This sleeve is supposed to cover groceries, utilities, and most of our travel budget."></textarea>
            </div>
          </div>
          <div class="warning-banner" id="warningBanner"></div>
          <div class="btn-row"><button class="btn-back" type="button" onclick="nextStep(1)">← Back</button><button class="btn-next" type="button" onclick="generateDividendWatch()">Generate My Dividend Watch Report →</button></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="analysis-section" id="analysisSection">
  <div class="analysis-card">
    <div class="analysis-orb"></div>
    <div class="analysis-title">Analyzing the Income Stream</div>
    <div class="analysis-sub">Pulling live dividend timing, payout-ratio signals, and portfolio-level concentration pressure.</div>
    <div class="analysis-steps">
      <div class="analysis-step" id="analysisStep1"><div class="analysis-indicator">1</div><div class="analysis-text">Validating the tickers and share counts...</div></div>
      <div class="analysis-step" id="analysisStep2"><div class="analysis-indicator">2</div><div class="analysis-text">Loading live quote, dividend, and payout-ratio data...</div></div>
      <div class="analysis-step" id="analysisStep3"><div class="analysis-indicator">3</div><div class="analysis-text">Building the paycheck calendar and alert stack...</div></div>
      <div class="analysis-step" id="analysisStep4"><div class="analysis-indicator">4</div><div class="analysis-text">Saving the finished report into Portal Documents and Tools...</div></div>
    </div>
  </div>
</section>

<section class="report-section" id="reportSection">
  <div class="report-shell fade-up" id="reportShell">
    <div class="report-header">
      <div class="report-kicker">Retirement Income Portfolio Monitor</div>
      <div class="report-title" id="reportTitle">Dividend Watch</div>
      <div class="report-subtitle" id="reportSubtitle">A saved holding-by-holding dividend monitor with timing, alert, and sustainability signals.</div>
      <div class="report-meta">
        <div class="report-meta-item" id="metaPortfolio">Portfolio —</div>
        <div class="report-meta-item" id="metaHoldings">Holdings —</div>
        <div class="report-meta-item" id="metaDate">Generated —</div>
      </div>
    </div>
    <div class="report-body">
      <div class="hero-summary">
        <div class="summary-lead">
          <div>
            <div class="section-kicker">Headline</div>
            <div class="summary-title" id="summaryTitle">Your dividend stream now has a <em>health score</em>.</div>
            <div class="summary-copy" id="summaryCopy">Summary appears here.</div>
          </div>
          <div class="summary-benchmark">
            <div class="section-kicker" style="color:rgba(255,255,255,0.6);">Primary Watchpoint</div>
            <div class="headline" id="benchmarkHeadline">Biggest income risk</div>
            <div id="benchmarkCopy">Benchmark summary appears here.</div>
          </div>
        </div>
        <div class="metric-grid" style="margin-top:22px;">
          <div class="metric-card"><div class="metric-label">Annual Dividend Income</div><div class="metric-value" id="annualIncomeValue">$0</div><div class="metric-sub" id="annualIncomeSub">Across supported holdings</div></div>
          <div class="metric-card"><div class="metric-label">Average Monthly Income</div><div class="metric-value" id="monthlyIncomeValue">$0</div><div class="metric-sub" id="monthlyIncomeSub">Across the calendar year</div></div>
          <div class="metric-card"><div class="metric-label">Dividend Health Score</div><div class="metric-value" id="healthScoreValue">0/100</div><div class="metric-sub" id="healthScoreSub">Blend of payout stress, cuts, and concentration</div></div>
        </div>
      </div>

      <div class="section-card">
        <div class="section-head">
          <div><div class="section-kicker">Live Alerts</div><div class="section-title">What needs attention now</div><div class="section-copy">These alerts are meant to pull the retiree back in when the income stream changes, not just when the price chart moves.</div></div>
          <div class="pill" id="alertsPill">Alerts</div>
        </div>
        <div class="alert-grid" id="alertsGrid"></div>
      </div>

      <div class="section-card">
        <div class="section-head">
          <div><div class="section-kicker">Paycheck Calendar</div><div class="section-title">Expected income by month</div><div class="section-copy">The point is not just total income. It is when the money should actually hit.</div></div>
          <div class="pill">Calendar</div>
        </div>
        <div class="calendar-grid" id="calendarGrid"></div>
      </div>

      <div class="section-card">
        <div class="section-head">
          <div><div class="section-kicker">Holding Health</div><div class="section-title">The income stream, one line at a time</div><div class="section-copy">This is where payout ratio strain, dividend-change pressure, and next ex-dividend timing become visible.</div></div>
          <div class="pill" id="concentrationPill">Concentration</div>
        </div>
        <table class="holdings-table">
          <thead>
            <tr>
              <th>Ticker</th>
              <th>Annual Income</th>
              <th>Yield</th>
              <th>Payout</th>
              <th>Next Ex-Date</th>
              <th>Health</th>
            </tr>
          </thead>
          <tbody id="holdingsTableRows"></tbody>
        </table>
      </div>
    </div>
    <div class="report-actions">
      <div class="report-note">Saved reports reopen from Portal Documents and print cleanly as a dividend-monitor PDF.</div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <button class="btn-secondary" type="button" onclick="editDividendWatch()">Edit Inputs</button>
        <button class="btn-print" type="button" onclick="window.print()">Print / Save PDF</button>
      </div>
    </div>
  </div>
</section>

<div class="disclaimer">
  <p><strong>Important Disclosures:</strong> Dividend Watch is for educational purposes only and does not constitute investment, legal, tax, or financial advice. Dividend yields, ex-dividend dates, payment dates, payout ratios, and dividend change records depend on third-party market data and can be delayed, revised, incomplete, or incorrect. A payout ratio warning is not a guarantee of a dividend cut, and a stable recent payment history is not a guarantee of future income. Always verify current company filings, fund notices, and tax consequences before acting. © 2026 Retirement Shield. All rights reserved.</p>
</div>

<script>
let currentStep = 1;
let holdingRowId = 0;

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach((section) => section.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');
  document.querySelectorAll('.step-item').forEach((item, index) => {
    item.classList.remove('active','done');
    if (index + 1 < step) item.classList.add('done');
    if (index + 1 === step) item.classList.add('active');
  });
  currentStep = step;
  document.getElementById('progressText').textContent = `Step ${step} of 2`;
  document.getElementById('progressFill').style.width = `${(step / 2) * 100}%`;
}

function addHoldingRow(data = {}) {
  holdingRowId += 1;
  const container = document.getElementById('holdingsRows');
  const row = document.createElement('div');
  row.className = 'holding-row';
  row.dataset.rowId = String(holdingRowId);
  row.innerHTML = `
    <div class="field-group">
      <label class="field-label" for="ticker-${holdingRowId}">Ticker</label>
      <input class="field-input" id="ticker-${holdingRowId}" type="text" value="${data.ticker || ''}" placeholder="e.g. JNJ">
    </div>
    <div class="field-group">
      <label class="field-label" for="shares-${holdingRowId}">Shares</label>
      <input class="field-input" id="shares-${holdingRowId}" type="number" min="0" step="0.01" value="${data.shares || ''}" placeholder="e.g. 100">
    </div>
    <button class="btn-add" type="button" onclick="removeHoldingRow(${holdingRowId})">Remove</button>
  `;
  container.appendChild(row);
}

function removeHoldingRow(id) {
  const row = document.querySelector(`.holding-row[data-row-id="${id}"]`);
  if (row) row.remove();
}

function getHoldings() {
  return Array.from(document.querySelectorAll('.holding-row')).map((row) => {
    const ticker = row.querySelector('input[id^="ticker-"]')?.value?.trim()?.toUpperCase() || '';
    const shares = Number(row.querySelector('input[id^="shares-"]')?.value || 0);
    return { ticker, shares };
  }).filter((row) => row.ticker && row.shares > 0);
}

function validateInput() {
  const holdings = getHoldings();
  if (!holdings.length) return 'Enter at least one holding with shares.';
  return '';
}

function populateReport(payload, notes, label) {
  const holdings = payload.holdings || [];
  const alerts = payload.alerts || [];
  const generatedDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  document.getElementById('reportTitle').textContent = `Dividend Watch for ${document.getElementById('fullName').value.trim() || 'your portfolio'}`;
  document.getElementById('reportSubtitle').textContent = `A saved retirement income monitor covering live dividend timing, warning signals, and health scoring across ${holdings.length} holding${holdings.length === 1 ? '' : 's'}.`;
  document.getElementById('metaPortfolio').textContent = label || 'Dividend income sleeve';
  document.getElementById('metaHoldings').textContent = `${holdings.length} holdings`;
  document.getElementById('metaDate').textContent = `Generated ${generatedDate}`;
  document.getElementById('summaryTitle').innerHTML = `Dividend Health Score: <em>${payload.portfolioScore}/100</em>.`;
  document.getElementById('summaryCopy').textContent = notes || `The income stream is currently projecting about ${payload.annualIncomeLabel} annually and about ${payload.averageMonthlyIncomeLabel} per month on average, but the real issue is whether that paycheck calendar is spreading cleanly across the year and whether any single holding is carrying too much of the burden.`;
  document.getElementById('benchmarkHeadline').textContent = payload.largestIncomeTicker ? `${payload.largestIncomeTicker} is the largest income contributor` : 'Primary income watchpoint';
  document.getElementById('benchmarkCopy').textContent = payload.concentrationPct != null
    ? `${payload.largestIncomeTicker} is currently contributing about ${payload.concentrationLabel} of the monitored annual dividend income. High concentration is not automatically bad, but it means one dividend cut can echo through the whole retirement paycheck system.`
    : 'Concentration review needs more supported holdings to become meaningful.';
  document.getElementById('annualIncomeValue').textContent = payload.annualIncomeLabel || '$0';
  document.getElementById('monthlyIncomeValue').textContent = payload.averageMonthlyIncomeLabel || '$0';
  document.getElementById('healthScoreValue').textContent = `${payload.portfolioScore}/100`;
  document.getElementById('alertsPill').textContent = `${alerts.length} alert${alerts.length === 1 ? '' : 's'}`;
  document.getElementById('concentrationPill').textContent = payload.concentrationPct != null ? `${payload.concentrationLabel} in top holding` : 'Concentration review';

  const alertsGrid = document.getElementById('alertsGrid');
  alertsGrid.innerHTML = (alerts.length ? alerts : [{
    tone: 'good',
    title: 'No major active warnings returned',
    copy: 'The latest pull did not produce a critical payout or dividend-change alert, though the stream should still be reviewed regularly.'
  }]).map((alert) => `
    <div class="alert-card ${alert.tone}">
      <div class="alert-label">${alert.type || 'monitor alert'}</div>
      <div class="metric-value">${alert.title}</div>
      <div class="alert-copy">${alert.copy}</div>
    </div>
  `).join('');

  const calendarGrid = document.getElementById('calendarGrid');
  calendarGrid.innerHTML = (payload.calendar || []).map((month) => `
    <div class="calendar-card">
      <div class="calendar-label">${month.month}</div>
      <div class="value">${month.incomeLabel}</div>
      <div class="sub">${(month.items || []).slice(0, 2).join(' · ') || 'No expected payment mapped'}</div>
    </div>
  `).join('');

  const holdingsTableRows = document.getElementById('holdingsTableRows');
  holdingsTableRows.innerHTML = holdings.map((holding) => `
    <tr>
      <td data-label="Ticker">${holding.ticker}</td>
      <td data-label="Annual Income">${holding.annualIncomeLabel}</td>
      <td data-label="Yield">${holding.dividendYieldLabel}</td>
      <td data-label="Payout">${holding.payoutRatioLabel}</td>
      <td data-label="Next Ex-Date">${holding.nextExDividendDateLabel}</td>
      <td data-label="Health">${holding.healthScore}/100</td>
    </tr>
  `).join('');
}

async function saveDividendWatch(payload, notes, label) {
  const supabase = window.dividendWatchSupabase;
  if (!supabase) return null;
  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const holdings = payload.holdings || [];
  const topHolding = holdings.reduce((best, row) => !best || (row.annualIncome || 0) > (best.annualIncome || 0) ? row : best, null);
  const { error } = await supabase
    .from('dividend_watch_reports')
    .insert({
      user_id: userId,
      full_name: document.getElementById('fullName').value.trim() || null,
      portfolio_label: label || null,
      holdings_count: holdings.length,
      annual_dividend_income: payload.annualIncome || 0,
      average_monthly_income: payload.averageMonthlyIncome || 0,
      dividend_health_score: payload.portfolioScore || 0,
      top_income_ticker: topHolding?.ticker || null,
      top_income_concentration_pct: payload.concentrationPct || null,
      report_title: `Dividend Watch for ${document.getElementById('fullName').value.trim() || 'Retirement Shield Client'}`,
      report_payload: {
        payload,
        notes,
        label,
        holdingsInput: getHoldings(),
        monitorPreference: document.getElementById('monitorPreference').value
      }
    });

  if (error) console.error('Failed to save Dividend Watch report:', error);
}

function showGeneratedReport() {
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  const steps = ['analysisStep1','analysisStep2','analysisStep3','analysisStep4'];
  let delay = 0;
  steps.forEach((id, index) => {
    delay += 450;
    setTimeout(() => {
      document.getElementById(id).classList.add('done');
      if (index === steps.length - 1) {
        setTimeout(() => {
          document.getElementById('analysisSection').classList.remove('active');
          document.getElementById('reportSection').classList.add('active');
          const shell = document.getElementById('reportShell');
          shell.classList.add('visible');
          shell.scrollIntoView({ behavior: 'smooth', block: 'start' });
          document.querySelectorAll('.fade-up').forEach((el, i) => setTimeout(() => el.classList.add('visible'), i * 80));
        }, 400);
      }
    }, delay);
  });
}

function showHydratedReport() {
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('reportSection').classList.add('active');
  document.getElementById('reportShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedSubmission(report) {
  const stored = report?.report_payload;
  if (!stored?.payload) return false;
  document.getElementById('fullName').value = report.full_name || '';
  document.getElementById('householdLabel').value = stored.label || report.portfolio_label || '';
  document.getElementById('portfolioNotes').value = stored.notes || '';
  document.getElementById('monitorPreference').value = stored.monitorPreference || 'alerts';
  document.getElementById('holdingsRows').innerHTML = '';
  (stored.holdingsInput || []).forEach((row) => addHoldingRow(row));
  if (!(stored.holdingsInput || []).length) addHoldingRow();
  populateReport(stored.payload, stored.notes || '', stored.label || '');
  showHydratedReport();
  return true;
}

async function generateDividendWatch() {
  const validationError = validateInput();
  if (validationError) {
    alert(validationError);
    return;
  }

  const response = await fetch('/api/dividend-watch/analyze', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ holdings: getHoldings() })
  });

  const data = await response.json().catch(() => null);
  if (!response.ok || !data?.portfolio) {
    const banner = document.getElementById('warningBanner');
    banner.classList.add('active');
    banner.textContent = data?.error || 'Unable to analyze the dividend holdings right now.';
    return;
  }

  const notes = document.getElementById('portfolioNotes').value.trim();
  const label = document.getElementById('householdLabel').value.trim();
  document.getElementById('warningBanner').classList.remove('active');
  document.getElementById('warningBanner').textContent = '';
  populateReport(data.portfolio, notes, label);
  await saveDividendWatch(data.portfolio, notes, label);
  showGeneratedReport();
}

function editDividendWatch() {
  document.getElementById('reportSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(2);
}

window.nextStep = nextStep;
window.addHoldingRow = addHoldingRow;
window.removeHoldingRow = removeHoldingRow;
window.generateDividendWatch = generateDividendWatch;
window.editDividendWatch = editDividendWatch;
window.hydrateDividendWatchSubmission = hydrateSavedSubmission;

addHoldingRow();
addHoldingRow();
addHoldingRow();
</script>
