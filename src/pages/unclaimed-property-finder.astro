        <button class="btn-secondary" type="button" onclick="editUnclaimedProperty()">Edit Inputs</button>
        <button class="btn-print" type="button" onclick="window.print()">Print / Save PDF</button>
      </div>
    </div>
  </div>
</section>

<div class="disclaimer">
  <p><strong>Important Disclosures:</strong> Unclaimed Property Finder is for educational purposes only and does not constitute legal, tax, or financial advice. State claim procedures, required proof, and processing rules can vary by jurisdiction and by claim type. Always verify final claim steps with the official state property office before filing. Retirement Shield is not a law firm and does not process claims on your behalf. © 2026 Retirement Shield. All rights reserved.</p>
</div>

<script>
const STATE_OPTIONS = [
  ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],['CA','California'],['CO','Colorado'],
  ['CT','Connecticut'],['DE','Delaware'],['FL','Florida'],['GA','Georgia'],['HI','Hawaii'],['ID','Idaho'],
  ['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],['KY','Kentucky'],['LA','Louisiana'],
  ['ME','Maine'],['MD','Maryland'],['MA','Massachusetts'],['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],
  ['MO','Missouri'],['MT','Montana'],['NE','Nebraska'],['NV','Nevada'],['NH','New Hampshire'],['NJ','New Jersey'],
  ['NM','New Mexico'],['NY','New York'],['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
  ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],['SD','South Dakota'],
  ['TN','Tennessee'],['TX','Texas'],['UT','Utah'],['VT','Vermont'],['VA','Virginia'],['WA','Washington'],
  ['WV','West Virginia'],['WI','Wisconsin'],['WY','Wyoming'],['DC','District of Columbia']
];

const TARGET_LABELS = {
  self: 'My Name',
  spouse: 'Spouse / Partner',
  parent: 'Parent',
  deceased_relative: 'Deceased Relative',
  prior_state: 'Prior State',
  business: 'Old Business / LLC'
};

const PROOF_LABELS = {
  basic: 'Basic',
  estate: 'Estate',
  multiple: 'Multi-Document',
  unknown: 'Unknown'
};

const FALLBACK_SEARCH_TEXT = {
  AL: 'alabama unclaimed property search',
  AK: 'alaska unclaimed property search',
  AZ: 'arizona unclaimed property search',
  AR: 'arkansas unclaimed property search',
  CA: 'california unclaimed property search',
  CO: 'colorado unclaimed property search',
  CT: 'connecticut unclaimed property search',
  DE: 'delaware unclaimed property search',
  FL: 'FloridaTreasureHunt.gov',
  GA: 'georgia unclaimed property search',
  HI: 'hawaii unclaimed property search',
  ID: 'idaho unclaimed property search',
  IL: 'illinois unclaimed property search',
  IN: 'indiana unclaimed property search',
  IA: 'iowa unclaimed property search',
  KS: 'kansas unclaimed property search',
  KY: 'kentucky unclaimed property search',
  LA: 'louisiana unclaimed property search',
  ME: 'maine unclaimed property search',
  MD: 'maryland unclaimed property search',
  MA: 'massachusetts unclaimed property search',
  MI: 'michigan unclaimed property search',
  MN: 'minnesota unclaimed property search',
  MS: 'mississippi unclaimed property search',
  MO: 'missouri unclaimed property search',
  MT: 'montana unclaimed property search',
  NE: 'nebraska unclaimed property search',
  NV: 'nevada unclaimed property search',
  NH: 'new hampshire unclaimed property search',
  NJ: 'new jersey unclaimed property search',
  NM: 'new mexico unclaimed property search',
  NY: 'new york unclaimed property search',
  NC: 'north carolina unclaimed property search',
  ND: 'north dakota unclaimed property search',
  OH: 'ohio unclaimed property search',
  OK: 'oklahoma unclaimed property search',
  OR: 'oregon unclaimed property search',
  PA: 'pennsylvania unclaimed property search',
  RI: 'rhode island unclaimed property search',
  SC: 'south carolina unclaimed property search',
  SD: 'south dakota unclaimed property search',
  TN: 'tennessee unclaimed property search',
  TX: 'texas unclaimed property search',
  UT: 'utah unclaimed property search',
  VT: 'vermont unclaimed property search',
  VA: 'virginia unclaimed property search',
  WA: 'washington unclaimed property search',
  WV: 'west virginia unclaimed property search',
  WI: 'wisconsin unclaimed property search',
  WY: 'wyoming unclaimed property search',
  DC: 'district of columbia unclaimed property search'
};

STATE_OPTIONS.forEach(([code, name]) => {
  const option = document.createElement('option');
  option.value = code;
  option.textContent = name;
  document.getElementById('stateSelect').appendChild(option);
});

document.querySelectorAll('.selection-card').forEach((card) => {
  card.addEventListener('click', () => {
    const input = card.querySelector('input');
    if (!input) return;
    input.checked = !input.checked;
    syncCards();
  });
});

function syncCards() {
  document.querySelectorAll('.selection-card').forEach((card) => {
    const input = card.querySelector('input');
    card.classList.toggle('selected', Boolean(input?.checked));
  });
}

function slugify(value) {
  return String(value || '').toLowerCase().trim().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '').replace(/-+/g, '-').replace(/^-|-$/g, '');
}

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach((section) => section.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');
  document.querySelectorAll('.step-item').forEach((item, index) => {
    item.classList.remove('active','done');
    if (index + 1 < step) item.classList.add('done');
    if (index + 1 === step) item.classList.add('active');
  });
  document.getElementById('progressText').textContent = `Step ${step} of 2`;
  document.getElementById('progressFill').style.width = `${(step / 2) * 100}%`;
}

function getFormData() {
  return {
    fullName: document.getElementById('fullName').value.trim() || 'Retirement Shield Client',
    stateCode: document.getElementById('stateSelect').value,
    stateName: STATE_OPTIONS.find(([code]) => code === document.getElementById('stateSelect').value)?.[1] || '',
    searchTargets: Array.from(document.querySelectorAll('.selection-card input:checked')).map((input) => input.value),
    proofLevel: document.getElementById('proofSelect').value,
    priorStates: document.getElementById('priorStates').value.trim(),
    notes: document.getElementById('notes').value.trim()
  };
}

function validateData(data) {
  if (!data.stateCode) return 'Choose a state.';
  if (!data.searchTargets.length) return 'Choose at least one search target.';
  if (!data.proofLevel) return 'Choose the likely proof situation.';
  return '';
}

async function loadStateGuide(supabase, stateName) {
  const { data } = await supabase
    .from('state_guides')
    .select('state_name,probate_cost_display,probate_timeline_display,medicaid_lookback_display,lady_bird_display,lady_bird_deed_available,tod_display,tod_deed_available')
    .eq('state_slug', slugify(stateName))
    .maybeSingle();
  return data || null;
}

async function loadStateDirectory(supabase, stateCode) {
  const { data } = await supabase
    .from('unclaimed_property_state_links')
    .select('*')
    .eq('state_code', stateCode)
    .maybeSingle();
  return data || null;
}

function buildDirectoryFallback(data) {
  return {
    state_code: data.stateCode,
    state_name: data.stateName,
    agency_name: `${data.stateName} unclaimed property office`,
    search_url: '',
    search_label: FALLBACK_SEARCH_TEXT[data.stateCode] || `${data.stateName} unclaimed property search`,
    search_hint: `Search ${FALLBACK_SEARCH_TEXT[data.stateCode] || `${data.stateName} unclaimed property search`} and use the official state treasury or comptroller result.`,
    documents_hint: 'Bring government ID, current address proof, and any old addresses or name variations you may need to prove ownership.',
    step_1: 'Run your current legal name first, then maiden names, prior married names, and common spelling variations.',
    step_2: 'Search prior states of residence, former employers, and deceased relatives if the household may have dormant checks or refunds.',
    step_3: 'If a result appears, gather the state-required proof before submitting the claim so the case does not stall.'
  };
}

function buildClaimInstructions(data, directory, guide) {
  const instructions = [];
  instructions.push({
    label: 'Step 1',
    title: 'Run the name search correctly',
    copy: directory.step_1 || 'Search current and prior names, including maiden names, old married names, and common variations.'
  });
  instructions.push({
    label: 'Step 2',
    title: 'Expand the search beyond the obvious',
    copy: data.priorStates ? `Also run searches in ${data.priorStates}. ${directory.step_2 || ''}`.trim() : (directory.step_2 || 'Check prior states, former employers, family members, and old business names when relevant.')
  });

  let proofCopy = directory.documents_hint || 'Gather ID, address proof, and ownership evidence before filing.';
  if (data.proofLevel === 'estate') {
    proofCopy = 'Expect to gather death certificate copies, executor or personal representative paperwork, and proof tying the claimant to the estate before filing.';
  } else if (data.proofLevel === 'multiple') {
    proofCopy = 'Expect to gather old addresses, name-change documents, prior statements, or other ownership proof before the state releases funds.';
  } else if (data.proofLevel === 'unknown') {
    proofCopy = 'Search first, then confirm the exact proof requirements from the state office before filing so the claim package is complete the first time.';
  }

  instructions.push({
    label: 'Step 3',
    title: 'Prepare the claim package',
    copy: proofCopy
  });

  if (guide?.probate_cost_display || guide?.probate_timeline_display) {
    instructions.push({
      label: 'Step 4',
      title: 'Keep the estate records together',
      copy: `Because ${data.stateName} can still involve ${guide.probate_cost_display || 'probate cost'} and ${guide.probate_timeline_display || 'probate delay'}, save claim confirmations and ownership records in the family binder instead of treating this as a one-off search.`
    });
  }

  return instructions.slice(0, 4);
}

function buildModel(data, guide, directoryRecord) {
  const directory = directoryRecord || buildDirectoryFallback(data);
  const instructions = buildClaimInstructions(data, directory, guide);
  const additionalStates = data.priorStates ? data.priorStates.split(',').map((item) => item.trim()).filter(Boolean) : [];
  const familyTargets = data.searchTargets.map((target) => TARGET_LABELS[target] || target);
  const likelyComplexity = data.proofLevel === 'estate' ? 'Estate' : data.proofLevel === 'multiple' ? 'Multi-Document' : data.proofLevel === 'unknown' ? 'Unknown' : 'Basic';
  const searchCards = [
    {
      label: 'Agency',
      title: directory.agency_name || `${data.stateName} unclaimed property office`,
      copy: directory.search_hint || 'Search through the official state database first.'
    },
    {
      label: 'Search Link',
      title: directory.search_url ? 'Open official database' : (directory.search_label || 'Search the official state database'),
      copy: directory.search_url ? directory.search_url : `Use the search phrase "${directory.search_label || `${data.stateName} unclaimed property search`}" and choose the official state result.`
    },
    {
      label: 'Claim Prep',
      title: 'Gather proof before filing',
      copy: directory.documents_hint || 'Bring identity and ownership proof so the claim does not stall.'
    }
  ];

  return {
    directory,
    instructions,
    additionalStates,
    familyTargets,
    likelyComplexity,
    searchCards
  };
}

function populateReport(data, guide, model) {
  const date = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  document.getElementById('reportTitle').textContent = `Unclaimed Property Finder for ${data.fullName}`;
  document.getElementById('reportSubtitle').textContent = `A ${data.stateName} search and claim checklist showing where to look, how to search, and what to gather before filing.`;
  document.getElementById('metaState').textContent = data.stateName;
  document.getElementById('metaTargets').textContent = `${model.familyTargets.length} target${model.familyTargets.length === 1 ? '' : 's'}`;
  document.getElementById('metaDate').textContent = `Generated ${date}`;
  document.getElementById('summaryTitle').innerHTML = `This family should run a <em>${data.stateName}</em> search now.`;
  document.getElementById('summaryCopy').textContent = `Americans are owed tens of billions in unclaimed assets, and the biggest mistake is assuming someone else already checked. This report turns that into a usable state-specific search plan.`;
  document.getElementById('benchmarkHeadline').textContent = model.directory.search_url ? 'Official state database ready' : 'Official state database prompt ready';
  document.getElementById('benchmarkCopy').textContent = model.directory.search_url ? `Use the curated ${data.stateName} link below, then gather proof before filing a claim.` : `A direct official link has not been loaded yet, so the report uses a safe state-specific search prompt instead of guessing.`;
  document.getElementById('targetsValue').textContent = String(model.familyTargets.length);
  document.getElementById('proofValue').textContent = model.likelyComplexity;
  document.getElementById('statesValue').textContent = String(model.additionalStates.length);
  document.getElementById('targetsSub').textContent = model.familyTargets.join(', ');
  document.getElementById('proofSub').textContent = PROOF_LABELS[data.proofLevel] ? `${PROOF_LABELS[data.proofLevel]} proof path likely` : 'Claim proof estimate';
  document.getElementById('statesSub').textContent = model.additionalStates.length ? model.additionalStates.join(', ') : 'No extra states noted';
  document.getElementById('searchPill').textContent = model.directory.search_url ? 'Official link loaded' : 'Fallback search prompt';
  document.getElementById('searchGrid').innerHTML = model.searchCards.map((item, index) => `
    <div class="info-card">
      <div class="info-label">${item.label}</div>
      <div class="info-title">${item.title}</div>
      <div class="info-copy">${item.copy}</div>
      ${index === 1 && model.directory.search_url ? `<a class="link-btn" href="${model.directory.search_url}" target="_blank" rel="noreferrer">Open State Search</a>` : ''}
    </div>
  `).join('');
  document.getElementById('prepPill').textContent = `${model.instructions.length} step${model.instructions.length === 1 ? '' : 's'}`;
  document.getElementById('instructionGrid').innerHTML = model.instructions.map((item) => `
    <div class="instruction-card">
      <div class="instruction-label">${item.label}</div>
      <div class="info-title">${item.title}</div>
      <div class="instruction-copy">${item.copy}</div>
    </div>
  `).join('');
  document.getElementById('contextPill').textContent = `${data.stateCode} backdrop`;
  document.getElementById('contextProbate').textContent = guide?.probate_cost_display && guide?.probate_timeline_display ? `${guide.probate_cost_display} · ${guide.probate_timeline_display}` : 'Review estate records carefully';
  document.getElementById('contextTransfer').textContent = guide?.lady_bird_deed_available ? guide.lady_bird_display : guide?.tod_display || 'Keep title and ownership records organized';
  document.getElementById('contextMedicaid').textContent = guide?.medicaid_lookback_display || 'Retain asset records in the family binder';
  document.getElementById('contextFamily').textContent = data.notes || (data.searchTargets.includes('deceased_relative') ? 'Deceased-relative claims usually require tighter document handling and family coordination.' : 'Share this report with a spouse, parent, or adult child so the search does not stay stuck with one person.');
}

async function saveUnclaimedProperty(data, guide, model) {
  const supabase = window.unclaimedPropertySupabase;
  if (!supabase) return null;
  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const { error } = await supabase
    .from('unclaimed_property_reports')
    .insert({
      user_id: userId,
      full_name: data.fullName,
      state_code: data.stateCode,
      state_name: data.stateName,
      search_targets: data.searchTargets,
      proof_level: data.proofLevel,
      prior_states: data.priorStates,
      report_title: `Unclaimed Property Finder for ${data.fullName}`,
      report_payload: { data, guide, model }
    });

  if (error) console.error('Failed to save unclaimed property report:', error);
}

function showGeneratedReport() {
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  const steps = ['analysisStep1','analysisStep2','analysisStep3','analysisStep4'];
  let delay = 0;
  steps.forEach((id, index) => {
    delay += 450;
    setTimeout(() => {
      document.getElementById(id).classList.add('done');
      if (index === steps.length - 1) {
        setTimeout(() => {
          document.getElementById('analysisSection').classList.remove('active');
          document.getElementById('reportSection').classList.add('active');
          const shell = document.getElementById('reportShell');
          shell.classList.add('visible');
          shell.scrollIntoView({ behavior: 'smooth', block: 'start' });
          document.querySelectorAll('.fade-up').forEach((el, i) => setTimeout(() => el.classList.add('visible'), i * 80));
        }, 400);
      }
    }, delay);
  });
}

function showHydratedReport() {
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('reportSection').classList.add('active');
  document.getElementById('reportShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedSubmission(report) {
  const payload = report?.report_payload;
  if (!payload?.data || !payload?.model) return false;
  document.getElementById('fullName').value = payload.data.fullName || '';
  document.getElementById('stateSelect').value = payload.data.stateCode || '';
  document.getElementById('proofSelect').value = payload.data.proofLevel || '';
  document.getElementById('priorStates').value = payload.data.priorStates || '';
  document.getElementById('notes').value = payload.data.notes || '';
  document.querySelectorAll('.selection-card input').forEach((input) => {
    input.checked = (payload.data.searchTargets || []).includes(input.value);
  });
  syncCards();
  populateReport(payload.data, payload.guide || null, payload.model);
  showHydratedReport();
  return true;
}

async function generateUnclaimedPropertyReport() {
  const data = getFormData();
  const validationError = validateData(data);
  if (validationError) {
    document.getElementById('warningBanner').classList.add('active');
    document.getElementById('warningBanner').textContent = validationError;
    return;
  }
  document.getElementById('warningBanner').classList.remove('active');
  document.getElementById('warningBanner').textContent = '';

  const supabase = window.unclaimedPropertySupabase;
  const [guide, directoryRecord] = await Promise.all([
    loadStateGuide(supabase, data.stateName),
    loadStateDirectory(supabase, data.stateCode)
  ]);

  const model = buildModel(data, guide, directoryRecord);
  populateReport(data, guide, model);
  await saveUnclaimedProperty(data, guide, model);
  showGeneratedReport();
}

function editUnclaimedProperty() {
  document.getElementById('reportSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(2);
}

window.nextStep = nextStep;
window.generateUnclaimedPropertyReport = generateUnclaimedPropertyReport;
window.editUnclaimedProperty = editUnclaimedProperty;
window.hydrateUnclaimedPropertySubmission = hydrateSavedSubmission;
window.UNCLAIMED_PROPERTY_STATE_OPTIONS = STATE_OPTIONS;
syncCards();
</script>

<script type="module">
