---
export const prerender = false;
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Home Equity Intelligence Report — Retirement Shield</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --navy: #0F1F3D;
  --navy-light: #1A2D52;
  --navy-mid: #152847;
  --gold: #C9A84C;
  --gold-light: #D4B96A;
  --gold-pale: #F5EDD6;
  --gold-glow: rgba(201, 168, 76, 0.15);
  --cream: #FAF7F0;
  --cream-dark: #F0EBE0;
  --white: #FFFFFF;
  --text-dark: #1A1A1A;
  --text-mid: #4A4A4A;
  --text-light: #7A7A7A;
  --red-alert: #C0392B;
  --red-bg: #FDF2F0;
  --green-ok: #27AE60;
  --green-bg: #F0FDF4;
  --amber: #E67E22;
  --amber-bg: #FFF8F0;
  --border: #E8E3D8;
  --shadow: 0 2px 20px rgba(15, 31, 61, 0.08);
  --shadow-lg: 0 8px 40px rgba(15, 31, 61, 0.12);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--text-dark);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

.site-header {
  background: var(--navy);
  padding: 16px 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2px solid var(--gold);
}

.logo {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
}

.logo-text {
  font-family: 'Playfair Display', serif;
  color: var(--white);
  font-size: 18px;
  font-weight: 600;
  letter-spacing: -0.3px;
}

.logo-text span { color: var(--gold); }

.hero {
  background: var(--navy);
  padding: 80px 32px 100px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(201,168,76,0.06) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 80%, rgba(201,168,76,0.04) 0%, transparent 50%);
  pointer-events: none;
}

.hero-content { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; }

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(201,168,76,0.12);
  border: 1px solid rgba(201,168,76,0.25);
  border-radius: 100px;
  padding: 8px 20px;
  margin-bottom: 32px;
  font-size: 12px;
  font-weight: 600;
  color: var(--gold);
  letter-spacing: 1.5px;
  text-transform: uppercase;
}

.hero-badge svg { width: 14px; height: 14px; fill: var(--gold); }

.hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 5vw, 52px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.15;
  margin-bottom: 20px;
  letter-spacing: -0.5px;
}

.hero h1 em {
  font-style: normal;
  color: var(--gold);
}

.hero-sub {
  font-size: 18px;
  color: rgba(255,255,255,0.66);
  line-height: 1.65;
  max-width: 620px;
  margin: 0 auto 40px;
  font-weight: 300;
}

.address-form {
  max-width: 640px;
  margin: 0 auto;
}

.address-input-wrap {
  display: flex;
  background: var(--white);
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 4px 30px rgba(0,0,0,0.25), 0 0 0 1px rgba(201,168,76,0.2);
  transition: box-shadow 0.3s;
}

.address-input-wrap:focus-within {
  box-shadow: 0 4px 30px rgba(0,0,0,0.25), 0 0 0 2px var(--gold);
}

.address-input-wrap .icon-wrap {
  display: flex;
  align-items: center;
  padding: 0 16px;
  color: var(--text-light);
}

.address-input-wrap input {
  flex: 1;
  border: none;
  outline: none;
  padding: 18px 4px;
  font-size: 16px;
  font-family: 'DM Sans', sans-serif;
  color: var(--text-dark);
  background: transparent;
}

.address-input-wrap input::placeholder { color: #B0B0B0; }

.address-btn {
  background: var(--gold);
  color: var(--navy);
  border: none;
  padding: 0 28px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.5px;
  cursor: pointer;
  transition: background 0.2s;
  white-space: nowrap;
}

.address-btn:hover:not(:disabled) { background: var(--gold-light); }
.address-btn:disabled { cursor: wait; opacity: 0.75; }

.input-helper-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
  margin-top: 14px;
}

.form-note {
  margin-top: 14px;
  font-size: 12px;
  color: rgba(255,255,255,0.38);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.form-note svg { width: 12px; height: 12px; fill: rgba(255,255,255,0.35); }

.inline-error {
  display: none;
  margin-top: 14px;
  background: rgba(192,57,43,0.14);
  border: 1px solid rgba(192,57,43,0.35);
  color: #ffd4cf;
  border-radius: 8px;
  padding: 12px 14px;
  text-align: left;
  font-size: 13px;
}

.trust-row {
  display: flex;
  justify-content: center;
  gap: 32px;
  margin-top: 40px;
  flex-wrap: wrap;
}

.trust-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: rgba(255,255,255,0.44);
}

.trust-item svg { width: 16px; height: 16px; fill: var(--gold); opacity: 0.6; }

.analyzing-section {
  display: none;
  background: var(--navy);
  padding: 100px 32px 120px;
  text-align: center;
  min-height: 100vh;
  position: relative;
}

.analyzing-content { max-width: 480px; margin: 0 auto; position: relative; z-index: 1; }

.analyzing-house {
  width: 120px;
  height: 120px;
  margin: 0 auto 48px;
  position: relative;
}

.house-outline {
  width: 100%;
  height: 100%;
  border: 2px solid rgba(201,168,76,0.3);
  border-radius: 8px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.house-outline svg {
  width: 48px;
  height: 48px;
  fill: none;
  stroke: var(--gold);
  stroke-width: 1.5;
}

.scan-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  animation: scanDown 2s ease-in-out infinite;
}

@keyframes scanDown {
  0% { top: 0; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { top: 100%; opacity: 0; }
}

.pulse-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 140px;
  height: 140px;
  margin: -70px 0 0 -70px;
  border: 1px solid rgba(201,168,76,0.15);
  border-radius: 50%;
  animation: pulseOut 2s ease-out infinite;
}

.pulse-ring:nth-child(2) { animation-delay: 0.6s; }
.pulse-ring:nth-child(3) { animation-delay: 1.2s; }

@keyframes pulseOut {
  0% { transform: scale(0.8); opacity: 0.6; }
  100% { transform: scale(1.8); opacity: 0; }
}

.analyzing-title {
  font-family: 'Playfair Display', serif;
  font-size: 24px;
  color: var(--white);
  margin-bottom: 12px;
}

.analyzing-address {
  font-size: 14px;
  color: var(--gold);
  margin-bottom: 48px;
  font-weight: 500;
}

.analysis-steps { text-align: left; }

.analysis-step {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  opacity: 0.3;
  transition: opacity 0.4s;
}

.analysis-step.active { opacity: 1; }
.analysis-step.done { opacity: 0.6; }
.analysis-step.error { opacity: 1; }

.step-indicator {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid rgba(201,168,76,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s;
}

.analysis-step.active .step-indicator {
  border-color: var(--gold);
  background: rgba(201,168,76,0.1);
}

.analysis-step.done .step-indicator {
  border-color: var(--green-ok);
  background: rgba(39,174,96,0.15);
}

.analysis-step.error .step-indicator {
  border-color: var(--red-alert);
  background: rgba(192,57,43,0.12);
}

.step-indicator .spinner {
  width: 14px;
  height: 14px;
  border: 2px solid rgba(201,168,76,0.2);
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  display: none;
}

.analysis-step.active .spinner { display: block; }

.step-indicator .check,
.step-indicator .cross {
  display: none;
  width: 12px;
  height: 12px;
}

.analysis-step.done .check { display: block; fill: var(--green-ok); }
.analysis-step.error .cross { display: block; fill: var(--red-alert); }

.step-text {
  font-size: 14px;
  color: rgba(255,255,255,0.7);
}

.analysis-step.active .step-text,
.analysis-step.error .step-text { color: var(--white); }

@keyframes spin { to { transform: rotate(360deg); } }

.report-section { display: none; padding: 0; }

.report-header {
  background: var(--navy);
  padding: 60px 32px 48px;
  position: relative;
  overflow: hidden;
}

.report-header::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
}

.report-header-inner {
  max-width: 900px;
  margin: 0 auto;
}

.report-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.report-label::before {
  content: '';
  width: 24px;
  height: 1px;
  background: var(--gold);
}

.report-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 4vw, 42px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.2;
  margin-bottom: 8px;
}

.report-address {
  font-size: 16px;
  color: rgba(255,255,255,0.5);
  margin-bottom: 28px;
}

.report-meta {
  display: flex;
  gap: 32px;
  flex-wrap: wrap;
}

.report-meta-item {
  font-size: 12px;
  color: rgba(255,255,255,0.4);
}

.report-meta-item strong {
  color: rgba(255,255,255,0.74);
  font-weight: 500;
}

.report-body {
  max-width: 900px;
  margin: 0 auto;
  padding: 48px 32px 80px;
}

.valuation-hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-bottom: 48px;
}

.val-card {
  background: var(--white);
  border-radius: 12px;
  padding: 32px;
  box-shadow: var(--shadow);
  position: relative;
  overflow: hidden;
}

.val-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
}

.val-card.primary::before { background: var(--gold); }
.val-card.secondary::before { background: var(--navy); }

.val-card-label {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--text-light);
  margin-bottom: 8px;
}

.val-card-number {
  font-family: 'Playfair Display', serif;
  font-size: 42px;
  font-weight: 700;
  color: var(--navy);
  line-height: 1;
  margin-bottom: 6px;
}

.val-card-sub {
  font-size: 13px;
  color: var(--text-light);
}

.val-card-sub .change {
  color: var(--green-ok);
  font-weight: 600;
}

.val-card-sub .change.down {
  color: var(--red-alert);
}

.report-block { margin-bottom: 40px; }

.block-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}

.block-icon {
  width: 36px;
  height: 36px;
  background: var(--gold-glow);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.block-icon svg { width: 18px; height: 18px; fill: var(--gold); }

.block-title {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  font-weight: 600;
  color: var(--navy);
}

.data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.data-item {
  background: var(--white);
  border-radius: 8px;
  padding: 20px 24px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  border: 1px solid var(--border);
}

.data-item.full { grid-column: 1 / -1; }

.data-label {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: var(--text-light);
  margin-bottom: 6px;
}

.data-value {
  font-size: 22px;
  font-weight: 700;
  color: var(--navy);
  font-family: 'Playfair Display', serif;
}

.data-note {
  font-size: 12px;
  color: var(--text-light);
  margin-top: 4px;
  line-height: 1.5;
}

.alert-card {
  border-radius: 8px;
  padding: 20px 24px;
  display: flex;
  gap: 16px;
  align-items: flex-start;
  margin-bottom: 12px;
}

.alert-card.danger {
  background: var(--red-bg);
  border: 1px solid rgba(192,57,43,0.15);
}

.alert-card.warning {
  background: var(--amber-bg);
  border: 1px solid rgba(230,126,34,0.15);
}

.alert-card.safe {
  background: var(--green-bg);
  border: 1px solid rgba(39,174,96,0.15);
}

.alert-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 16px;
  font-weight: 700;
}

.alert-card.danger .alert-icon { background: rgba(192,57,43,0.12); color: var(--red-alert); }
.alert-card.warning .alert-icon { background: rgba(230,126,34,0.12); color: var(--amber); }
.alert-card.safe .alert-icon { background: rgba(39,174,96,0.12); color: var(--green-ok); }

.alert-title {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 4px;
}

.alert-card.danger .alert-title { color: var(--red-alert); }
.alert-card.warning .alert-title { color: var(--amber); }
.alert-card.safe .alert-title { color: var(--green-ok); }

.alert-text {
  font-size: 13px;
  color: var(--text-mid);
  line-height: 1.55;
}

.equity-viz {
  background: var(--white);
  border-radius: 12px;
  padding: 32px;
  box-shadow: var(--shadow);
  display: flex;
  align-items: center;
  gap: 40px;
  margin-bottom: 24px;
}

.donut-wrap {
  width: 160px;
  height: 160px;
  flex-shrink: 0;
  position: relative;
}

.donut-wrap svg { width: 100%; height: 100%; transform: rotate(-90deg); }

.donut-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.donut-pct {
  font-family: 'Playfair Display', serif;
  font-size: 36px;
  font-weight: 700;
  color: var(--navy);
  line-height: 1;
}

.donut-label-small {
  font-size: 11px;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.equity-breakdown { flex: 1; }

.equity-breakdown h4 {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-weight: 600;
  color: var(--navy);
  margin-bottom: 16px;
}

.breakdown-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
  gap: 16px;
}

.breakdown-row:last-child { border-bottom: none; }

.breakdown-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  margin-right: 10px;
  flex-shrink: 0;
}

.breakdown-label {
  font-size: 14px;
  color: var(--text-mid);
  display: flex;
  align-items: center;
  flex: 1;
}

.breakdown-val {
  font-size: 14px;
  font-weight: 600;
  color: var(--navy);
  text-align: right;
}

.comp-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.comp-card {
  background: var(--white);
  border-radius: 12px;
  padding: 24px;
  box-shadow: var(--shadow);
}

.comp-card h4 {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  color: var(--navy);
  margin-bottom: 12px;
}

.comp-list {
  display: grid;
  gap: 12px;
}

.comp-item {
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 14px 16px;
}

.comp-item-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 4px;
}

.comp-price {
  font-weight: 700;
  color: var(--navy);
}

.comp-distance {
  font-size: 12px;
  color: var(--text-light);
}

.comp-address {
  font-size: 13px;
  color: var(--text-mid);
}

.comp-meta {
  font-size: 12px;
  color: var(--text-light);
  margin-top: 4px;
}

.empty-state {
  padding: 16px;
  border: 1px dashed var(--border);
  border-radius: 8px;
  font-size: 13px;
  color: var(--text-light);
}

.snapshot-card {
  background: var(--navy);
  border-radius: 12px;
  padding: 40px;
  text-align: center;
  position: relative;
  overflow: hidden;
  margin-top: 48px;
}

.snapshot-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
}

.snapshot-eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 16px;
}

.snapshot-headline {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 600;
  color: var(--white);
  line-height: 1.4;
  max-width: 620px;
  margin: 0 auto 12px;
}

.snapshot-headline em {
  font-style: normal;
  color: var(--gold);
}

.snapshot-sub {
  font-size: 14px;
  color: rgba(255,255,255,0.56);
  margin-bottom: 32px;
  max-width: 540px;
  margin-left: auto;
  margin-right: auto;
}

.snapshot-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--gold);
  color: var(--navy);
  border: none;
  padding: 16px 36px;
  border-radius: 6px;
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
  text-decoration: none;
}

.snapshot-cta:hover { background: var(--gold-light); transform: translateY(-1px); }

.snapshot-cta svg { width: 16px; height: 16px; fill: var(--navy); }

.report-disclaimer {
  max-width: 900px;
  margin: 0 auto;
  padding: 32px 32px 48px;
  border-top: 1px solid var(--border);
}

.disclaimer-text {
  font-size: 11px;
  color: var(--text-light);
  line-height: 1.7;
}

.disclaimer-text strong { color: var(--text-mid); }

.fade-up {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}

.fade-up.visible {
  opacity: 1;
  transform: translateY(0);
}

@media (max-width: 768px) {
  .site-header { padding: 14px 16px; }
  .hero { padding: 48px 20px 64px; }
  .hero-sub { font-size: 16px; }
  .address-input-wrap { flex-direction: column; }
  .address-btn { padding: 16px; }
  .trust-row { gap: 16px; }
  .valuation-hero,
  .data-grid,
  .comp-grid { grid-template-columns: 1fr; }
  .equity-viz { flex-direction: column; text-align: center; }
  .report-body { padding: 32px 20px 60px; }
  .report-header { padding: 40px 20px 32px; }
  .snapshot-card { padding: 32px 20px; }
  .report-meta { gap: 16px; }
}
</style>
</head>
<body>
<header class="site-header">
  <a href="/portal" class="logo">
