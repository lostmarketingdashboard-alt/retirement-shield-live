<script is:inline>
const STATE_OPTIONS = [
  ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],['CA','California'],
  ['CO','Colorado'],['CT','Connecticut'],['DE','Delaware'],['FL','Florida'],['GA','Georgia'],
  ['HI','Hawaii'],['ID','Idaho'],['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],
  ['KY','Kentucky'],['LA','Louisiana'],['ME','Maine'],['MD','Maryland'],['MA','Massachusetts'],
  ['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],['MO','Missouri'],['MT','Montana'],
  ['NE','Nebraska'],['NV','Nevada'],['NH','New Hampshire'],['NJ','New Jersey'],['NM','New Mexico'],
  ['NY','New York'],['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
  ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],['SD','South Dakota'],
  ['TN','Tennessee'],['TX','Texas'],['UT','Utah'],['VT','Vermont'],['VA','Virginia'],['WA','Washington'],
  ['WV','West Virginia'],['WI','Wisconsin'],['WY','Wyoming']
];

const STATE_LONGEVITY = {
  CA: 84.0, FL: 83.2, NY: 83.4, NJ: 83.8, WA: 83.2, MA: 84.1, MD: 82.8, CO: 82.6,
  OR: 82.7, AZ: 82.1, TX: 80.9, NC: 80.7, GA: 80.1, PA: 81.3, OH: 79.8, MI: 79.9,
  TN: 78.9, SC: 79.4, AL: 77.9, LA: 76.8
};

let latestInflationPayload = null;

const stateSelect = document.getElementById('stateSelect');
const placeholderOption = document.createElement('option');
placeholderOption.value = '';
placeholderOption.textContent = 'Select your state...';
placeholderOption.disabled = true;
placeholderOption.selected = true;
stateSelect.appendChild(placeholderOption);

STATE_OPTIONS.forEach(([code, name]) => {
  const option = document.createElement('option');
  option.value = code;
  option.textContent = name;
  stateSelect.appendChild(option);
});

function formatMoney(value) {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(value || 0);
}

function parseMoney(value) {
  const parsed = Number(String(value || '').replace(/[^0-9.]/g, ''));
  return Number.isFinite(parsed) ? parsed : 0;
}

function parsePercent(value, fallback = 0) {
  const parsed = Number(String(value || '').replace(/[^0-9.-]/g, ''));
  return Number.isFinite(parsed) ? parsed : fallback;
}

function stateName(code) {
  return STATE_OPTIONS.find(([v]) => v === code)?.[1] ?? code;
}

function getLongevityAge(stateCode, currentAge) {
  const target = STATE_LONGEVITY[stateCode] || 81.5;
  return Math.max(target, currentAge + 8);
}

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach((panel) => panel.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');
  document.querySelectorAll('[data-step-indicator]').forEach((item, index) => {
    const num = index + 1;
    item.classList.toggle('active', num === step);
    item.classList.toggle('done', num < step);
  });
  document.getElementById('progressText').textContent = `Step ${step} of 3`;
  document.getElementById('progressFill').style.width = `${(step / 3) * 100}%`;
  window.scrollTo({ top: document.getElementById('wizardSection').offsetTop - 76, behavior: 'smooth' });
}

function buildInflationSeries(startAge, endAge, monthlyBudget, rate) {
  const years = [];
  for (let age = startAge; age <= endAge; age += 1) {
    const yearOffset = age - startAge;
    const monthlyCost = monthlyBudget * Math.pow(1 + rate / 100, yearOffset);
    years.push({ age, monthlyCost });
  }
  return years;
}

function buildInflationPayload() {
  const fullName = document.getElementById('fullName').value.trim();
  const stateCode = document.getElementById('stateSelect').value;
  const stateFullName = stateName(stateCode);
  const countyName = document.getElementById('countyName').value.trim();
  const currentAge = Number(document.getElementById('currentAge').value || 0);
  const monthlyBudget = parseMoney(document.getElementById('monthlyBudget').value);
  const budgetPriority = document.getElementById('budgetPriority').value.trim();
  const budgetNotes = document.getElementById('budgetNotes').value.trim();
  const targetAge = Number(document.getElementById('targetAge').value || 85);
  const inflationRate = parsePercent(document.getElementById('inflationRate').value, 3);
  const stressInflationRate = parsePercent(document.getElementById('stressInflationRate').value, 5.5);
  const planningGoal = document.getElementById('planningGoal').value;

  const longevityAge = getLongevityAge(stateCode, currentAge);
  const finalAge = Math.max(targetAge, Math.ceil(longevityAge));
  const baselineSeries = buildInflationSeries(currentAge, finalAge, monthlyBudget, inflationRate);
  const stressSeries = buildInflationSeries(currentAge, finalAge, monthlyBudget, stressInflationRate);
  const targetPoint = baselineSeries.find((point) => point.age === targetAge) || baselineSeries[baselineSeries.length - 1];
  const longevityPoint = baselineSeries.find((point) => point.age === Math.ceil(longevityAge)) || baselineSeries[baselineSeries.length - 1];

  const narrative = `A ${formatMoney(monthlyBudget)} monthly budget today grows to about ${formatMoney(targetPoint.monthlyCost)} by age ${targetAge} at a ${inflationRate.toFixed(1)}% inflation assumption. If this household needs the budget to last through roughly age ${longevityAge.toFixed(1)} in ${countyName || stateFullName || 'their area'}, the same lifestyle could require about ${formatMoney(longevityPoint.monthlyCost)} per month. ${budgetNotes ? budgetNotes : 'That is why retirement income planning has to keep pace with cost growth, not just today’s spending.'}`;

  return {
    fullName,
    stateCode,
    stateName: stateFullName,
    countyName,
    currentAge,
    monthlyBudget,
    budgetPriority,
    budgetNotes,
    targetAge,
    inflationRate,
    stressInflationRate,
    planningGoal,
    longevityAge,
    baselineSeries,
    stressSeries,
    targetBudget: targetPoint.monthlyCost,
    longevityBudget: longevityPoint.monthlyCost,
    narrative
  };
}

function drawChart(payload) {
  const svg = document.getElementById('erosionChart');
  const width = 900;
  const height = 360;
  const padding = { top: 24, right: 24, bottom: 44, left: 70 };
  const chartWidth = width - padding.left - padding.right;
  const chartHeight = height - padding.top - padding.bottom;
  const allValues = [...payload.baselineSeries, ...payload.stressSeries].map((point) => point.monthlyCost);
  const maxValue = Math.max(...allValues);
  const minAge = payload.currentAge;
  const maxAge = payload.baselineSeries[payload.baselineSeries.length - 1].age;

  function x(age) {
    return padding.left + ((age - minAge) / Math.max(1, maxAge - minAge)) * chartWidth;
  }

  function y(value) {
    return padding.top + chartHeight - (value / maxValue) * chartHeight;
  }

  function pathFor(series) {
    return series.map((point, index) => `${index === 0 ? 'M' : 'L'} ${x(point.age).toFixed(2)} ${y(point.monthlyCost).toFixed(2)}`).join(' ');
  }

  const baselinePath = pathFor(payload.baselineSeries);
  const stressPath = pathFor(payload.stressSeries);

  const yTicks = 4;
  const xTicks = payload.baselineSeries.filter((_, index) => index % Math.max(1, Math.floor(payload.baselineSeries.length / 5)) === 0);

  svg.innerHTML = `
    <rect x="0" y="0" width="${width}" height="${height}" fill="transparent"></rect>
    ${new Array(yTicks + 1).fill(null).map((_, index) => {
      const value = (maxValue / yTicks) * index;
      const yPos = y(value);
      return `
        <line x1="${padding.left}" y1="${yPos}" x2="${width - padding.right}" y2="${yPos}" stroke="#E8E3D8" stroke-width="1"></line>
        <text x="${padding.left - 10}" y="${yPos + 4}" text-anchor="end" font-size="11" fill="#7A7A7A">${formatMoney(value)}</text>
      `;
    }).join('')}
    ${xTicks.map((point) => `
      <line x1="${x(point.age)}" y1="${padding.top}" x2="${x(point.age)}" y2="${height - padding.bottom}" stroke="#F0EBE0" stroke-width="1"></line>
      <text x="${x(point.age)}" y="${height - 16}" text-anchor="middle" font-size="11" fill="#7A7A7A">Age ${point.age}</text>
    `).join('')}
    <path d="${stressPath}" fill="none" stroke="#0F1F3D" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"></path>
    <path d="${baselinePath}" fill="none" stroke="#C9A84C" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"></path>
    <circle cx="${x(payload.targetAge)}" cy="${y(payload.targetBudget)}" r="5" fill="#C9A84C"></circle>
    <circle cx="${x(Math.ceil(payload.longevityAge))}" cy="${y(payload.longevityBudget)}" r="5" fill="#0F1F3D"></circle>
  `;
}

function renderInflationReport(payload) {
  latestInflationPayload = payload;
  document.getElementById('reportTitle').textContent = `The Inflation Erosion Visualizer for ${payload.fullName || 'Your Budget'}`;
  document.getElementById('reportSubtitle').textContent = `A year-by-year inflation curve for ${payload.countyName || 'your county'}${payload.stateName ? `, ${payload.stateName}` : ''}, extending through the likely planning horizon.`;
  document.getElementById('metaName').textContent = `Prepared for ${payload.fullName || '—'}`;
  document.getElementById('metaLocation').textContent = `${payload.countyName || 'County not entered'} · ${payload.stateName || 'State not entered'} longevity framing`;
  document.getElementById('metaDate').textContent = `Generated ${new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;

  document.getElementById('summaryCopy').textContent = payload.budgetNotes || payload.narrative;
  document.getElementById('benchmarkHeadline').textContent = `${formatMoney(payload.monthlyBudget)} today becomes about ${formatMoney(payload.targetBudget)} by age ${payload.targetAge}`;
  document.getElementById('benchmarkCopy').textContent = `Using a baseline inflation assumption of ${payload.inflationRate.toFixed(1)}%, this budget could rise to about ${formatMoney(payload.targetBudget)} by age ${payload.targetAge} and roughly ${formatMoney(payload.longevityBudget)} by age ${payload.longevityAge.toFixed(1)}.`;
  document.getElementById('currentBudgetValue').textContent = formatMoney(payload.monthlyBudget);
  document.getElementById('targetBudgetValue').textContent = formatMoney(payload.targetBudget);
  document.getElementById('longevityBudgetValue').textContent = formatMoney(payload.longevityBudget);
  document.getElementById('targetBudgetSub').textContent = `Projected monthly need at age ${payload.targetAge}`;
  document.getElementById('longevityBudgetSub').textContent = `Projected monthly need near age ${payload.longevityAge.toFixed(1)}`;
  document.getElementById('chartPill').textContent = `${payload.inflationRate.toFixed(1)}% baseline · ${payload.stressInflationRate.toFixed(1)}% stress`;

  drawChart(payload);

  document.getElementById('compareGrid').innerHTML = [
    {
      label: 'Now',
      value: formatMoney(payload.monthlyBudget),
      sub: 'Current monthly budget entered into the report'
    },
    {
      label: `Age ${payload.targetAge}`,
      value: formatMoney(payload.targetBudget),
      sub: 'Projected monthly budget at the headline target age'
    },
    {
      label: `Age ${payload.longevityAge.toFixed(1)}`,
      value: formatMoney(payload.longevityBudget),
      sub: 'Projected monthly budget at the local planning horizon'
    }
  ].map((item) => `
    <div class="compare-card">
      <div class="label">${item.label}</div>
      <div class="value">${item.value}</div>
      <div class="sub">${item.sub}</div>
    </div>
  `).join('');

  document.getElementById('erosionCallout').textContent = payload.narrative;
}

function runAnalysisAnimation(payload) {
  document.getElementById('analysisSub').textContent = `Projecting inflation erosion for ${payload.fullName || 'your budget'} in ${payload.stateName || 'your state'}.`;
  ['analysisStep1','analysisStep2','analysisStep3','analysisStep4'].forEach((id, index) => {
    const el = document.getElementById(id);
    el.classList.remove('done');
    setTimeout(() => el.classList.add('done'), (index + 1) * 360);
  });
}

async function saveInflationReport(payload) {
  const supabase = window.inflationVisualizerSupabase;
  if (!supabase) return null;
  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const insertPayload = {
    user_id: userId,
    full_name: payload.fullName || null,
    state_code: payload.stateCode || null,
    state_name: payload.stateName || null,
    county_name: payload.countyName || null,
    current_age: payload.currentAge || null,
    monthly_budget: payload.monthlyBudget,
    target_age: payload.targetAge,
    baseline_inflation_rate_pct: payload.inflationRate,
    stress_inflation_rate_pct: payload.stressInflationRate,
    longevity_age: payload.longevityAge,
    target_budget_value: payload.targetBudget,
    longevity_budget_value: payload.longevityBudget,
    report_title: `The Inflation Erosion Visualizer for ${payload.fullName || 'Your Budget'}`,
    report_payload: payload
  };

  const { error } = await supabase
    .from('inflation_erosion_reports')
    .insert(insertPayload);

  if (error) {
    console.error('Failed to save Inflation Erosion report:', error);
  }
}

function showGeneratedInflationReport(payload) {
  renderInflationReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  runAnalysisAnimation(payload);

  setTimeout(() => {
    document.getElementById('analysisSection').classList.remove('active');
    document.getElementById('reportSection').classList.add('active');
    document.getElementById('reportShell').classList.add('visible');
    document.getElementById('reportShell').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 1800);
}

function showHydratedInflationReport(payload) {
  renderInflationReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('reportSection').classList.add('active');
  document.getElementById('reportShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedInflationReport(report) {
  const payload = report?.report_payload;
  if (!payload) return false;

  const fields = {
    fullName: payload.fullName,
    countyName: payload.countyName,
    currentAge: payload.currentAge,
    monthlyBudget: payload.monthlyBudget,
    budgetPriority: payload.budgetPriority,
    budgetNotes: payload.budgetNotes,
    targetAge: payload.targetAge,
    inflationRate: payload.inflationRate,
    stressInflationRate: payload.stressInflationRate
  };

  Object.entries(fields).forEach(([id, value]) => {
    const input = document.getElementById(id);
    if (input && value !== undefined && value !== null) input.value = String(value);
  });

  if (payload.stateCode) document.getElementById('stateSelect').value = payload.stateCode;
  if (payload.planningGoal) document.getElementById('planningGoal').value = payload.planningGoal;

  showHydratedInflationReport(payload);
  return true;
}

async function generateInflationReport() {
  const payload = buildInflationPayload();
  await saveInflationReport(payload);
  showGeneratedInflationReport(payload);
}

function editInflationReport() {
  document.getElementById('reportSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(3);
}

window.nextStep = nextStep;
window.generateInflationReport = generateInflationReport;
window.editInflationReport = editInflationReport;
window.hydrateInflationReport = hydrateSavedInflationReport;
</script>
