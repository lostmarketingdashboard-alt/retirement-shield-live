---
import { supabase } from '../../lib/supabase'

export const prerender = false

export async function getStaticPaths() {
  const { data } = await supabase
    .from('articles')
    .select('slug')

  if (!data) return []

  return data.map(row => ({
    params: { slug: row.slug }
  }))
}

const { slug } = Astro.params

const { data: article } = await supabase
  .from('articles')
  .select('*')
  .eq('slug', slug)
  .single()

if (!article) {
  throw new Error(`Article not found: ${slug}`)
}

const formatDate = (dateStr) => {
  if (!dateStr) return null
  const d = new Date(dateStr)
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  })
}

const tags = article.tags ? article.tags.split(',').map(t => t.trim()) : []
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{article.meta_title || article.headline}</title>
  <meta name="description" content={article.meta_description || ''} />

  {article.og_image_url && (
    <meta property="og:image" content={article.og_image_url} />
  )}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<style>


  :root {
   
    --gold:#c9973a;
    --slate:#4a5568;
    --light-bg:#f7f8fc;
    --white:#ffffff;
    --border:#e2e8f0;
    --text:#1a202c;
    --text-muted:#718096;
  --navy: #0d1b2a;
  --navy-mid: #1a2e45;
  --navy-light: #243b55;
  --cream: #f5f0e8;
  --cream-dark: #ede6d6;
  --amber: #c8821a;
  --amber-light: #e8a840;
  --text-primary: #1a1208;
  --text-secondary: #4a3f32;
  --text-muted: #7a6e62;
  --white: #ffffff;
  --rule: #c8b89a;
  --rule-light: rgba(200,184,154,0.35);
  --tap-min: 48px; /* WCAG minimum tap target */
}

  html,body{margin:0;padding:0;background:var(--light-bg);font-family:'DM Sans',sans-serif;color:var(--text)}

  header{
    background:var(--navy);
    padding:18px 32px;
    display:flex;
    justify-content:space-between;
    align-items:center;
  }

  .logo{
    font-family:'Playfair Display',serif;
    color:white;
    font-size:20px;
    font-weight:600;
    text-decoration:none;
  }

  .logo span{color:var(--gold)}

  .container{
    max-width:880px;
    margin:0 auto;
    padding:60px 24px 100px;
  }

  .eyebrow{
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:1.5px;
    color:var(--gold);
    margin-bottom:12px;
  }

  h1{
    font-family:'Playfair Display',serif;
    font-size:42px;
    line-height:1.2;
    margin-bottom:18px;
  }

  .subheadline{
    font-size:18px;
    color:var(--slate);
    margin-bottom:28px;
  }

  .meta{
    font-size:13px;
    color:var(--text-muted);
    margin-bottom:40px;
  }

  .meta span{margin-right:16px}

  .section{
    background:white;
    padding:32px;
    border-radius:16px;
    border:1px solid var(--border);
    margin-bottom:24px;
  }

  .section h2{
    font-family:'Playfair Display',serif;
    font-size:26px;
    margin-bottom:14px;
  }

  .section p{
    line-height:1.75;
    font-size:16px;
    margin-bottom:14px;
    color:var(--slate);
  }

  .key-takeaways{
    background:#f0f4fb;
    border-left:4px solid var(--navy);
    padding:20px;
    border-radius:10px;
  }

  .tags{
    margin-top:30px;
    display:flex;
    flex-wrap:wrap;
    gap:8px;
  }

  .tag{
    background:#eef2fa;
    padding:6px 12px;
    border-radius:20px;
    font-size:12px;
    color:var(--navy);
    font-weight:600;
  }

  footer{
    background:var(--navy);
    color:rgba(255,255,255,0.6);
    text-align:center;
    padding:24px;
    font-size:12px;
  }

  /* ══════════════════════════════════════════════════
   MASTHEAD — DESKTOP
══════════════════════════════════════════════════ */
.masthead {
  background: var(--navy);
  padding: 0 48px;
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  border-bottom: 3px solid var(--amber);
  position: sticky;
  top: 0;
  z-index: 200;
}
.masthead-brand {
  display: flex; align-items: center; gap: 14px; padding: 16px 0; text-decoration: none;
}
.shield-mark { width: 34px; height: 40px; flex-shrink: 0; }
.brand-name {
  font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1.28rem;
  color: var(--cream); letter-spacing: 0.02em; line-height: 1.1;
}
.brand-tagline {
  font-family: 'DM Mono', monospace; font-size: 0.55rem; color: var(--amber-light);
  text-transform: uppercase; letter-spacing: 0.14em; margin-top: 2px; display: block; opacity: 0.85;
}
nav.desktop-nav { display: flex; align-items: center; gap: 28px; }
nav.desktop-nav a {
  font-family: 'DM Mono', monospace; font-size: 0.68rem; text-transform: uppercase;
  letter-spacing: 0.11em; color: var(--cream-dark); text-decoration: none;
  opacity: 0.75; transition: opacity 0.2s, color 0.2s; border-bottom: 1px solid transparent;
  padding: 4px 0;
}
nav.desktop-nav a:hover { opacity: 1; color: var(--amber-light); border-bottom-color: var(--amber-light); }
.nav-cta {
  background: var(--amber); color: var(--navy) !important; opacity: 1 !important;
  padding: 10px 20px !important; border-bottom: none !important; transition: background 0.2s !important;
}
.nav-cta:hover { background: var(--amber-light) !important; }

/* Hamburger — hidden on desktop */
.hamburger {
  display: none; background: none; border: none; cursor: pointer;
  padding: 16px 0; flex-direction: column; gap: 5px; align-items: center; justify-content: center;
}
.hamburger span {
  display: block; width: 22px; height: 2px; background: var(--cream);
  transition: transform 0.25s, opacity 0.25s;
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile nav drawer */
.mobile-nav {
  display: none;
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: var(--navy); z-index: 199;
  flex-direction: column; align-items: flex-start;
  padding: 90px 32px 40px;
  gap: 0;
  overflow-y: auto;
}
.mobile-nav.open { display: flex; }
.mobile-nav a {
  font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700;
  color: var(--cream); text-decoration: none; opacity: 0.8;
  padding: 16px 0; border-bottom: 1px solid rgba(200,184,154,0.12);
  width: 100%; transition: opacity 0.2s, color 0.2s;
  min-height: var(--tap-min); display: flex; align-items: center;
}
.mobile-nav a:hover, .mobile-nav a:active { opacity: 1; color: var(--amber-light); }
.mobile-nav .mobile-nav-cta {
  background: var(--amber); color: var(--navy) !important; opacity: 1 !important;
  padding: 18px 28px; margin-top: 24px; border-bottom: none;
  font-size: 0.8rem; font-family: 'DM Mono', monospace; font-weight: 400;
  text-transform: uppercase; letter-spacing: 0.12em; width: 100%; justify-content: center;
}

</style>

<!-- ══ MASTHEAD ══════════════════════════════════════ -->
<header class="masthead">
  <a href="/" class="masthead-brand">
    <svg class="shield-mark" viewBox="0 0 38 44" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M19 2L3 8.5V22c0 9.3 6.8 18 16 20.5C28.2 40 35 31.3 35 22V8.5L19 2z" fill="none" stroke="#c8821a" stroke-width="1.5"/>
      <path d="M19 7L7 12.5V22c0 7 5.1 13.5 12 15.5C25.9 35.5 31 29 31 22V12.5L19 7z" fill="rgba(200,130,26,0.1)"/>
      <path d="M12 22l5 5 9-10" stroke="#c8821a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <div>
      <div class="brand-name">Retirement Shield</div>
      <span class="brand-tagline">Retirement education for Americans 55–75</span>
    </div>
  </a>
  <nav class="desktop-nav">
    <a href="/list">Check Your County’s Life Expectancy</a>
    <a href="/lifeexpectancycalculator">Life Expectancy</a>
    <a href="/guidelist">Estate</a>
    <a href="/quiz" class="nav-cta">Estate Planning Quiz</a>
  </nav>
  <button class="hamburger" id="hamburgerBtn" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</header>

<div class="container">

  <div class="eyebrow">{article.category} · {article.pillar}</div>

  <h1>{article.headline}</h1>

  {article.subheadline && (
    <div class="subheadline">{article.subheadline}</div>
  )}

  <div class="meta">
    {formatDate(article.published_at) && (
      <span>Published {formatDate(article.published_at)}</span>
    )}
    {article.author_name && (
      <span>By {article.author_name}</span>
    )}
    {article.reviewer_name && (
      <span>Reviewed by {article.reviewer_name}</span>
    )}
    {article.word_count && (
      <span>{article.word_count} words</span>
    )}
  </div>

  <div class="section">
    {article.lede && <p><strong>{article.lede}</strong></p>}

    {article.section_1_heading && <h2>{article.section_1_heading}</h2>}
    {article.section_1_body && <p>{article.section_1_body}</p>}

    {article.section_2_heading && <h2>{article.section_2_heading}</h2>}
    {article.section_2_body && <p>{article.section_2_body}</p>}

    {article.section_3_heading && <h2>{article.section_3_heading}</h2>}
    {article.section_3_body && <p>{article.section_3_body}</p>}

    {article.section_4_heading && <h2>{article.section_4_heading}</h2>}
    {article.section_4_body && <p>{article.section_4_body}</p>}
  </div>

  {article.key_takeaways && (
    <div class="section key-takeaways">
      <h2>Key Takeaways</h2>
      <p>{article.key_takeaways}</p>
    </div>
  )}

  {article.sources && (
    <div class="section">
      <h2>Sources</h2>
      <p>{article.sources}</p>
    </div>
  )}

  {tags.length > 0 && (
    <div class="tags">
      {tags.map(tag => (
        <div class="tag">{tag}</div>
      ))}
    </div>
  )}

</div>

<footer>
  © {new Date().getFullYear()} Retirement Shield · Educational content only · Not legal or financial advice
</footer>