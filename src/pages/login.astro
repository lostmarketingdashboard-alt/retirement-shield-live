---
export const prerender = false;
export const ssr = false;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | Retirement Shield</title>

    <style is:global>
      :root {
        --navy: #0d1b2a;
        --navy-mid: #162032;
        --navy-light: #1e2f45;
        --gold: #c9a84c;
        --gold-light: #e8c96a;
        --gold-pale: #f5e8c0;
        --cream: #faf7f0;
        --cream-dark: #f0ead8;
        --red: #b84040;
        --red-light: #d94f4f;
        --green: #2d6a4f;
        --green-light: #52b788;
        --text-dark: #1a1a1a;
        --text-mid: #3d3d3d;
        --text-light: #6b6b6b;
        --border: #d4c9a8;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: var(--navy);
        color: var(--cream);
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100vh;
      }

      .logo {
        position: absolute;
        top: 28px;
        left: 40px;
        font-size: 20px;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-decoration: none;
        color: var(--cream);
      }

      .logo span {
        color: var(--gold);
      }

      .login-card {
        background: var(--cream);
        color: var(--text-dark);
        width: 100%;
        max-width: 420px;
        padding: 48px 42px;
        border-top: 4px solid var(--gold);
        box-shadow: 0 25px 70px rgba(0,0,0,0.4);
      }

      .login-card h1 {
        margin: 0 0 12px 0;
        font-size: 26px;
      }

      .login-sub {
        margin-bottom: 32px;
        font-size: 14px;
        color: var(--text-light);
      }

      .input-group {
        margin-bottom: 18px;
      }

      .input-group label {
        font-size: 12px;
        color: var(--text-light);
        display: block;
        margin-bottom: 6px;
      }

      .input-group input {
        width: 100%;
        padding: 14px;
        border: 1.5px solid var(--border);
        font-size: 14px;
        outline: none;
        transition: border 0.2s ease;
      }

      .input-group input:focus {
        border-color: var(--gold);
      }

      .login-btn {
        width: 100%;
        margin-top: 10px;
        padding: 16px;
        border: none;
        background: var(--navy);
        color: var(--cream);
        font-size: 14px;
        cursor: pointer;
        transition: background 0.2s ease;
      }

      .register-btn {
        display: block;
        width: 100%;
        margin-top: 14px;
        padding: 14px 16px;
        border: 1.5px solid var(--navy);
        background: var(--cream);
        color: var(--navy);
        font-size: 13px;
        font-weight: 500;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s ease;
        appearance: none;
        -webkit-appearance: none;
        border-radius: 0;
        font-family: inherit;
      }

      .register-btn:hover {
        background: var(--navy);
        color: var(--cream);
      }

      .login-btn:hover {
        background: var(--navy-light);
      }

      .error-msg {
        margin-top: 14px;
        font-size: 13px;
        color: var(--red);
      }

      .forgot-link {
        display: block;
        margin-top: 10px;
        font-size: 12px;
        color: var(--navy);
        text-align: right;
        cursor: pointer;
        text-decoration: underline;
      }

      .forgot-link:hover {
        color: var(--gold);
      }

      .success-msg {
        margin-top: 10px;
        font-size: 12px;
        color: var(--green);
      }

      .footer-note {
        margin-top: 24px;
        font-size: 12px;
        color: var(--text-light);
        text-align: center;
      }

      .payment-modal {
        position: fixed;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: rgba(13, 27, 42, 0.72);
        z-index: 1000;
      }

      .payment-modal.open {
        display: flex;
      }

      .payment-modal-card {
        width: 100%;
        max-width: 440px;
        background: var(--cream);
        color: var(--text-dark);
        border-top: 4px solid var(--gold);
        box-shadow: 0 25px 70px rgba(0,0,0,0.4);
        padding: 32px 28px;
      }

      .payment-modal-card h2 {
        margin: 0 0 12px;
        font-size: 24px;
      }

      .payment-modal-card p {
        margin: 0;
        font-size: 14px;
        line-height: 1.6;
        color: var(--text-mid);
      }

      .payment-modal-actions {
        margin-top: 22px;
        display: flex;
        justify-content: flex-end;
      }

      .payment-modal-btn {
        border: none;
        background: var(--navy);
        color: var(--cream);
        padding: 12px 18px;
        font-size: 14px;
        cursor: pointer;
      }

    </style>
  </head>

  <body>

    <a href="/" class="logo">Retirement<span>Shield</span></a>

    <div class="login-card">
      <h1>Secure Portal Login</h1>
      <div class="login-sub">
        Access your personalized estate planning report and protection dashboard.
      </div>

      <form id="loginForm">
        <div class="input-group">
          <label>Email Address</label>
          <input type="email" id="email" required />
        </div>

        <div class="input-group">
          <label>Password</label>
          <input type="password" id="password" required />
        </div>
        <div class="forgot-link" id="forgotPassword">Forgot password?</div>

        <button type="submit" class="login-btn">Login to Portal →</button>
        <button type="button" class="register-btn" onclick="window.location.href='/quiz'">
          New here? Start Free Assessment →
        </button>
      </form>

      <div id="error" class="error-msg"></div>
      <div id="success" class="success-msg"></div>

      <div class="footer-note">
        Protected access. Encrypted authentication via Supabase.
      </div>
    </div>

    <div id="paymentModal" class="payment-modal" aria-hidden="true">
      <div class="payment-modal-card" role="dialog" aria-modal="true" aria-labelledby="paymentModalTitle">
        <h2 id="paymentModalTitle">Payment Required</h2>
        <p id="paymentModalMessage">
          Your account is not marked as paid yet. Please complete payment before accessing the portal.
        </p>
        <div class="payment-modal-actions">
          <button type="button" id="closePaymentModal" class="payment-modal-btn">Close</button>
        </div>
      </div>
    </div>

  <script type="module">
  import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'

  const supabase = createClient(
    "https://nyiturqeotdxucfdurzu.supabase.co",  
    "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im55aXR1cnFlb3RkeHVjZmR1cnp1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIxMzI0ODgsImV4cCI6MjA4NzcwODQ4OH0.CvYju6UTaCGD_Zd-8FVTcB-yW9YVG_jQtwkd0l7mIV0",              
    {
      auth: {
        persistSession: true,
        autoRefreshToken: true,
        detectSessionInUrl: true,
        flowType: 'pkce'
      }
    }
  )

      const form = document.getElementById('loginForm')
      const errorEl = document.getElementById('error')
      const successEl = document.getElementById('success')
      const forgotLink = document.getElementById('forgotPassword')
      const paymentModal = document.getElementById('paymentModal')
      const paymentModalMessage = document.getElementById('paymentModalMessage')
      const closePaymentModal = document.getElementById('closePaymentModal')

      function showPaymentModal(message) {
        paymentModalMessage.textContent = message
        paymentModal.classList.add('open')
        paymentModal.setAttribute('aria-hidden', 'false')
      }

      function hidePaymentModal() {
        paymentModal.classList.remove('open')
        paymentModal.setAttribute('aria-hidden', 'true')
      }

      closePaymentModal.addEventListener('click', hidePaymentModal)
      paymentModal.addEventListener('click', (e) => {
        if (e.target === paymentModal) hidePaymentModal()
      })

      const paymentRequired = new URLSearchParams(window.location.search).get('payment')
      if (paymentRequired === 'required') {
        showPaymentModal('Your account has not been marked as paid yet. Please complete payment before accessing the portal.')
      }

      forgotLink.addEventListener('click', async () => {
        const email = document.getElementById('email').value

        if (!email) {
          errorEl.textContent = 'Please enter your email above first.'
          return
        }

        errorEl.textContent = ''
        successEl.textContent = ''

        const { error } = await supabase.auth.resetPasswordForEmail(email, {
          redirectTo: window.location.origin + '/reset-password'
        })

        if (error) {
          errorEl.textContent = error.message
        } else {
          successEl.textContent = 'Password reset link sent. Check your email.'
        }
      })

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        errorEl.textContent = ''
        successEl.textContent = ''

        const email = document.getElementById('email').value
        const password = document.getElementById('password').value

        const { data, error } = await supabase.auth.signInWithPassword({
          email,
          password,
        })

        if (error) {
          errorEl.textContent = error.message
          return
        }

        const userId = data.user?.id

        if (!userId) {
          errorEl.textContent = 'Unable to verify your account.'
          await supabase.auth.signOut()
          return
        }

        const { data: profile, error: profileError } = await supabase
          .from('profiles')
          .select('role, paid')
          .eq('id', userId)
          .single()

        if (profileError || !profile) {
          errorEl.textContent = 'Unable to load your profile.'
          await supabase.auth.signOut()
          return
        }

        if (profile.role === 'user' && !profile.paid) {
          await supabase.auth.signOut()
          showPaymentModal('Your account has not been marked as paid yet. Please complete payment before accessing the portal.')
          return
        }

        window.location.href = '/portal'
      })
    </script>

  </body>
</html>
