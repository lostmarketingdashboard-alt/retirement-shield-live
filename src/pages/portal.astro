      color: var(--white);
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) 300px;
      gap: 24px;
      align-items: stretch;
      box-shadow: 0 24px 60px rgba(13,27,42,.18);
      width: 100%;
      min-width: 0;
      box-sizing: border-box;
    }

    .profile-kicker {
      font-size: 12px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--amber-light);
      margin-bottom: 12px;
