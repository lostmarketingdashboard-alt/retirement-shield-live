    .from('profiles')
    .select('full_name')
    .eq('id', utm)
    .maybeSingle();

  if (profile?.full_name) {
    const input = document.getElementById('fullName');
    if (input && !input.value) input.value = profile.full_name;
  }
}
</script>
</body>
</html>
