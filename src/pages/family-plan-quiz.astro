let currentQ = 0;
let answers = [];

function getQuizSummary() {
  let total = 0;

  const results = questions.map((q, idx) => {
    const chosen = answers[idx] !== undefined ? answers[idx] : null;
    const opt = chosen !== null ? q.options[chosen] : null;
    if (opt) total += opt.score;

    return {
      context: q.context,
      question: q.question,
      selected_index: chosen,
      selected_text: opt?.text ?? null,
      status: opt?.status ?? 'unknown',
      score: opt?.score ?? 0,
      explanation: opt?.explain ?? null
    };
  });

  const pct = total / questions.length;
  let grade;
  let line;

  if (pct >= 0.85) {
    grade = "Well Prepared";
    line = "Your family appears to have the key foundations in place. Review the items flagged below to close any remaining gaps.";
  } else if (pct >= 0.5) {
    grade = "Partially Protected";
    line = "Some pieces are in place, but there are meaningful gaps that could cost your family time, money, or conflict. The checklist below shows exactly where.";
  } else {
    grade = "Significant Gaps";
    line = "Your family has several critical planning gaps. The good news: most of these can be addressed in a single afternoon with the right information.";
  }

  return { total, pct, grade, line, results };
}

async function saveFamilyPlanSubmission(summary) {
  const supabase = window.familyPlanQuizSupabase;
  if (!supabase) return;

  const payload = {
    user_id: new URLSearchParams(window.location.search).get('utm') || null,
    score: summary.total,
    max_score: questions.length,
    completion_percent: summary.pct,
    grade: summary.grade,
    summary_line: summary.line,
    answers: summary.results
  };

  const { error } = await supabase
    .from('family-plan-quiz-data')
    .insert(payload);

  if (error) {
    console.error('Failed to save Family Plan Quiz submission:', error);
  }
}

function startQuiz() {
  document.getElementById('introSection').style.display = 'none';
  document.getElementById('quizSection').style.display = 'block';
  window.scrollTo({top:0,behavior:'instant'});
  renderQuestion(0);
}

function renderQuestion(idx) {
  currentQ = idx;
  const q = questions[idx];
  const isFirst = idx === 0;
  const isLast = idx === questions.length - 1;
  const selected = answers[idx] !== undefined ? answers[idx] : -1;

  document.getElementById('qpFill').style.width = ((idx+1)/questions.length*100)+'%';
  document.getElementById('qpText').textContent = `Question ${idx+1} of ${questions.length}`;

  let html = `<div class="q-card">
    <div class="q-context">${q.context}</div>
    <div class="q-text">${q.question}</div>
    <div class="q-why">${q.why}</div>
    <div class="answer-grid">`;

  q.options.forEach((opt, i) => {
    html += `<label class="answer-opt ${selected===i?'selected':''}" onclick="selectAnswer(${i})">
      <input type="radio" name="q${idx}" value="${i}" ${selected===i?'checked':''} />
      <div class="answer-dot"></div>
      <div class="answer-label">${opt.text}</div>
    </label>`;
  });

  html += `</div><div class="q-nav">`;
  if (!isFirst) html += `<button class="q-back" onclick="renderQuestion(${idx-1})">← Back</button>`;
  if (isLast) {
    html += `<button class="q-next ${selected>=0?'enabled':''}" id="nextBtn" onclick="showResults()">See My Results →</button>`;
  } else {
    html += `<button class="q-next ${selected>=0?'enabled':''}" id="nextBtn" onclick="renderQuestion(${idx+1})">Continue →</button>`;
  }
  html += `</div></div>`;

  document.getElementById('questionContainer').innerHTML = html;
  window.scrollTo({top:0,behavior:'smooth'});
}

function selectAnswer(i) {
  answers[currentQ] = i;
  document.querySelectorAll('.answer-opt').forEach((el,idx) => {
    el.classList.toggle('selected', idx === i);
  });
  const btn = document.getElementById('nextBtn');
  if (btn) { btn.classList.add('enabled'); }
}

function showResults() {
  if (answers[currentQ] === undefined) return;

  const summary = getQuizSummary();
  let total = summary.total;
  let cardsHtml = '';

  questions.forEach((q, idx) => {
    const chosen = answers[idx] !== undefined ? answers[idx] : 2;
    const opt = q.options[chosen];

    const statusIcon = opt.status === 'pass' ? '✓' : opt.status === 'fail' ? '✗' : opt.status === 'warn' ? '–' : '?';
    const answerClass = opt.status === 'pass' ? 'pass-text' : opt.status === 'fail' ? 'fail-text' : opt.status === 'warn' ? 'warn-text' : 'unknown-text';
    const answerLabel = opt.status === 'pass' ? 'Protected' : opt.status === 'fail' ? 'Gap Identified' : opt.status === 'warn' ? 'Needs Review' : 'Unknown — Needs Investigation';

    cardsHtml += `<div class="result-card fade-up">
      <div class="result-status ${opt.status}">${statusIcon}</div>
      <div class="result-content">
        <div class="result-title">${q.question}</div>
        <div class="result-answer ${answerClass}">${answerLabel}</div>
        <div class="result-explain">${opt.explain}</div>
        ${opt.status !== 'pass' ? `<a href="#" class="result-link">Learn more in their State Guide <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>` : ''}
      </div>
    </div>`;
  });

  const pct = summary.pct;
  const circumference = 2 * Math.PI * 65;
  const dashLen = pct * circumference;

  let scoreColor;
  if (pct >= 0.85) {
    scoreColor = 'var(--green)';
  } else if (pct >= 0.5) {
    scoreColor = 'var(--amber)';
  } else {
    scoreColor = 'var(--red)';
  }

  document.getElementById('quizSection').style.display = 'none';
  document.getElementById('resultsSection').style.display = 'block';
  window.scrollTo({top:0,behavior:'instant'});

  document.getElementById('scoreGrade').textContent = summary.grade;
  document.getElementById('scoreLine').textContent = summary.line;
  document.getElementById('resultCards').innerHTML = cardsHtml;

  // Animate score
  setTimeout(() => {
    document.getElementById('scoreArc').style.strokeDasharray = `${dashLen} ${circumference}`;
    document.getElementById('scoreArc').style.stroke = scoreColor;
    document.getElementById('scoreNum').style.color = scoreColor;

    let counter = 0;
    const target = total;
    const step = target / 30;
    const interval = setInterval(() => {
      counter += step;
      if (counter >= target) { counter = target; clearInterval(interval); }
      document.getElementById('scoreNum').textContent = counter % 1 === 0 ? counter : counter.toFixed(1);
    }, 30);
  }, 200);

  // Fade in cards
  setTimeout(() => {
    const fadeEls = document.querySelectorAll('.fade-up');
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          setTimeout(() => e.target.classList.add('visible'), i * 60);
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.05 });
    fadeEls.forEach(el => obs.observe(el));
  }, 400);

  saveFamilyPlanSubmission(summary);
}

function copyLink() {
  // Dummy — would copy a shareable URL in production
  const btn = event.target.closest('.share-btn');
  const original = btn.innerHTML;
  btn.innerHTML = '<svg viewBox="0 0 24 24" fill="var(--navy)" width="16" height="16"><path d="M20 6L9 17l-5-5"/></svg> Link Copied!';
  setTimeout(() => { btn.innerHTML = original; }, 2000);
}

window.startQuiz = startQuiz;
window.renderQuestion = renderQuestion;
window.selectAnswer = selectAnswer;
window.showResults = showResults;
window.copyLink = copyLink;
</script>

