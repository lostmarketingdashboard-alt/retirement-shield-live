    try {
      value = JSON.parse(value);
    } catch {
      value = [{ note: value }];
    }
  }

  newArticle[key] = value;
});

                const { error } = await supabase
                  .from('articles')
                  .insert(newArticle);

                if (error) {
                  alert("Error creating article.");
                  console.error(error);
                  return;
                }

                modal.remove();
                renderArticles();
              };

            });
          }
        }

        // Tab click handler (SAFE RESET)
        const tabs = document.querySelectorAll('.tab')

        // Default load
        if (profile.role === 'admin') {
          renderUsers()
        } else if (profile.role === 'referral') {
          renderAssignedMembers()
        }

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('active'))
            tab.classList.add('active')

            const type = tab.dataset.tab

            if (type === 'users') renderUsers()
            if (type === 'tasks') renderActionTasks()
            if (type === 'add-users') renderAddUsers()
            if (type === 'assign-referrals') renderAssignReferrals()
            if (type === 'assigned-members') renderAssignedMembers()
            if (type === 'team-members') renderTeamMembers()
            if (type === 'articles') renderArticles()
          })
        })
