        input.value = numeric ? String(Math.round(numeric)) : '';
      });
      input.addEventListener('input', () => {
        input.value = input.value.replace(/[^\d.]/g, '');
      });
    });
    return;
  }

  const messages = {
    pension: 'We will estimate survivor income using a conservative pension-survivor assumption until you add actual pension option details.',
    investments: 'We will estimate post-death spendable income conservatively unless you later add actual account balances and yield data.',
    employment: 'We will estimate how much cash flow disappears after one paycheck ends unless you later add employer survivor benefits or insurance.'
  };

  wrap.innerHTML = `<div class="field-help">${messages[source] || ''}</div>`;
}

function getIncomeModel(formData, federalRules) {
  const { monthlyIncome, primaryEarner, source, yourSSBenefit, spouseSSBenefit } = formData;
  const primaryShare = primaryEarner === 'me' ? 0.62 : 0.38;
  const yourCurrent = monthlyIncome * primaryShare;
  const spouseCurrent = monthlyIncome - yourCurrent;

  let visibleYourCurrent = yourCurrent;
  let visibleSpouseCurrent = spouseCurrent;
  let survivingIncome = Math.max(yourCurrent, spouseCurrent);
  let survivorText = 'the higher monthly benefit';
  let narrative = 'Social Security survivor rules usually preserve the higher check and eliminate the lower one.';
  let analysisTitle = 'Primary Income Survivor Analysis';
  let isEstimated = true;

  if (source === 'ss') {
    const fallbackYour = primaryEarner === 'me' ? monthlyIncome * 0.62 : monthlyIncome * 0.38;
    const fallbackSpouse = monthlyIncome - fallbackYour;
    const actualYour = yourSSBenefit > 0 ? yourSSBenefit : fallbackYour;
    const actualSpouse = spouseSSBenefit > 0 ? spouseSSBenefit : fallbackSpouse;
    const continuingOtherIncome = Math.max(monthlyIncome - (actualYour + actualSpouse), 0);
    const survivorBase = Math.max(actualYour, actualSpouse);

    visibleYourCurrent = actualYour;
    visibleSpouseCurrent = actualSpouse;
    survivingIncome = survivorBase + continuingOtherIncome;
    survivorText = `one Social Security check plus any continuing non-SSA income`;
    narrative = 'SSA survivor rules generally mean the surviving spouse keeps the higher check, not both checks.';
    analysisTitle = 'Social Security Survivor Benefit Analysis';
    isEstimated = !(yourSSBenefit > 0 && spouseSSBenefit > 0);
  }

  if (source === 'pension') {
    const retainedSpouseShare = primaryEarner === 'spouse' ? 0.35 : 0.15;
    survivingIncome = yourCurrent + spouseCurrent * retainedSpouseShare;
    survivorText = 'your income plus a reduced survivor pension';
    narrative = 'Many pensions reduce or eliminate the deceased spouse’s payment unless a survivor option was elected.';
    analysisTitle = 'Pension Survivor Income Analysis';
  } else if (source === 'investments') {
    survivingIncome = monthlyIncome * 0.88;
    survivorText = 'most portfolio income, after likely account and tax friction';
    narrative = 'Investment income is often more portable, but taxes, required distributions, and account retitling can still reduce spendable cash flow.';
    analysisTitle = 'Investment Income Continuity Analysis';
  } else if (source === 'employment') {
    const retainedSpouseShare = primaryEarner === 'spouse' ? 0.15 : 0.05;
    survivingIncome = yourCurrent + spouseCurrent * retainedSpouseShare;
    survivorText = 'your own income plus only limited replacement from the deceased spouse’s earnings';
    narrative = 'Employment income usually stops quickly unless there is life insurance, survivor pay, or disability-style replacement built in.';
    analysisTitle = 'Employment Income Continuity Analysis';
  }

  survivingIncome = clamp(survivingIncome, monthlyIncome * 0.15, monthlyIncome);
  const monthlyDrop = Math.max(monthlyIncome - survivingIncome, 0);
  const annualDrop = monthlyDrop * 12;
  const dropPct = monthlyIncome > 0 ? Math.round((monthlyDrop / monthlyIncome) * 100) : 0;

  return {
    yourCurrent: visibleYourCurrent,
    spouseCurrent: visibleSpouseCurrent,
    survivingIncome,
    monthlyDrop,
    annualDrop,
    dropPct,
    survivorText,
    narrative,
    analysisTitle,
    isEstimated,
    lumpSumDeathBenefit: federalRules?.social_security?.lump_sum_death_benefit ?? 255
  };
}

