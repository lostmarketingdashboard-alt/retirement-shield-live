@media (max-width: 640px) {
  .binder-body { padding: 18px; }
  .section-card,
  .cover-card,
  .inventory-card,
  .map-card,
  .contact-card,
  .doc-status-card {
    padding: 16px;
  }

  .section-head {
    gap: 10px;
  }

  .inventory-table thead,
  .contact-table thead {
    display: none;
  }

  .inventory-table,
  .contact-table,
  .inventory-table tbody,
  .contact-table tbody,
