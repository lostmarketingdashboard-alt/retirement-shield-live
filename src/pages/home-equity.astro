<script is:inline>
const steps = ['astep1', 'astep2', 'astep3', 'astep4', 'astep5'];

function resetStepClasses() {
  steps.forEach((id) => {
    const el = document.getElementById(id);
    el.classList.remove('active', 'done', 'error');
  });
}

function setActiveStep(index) {
  steps.forEach((id, i) => {
    const el = document.getElementById(id);
    el.classList.remove('active', 'done', 'error');
    if (i < index) el.classList.add('done');
    if (i === index) el.classList.add('active');
  });
}

function failStep(index) {
  steps.forEach((id, i) => {
    const el = document.getElementById(id);
    el.classList.remove('active');
    if (i < index) el.classList.add('done');
    if (i === index) el.classList.add('error');
  });
}

function formatCurrency(value, compact = false) {
  if (value == null || Number.isNaN(Number(value))) return '--';
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 0,
    notation: compact ? 'compact' : 'standard'
  }).format(Number(value));
}

function formatNumber(value) {
  if (value == null || Number.isNaN(Number(value))) return '--';
  return new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(Number(value));
}

function formatPercent(value) {
  if (value == null || Number.isNaN(Number(value))) return '--';
  return `${Number(value).toFixed(1)}%`;
}

function formatDate(value) {
  if (!value) return '--';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return '--';
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}

function setText(id, value) {
  const el = document.getElementById(id);
  if (el) el.textContent = value;
}

function buildCompMarkup(items, emptyMessage) {
  if (!items || !items.length) {
    return `<div class="empty-state">${emptyMessage}</div>`;
  }

  return items.map((item) => `
    <div class="comp-item">
      <div class="comp-item-top">
        <div class="comp-price">${item.priceLabel || '--'}</div>
        <div class="comp-distance">${item.distanceLabel || 'Distance unavailable'}</div>
      </div>
      <div class="comp-address">${item.address || 'Comparable property'}</div>
      <div class="comp-meta">${item.meta || 'No additional details returned.'}</div>
    </div>
  `).join('');
}

function animateFadeIns() {
  const fadeEls = document.querySelectorAll('.fade-up');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, index) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), index * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  fadeEls.forEach((el) => observer.observe(el));
}

function revealReportSection() {
  document.getElementById('step1').style.display = 'none';
  document.getElementById('step2').style.display = 'none';
  document.getElementById('step3').style.display = 'block';
  window.scrollTo({ top: 0, behavior: 'auto' });
  animateFadeIns();
}

function updateEquityVisualization(valueEstimate, lowEstimate, highEstimate) {
  const circumference = 377;
  const marketValue = Number(valueEstimate) || 0;
  const low = Number(lowEstimate) || 0;
  const high = Number(highEstimate) || 0;
  const spreadPct = marketValue > 0 && high >= low ? ((high - low) / marketValue) * 100 : 0;
  const midpointPosition = marketValue > 0 ? ((marketValue - low) / Math.max(high - low, 1)) * 100 : 0;
  const primaryArc = Math.round((Math.min(Math.max(midpointPosition, 0), 100) / 100) * circumference);
  const secondaryArc = Math.max(circumference - primaryArc, 0);

  setText('equityMarketValue', formatCurrency(marketValue));
  setText('equityMortgage', formatCurrency(low));
  setText('equityValue', formatCurrency(high));
  setText('equityPercent', formatPercent(spreadPct));
  setText('equityPercentLabel', 'Value range spread');
  setText('equityHeadline', 'The point estimate sits inside the low-to-high range returned by RentCast.');
  setText('equityAlertTitle', 'AVM range reflects estimate uncertainty');
  setText('equityAlertText', `RentCast returned a value range from ${formatCurrency(low)} to ${formatCurrency(high)} around a point estimate of ${formatCurrency(marketValue)}.`);

  document.getElementById('equityDonutPrimary').setAttribute('stroke-dasharray', `${primaryArc} ${circumference}`);
  document.getElementById('equityDonutSecondary').setAttribute('stroke-dasharray', `${secondaryArc} ${circumference}`);
  document.getElementById('equityDonutSecondary').setAttribute('stroke-dashoffset', `-${primaryArc}`);
}

function applyReport(data) {
  setText('reportTitle', data.property.shortAddress || data.property.addressLine || data.requestedAddress);
  setText('reportAddress', data.property.fullAddress || data.requestedAddress);
  setText('generatedAt', data.generatedAtLabel);
  setText('dataSources', data.dataSourcesLabel);
  setText('reportId', data.reportId);

  setText('estimatedValue', formatCurrency(data.value.estimate));
  setText('estimatedValueSub', data.value.summary || 'Live value estimate from RentCast.');
  setText('estimatedRent', formatCurrency(data.rent.estimate));
  setText('estimatedRentSub', data.rent.summary || 'Long-term rent estimate from comparable rentals.');

  setText('propertyType', data.property.propertyType || '--');
  setText('bedsBaths', data.property.bedsBaths || '--');
  setText('squareFootage', data.property.squareFootageLabel || '--');
  setText('lotSize', data.property.lotSizeLabel || '--');
  setText('yearBuilt', data.property.yearBuiltLabel || '--');
  setText('countyAndApn', data.property.countyApnLabel || '--');

  setText('valueRange', data.value.rangeLabel || '--');
  setText('valueRangeNote', data.value.rangeNote || 'Range based on the AVM response.');
  setText('rentRange', data.rent.rangeLabel || '--');
  setText('rentRangeNote', data.rent.rangeNote || 'Range based on the rent AVM response.');
  setText('grossYield', data.derived.grossYieldLabel || '--');
  setText('pricePerFoot', data.derived.pricePerSquareFootLabel || '--');
  setText('lastSaleValue', data.property.lastSaleLabel || '--');
  setText('lastSaleNote', data.property.lastSaleNote || 'The most recent sale event returned on the property record.');
  setText('appreciationValue', data.derived.appreciationLabel || '--');
  setText('appreciationNote', data.derived.appreciationNote || 'Difference between the AVM and the last recorded sale price when available.');

  setText('salesCompHeading', `Comparable sales (${data.value.comparableCountLabel})`);
  setText('rentCompHeading', `Comparable rentals (${data.rent.comparableCountLabel})`);
  document.getElementById('salesCompsList').innerHTML = buildCompMarkup(
    data.value.comparables,
    'RentCast did not return sale comparables for this address.'
  );
  document.getElementById('rentCompsList').innerHTML = buildCompMarkup(
    data.rent.comparables,
    'RentCast did not return rental comparables for this address.'
  );

  setText('summaryHeadline', data.summary.headline);
  setText('summarySub', data.summary.subline);

  updateEquityVisualization(data.value.estimate, data.value.low, data.value.high);
}

async function saveHomeEquityReport(data) {
  const supabase = window.homeEquitySupabase;
  if (!supabase) return;

  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');

  if (!userId) return;

  const { error } = await supabase
    .from('home_equity_reports')
    .insert({
      user_id: userId,
      report_id: data.reportId,
      requested_address: data.requestedAddress,
      short_address: data.property.shortAddress || null,
      full_address: data.property.fullAddress || null,
      property_type: data.property.propertyType || null,
      estimated_value: data.value.estimate ?? null,
      estimated_rent: data.rent.estimate ?? null,
      report_payload: data
    });

  if (error) {
    console.error('Failed to save Home Equity report:', error);
  }
}

async function hydrateLatestSavedReport() {
  const supabase = window.homeEquitySupabase;
  if (!supabase) return false;

  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');

  if (!userId) return false;

  const { data: savedReport, error } = await supabase
    .from('home_equity_reports')
    .select('*')
    .eq('user_id', userId)
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();

  if (error || !savedReport?.report_payload) {
    return false;
  }

  const addressInput = document.getElementById('addressInput');
  if (addressInput && savedReport.requested_address) {
    addressInput.value = savedReport.requested_address;
  }

  applyReport(savedReport.report_payload);
  revealReportSection();
  return true;
}

async function startAnalysis() {
  const address = document.getElementById('addressInput').value.trim();
  const formError = document.getElementById('formError');
  const analyzeButton = document.getElementById('analyzeButton');

  formError.style.display = 'none';
  formError.textContent = '';

  if (!address) {
    formError.textContent = 'Enter a full U.S. property address before running the report.';
    formError.style.display = 'block';
    return;
  }

  analyzeButton.disabled = true;
  document.getElementById('analyzingAddress').textContent = address;
  document.getElementById('step1').style.display = 'none';
  document.getElementById('step3').style.display = 'none';
  document.getElementById('step2').style.display = 'block';
  resetStepClasses();
  setActiveStep(0);

  try {
    const progressTimers = [
      setTimeout(() => setActiveStep(1), 450),
      setTimeout(() => setActiveStep(2), 900),
      setTimeout(() => setActiveStep(3), 1350),
      setTimeout(() => setActiveStep(4), 1800)
    ];

    const response = await fetch('/api/rentcast/home-equity', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ address })
    });

    progressTimers.forEach((timer) => clearTimeout(timer));

    if (!response.ok) {
      const errorPayload = await response.json().catch(() => ({}));
      throw new Error(errorPayload.error || 'The RentCast request failed.');
    }

    const payload = await response.json();
    setActiveStep(5);
    applyReport(payload);
    await saveHomeEquityReport(payload);

    setTimeout(() => {
      steps.forEach((id) => document.getElementById(id).classList.remove('active'));
      steps.forEach((id) => document.getElementById(id).classList.add('done'));
      revealReportSection();
    }, 250);
  } catch (error) {
    failStep(0);
    document.getElementById('step2').style.display = 'none';
    document.getElementById('step1').style.display = 'block';
    formError.textContent = error.message || 'Unable to generate the report right now.';
    formError.style.display = 'block';
  } finally {
    analyzeButton.disabled = false;
  }
}

window.startAnalysis = startAnalysis;
window.hydrateLatestSavedHomeEquityReport = hydrateLatestSavedReport;
</script>
