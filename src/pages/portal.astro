      color: var(--navy);
    }

    .documents-search-meta {
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 14px;
    }

    .portal-search {
      width: 100%;
      border: 1px solid var(--rule-light);
      border-radius: 14px;
      background: rgba(250, 247, 240, 0.92);
      padding: 14px 16px;
      font-size: 14px;
      color: var(--text-primary);
