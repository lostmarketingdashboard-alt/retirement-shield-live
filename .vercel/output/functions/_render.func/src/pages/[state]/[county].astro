---
import { supabase } from '../../lib/supabase'
import CountyLayout from '../../layouts/CountyLayout.astro'

export async function getStaticPaths() {
  let allRows = []
  let from = 0
  const batchSize = 1000

  while (true) {
    const { data, error } = await supabase
      .from('counties')
      .select('State, County')
      .range(from, from + batchSize - 1)

    if (error) break
    if (!data?.length) break

    allRows = allRows.concat(data)
    from += batchSize
  }

  const unique = Array.from(
    new Map(
      allRows
        .filter(row => row?.State && row?.County)
        .map(row => [row.State + '-' + row.County, row])
    ).values()
  )

  return unique.map((row) => ({
    params: {
      state: row.State.toLowerCase().replace(/\s+/g, '-'),
      county: row.County.replace(' County', '').toLowerCase().replace(/\s+/g, '-')
    }
  }))
}

const { state, county } = Astro.params

const countyName = county.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) + ' County'
const stateName = state.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
const countyFullName = countyName

// ─────────────────────────────
// POPULATION (Supabase)
// ─────────────────────────────

let population = null

const normalizedState = state.toLowerCase().trim()

const normalizedCounty = county
  .toLowerCase()
  .replace('-county', '')
  .trim()

const { data: populationRow } = await supabase
  .from('county_population')
  .select('population')
  .eq('state', normalizedState)
  .eq('county', normalizedCounty)
  .single()

if (populationRow?.population) {
  population = populationRow.population
}

// ─────────────────────────────
// COUNTY AVERAGE
// ─────────────────────────────

const { data: countyRows } = await supabase
  .from('counties')
  .select('"Life Expectancy (Years)"')
  .eq('State', stateName)
  .eq('County', countyFullName)

let countyAverage = 0
if (countyRows?.length) {
  const values = countyRows
    .map(r => r["Life Expectancy (Years)"])
    .filter(v => typeof v === 'number')

  if (values.length) {
    countyAverage = values.reduce((a,b)=>a+b,0) / values.length
  }
}

const retirementSpend = 72000

// ─────────────────────────────
// NATIONAL AVERAGE
// ─────────────────────────────

const { data: nationalRows } = await supabase
  .from('counties')
  .select('"Life Expectancy (Years)"')

let nationalAverage = 0
if (nationalRows?.length) {
  const values = nationalRows
    .map(r => r["Life Expectancy (Years)"])
    .filter(v => typeof v === 'number')

  if (values.length) {
    nationalAverage = values.reduce((a,b)=>a+b,0) / values.length
  }
}

// ─────────────────────────────
// STATE COUNTIES (FOR SIDEBAR)
// ─────────────────────────────

const { data: stateRows } = await supabase
  .from('counties')
  .select('County, "Life Expectancy (Years)"')
  .eq('State', stateName)

let stateCounties = []

if (stateRows?.length) {
  const grouped = {}

  stateRows.forEach(row => {
    if (!row?.County) return
    const name = row.County.replace(' County', '')
    if (!grouped[name]) grouped[name] = []
    if (typeof row["Life Expectancy (Years)"] === 'number') {
      grouped[name].push(row["Life Expectancy (Years)"])
    }
  })

  stateCounties = Object.entries(grouped).map(([name, values]) => {
    const avg = values.length
      ? values.reduce((a,b)=>a+b,0) / values.length
      : 0

    const diff = avg - nationalAverage

    const nearbySurvival75 = Math.max(0, Math.min(100, Math.round(85 + (diff * 2))))
    const nearbySurvival85 = Math.max(0, Math.min(100, Math.round(50 + (diff * 3))))
    const nearbySurvival95 = Math.max(0, Math.min(100, Math.round(12 + (diff * 2))))
    const nearbySurvival90 = Math.max(0, Math.min(100, Math.round(28 + (diff * 2))))

    const nearbyPlan20 = retirementSpend * 20
    const nearbyPlan30 = retirementSpend * 30
    const nearbySavingsGap = nearbyPlan30 - nearbyPlan20

    return {
      name,
      lifeExpectancy: avg.toFixed(2),
      difference: diff.toFixed(2),
      survival75: nearbySurvival75,
      survival85: nearbySurvival85,
      survival95: nearbySurvival95,
      survival90: nearbySurvival90,
      ssRecommendation: diff > 0 ? 70 : 67,
      savingsGap: (nearbySavingsGap / 1000000).toFixed(2),
      href: `/${state}/${name.toLowerCase().replace(/\s+/g,'-')}`
    }
  })
}

const difference = countyAverage - nationalAverage

// ─────────────────────────────
// SSA LIFE EXPECTANCY AT 65
// ─────────────────────────────

const { data: ssaData } = await supabase
  .from('ssa_life_tables')
  .select('ex')
  .eq('birth_year', 2020)
  .eq('sex', 'Male')
  .eq('age', 65)
  .single()

const lifeAt65 = ssaData?.ex ?? 0

// ─────────────────────────────
// DERIVED VALUES
// ─────────────────────────────

const survival75 = Math.max(0, Math.min(100, Math.round(85 + (difference * 2))))
const survival85 = Math.max(0, Math.min(100, Math.round(50 + (difference * 3))))
const survival95 = Math.max(0, Math.min(100, Math.round(12 + (difference * 2))))

const survival90 = Math.max(0, Math.min(100, Math.round(28 + (difference * 2))))

const prob90 = survival90
const s90National = 28

const s75County = survival75
const s75State = 84
const s75National = 83

const s85County = survival85
const s85State = 52
const s85National = 50

const s95County = survival95
const s95State = 13
const s95National = 12

const plan20 = retirementSpend * 20
const plan30 = retirementSpend * 30
const additionalCapital = plan30 - plan20
---


<CountyLayout
  countyName={countyName}
  stateName={stateName}
  countyAverage={countyAverage.toFixed(2)}
  nationalAverage={nationalAverage.toFixed(2)}
  difference={difference}
  lifeAt65={lifeAt65}

  s75County={s75County}
  s75State={s75State}
  s75National={s75National}

  s85County={s85County}
  s85State={s85State}
  s85National={s85National}

  s95County={s95County}
  s95State={s95State}
  s95National={s95National}

  prob90={prob90}
  s90National={s90National}

  stateCounties={stateCounties}
  population={population}
/>
