function buildSteps() {
  const list = document.getElementById('stepsList');
  list.innerHTML = '';
  Object.entries(STEP_GROUPS).forEach(([group, indices]) => {
    const groupEl = document.createElement('div');
    groupEl.className = 'step-group';
    groupEl.innerHTML = `<div class="step-group-label">${group}</div>`;
    indices.forEach(i => {
      const q = QUESTIONS[i];
      const item = document.createElement('div');
      item.className = 'step-item';
      item.id = `step-${i}`;
      item.innerHTML = `
        <div class="step-dot" id="dot-${i}">${i+1}</div>
        <div class="step-label">${q.label}</div>
      `;
      groupEl.appendChild(item);
    });
    list.appendChild(groupEl);
  });
}

function updateSteps() {
