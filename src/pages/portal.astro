              <table style="width:100%;border-collapse:collapse;font-size:14px;">
                <thead>
                  <tr>
                    <th style="text-align:left;padding:8px;border-bottom:1px solid var(--rule-light);">Title</th>
                    <th style="text-align:left;padding:8px;border-bottom:1px solid var(--rule-light);">Category</th>
                    <th style="text-align:right;padding:8px;border-bottom:1px solid var(--rule-light);">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  ${(templates || []).map(t => `
                    <tr>
                      <td style="padding:8px;border-bottom:1px solid var(--rule-light);">${t.title}</td>
                      <td style="padding:8px;border-bottom:1px solid var(--rule-light);">${t.category ?? ''}</td>
                      <td style="padding:8px;border-bottom:1px solid var(--rule-light);text-align:right;">
                        <button data-edit="${t.id}" class="edit-template-btn" style="margin-right:8px;">Edit</button>
                        <button data-delete="${t.id}" style="background:#b84040;color:white;border:none;padding:6px 12px;border-radius:6px;">Delete</button>
                      </td>
                    </tr>
                  `).join('')}
                </tbody>
              </table>
            </div>
          `;

          // -------- Checklist logic --------
          const subtaskContainer = document.getElementById('subtaskContainer');
          const addSubtaskBtn = document.getElementById('addSubtaskBtn');

          function addSubtaskInput(value = '') {
            const wrapper = document.createElement('div');
            wrapper.style.display = 'flex';
            wrapper.style.gap = '8px';
            wrapper.style.marginBottom = '8px';

            wrapper.innerHTML = `
              <input type="text"
                class="subtask-input"
                placeholder="Checklist item"
                value="${value}"
                style="flex:1;padding:8px;border-radius:6px;border:1px solid #ddd;">
              <button class="remove-subtask"
                style="background:#b84040;color:white;border:none;padding:6px 10px;border-radius:6px;cursor:pointer;">
                ✕
              </button>
            `;

            wrapper.querySelector('.remove-subtask').addEventListener('click', () => {
              wrapper.remove();
            });

            subtaskContainer.appendChild(wrapper);
          }

          addSubtaskBtn.addEventListener('click', () => addSubtaskInput());

          // --- Step 3: Unified create/edit handler ---
          const createBtn = document.getElementById('createPlanBtn');
          createBtn.addEventListener('click', async () => {

            const title = document.getElementById('newTitle').value.trim();
            const category = document.getElementById('newCategory').value.trim();

            if (!title) return alert("Title required.");

            // --- EDIT MODE ---
            if (editingTemplateId) {

              await supabase
                .from('action_plan_templates')
                .update({ title, category })
                .eq('id', editingTemplateId);

              await supabase
                .from('action_plan_template_subtasks')
                .delete()
                .eq('template_id', editingTemplateId);

              const subtaskInputs = document.querySelectorAll('.subtask-input');
              const subtasks = [];

              subtaskInputs.forEach(input => {
                if (input.value.trim()) {
                  subtasks.push({
                    template_id: editingTemplateId,
                    label: input.value.trim()
                  });
                }
              });

              if (subtasks.length) {
                await supabase.from('action_plan_template_subtasks').insert(subtasks);
              }

              editingTemplateId = null;
              createBtn.innerText = "Create Template";
            }

            // --- CREATE MODE ---
            else {

              const { data: template, error } = await supabase
                .from('action_plan_templates')
                .insert({ title, category })
                .select()
                .single();

              if (error) return alert("Error creating template.");

              const subtaskInputs = document.querySelectorAll('.subtask-input');
              const subtasks = [];

              subtaskInputs.forEach(input => {
                if (input.value.trim()) {
                  subtasks.push({
                    template_id: template.id,
                    label: input.value.trim()
                  });
                }
              });

              if (subtasks.length) {
                await supabase.from('action_plan_template_subtasks').insert(subtasks);
              }
            }

            // Reset form
            document.getElementById('newTitle').value = '';
            document.getElementById('newCategory').value = '';
            subtaskContainer.innerHTML = '';

            renderActionTasks();
          });

          // -------- DELETE TEMPLATE --------
          document.querySelectorAll('[data-delete]').forEach(btn => {
            btn.addEventListener('click', async (e) => {

              const id = e.target.dataset.delete;
              if (!confirm("Delete this template?")) return;

              await supabase.from('action_plan_template_subtasks').delete().eq('template_id', id);
              await supabase.from('action_plan_templates').delete().eq('id', id);

              renderActionTasks();
            });
          });

          // -------- EDIT TEMPLATE --------
          document.querySelectorAll('.edit-template-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {

              const id = e.target.dataset.edit;

              // Load template
              const { data: template } = await supabase
                .from('action_plan_templates')
                .select('*')
                .eq('id', id)
                .single();

              if (!template) return alert("Template not found.");

              // Load subtasks
              const { data: subtasks } = await supabase
                .from('action_plan_template_subtasks')
                .select('*')
                .eq('template_id', id)
                .order('created_at', { ascending: true });

              // Populate form
              document.getElementById('newTitle').value = template.title || '';
              document.getElementById('newCategory').value = template.category || '';

              const subtaskContainer = document.getElementById('subtaskContainer');
