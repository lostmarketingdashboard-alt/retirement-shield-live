---
const res = await fetch(`${import.meta.env.PUBLIC_STRAPI_URL}/api/articles?populate=*`);
const json = await res.json();

const articles = json.data || [];
---

<h1>Blog</h1>

<div class="grid">
  {articles.map((a) => (
    <a href={`/blog/${a.attributes.slug}`} class="card">
      <h2>{a.attributes.title}</h2>
      <p>{a.attributes.excerpt}</p>
    </a>
  ))}
</div>

<style>
.grid {
  display: grid;
  gap: 20px;
}
.card {
  padding: 20px;
  border: 1px solid #eee;
  border-radius: 12px;
  text-decoration: none;
  color: inherit;
}
.card:hover {
  border-color: #999;
}
</style>