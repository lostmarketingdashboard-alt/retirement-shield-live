function getFormData() {
  const name = document.getElementById('firstName').value.trim();
  const monthlyIncome = parseCurrency(document.getElementById('monthlyIncome').value);
  const homeValue = parseCurrency(document.getElementById('homeValue').value);
  const yourAge = Number.parseInt(document.getElementById('yourAge').value, 10);
  const spouseAge = Number.parseInt(document.getElementById('spouseAge').value, 10);
  const { code: stateCode, name: stateName } = getSelectedState();
  const primaryEarner = getSelectedValue('earner') || 'spouse';
  const source = getSelectedValue('source') || 'ss';
  const sourceLabel = {
    ss: 'Social Security',
    pension: 'Pension',
    investments: 'Investments',
    employment: 'Employment'
  }[source] || 'Social Security';

  return {
    rawName: name,
    name: name || 'You',
    stateCode,
    stateName: stateName || 'Your State',
    monthlyIncome,
    homeValue,
    yourAge,
    spouseAge,
    primaryEarner,
    source,
    sourceLabel,
    yourSSBenefit: parseCurrency(document.getElementById('yourSSBenefit')?.value || 0),
    spouseSSBenefit: parseCurrency(document.getElementById('spouseSSBenefit')?.value || 0)
  };
}

function validateFormData(data) {
  if (!data.rawName) return 'Please enter your first name.';
  if (!data.stateCode) return 'Please select your state of primary residence.';
  if (!Number.isFinite(data.yourAge) || data.yourAge < 18 || data.yourAge > 100) return 'Please enter a valid age for yourself.';
  if (!Number.isFinite(data.spouseAge) || data.spouseAge < 18 || data.spouseAge > 100) return 'Please enter a valid age for your spouse.';
  if (data.monthlyIncome <= 0) return 'Please enter your combined monthly income.';
  if (data.homeValue <= 0) return 'Please enter an estimated home value.';
  return '';
}

function updateMoneyInputs() {
  currencyFields.forEach((fieldId) => {
    const input = document.getElementById(fieldId);
    if (!input) return;
    input.addEventListener('blur', formatCurrencyInput);
    input.addEventListener('focus', () => {
      const numeric = parseCurrency(input.value);
      input.value = numeric ? String(Math.round(numeric)) : '';
    });
    input.addEventListener('input', () => {
      input.value = input.value.replace(/[^\d.]/g, '');
    });
  });
}

function setMoneyBarHeights(monthlyIncome, survivingIncome) {
  const maxHeight = 180;
  const afterHeight = Math.max(18, Math.round((survivingIncome / Math.max(monthlyIncome, 1)) * maxHeight));
  document.getElementById('barBefore').style.height = `${maxHeight}px`;
  document.getElementById('barAfter').style.height = `${afterHeight}px`;
}

function hydrateSavedSubmission(record) {
  const payload = record.form_payload || {};
  const formData = {
    rawName: record.full_name || payload.full_name || '',
    name: record.full_name || payload.full_name || 'You',
    stateCode: record.state_code || payload.state_code || '',
    stateName: record.state_name || payload.state_name || 'Your State',
    monthlyIncome: Number(record.combined_monthly_income ?? payload.combined_monthly_income ?? 0),
    homeValue: Number(record.home_value ?? payload.home_value ?? 0),
    yourAge: Number(record.your_age ?? payload.your_age ?? 0),
    spouseAge: Number(record.spouse_age ?? payload.spouse_age ?? 0),
    primaryEarner: record.primary_earner || payload.primary_earner || 'spouse',
    source: record.income_source || payload.income_source || 'ss',
    yourSSBenefit: Number(record.your_ss_benefit ?? payload.your_ss_benefit ?? 0),
    spouseSSBenefit: Number(record.spouse_ss_benefit ?? payload.spouse_ss_benefit ?? 0),
    sourceLabel: {
      ss: 'Social Security',
      pension: 'Pension',
      investments: 'Investments',
      employment: 'Employment'
    }[record.income_source || payload.income_source || 'ss']
  };

  const firstNameInput = document.getElementById('firstName');
  const stateSelect = document.getElementById('stateSelect');
  const yourAgeInput = document.getElementById('yourAge');
  const spouseAgeInput = document.getElementById('spouseAge');
  const monthlyIncomeInput = document.getElementById('monthlyIncome');
  const homeValueInput = document.getElementById('homeValue');

  if (firstNameInput) firstNameInput.value = formData.name;
  if (stateSelect && formData.stateCode) stateSelect.value = formData.stateCode;
  if (yourAgeInput && formData.yourAge) yourAgeInput.value = String(formData.yourAge);
  if (spouseAgeInput && formData.spouseAge) spouseAgeInput.value = String(formData.spouseAge);
  if (monthlyIncomeInput && formData.monthlyIncome) monthlyIncomeInput.value = formatCurrency(formData.monthlyIncome);
  if (homeValueInput && formData.homeValue) homeValueInput.value = formatCurrency(formData.homeValue);

  document.querySelectorAll('input[name="earner"]').forEach((input) => {
    input.checked = input.value === formData.primaryEarner;
    input.closest('.radio-card')?.classList.toggle('selected', input.checked);
  });

  document.querySelectorAll('input[name="source"]').forEach((input) => {
    input.checked = input.value === formData.source;
    input.closest('.radio-card')?.classList.toggle('selected', input.checked);
  });

  renderSourceSpecificFields();

  const yourSSInput = document.getElementById('yourSSBenefit');
  const spouseSSInput = document.getElementById('spouseSSBenefit');
  if (yourSSInput && formData.yourSSBenefit) yourSSInput.value = formatCurrency(formData.yourSSBenefit);
  if (spouseSSInput && formData.spouseSSBenefit) spouseSSInput.value = formatCurrency(formData.spouseSSBenefit);

  const model = getIncomeModel(formData, DEFAULT_FEDERAL_RULES);
  populateReport({ ...formData, model, stateRuleRecord: record.state_rule_snapshot || null, sourcesLabel: record.sources_label || null });

  document.getElementById('step1').style.display = 'none';
  document.getElementById('step2').style.display = 'none';
  document.getElementById('step3').style.display = 'block';
  document.querySelectorAll('.fade-up').forEach((el) => el.classList.add('visible'));
  setMoneyBarHeights(formData.monthlyIncome, model.survivingIncome);
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function saveReportSubmission(data, model) {
  const supabase = window.widowsPlaybookSupabase;
  if (!supabase) return;

  const rulesBundle = await loadWidowsRules(data.stateCode, data.stateName);
  const stateRuleRecord = rulesBundle.state;
  const sourcesLabel = [
    'SSA official survivor guidance',
    stateRuleRecord?.is_verified ? `${data.stateCode} verified state rules` : `${data.stateCode} fallback state rules`,
    'Medicaid rules dataset'
  ].join(' · ');

  const payload = {
    user_id: new URLSearchParams(window.location.search).get('utm') || null,
    full_name: data.name,
    state_code: data.stateCode,
    state_name: data.stateName,
    your_age: data.yourAge,
    spouse_age: data.spouseAge,
    primary_earner: data.primaryEarner,
    income_source: data.source,
    combined_monthly_income: data.monthlyIncome,
    home_value: data.homeValue,
    your_ss_benefit: data.yourSSBenefit || null,
    spouse_ss_benefit: data.spouseSSBenefit || null,
    survivor_income_estimate: model.survivingIncome,
    monthly_income_drop: model.monthlyDrop,
    annual_income_drop: model.annualDrop,
    state_rule_version: stateRuleRecord?.rule_version || null,
    state_rule_snapshot: stateRuleRecord || null,
    sources_label: sourcesLabel,
    form_payload: {
      full_name: data.name,
      state_code: data.stateCode,
      state_name: data.stateName,
      your_age: data.yourAge,
      spouse_age: data.spouseAge,
      primary_earner: data.primaryEarner,
      income_source: data.source,
      combined_monthly_income: data.monthlyIncome,
      home_value: data.homeValue,
      your_ss_benefit: data.yourSSBenefit || null,
      spouse_ss_benefit: data.spouseSSBenefit || null
    }
  };

  const { error } = await supabase
    .from('widows_playbook_reports')
    .insert(payload);

  if (error) {
    console.error('Failed to save Widow\'s Playbook submission:', error);
  }
}

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach(s => s.classList.remove('active'));
  document.getElementById('fs' + step).classList.add('active');

  document.querySelectorAll('.progress-dot').forEach((d, i) => {
    d.classList.remove('active', 'done');
    if (i + 1 < step) d.classList.add('done');
    else if (i + 1 === step) d.classList.add('active');
  });

  currentStep = step;
}

function selectRadio(card) {
  const group = card.closest('.radio-group');
  group.querySelectorAll('.radio-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');
  card.querySelector('input').checked = true;
  if (card.querySelector('input')?.name === 'source') {
    renderSourceSpecificFields();
  }
}

async function generateReport() {
  const formData = getFormData();
  const validationError = validateFormData(formData);

  if (validationError) {
    alert(validationError);
    return;
  }

  const rulesBundle = await loadWidowsRules(formData.stateCode, formData.stateName);
  const model = getIncomeModel(formData, rulesBundle.federal);
  await saveReportSubmission(formData, model);
  populateReport({
    ...formData,
    model,
    stateRuleRecord: rulesBundle.state,
    sourcesLabel: [
      'SSA official survivor guidance',
      rulesBundle.state?.is_verified ? `${formData.stateCode} verified state rules` : `${formData.stateCode} fallback state rules`,
      'Medicaid rules dataset'
    ].join(' · ')
  });

  document.getElementById('step1').style.display = 'none';
  document.getElementById('step2').style.display = 'block';

  const steps = ['as1','as2','as3','as4','as5','as6'];
  let idx = 0;

  function activate(i) {
    if (i > 0) {
      document.getElementById(steps[i-1]).classList.remove('active');
      document.getElementById(steps[i-1]).classList.add('done');
    }
    if (i < steps.length) {
      document.getElementById(steps[i]).classList.add('active');
    }
  }

  activate(0);
  const delays = [1000, 900, 1200, 1100, 800, 1000];
  let total = 0;

  for (let i = 1; i <= steps.length; i++) {
    total += delays[i-1];
    setTimeout(() => {
      if (i < steps.length) {
        activate(i);
      } else {
        document.getElementById(steps[steps.length-1]).classList.remove('active');
        document.getElementById(steps[steps.length-1]).classList.add('done');

        setTimeout(() => {
          document.getElementById('step2').style.display = 'none';
          document.getElementById('step3').style.display = 'block';
          window.scrollTo({ top: 0, behavior: 'auto' });

          // Animate income bars
          setTimeout(() => {
            const formData = getFormData();
            const model = getIncomeModel(formData, DEFAULT_FEDERAL_RULES);
            setMoneyBarHeights(formData.monthlyIncome, model.survivingIncome);
          }, 300);

          // Fade-in
          const fadeEls = document.querySelectorAll('.fade-up');
          const obs = new IntersectionObserver((entries) => {
            entries.forEach((e, i) => {
              if (e.isIntersecting) {
                setTimeout(() => e.target.classList.add('visible'), i * 80);
                obs.unobserve(e.target);
              }
            });
          }, { threshold: 0.1 });
          fadeEls.forEach(el => obs.observe(el));
        }, 500);
      }
    }, total);
  }
}

updateMoneyInputs();
renderSourceSpecificFields();
currencyFields.forEach((fieldId) => {
  const input = document.getElementById(fieldId);
  if (input && input.value) input.value = formatCurrency(parseCurrency(input.value));
});

window.nextStep = nextStep;
window.selectRadio = selectRadio;
window.generateReport = generateReport;
window.hydrateSavedSubmission = hydrateSavedSubmission;
</script>

