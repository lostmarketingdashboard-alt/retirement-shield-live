<script>
const STATE_OPTIONS = [
  ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],['CA','California'],['CO','Colorado'],
  ['CT','Connecticut'],['DE','Delaware'],['FL','Florida'],['GA','Georgia'],['HI','Hawaii'],['ID','Idaho'],
  ['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],['KY','Kentucky'],['LA','Louisiana'],
  ['ME','Maine'],['MD','Maryland'],['MA','Massachusetts'],['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],
  ['MO','Missouri'],['MT','Montana'],['NE','Nebraska'],['NV','Nevada'],['NH','New Hampshire'],['NJ','New Jersey'],
  ['NM','New Mexico'],['NY','New York'],['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
  ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],['SD','South Dakota'],
  ['TN','Tennessee'],['TX','Texas'],['UT','Utah'],['VT','Vermont'],['VA','Virginia'],['WA','Washington'],
  ['WV','West Virginia'],['WI','Wisconsin'],['WY','Wyoming'],['DC','District of Columbia']
];

const COMMUNITY_PROPERTY_STATES = new Set(['AZ','CA','ID','LA','NV','NM','TX','WA','WI']);

const GENERIC_RULE_COPY = {
  spouse_only: {
    display: 'Surviving spouse takes the probate estate',
    narrative: 'With no descendants in the picture, the surviving spouse is usually first in line for the probate estate under intestacy.',
    spouse_pct: 1,
    descendants_pct: 0
  },
  spouse_and_joint_descendants: {
    display: 'Surviving spouse typically has the strongest claim',
    narrative: 'When all children are from the current marriage, many states heavily favor the surviving spouse, but the exact allocation should come from the state rule snapshot.',
    spouse_pct: 1,
    descendants_pct: 0
  },
  spouse_and_prior_descendants: {
    display: 'Spouse and prior-marriage children are put on a collision course',
    narrative: 'This is the classic blended-family fight: the surviving spouse does not automatically absorb everything, and children from a prior marriage usually gain direct inheritance rights.',
    spouse_pct: 0.5,
    descendants_pct: 0.5
  },
  spouse_and_mixed_descendants: {
    display: 'Current-family and prior-family branches both matter',
    narrative: 'When there are both shared children and prior-marriage children, a surviving spouse and multiple descendant branches can all end up pulling against each other.',
    spouse_pct: 0.5,
    descendants_pct: 0.5
  },
  unmarried_descendants: {
    display: 'Descendants take the estate',
    narrative: 'Without a surviving spouse, descendants usually take the probate estate by representation.',
    spouse_pct: 0,
    descendants_pct: 1
  }
};

let currentStep = 1;

STATE_OPTIONS.forEach(([code, name]) => {
  const option = document.createElement('option');
  option.value = code;
  option.textContent = name;
  document.getElementById('stateSelect').appendChild(option);
});

function slugify(value) {
  return String(value || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

function currency(value) {
  if (value == null || Number.isNaN(value)) return '—';
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(value);
}

function parseMoney(value) {
  const parsed = Number(String(value || '').replace(/[^\d.-]/g, ''));
  return Number.isFinite(parsed) ? parsed : 0;
}

function formatCurrencyInput(event) {
  const raw = parseMoney(event.target.value);
  event.target.value = raw ? String(Math.round(raw)) : '';
}

function getSelectedValue(name) {
  return document.querySelector(`input[name="${name}"]:checked`)?.value || '';
}

function updateRadioCards() {
  document.querySelectorAll('.radio-card').forEach((card) => {
    const input = card.querySelector('input');
    card.classList.toggle('selected', Boolean(input?.checked));
  });
}

function toggleMarriageOrder() {
  const married = getSelectedValue('maritalStatus') === 'married';
  document.getElementById('marriageOrderWrap').style.display = married ? '' : 'none';
}

document.querySelectorAll('.radio-card').forEach((card) => {
  card.addEventListener('click', () => {
    const input = card.querySelector('input');
    if (!input) return;
    input.checked = true;
    updateRadioCards();
    toggleMarriageOrder();
  });
});

['estateSize','homeValue'].forEach((id) => {
  const input = document.getElementById(id);
  input.addEventListener('blur', formatCurrencyInput);
});

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach((section) => section.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');
  document.querySelectorAll('.step-item').forEach((item, index) => {
    item.classList.remove('active','done');
    if (index + 1 < step) item.classList.add('done');
    if (index + 1 === step) item.classList.add('active');
  });
  currentStep = step;
  document.getElementById('progressText').textContent = `Step ${step} of 3`;
  document.getElementById('progressFill').style.width = `${(step / 3) * 100}%`;
}

function getScenarioKey(data) {
  const currentChildren = data.currentMarriageChildren;
  const priorChildren = data.priorMarriageChildren;
  const totalChildren = currentChildren + priorChildren;

  if (data.maritalStatus !== 'married') return totalChildren > 0 ? 'unmarried_descendants' : 'spouse_only';
  if (!totalChildren) return 'spouse_only';
  if (currentChildren > 0 && priorChildren > 0) return 'spouse_and_mixed_descendants';
  if (priorChildren > 0) return 'spouse_and_prior_descendants';
  return 'spouse_and_joint_descendants';
}

function percentileLabel(value) {
  if (value == null) return 'Review needed';
  return `${Math.round(value * 100)}%`;
}

async function loadStateGuide(supabase, stateCode) {
  if (!supabase || !stateCode) return null;
  const stateName = STATE_OPTIONS.find(([code]) => code === stateCode)?.[1];
  if (!stateName) return null;
  const { data } = await supabase
    .from('state_guides')
    .select('state_name,probate_cost_display,probate_timeline_display,homestead_display,homestead_protects_from_creditors,lady_bird_display,lady_bird_deed_available,tod_display,tod_deed_available,state_estate_tax,state_inheritance_tax')
    .eq('state_slug', slugify(stateName))
    .maybeSingle();
  return data || null;
}

async function loadStateRules(supabase, stateCode) {
  if (!supabase || !stateCode) return null;
  const { data } = await supabase
    .from('inheritance_collision_state_rules')
    .select('*')
    .eq('state_code', stateCode)
    .eq('is_active', true)
    .order('updated_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  return data || null;
}

function buildInputData() {
  return {
    fullName: document.getElementById('fullName').value.trim() || 'Retirement Shield Client',
    stateCode: document.getElementById('stateSelect').value,
    stateName: STATE_OPTIONS.find(([code]) => code === document.getElementById('stateSelect').value)?.[1] || '',
    maritalStatus: getSelectedValue('maritalStatus') || 'married',
    marriageOrder: getSelectedValue('marriageOrder') || 'first',
    currentMarriageChildren: Number(document.getElementById('currentMarriageChildren').value || 0),
    priorMarriageChildren: Number(document.getElementById('priorMarriageChildren').value || 0),
    estateSize: parseMoney(document.getElementById('estateSize').value),
    homeValue: parseMoney(document.getElementById('homeValue').value)
  };
}

function validateInput(data) {
  if (!data.stateCode) return 'Choose a state.';
  if (!data.maritalStatus) return 'Choose a marital status.';
  if (data.maritalStatus === 'married' && !data.marriageOrder) return 'Choose whether this is a first or subsequent marriage.';
  if (data.currentMarriageChildren < 0 || data.priorMarriageChildren < 0) return 'Children counts cannot be negative.';
  if (!data.estateSize) return 'Enter an approximate estate size.';
  return '';
}

function fallbackElectiveShare(stateCode, stateName) {
  if (COMMUNITY_PROPERTY_STATES.has(stateCode)) {
    return {
      display: 'Community property rules apply before any separate-property claim',
      narrative: `${stateName} is treated here as a community property state. The surviving spouse usually already owns one-half of community property, but separate-property and quasi-community-property claims still require a state-specific rule row for exact modeling.`,
      label: 'Community property overlay'
    };
  }
  return {
    display: 'State-specific elective-share row still needs to be loaded',
    narrative: `This report can save and render without a dedicated ${stateName} rule snapshot, but exact elective-share percentages and scope should be added in the database for a production-grade state result.`,
    label: 'State rule needed'
  };
}

function buildCollisionModel(data, guide, stateRuleRecord) {
  const rules = stateRuleRecord?.rules_payload || {};
  const scenarioKey = getScenarioKey(data);
  const scenarioRule = rules.intestacy?.[scenarioKey] || GENERIC_RULE_COPY[scenarioKey] || GENERIC_RULE_COPY.spouse_only;
  const electiveRule = rules.elective_share || fallbackElectiveShare(data.stateCode, data.stateName);
  const communityProperty = rules.property_system === 'community_property' || (!rules.property_system && COMMUNITY_PROPERTY_STATES.has(data.stateCode));
  const propertySystemLabel = communityProperty ? 'Community property state' : 'Common law / separate property state';
  const spousePct = typeof scenarioRule.spouse_pct === 'number' ? scenarioRule.spouse_pct : null;
  const descendantsPct = typeof scenarioRule.descendants_pct === 'number' ? scenarioRule.descendants_pct : null;
  const spouseShareAmount = spousePct != null ? data.estateSize * spousePct : null;
  const descendantsShareAmount = descendantsPct != null ? data.estateSize * descendantsPct : null;
  const totalChildren = data.currentMarriageChildren + data.priorMarriageChildren;
  const perChildAmount = descendantsShareAmount != null && totalChildren > 0 ? descendantsShareAmount / totalChildren : null;
  const homeText = data.homeValue ? currency(data.homeValue) : 'the home';
  const probateSummary = [guide?.probate_cost_display, guide?.probate_timeline_display].filter(Boolean).join(' · ') || 'State guide review needed';
  const transferSummary = guide?.lady_bird_deed_available ? guide.lady_bird_display : guide?.tod_deed_available ? guide.tod_display : guide?.homestead_display || 'Title review needed';
  const taxSummary = [guide?.state_estate_tax, guide?.state_inheritance_tax].filter(Boolean).join(' / ') || 'Review needed';
  const stepchildrenInherit = rules.stepchildren?.inherit_without_adoption === true;
  const stepchildrenCopy = rules.stepchildren?.display || (stepchildrenInherit ? 'This state rule row says stepchildren may have rights in limited circumstances.' : 'No automatic inheritance rights without adoption or explicit planning.');

  let riskScore = 18;
  if (data.maritalStatus === 'married') riskScore += 10;
  if (data.marriageOrder === 'subsequent') riskScore += 18;
  if (data.priorMarriageChildren > 0) riskScore += 28;
  if (data.currentMarriageChildren > 0) riskScore += 8;
  if (data.estateSize >= 500000) riskScore += 10;
  if (data.homeValue >= 300000) riskScore += 8;
  if (communityProperty) riskScore += 8;
  if (!stepchildrenInherit) riskScore += 6;
  if (guide?.state_estate_tax && guide.state_estate_tax !== 'None') riskScore += 4;
  if (guide?.state_inheritance_tax && guide.state_inheritance_tax !== 'None') riskScore += 4;
  riskScore = Math.max(10, Math.min(100, riskScore));

  const riskLevel = riskScore >= 80 ? 'severe' : riskScore >= 60 ? 'high' : riskScore >= 35 ? 'moderate' : 'low';
  const riskTitle = riskLevel === 'severe' ? 'Severe' : riskLevel === 'high' ? 'High' : riskLevel === 'moderate' ? 'Moderate' : 'Low';

  const benchmarkHeadline = data.priorMarriageChildren > 0
    ? 'Prior-marriage children and the spouse both have real claims'
    : data.maritalStatus === 'married'
      ? 'The spouse likely leads, but title and override rights still matter'
      : 'Direct descendants control the baseline result';

  const benchmarkCopy = data.priorMarriageChildren > 0
    ? `The emotional collision is usually not about percentages. It is about whether ${homeText} and the rest of the estate are being used first to protect the surviving spouse, preserved for first-marriage children, or both.`
    : `The cleaner family tree lowers the risk, but probate design, beneficiary coordination, and spouse-protection rules still decide how smooth the outcome actually is.`;

  const summaryCopy = data.maritalStatus === 'married'
    ? `In ${data.stateName}, this ${data.marriageOrder === 'subsequent' ? 'later-marriage' : 'married'} household is modeled with ${data.currentMarriageChildren} current-marriage child${data.currentMarriageChildren === 1 ? '' : 'ren'} and ${data.priorMarriageChildren} prior-marriage child${data.priorMarriageChildren === 1 ? '' : 'ren'}. On a probate estate of about ${currency(data.estateSize)}, the surviving spouse and the descendant line do not necessarily want the same thing.`
    : `In ${data.stateName}, the model shows what happens when the spouse layer falls away and descendants inherit more directly. This is the clean baseline many blended families compare against when deciding how much to guarantee a later spouse versus preserve for children.`;

  const actionOne = data.priorMarriageChildren > 0
    ? ['Coordinate the spouse plan with the children plan', 'A blended-family estate should not rely on “the kids will understand.” Spell out the trust, deed, and beneficiary structure so the spouse is secure without accidentally rewriting the children out of the estate.']
    : ['Confirm the probate path', 'A calmer family structure still needs title, beneficiary, and will/trust coordination so the default state outcome does not control more than expected.'];
  const actionTwo = communityProperty
    ? ['Review community vs. separate property tracing', 'In a community property state, the fight often shifts from “who inherits” to “what bucket was this asset in?” The house, brokerage account, and commingled savings deserve a tracing review.']
    : ['Pressure-test the elective-share exposure', 'If the plan leaves the spouse less than the statutory floor, the surviving spouse may be able to challenge the arrangement anyway.'];
  const actionThree = !stepchildrenInherit
    ? ['Name stepchildren explicitly if they matter', 'If a stepchild is intended to inherit, say so directly in the documents. States almost never give that child an automatic share.']
    : ['Check descendant definitions carefully', 'Even where stepchild or blended-family definitions are broader, the estate plan should still define which children, branches, or substitute takers are intended.'];

  return {
    stateRuleLoaded: Boolean(stateRuleRecord),
    stateRuleVersion: stateRuleRecord?.rule_version || 'fallback',
    scenarioKey,
    scenarioDisplay: scenarioRule.display,
    intestacyNarrative: scenarioRule.narrative,
    childrenNarrative: descendantsPct && totalChildren
      ? `The descendant side is modeled at ${percentileLabel(descendantsPct)} of the probate estate, or about ${currency(descendantsShareAmount)} total${perChildAmount != null ? ` before any per-stirpes/per-capita adjustments, which is about ${currency(perChildAmount)} per child if divided evenly.` : '.'}`
      : 'The descendant line is not modeled as taking a direct probate share in this baseline scenario.',
    spousePct,
    descendantsPct,
    spouseShareAmount,
    descendantsShareAmount,
    electiveRule,
    propertySystemLabel,
    communityProperty,
    probateSummary,
    transferSummary,
    taxSummary,
    stepchildrenCopy,
    riskScore,
    riskLevel,
    riskTitle,
    benchmarkHeadline,
    benchmarkCopy,
    summaryCopy,
    actionOne,
    actionTwo,
    actionThree
  };
}

function populateReport(data, guide, stateRuleRecord, model) {
  const generatedDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  const familyLabel = `${data.currentMarriageChildren} current-marriage / ${data.priorMarriageChildren} prior-marriage children`;
  const electiveLabel = model.electiveRule.display || model.electiveRule.label || 'Review needed';
  const probateTool = guide?.lady_bird_deed_available ? guide.lady_bird_display : guide?.tod_deed_available ? guide.tod_display : 'Review title strategy';
  const taxLine = [guide?.state_estate_tax || 'Estate tax review', guide?.state_inheritance_tax || 'Inheritance tax review'].join(' · ');

  document.getElementById('reportTitle').textContent = `The Inheritance Collision Report for ${data.fullName}`;
  document.getElementById('reportSubtitle').textContent = `A ${data.stateName} blended-family conflict snapshot showing default intestacy, surviving-spouse override pressure, and the traps that commonly disinherit one side of the family.`;
  document.getElementById('metaState').textContent = `${data.stateName} · ${model.propertySystemLabel}`;
  document.getElementById('metaFamily').textContent = familyLabel;
  document.getElementById('metaDate').textContent = `Generated ${generatedDate}`;
  document.getElementById('summaryTitle').innerHTML = `${model.riskTitle} collision risk in a <em>${data.stateName}</em> ${data.maritalStatus === 'married' ? 'spouse-versus-children' : 'descendants-only'} scenario.`;
  document.getElementById('summaryCopy').textContent = model.summaryCopy;
  document.getElementById('benchmarkHeadline').textContent = model.benchmarkHeadline;
  document.getElementById('benchmarkCopy').textContent = model.benchmarkCopy;
  document.getElementById('riskScoreValue').textContent = `${model.riskScore}/100`;
  document.getElementById('riskScoreSub').textContent = stateRuleRecord ? `Using ${stateRuleRecord.state_code} rule snapshot + state guide overlay` : 'Using fallback logic until a state rule snapshot is loaded';
  document.getElementById('spouseShareValue').textContent = model.spousePct != null ? `${percentileLabel(model.spousePct)} / ${currency(model.spouseShareAmount)}` : 'Review needed';
  document.getElementById('spouseShareSub').textContent = model.scenarioDisplay;
  document.getElementById('electiveShareValue').textContent = electiveLabel;
  document.getElementById('electiveShareSub').textContent = model.electiveRule.label || 'Surviving-spouse minimum claim';
  document.getElementById('propertySystemPill').textContent = model.propertySystemLabel;
  document.getElementById('riskValue').textContent = `${model.riskTitle} collision risk`;
  const riskPill = document.getElementById('riskPill');
  riskPill.textContent = `${model.riskTitle} conflict risk`;
  riskPill.className = `status-pill ${model.riskLevel}`;
  document.getElementById('scenarioPill').textContent = model.scenarioKey.replaceAll('_',' ');
  document.getElementById('intestacyHeadline').textContent = model.scenarioDisplay;
  document.getElementById('intestacyNarrative').textContent = model.intestacyNarrative;
  document.getElementById('childrenHeadline').textContent = data.priorMarriageChildren > 0 ? 'Prior-marriage children are not automatically pushed aside' : 'Descendant branch outcome';
  document.getElementById('childrenNarrative').textContent = model.childrenNarrative;
  document.getElementById('listSpouseShare').textContent = model.spousePct != null ? `${percentileLabel(model.spousePct)} of about ${currency(data.estateSize)} = ${currency(model.spouseShareAmount)}` : 'State-specific review needed';
  document.getElementById('listChildrenShare').textContent = model.descendantsPct != null ? `${percentileLabel(model.descendantsPct)} of about ${currency(data.estateSize)} = ${currency(model.descendantsShareAmount)}` : 'No direct modeled share';
  document.getElementById('listStepchildren').textContent = model.stepchildrenCopy;
  document.getElementById('listProbateOverlay').textContent = `${model.probateSummary} · ${probateTool}`;
  document.getElementById('electiveSharePill').textContent = model.electiveRule.label || 'Elective share';
  document.getElementById('electiveShareNote').textContent = model.electiveRule.narrative || electiveLabel;
  document.getElementById('taxPill').textContent = taxLine;
  document.getElementById('probateValue').textContent = guide?.probate_timeline_display || 'Review';
  document.getElementById('probateCopy').textContent = guide?.probate_cost_display ? `${guide.probate_cost_display}. If the house and titled assets are still flowing through probate, delay and family pressure both increase.` : 'The state guide row for probate timing and cost still needs review.';
  document.getElementById('transferValue').textContent = probateTool || 'Review';
  document.getElementById('transferCopy').textContent = guide?.homestead_display ? `${guide.homestead_display}. The house is often where blended-family emotions are strongest, so deed and title mechanics matter more than people expect.` : 'Title planning tools and homestead restrictions should be reviewed for this state.';
  document.getElementById('taxValue').textContent = guide?.state_estate_tax && guide?.state_estate_tax !== 'None' ? guide.state_estate_tax : guide?.state_inheritance_tax && guide?.state_inheritance_tax !== 'None' ? guide.state_inheritance_tax : 'None / low';
  document.getElementById('taxCopy').textContent = `${taxLine}. Death taxes may be irrelevant for many households, but when they apply they intensify pressure between spouse liquidity and descendant expectations.`;
  document.getElementById('actionOneTitle').textContent = model.actionOne[0];
  document.getElementById('actionOneCopy').textContent = model.actionOne[1];
  document.getElementById('actionTwoTitle').textContent = model.actionTwo[0];
  document.getElementById('actionTwoCopy').textContent = model.actionTwo[1];
  document.getElementById('actionThreeTitle').textContent = model.actionThree[0];
  document.getElementById('actionThreeCopy').textContent = model.actionThree[1];

  const warning = document.getElementById('fallbackWarning');
  if (stateRuleRecord) {
    warning.classList.remove('active');
    warning.textContent = '';
  } else {
    warning.classList.add('active');
    warning.textContent = `${data.stateName} does not have a dedicated rule row in inheritance_collision_state_rules yet, so this report is using safe fallback logic plus the broader state guide overlay. Add a state rule row for exact elective-share and intestacy wording.`;
  }
}

async function saveCollisionReport(data, guide, stateRuleRecord, model) {
  const supabase = window.inheritanceCollisionSupabase;
  if (!supabase) return null;

  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const payload = {
    user_id: userId,
    full_name: data.fullName,
    state_code: data.stateCode,
    state_name: data.stateName,
    marital_status: data.maritalStatus,
    marriage_order: data.marriageOrder,
    current_marriage_children: data.currentMarriageChildren,
    prior_marriage_children: data.priorMarriageChildren,
    approximate_estate_size: data.estateSize,
    home_value: data.homeValue || null,
    scenario_key: model.scenarioKey,
    property_system: model.propertySystemLabel,
    collision_risk_score: model.riskScore,
    spouse_share_pct: model.spousePct,
    descendants_share_pct: model.descendantsPct,
    elective_share_display: model.electiveRule.display || null,
    state_rule_version: stateRuleRecord?.rule_version || null,
    state_rule_snapshot: stateRuleRecord || null,
    report_title: `The Inheritance Collision Report for ${data.fullName}`,
    report_payload: { ...data, guide, stateRuleRecord, model }
  };

  const { error } = await supabase
    .from('inheritance_collision_reports')
    .insert(payload);

  if (error) {
    console.error('Failed to save Inheritance Collision report:', error);
  }
}

function showGeneratedReport() {
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  const steps = ['analysisStep1','analysisStep2','analysisStep3','analysisStep4'];
  steps.forEach((id) => document.getElementById(id).classList.remove('done'));
  let delay = 0;
  steps.forEach((id, index) => {
    delay += 500;
    setTimeout(() => {
      document.getElementById(id).classList.add('done');
      if (index === steps.length - 1) {
        setTimeout(() => {
          document.getElementById('analysisSection').classList.remove('active');
          document.getElementById('reportSection').classList.add('active');
          const shell = document.getElementById('reportShell');
          shell.classList.add('visible');
          shell.scrollIntoView({ behavior: 'smooth', block: 'start' });
          const fadeEls = document.querySelectorAll('.fade-up');
          fadeEls.forEach((el, i) => setTimeout(() => el.classList.add('visible'), i * 80));
        }, 400);
      }
    }, delay);
  });
}

function showHydratedReport() {
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('reportSection').classList.add('active');
  document.getElementById('reportShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedSubmission(report) {
  const payload = report?.report_payload;
  if (!payload) return false;

  document.getElementById('fullName').value = payload.fullName || '';
  document.getElementById('stateSelect').value = payload.stateCode || '';
  document.getElementById('currentMarriageChildren').value = payload.currentMarriageChildren ?? 0;
  document.getElementById('priorMarriageChildren').value = payload.priorMarriageChildren ?? 0;
  document.getElementById('estateSize').value = payload.estateSize ? String(Math.round(payload.estateSize)) : '';
  document.getElementById('homeValue').value = payload.homeValue ? String(Math.round(payload.homeValue)) : '';

  ['maritalStatus','marriageOrder'].forEach((group) => {
    document.querySelectorAll(`input[name="${group}"]`).forEach((input) => {
      input.checked = input.value === payload[group];
    });
  });

  updateRadioCards();
  toggleMarriageOrder();
  populateReport(payload, payload.guide || null, payload.stateRuleRecord || null, payload.model);
  showHydratedReport();
  return true;
}

async function generateCollisionReport() {
  const data = buildInputData();
  const validationError = validateInput(data);
  if (validationError) {
    alert(validationError);
    return;
  }

  const supabase = window.inheritanceCollisionSupabase;
  const [guide, stateRuleRecord] = await Promise.all([
    loadStateGuide(supabase, data.stateCode),
    loadStateRules(supabase, data.stateCode)
  ]);

  const model = buildCollisionModel(data, guide, stateRuleRecord);
  populateReport(data, guide, stateRuleRecord, model);
  await saveCollisionReport(data, guide, stateRuleRecord, model);
  showGeneratedReport();
}

function editCollisionReport() {
  document.getElementById('reportSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(3);
}

window.nextStep = nextStep;
window.generateCollisionReport = generateCollisionReport;
window.editCollisionReport = editCollisionReport;
window.hydrateInheritanceCollisionSubmission = hydrateSavedSubmission;
updateRadioCards();
toggleMarriageOrder();
</script>

