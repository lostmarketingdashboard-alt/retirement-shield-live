          document.querySelectorAll('.user-card').forEach(card => {
            card.querySelector('.user-row').addEventListener('click', async (e) => {

              // Prevent click from firing when clicking buttons/select
              if (e.target.closest('select') || e.target.closest('button')) return

              const userId = card.dataset.user
              const answersContainer = card.querySelector('.user-answers')

              // Toggle close if already open
              if (answersContainer.style.display === 'block') {
                answersContainer.style.display = 'none'
                answersContainer.innerHTML = ''
                return
              }

              // Close other open cards
              document.querySelectorAll('.user-answers').forEach(a => {
                a.style.display = 'none'
                a.innerHTML = ''
