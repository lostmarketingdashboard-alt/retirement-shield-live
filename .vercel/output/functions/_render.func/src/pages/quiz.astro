    dot.innerHTML = i + 1;
    if (i === currentQ) {
      item.classList.add('active');
    } else if (answers[q.id] !== undefined) {
      item.classList.add('completed');
      dot.innerHTML = '✓';
    }
  });
}

function calcScore() {
  let deductions = 0;
  QUESTIONS.forEach(q => {
    if (q.scoring && answers[q.id] !== undefined) {
      deductions += q.scoring[answers[q.id]] || 0;
    }
  });
  return Math.max(0, 100 - deductions);
}

function updateScorePreview() {
  const answered = QUESTIONS.filter(q => q.scoring && answers[q.id] !== undefined).length;
  const total = QUESTIONS.filter(q => q.scoring).length;
  if (answered === 0) {
    document.getElementById('scoreDisplay').textContent = '—';
    document.getElementById('scoreStatus').textContent = 'Not yet calculated';
    document.getElementById('scoreBarFill').style.width = '0%';
    return;
  }
  const score = calcScore();
  const partial = Math.round(score * (answered / total));
  document.getElementById('scoreDisplay').textContent = partial;
  document.getElementById('scoreBarFill').style.width = partial + '%';
  if (partial >= 80) document.getElementById('scoreStatus').textContent = 'Well Protected';
  else if (partial >= 60) document.getElementById('scoreStatus').textContent = 'Some Gaps Found';
  else if (partial >= 40) document.getElementById('scoreStatus').textContent = 'Significant Gaps';
  else document.getElementById('scoreStatus').textContent = 'Critical Exposure';
}

function buildSlides() {
  const container = document.getElementById('slidesContainer');
  container.innerHTML = '';
  QUESTIONS.forEach((q, i) => {
    const slide = document.createElement('div');
    slide.className = 'question-slide';
    slide.id = `slide-${i}`;
    slide.innerHTML = buildSlideHTML(q, i);
    container.appendChild(slide);
  });
}

function buildSlideHTML(q, i) {
  let optionsHTML = '';

  if (q.type === 'select') {
    const opts = q.options.map(s => `<option value="${s}">${s}</option>`).join('');
    optionsHTML = `
      <div class="state-select-wrap">
        <select class="state-select" id="input-${q.id}" onchange="onSelectChange('${q.id}', this.value)">
          <option value="">Select your state…</option>
          ${opts}
        </select>
      </div>`;
  }
  else if (q.type === 'state_county') {
    const opts = q.options.map(s => `<option value="${s}">${s}</option>`).join('');
    optionsHTML = `
      <div class="state-select-wrap" style="margin-bottom:14px;">
        <select class="state-select" id="input-state" onchange="onStateChange(this.value)">
          <option value="">Select your state…</option>
          ${opts}
        </select>
      </div>
      <div class="state-select-wrap">
        <select class="state-select" id="input-county" disabled onchange="onCountyChange(this.value)">
          <option value="">Select your county…</option>
        </select>
      </div>
    `;
  }
  else if (q.type === 'options') {
    const gridClass = q.twoCol ? 'options-grid two-col' : 'options-grid';
    const btns = q.options.map((o, idx) => {
      const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
      return `
        <button class="option-btn" id="opt-${q.id}-${o.value}" onclick="selectOption('${q.id}','${o.value}')">
          <div class="option-indicator">${letters[idx]}</div>
          <div class="option-text">
            <div class="option-label">${o.label}</div>
            ${o.sub ? `<div class="option-sublabel">${o.sub}</div>` : ''}
          </div>
        </button>`;
    }).join('');
    optionsHTML = `<div class="${gridClass}">${btns}</div>`;
  } else if (q.type === 'email') {
    optionsHTML = `
      <div class="input-row">
        <input type="text" class="text-input" id="input-firstName" placeholder="First name" oninput="onEmailChange()">
        <input type="text" class="text-input" id="input-lastName" placeholder="Last name" oninput="onEmailChange()">
      </div>
      <div class="text-input-wrap">
        <input type="email" class="text-input" id="input-email" placeholder="Email address" oninput="onEmailChange()">
      </div>
      <p class="email-note">Your information is secure and will never be shared or sold.</p>`;
  }

  return `
    <div class="q-number">${String(i+1).padStart(2,'0')}</div>
    <div class="q-eyebrow">${q.category}</div>
    <h2 class="q-title">${q.title}</h2>
    <p class="q-sub">${q.sub}</p>
    ${optionsHTML}
  `;
}

function selectOption(qId, value) {
  answers[qId] = value;
  // Clear all selected in this question
  const q = QUESTIONS.find(q => q.id === qId);
  q.options.forEach(o => {
    const btn = document.getElementById(`opt-${qId}-${o.value}`);
    if (btn) btn.classList.remove('selected');
  });
  // Set selected
  const selected = document.getElementById(`opt-${qId}-${value}`);
  if (selected) selected.classList.add('selected');
  document.getElementById('btnNext').disabled = false;
  updateScorePreview();
  updateSteps();
}

function onSelectChange(qId, value) {
  if (value) {
    answers[qId] = value;
    document.getElementById('btnNext').disabled = false;
    updateSteps();
  } else {
    document.getElementById('btnNext').disabled = true;
  }
}

// --- State + County handlers ---
async function onStateChange(value) {
  const countySelect = document.getElementById('input-county')

  if (!value) {
    countySelect.innerHTML = '<option value="">Select your county…</option>'
    countySelect.disabled = true
    document.getElementById('btnNext').disabled = true
    return
  }

  answers['state'] = value

  // Normalize state to match DB format (e.g., "New York" -> "new-york")
  const normalizedState = value
    .toLowerCase()
    .trim()
    .replace(/\s+/g, '-')

  const { data, error } = await supabase
    .from('county_population')
    .select('county')
    .eq('state', normalizedState)
    .order('county', { ascending: true })

  if (error) {
    console.error('County fetch error:', error)
    return
  }

  const countyOptions = data
    .map(row => `<option value="${row.county}">${row.county}</option>`)
    .join('')

  countySelect.innerHTML = `
    <option value="">Select your county…</option>
    ${countyOptions}
  `

  countySelect.disabled = false
  document.getElementById('btnNext').disabled = true
}

function onCountyChange(value) {
  if (!value) {
    document.getElementById('btnNext').disabled = true
    return
  }

  answers['county'] = value
  document.getElementById('btnNext').disabled = false
  updateSteps()
}

function onEmailChange() {
  const fn = document.getElementById('input-firstName')?.value.trim();
  const ln = document.getElementById('input-lastName')?.value.trim();
  const email = document.getElementById('input-email')?.value.trim();

  const valid = fn && ln && email && email.includes('@');
  document.getElementById('btnNext').disabled = !valid;

  if (valid) {
    answers['firstName'] = fn;
    answers['lastName'] = ln;
    answers['email'] = email;
  }
}

function updateProgress() {
  const pct = ((currentQ) / QUESTIONS.length) * 100;
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressLabel').textContent = `Question ${currentQ + 1} of ${QUESTIONS.length}`;
  const remaining = QUESTIONS.length - currentQ;
  const mins = Math.ceil(remaining * 0.3);
  document.getElementById('timeLeft').textContent = mins <= 1 ? '< 1 min left' : `~${mins} min left`;
}

function showSlide(idx) {
  document.querySelectorAll('.question-slide').forEach(s => {
    s.classList.remove('active', 'exiting');
  });
  document.getElementById('resultsSlide').classList.remove('active');
  const slide = document.getElementById(`slide-${idx}`);
  if (slide) slide.classList.add('active');
  // Restore answer if exists
  const q = QUESTIONS[idx];
  if (q && answers[q.id] && q.type === 'options') {
    const btn = document.getElementById(`opt-${q.id}-${answers[q.id]}`);
    if (btn) btn.classList.add('selected');
    document.getElementById('btnNext').disabled = false;
  } else if (q && q.type === 'select' && answers[q.id]) {
    const sel = document.getElementById(`input-${q.id}`);
    if (sel) sel.value = answers[q.id];
    document.getElementById('btnNext').disabled = false;
  }
  else if (q && q.type === 'state_county') {
    const stateSel = document.getElementById('input-state')
    const countySel = document.getElementById('input-county')

    if (answers.state) {
      stateSel.value = answers.state
      onStateChange(answers.state).then(() => {
        if (answers.county) {
          countySel.value = answers.county
          document.getElementById('btnNext').disabled = false
        }
      })
    } else {
      document.getElementById('btnNext').disabled = true
    }
  }
  else {
    document.getElementById('btnNext').disabled = true;
  }
}

function nextQuestion() {
  // Prevent advancing if current question not answered
  const currentQuestion = QUESTIONS[currentQ];
  if (currentQuestion.type !== 'email' && answers[currentQuestion.id] === undefined) {
    return;
  }
  if (currentQ < QUESTIONS.length - 1) {
    // Animate out
    const cur = document.getElementById(`slide-${currentQ}`);
    if (cur) cur.classList.add('exiting');
    setTimeout(() => { if (cur) cur.classList.remove('active','exiting'); }, 300);
    currentQ++;
    showSlide(currentQ);
    updateProgress();
    updateSteps();
    document.getElementById('btnBack').disabled = false;
    if (currentQ === QUESTIONS.length - 1) {
      document.getElementById('btnNext').textContent = '';
      document.getElementById('btnNext').innerHTML = 'Get My Score <span class="btn-next-arrow">→</span>';
    }
  } else {
    showResults();
  }
}

function prevQuestion() {
  if (currentQ > 0) {
    const cur = document.getElementById(`slide-${currentQ}`);
    if (cur) { cur.classList.remove('active'); }
    currentQ--;
    showSlide(currentQ);
    updateProgress();
    updateSteps();
    document.getElementById('btnBack').disabled = currentQ === 0;
    document.getElementById('btnNext').innerHTML = 'Continue <span class="btn-next-arrow">→</span>';
  }
}

function showResults() {
  document.querySelectorAll('.question-slide').forEach(s => s.classList.remove('active','exiting'));
  document.getElementById('bottomNav').style.display = 'none';

  const score = calcScore();

  // DEBUG: Log all user answers to console
  console.log('----- QUIZ SUBMISSION DATA -----');
  console.log('Full Answers Object:', answers);

  QUESTIONS.forEach(q => {
    const value = answers[q.id];
    if (value !== undefined) {
      console.log(`${q.label} (${q.id}):`, value);
    }
  });

  if (answers.firstName) {
    console.log('First Name:', answers.firstName);
  }
  if (answers.lastName) {
    console.log('Last Name:', answers.lastName);
  }
  if (answers.email) {
    console.log('Email:', answers.email);
  }

  console.log('Final Score:', score);
  console.log('--------------------------------');

  document.getElementById('finalScoreNum').textContent = score;
  document.getElementById('scoreDisplay').textContent = score;
  document.getElementById('scoreBarFill').style.width = score + '%';

  let headline, status;
  if (score >= 80) {
    headline = 'Your estate plan is <em>well structured</em> — but 2 areas need a closer look.';
    status = 'Well Protected';
  } else if (score >= 60) {
    headline = 'Your estate plan has <em>several gaps</em> that could cost your family.';
    status = 'Some Gaps Found';
  } else if (score >= 40) {
    headline = 'Your estate plan has <em>significant exposure</em> that requires attention.';
    status = 'Significant Gaps';
  } else {
    headline = 'Your estate plan has <em>critical vulnerabilities</em> that put your family at risk.';
    status = 'Critical Exposure';
  }

  document.getElementById('resultsHeadline').innerHTML = headline;
  document.getElementById('scoreStatus').textContent = status;

  const gapDefs = [
    { id: 'will',       name: 'Will Status',               scoring: { recent: 'ok', old: 'warning', unsure: 'warning', none: 'critical' }, labels: { recent: 'Current & valid', old: 'Outdated — needs review', unsure: 'Needs verification', none: 'Critical: No will in place' } },
    { id: 'trust',      name: 'Trust Structure',           scoring: { revocable: 'ok', irrevocable: 'ok', unsure: 'warning', none: 'critical' }, labels: { revocable: 'Trust in place', irrevocable: 'Trust in place', unsure: 'Needs verification', none: 'Critical: No trust — probate risk' } },
    { id: 'beneficiary',name: 'Beneficiary Designations',  scoring: { recent: 'ok', medium: 'warning', old: 'critical', never: 'critical' }, labels: { recent: 'Recently verified', medium: 'May need review', old: 'High risk — outdated', never: 'Critical: Never reviewed' } },
    { id: 'poa',        name: 'Power of Attorney',         scoring: { recent: 'ok', old: 'warning', none: 'critical', unsure: 'warning' }, labels: { recent: 'Current & valid', old: 'Needs review', none: 'Critical: No POA in place', unsure: 'Needs verification' } },
    { id: 'healthcare', name: 'Healthcare Directive',      scoring: { both: 'ok', proxy: 'warning', living: 'warning', none: 'critical' }, labels: { both: 'Fully documented', proxy: 'Partial — missing living will', living: 'Partial — missing proxy', none: 'Critical: No directive' } },
    { id: 'ltc',        name: 'Long-Term Care / Medicaid', scoring: { insurance: 'ok', assets: 'ok', medicaid: 'warning', none: 'critical' }, labels: { insurance: 'LTC insurance in place', assets: 'Assets allocated', medicaid: 'Medicaid exposure — review lookback', none: 'Critical: No LTC planning' } },
    { id: 'insurance',  name: 'Life Insurance Structure',  scoring: { permanent: 'ok', term: 'warning', both: 'ok', none: 'critical' }, labels: { permanent: 'Permanent coverage in place', term: 'Term only — check expiry & structure', both: 'Well covered', none: 'Critical: No coverage' } }
  ];

  const icons = { critical: '⚠', warning: '◈', ok: '✓' };

  const gapsList = document.getElementById('gapsList');
  gapsList.innerHTML = '';
  gapDefs.forEach(g => {
    const ans = answers[g.id];
    if (!ans) return;
    const status = g.scoring[ans] || 'warning';
    const label = g.labels[ans] || 'Review needed';
    gapsList.innerHTML += `
      <div class="gap-result-item">
        <div class="gap-result-icon ${status}">${icons[status]}</div>
        <div class="gap-result-text">
          <div class="gap-result-name">${g.name}</div>
          <div class="gap-result-desc">${label}</div>
        </div>
        <div class="gap-result-badge ${status}">${status === 'critical' ? 'Critical' : status === 'warning' ? 'Review' : 'OK'}</div>
      </div>`;
  });

  setTimeout(() => {
    document.getElementById('resultsSlide').classList.add('active');
    updateSteps();
  }, 100);
}

function openRegisterModal() {
  document.getElementById('modal-firstName').value = answers.firstName || '';
  document.getElementById('modal-lastName').value = answers.lastName || '';
  document.getElementById('modal-email').value = answers.email || '';
  document.getElementById('modal-phone').value = answers.phone || '';
  document.getElementById('registerModal').classList.add('active');
}

function closeRegisterModal() {
  document.getElementById('registerModal').classList.remove('active');
}

async function registerFromQuiz() {
  const password = document.getElementById('modal-password').value.trim();
  const phoneInput = document.getElementById('modal-phone').value.trim();
  const countryCode = document.getElementById('modal-country').value;
  const phone = phoneInput ? (countryCode === '+1-ca' ? '+1' : countryCode) + phoneInput : '';

  if (!password || password.length < 6) {
    alert('Password must be at least 6 characters.');
    return;
  }

  const submitBtn = document.querySelector('.modal-submit-btn');
  submitBtn.classList.add('loading');
  submitBtn.textContent = 'Creating Account...';

  // 1. Create auth user
  const { data: signUpData, error: signUpError } = await supabase.auth.signUp({
    email: answers.email,
    password: password
  });

  // Save phone in answers for later use
  answers.phone = phone;

  if (signUpError) {
    // If user already exists, attempt login instead of stopping
    if (signUpError.message.toLowerCase().includes('already')) {
      console.log('User already exists, attempting login...');
    } else {
      submitBtn.classList.remove('loading');
      submitBtn.textContent = 'Create My Account →';
      alert('Signup error: ' + signUpError.message);
      console.error(signUpError);
      return;
    }
  }

  const user = signUpData?.user;

  if (user) {
    console.log('Auth user created:', user.id);

    // Insert profile only if new user was created
    const { error: profileError } = await supabase
      .from('profiles')
      .insert({
        id: user.id,
        full_name: `${answers.firstName || ''} ${answers.lastName || ''}`.trim(),
        email: user.email,
        role: 'user',
        state: answers.state || null,
        county: answers.county || null,
        phone: phone || null
      });

    if (profileError) {
      console.error('Profile insert failed:', profileError);
    }

    // Insert quiz submission for new user
    const completeAnswers = { ...answers };
    QUESTIONS.forEach(q => {
      if (!(q.id in completeAnswers)) completeAnswers[q.id] = null;
    });

    await supabase
      .from('quiz_submissions')
      .insert({
        user_id: user.id,
        score: calcScore(),
        answers: completeAnswers
      });
  }

  // Send submission to CRM webhook (after phone is captured)
  await fetch('https://services.leadconnectorhq.com/hooks/t6CIiDKX4tJt5AYWbWxc/webhook-trigger/6bfde984-ec5d-43b9-9e4e-e632ecd41894', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      submittedAt: new Date().toISOString(),
      score: calcScore(),
      firstName: answers.firstName || '',
      lastName: answers.lastName || '',
      email: answers.email || '',
      phone: answers.phone || '',
      state: answers.state || '',
      county: answers.county || '',
      age: answers.age || '',
      marital: answers.marital || '',
      dependents: answers.dependents || '',
      will: answers.will || '',
      trust: answers.trust || '',
      beneficiary: answers.beneficiary || '',
      poa: answers.poa || '',
      healthcare: answers.healthcare || '',
      ltc: answers.ltc || '',
      insurance: answers.insurance || '',
      networth: answers.networth || '',
      fullAnswers: answers
    })
  });

  // 4. Sign user in explicitly (guarantee session)
  const { error: signInError } = await supabase.auth.signInWithPassword({
    email: answers.email,
    password: password
  });

  if (signInError) {
    submitBtn.classList.remove('loading');
    submitBtn.textContent = 'Create My Account →';
    alert('Login after signup failed: ' + signInError.message);
    console.error(signInError);
    return;
  }

  console.log('User logged in — redirecting to portal');

  window.location.href = '/portal';
}

function startQuiz() {
  document.getElementById('introScreen').classList.add('hidden');
  document.getElementById('topBar').style.display = 'flex';
  document.getElementById('questionArea').style.display = 'block';
  document.getElementById('bottomNav').style.display = 'flex';
  buildSlides();
  showSlide(0);
  updateProgress();
  updateSteps();
  quizStarted = true;
}

// Add goBack function for use in onclick handlers
function goBack() {
  if (window.history.length > 1) {
    window.history.back();
  } else {
    window.location.href = '/';
  }
}

// Expose functions globally for onclick handlers
window.startQuiz = startQuiz;
window.nextQuestion = nextQuestion;
window.prevQuestion = prevQuestion;
window.openRegisterModal = openRegisterModal;
window.closeRegisterModal = closeRegisterModal;
window.registerFromQuiz = registerFromQuiz;
window.selectOption = selectOption;
window.onSelectChange = onSelectChange;
window.onStateChange = onStateChange;
window.onCountyChange = onCountyChange;
window.onEmailChange = onEmailChange;
window.goBack = goBack;

// Initialize steps
buildSteps();
</script>