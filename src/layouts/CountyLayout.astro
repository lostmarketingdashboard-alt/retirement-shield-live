---
const {
  countyName,
  stateName,
  countyAverage,
  nationalAverage,
  difference,
  lifeAt65,
  stateCounties = [],
  prob90,
  s90National
} = Astro.props

const diffNumber = Number(difference)
const diffClass = diffNumber >= 0 ? "positive" : "negative"

const otherCounties = stateCounties
  .filter(c => c.name !== countyName)
  .sort(() => 0.5 - Math.random())
  .slice(0, 4)
---



<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<meta name="description" content="{countyName} residents live an average of {countyAverage} years — {Math.abs(diffNumber).toFixed(2)} years {diffNumber >= 0 ? 'above' : 'below'} the national average. See how this affects your Social Security strategy, retirement savings, and estate plan.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #1A2E4A;
    --navy-dk: #0F1E33;
    --navy-lt: #243B55;
    --gold: #C9A84C;
    --gold-lt: #E8C97A;
    --teal: #2E9CCA;
    --teal-lt: #4FB8E0;
    --red: #C0392B;
    --green: #27AE60;
    --amber: #E67E22;
    --white: #FFFFFF;
    --off-white: #F4F6F9;
    --slate: #8A9BB5;
    --slate-lt: #D0D9E8;
    --text: #1A2E4A;
    --text-muted: #6B7A90;
    --border: #E2E8F0;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    color: var(--text);
    background: var(--white);
    line-height: 1.6;
    font-size: 16px;
  }

  /* ── NAV ── */
  nav {
    background: var(--navy-dk);
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 2px solid var(--gold);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    color: var(--white);
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  .nav-logo span { color: var(--gold); }
  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }
  .nav-links a {
    color: var(--slate-lt);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta {
    background: var(--gold);
    color: var(--navy-dk) !important;
    padding: 8px 20px;
    border-radius: 4px;
    font-weight: 600 !important;
    font-size: 13px !important;
  }

  /* ── BREADCRUMB ── */
  .breadcrumb {
    background: var(--off-white);
    padding: 12px 40px;
    border-bottom: 1px solid var(--border);
  }
  .breadcrumb ol {
    display: flex;
    gap: 8px;
    list-style: none;
    font-size: 13px;
    color: var(--text-muted);
    align-items: center;
  }
  .breadcrumb a { color: var(--teal); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb .sep { color: var(--slate); }

  /* ── HERO ── */
  .hero {
    background: var(--navy-dk);
    padding: 56px 40px 48px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(46,156,202,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
    align-items: start;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(201,168,76,0.15);
    border: 1px solid rgba(201,168,76,0.3);
    color: var(--gold);
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-bottom: 16px;
  }
  .hero-badge .dot {
    width: 6px; height: 6px;
    background: var(--gold);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; } 50% { opacity: 0.4; }
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 44px);
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 16px;
    font-weight: 700;
  }
  .hero h1 .highlight { color: var(--gold); }
  .hero-sub {
    color: var(--slate-lt);
    font-size: 16px;
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 28px;
  }
  .hero-meta {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .hero-meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--slate);
  }
  .hero-meta-item svg { width: 14px; height: 14px; opacity: 0.7; }

  /* Hero stat cards */
  .hero-stats {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 220px;
  }
  .hero-stat {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 16px 20px;
    text-align: center;
  }
  .hero-stat .label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--slate);
    font-weight: 600;
    margin-bottom: 6px;
  }
  .hero-stat .value {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    color: var(--white);
    font-weight: 700;
    line-height: 1;
  }
  .hero-stat .value.positive { color: var(--teal-lt); }
  .hero-stat .value.negative { color: #E57373; }
  .hero-stat .sub {
    font-size: 11px;
    color: var(--slate);
    margin-top: 4px;
  }
  .hero-stat.featured {
    background: rgba(201,168,76,0.1);
    border-color: rgba(201,168,76,0.3);
  }
  .hero-stat.featured .value { color: var(--gold); }

  /* ── LAYOUT ── */
  .page-body {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 40px;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 48px;
    align-items: start;
  }
  .main-content { min-width: 0; }
  .sidebar { position: sticky; top: 80px; }

  /* ── SECTION ── */
  .section {
    margin-bottom: 48px;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--border);
  }
  .section-icon {
    width: 36px; height: 36px;
    background: var(--navy);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .section-icon svg { width: 18px; height: 18px; color: var(--gold); }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    color: var(--navy);
    font-weight: 600;
  }

  /* ── STAT GRID ── */
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  .stat-card {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    position: relative;
    overflow: hidden;
  }
  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--slate-lt);
  }
  .stat-card.good::before { background: var(--green); }
  .stat-card.warn::before { background: var(--amber); }
  .stat-card.bad::before { background: var(--red); }
  .stat-card .card-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .stat-card .card-value {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    color: var(--navy);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-card .card-delta {
    font-size: 12px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }
  .stat-card .card-delta.up { color: var(--green); }
  .stat-card .card-delta.down { color: var(--red); }
  .stat-card .card-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

  /* ── SURVIVAL CHART ── */
  .chart-container {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    margin-bottom: 24px;
  }
  .chart-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 4px;
  }
  .chart-sub {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 20px;
  }
  .survival-bars {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .survival-row {
    display: grid;
    grid-template-columns: 90px 1fr 70px;
    align-items: center;
    gap: 12px;
  }
  .survival-label {
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 500;
  }
  .bar-track {
    background: var(--border);
    height: 28px;
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }
  .bar-fill {
    height: 100%;
    border-radius: 4px;
    display: flex;
    align-items: center;
    padding: 0 10px;
    font-size: 11px;
    font-weight: 700;
    color: white;
    transition: width 1s ease;
    position: relative;
  }
  .bar-fill.miami { background: linear-gradient(90deg, var(--teal) 0%, var(--teal-lt) 100%); }
  .bar-fill.national { background: linear-gradient(90deg, var(--navy) 0%, var(--navy-lt) 100%); }
  .bar-fill.florida { background: linear-gradient(90deg, #6B7A90 0%, #8A9BB5 100%); }
  .survival-pct {
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    color: var(--navy);
    text-align: right;
  }
  .chart-legend {
    display: flex;
    gap: 20px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-muted);
  }
  .legend-dot {
    width: 10px; height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* ── FINANCIAL GAP ── */
  .gap-box {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-lt) 100%);
    border-radius: 12px;
    padding: 28px;
    color: white;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }
  .gap-box::after {
    content: '$';
    position: absolute;
    right: -20px; top: -20px;
    font-size: 160px;
    font-family: 'Playfair Display', serif;
    color: rgba(255,255,255,0.04);
    line-height: 1;
  }
  .gap-box-title {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .gap-box h3 {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    color: white;
    margin-bottom: 16px;
    line-height: 1.3;
  }
  .gap-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 20px;
  }
  .gap-item .gi-label {
    font-size: 11px;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }
  .gap-item .gi-value {
    font-family: 'DM Mono', monospace;
    font-size: 22px;
    color: white;
    font-weight: 500;
  }
  .gap-item .gi-value.gold { color: var(--gold); }
  .gap-note {
    font-size: 12px;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 14px;
  }

  /* ── SS STRATEGY ── */
  .ss-box {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    margin-bottom: 24px;
  }
  .ss-verdict {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 20px;
  }
  .verdict-badge {
    background: var(--green);
    color: white;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
    margin-top: 2px;
  }
  .verdict-badge.warn { background: var(--amber); }
  .verdict-text { font-size: 15px; color: var(--text); line-height: 1.6; }
  .ss-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .ss-table th {
    background: var(--navy);
    color: white;
    padding: 10px 14px;
    text-align: left;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }
  .ss-table td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }
  .ss-table tr:last-child td { border-bottom: none; }
  .ss-table tr:nth-child(even) td { background: rgba(0,0,0,0.02); }
  .ss-table .recommended {
    background: rgba(39,174,96,0.06) !important;
    font-weight: 600;
  }
  .rec-tag {
    background: var(--green);
    color: white;
    font-size: 10px;
    padding: 2px 7px;
    border-radius: 10px;
    font-weight: 700;
    margin-left: 6px;
    vertical-align: middle;
  }

  /* ── HEALTH RISKS ── */
  .risk-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }
  .risk-item {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 18px;
    gap: 16px;
  }
  .risk-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 3px;
  }
  .risk-desc { font-size: 12px; color: var(--text-muted); }
  .risk-rate {
    text-align: right;
    flex-shrink: 0;
  }
  .risk-rate .rate-num {
    font-family: 'DM Mono', monospace;
    font-size: 18px;
    font-weight: 500;
    color: var(--navy);
  }
  .risk-rate .rate-label { font-size: 10px; color: var(--text-muted); }
  .risk-bar-wrap {
    grid-column: 1 / -1;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .risk-bar { height: 100%; border-radius: 2px; }

  /* ── COMPARISON ── */
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 60px 1fr;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 24px;
  }
  .compare-county {
    padding: 24px;
    background: var(--off-white);
  }
  .compare-county.featured {
    background: var(--navy);
  }
  .compare-county.featured .cc-name { color: var(--gold); }
  .compare-county.featured .cc-stat { color: var(--white); }
  .compare-county.featured .cc-label { color: rgba(255,255,255,0.5); }
  .cc-name {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--teal);
    margin-bottom: 12px;
  }
  .cc-stat {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
    color: var(--navy);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
  }
  .cc-label {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 16px;
  }
  .cc-rows { display: flex; flex-direction: column; gap: 8px; }
  .cc-row {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
  }
  .cc-row .cr-label { color: var(--text-muted); }
  .cc-row .cr-val { font-weight: 600; color: inherit; }
  .compare-vs {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--navy-dk);
    font-weight: 700;
    color: var(--gold);
    font-size: 14px;
    writing-mode: vertical-rl;
    letter-spacing: 2px;
  }

  /* ── BODY TEXT ── */
  .body-text {
    font-size: 15px;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 16px;
  }
  .body-text strong { color: var(--navy); }

  /* ── METHODOLOGY BOX ── */
  .methodology {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-left: 3px solid var(--teal);
    border-radius: 0 8px 8px 0;
    padding: 16px 20px;
    margin-bottom: 24px;
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .methodology strong {
    display: block;
    color: var(--navy);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
  }

  /* ── FAQ ── */
  .faq-list { display: flex; flex-direction: column; gap: 0; }
  .faq-item {
    border-bottom: 1px solid var(--border);
  }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-q {
    padding: 16px 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--navy);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    list-style: none;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-arrow {
    width: 20px; height: 20px;
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--teal);
    font-size: 14px;
    transition: transform 0.2s;
  }
  details[open] .faq-arrow { transform: rotate(180deg); }
  .faq-a {
    padding: 0 0 16px;
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ── SIDEBAR ── */
  .sidebar-card {
    background: var(--navy);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 20px;
    color: white;
  }
  .sidebar-card.light {
    background: var(--off-white);
    border: 1px solid var(--border);
    color: var(--text);
  }
  .sidebar-card .sc-eyebrow {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .sidebar-card.light .sc-eyebrow { color: var(--teal); }
  .sidebar-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .sidebar-card p {
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
    margin-bottom: 16px;
  }
  .sidebar-card.light p { color: var(--text-muted); }
  .btn-primary {
    display: block;
    width: 100%;
    background: var(--gold);
    color: var(--navy-dk);
    padding: 12px 20px;
    border-radius: 6px;
    font-weight: 700;
    font-size: 14px;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: var(--gold-lt); transform: translateY(-1px); }
  .btn-secondary {
    display: block;
    width: 100%;
    background: transparent;
    color: var(--teal);
    padding: 10px 20px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 14px;
    text-align: center;
    text-decoration: none;
    border: 1px solid var(--teal);
    transition: all 0.2s;
    margin-top: 10px;
  }
  .btn-secondary:hover { background: var(--teal); color: white; }
  .sidebar-nearby {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .nearby-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
    text-decoration: none;
    color: var(--text);
    transition: color 0.2s;
  }
  .nearby-item:last-child { border-bottom: none; }
  .nearby-item:hover { color: var(--teal); }
  .nearby-name { font-weight: 500; }
  .nearby-stat {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
  }
  .nearby-delta {
    font-size: 11px;
    font-weight: 600;
    margin-left: 6px;
  }
  .nearby-delta.up { color: var(--green); }
  .nearby-delta.down { color: var(--red); }

  /* ── EMAIL CAPTURE ── */
  .email-banner {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-lt) 100%);
    border-radius: 12px;
    padding: 36px 40px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 48px;
  }
  .email-banner .eb-eyebrow {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .email-banner h2 {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    color: white;
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .email-banner p {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
  }
  .email-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 100%;
  }
  .email-form input {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    padding: 12px 16px;
    color: white;
    font-size: 14px;
    font-family: 'DM Sans', sans-serif;
    outline: none;
    transition: border 0.2s;
  }
  .email-form input::placeholder { color: rgba(255,255,255,0.4); }
  .email-form input:focus { border-color: var(--gold); }
  .email-disclaimer {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
    line-height: 1.5;
  }

  /* ── FOOTER ── */
  footer {
    background: var(--navy-dk);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 32px 40px;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }
  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    color: var(--white);
    font-weight: 700;
  }
  .footer-logo span { color: var(--gold); }
  .footer-disclaimer {
    font-size: 11px;
    color: var(--slate);
    max-width: 600px;
    line-height: 1.6;
    text-align: center;
  }
  .footer-links {
    display: flex;
    gap: 20px;
  }
  .footer-links a {
    font-size: 12px;
    color: var(--slate);
    text-decoration: none;
  }
  .footer-links a:hover { color: var(--gold); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .page-body { grid-template-columns: 1fr; padding: 32px 20px; }
    .sidebar { position: static; }
    .hero-inner { grid-template-columns: 1fr; }
    .hero-stats { flex-direction: row; flex-wrap: wrap; }
    .stat-grid { grid-template-columns: 1fr 1fr; }
    .gap-grid { grid-template-columns: 1fr; }
    .email-banner { grid-template-columns: 1fr; }
    .email-form { min-width: unset; }
    .compare-grid { grid-template-columns: 1fr; }
    .compare-vs { writing-mode: horizontal-tb; padding: 8px; }
    nav { padding: 0 20px; }
    .nav-links { display: none; }
    .breadcrumb { padding: 12px 20px; }
    .hero { padding: 36px 20px; }
    footer { padding: 24px 20px; }
    .footer-inner { flex-direction: column; text-align: center; }
  }

  /* ── ANIMATIONS ── */
  .fade-in {
    opacity: 0;
    transform: translateY(16px);
    animation: fadeUp 0.5s ease forwards;
  }
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  .fade-in:nth-child(1) { animation-delay: 0.1s; }
  .fade-in:nth-child(2) { animation-delay: 0.2s; }
  .fade-in:nth-child(3) { animation-delay: 0.3s; }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">Retirement<span>Shield</span></div>
  <ul class="nav-links">
    <li><a href="/lifeexpectancycalculator">Life Expectancy</a></li>
    <li><a href="/quiz">Estate Planning</a></li>
<!-- <li><a href="#">Calculators</a></li> -->
    <li><a href="#" onclick="openNewsletterModal(event)">Newsletter</a></li>
    <li><a href="/quiz" class="nav-cta">Free Assessment</a></li>
  </ul>
</nav>

<!-- BREADCRUMB -->
<div class="breadcrumb">
  <ol>
    <li><a href="#">Home</a></li>
    <li class="sep">›</li>
    <li><a href="/list">Life Expectancy</a></li>
    <li class="sep">›</li>
    <li><a href="/list">{stateName}</a></li>
    <li class="sep">›</li>
    <li>{countyName}</li>
  </ol>
</div>

<!-- HERO -->
<div class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-badge"><span class="dot"></span> 2024 CDC Data</div>
      <h1>Life Expectancy in <span class="highlight">{countyName}</span>, {stateName}</h1>
      <p class="hero-sub">{countyName} residents live an average of <strong style="color:var(--gold)">{countyAverage} years</strong> — {Math.abs(diffNumber).toFixed(2)} years {diffNumber >= 0 ? 'above' : 'below'} the national average. Here's what that means for your Social Security strategy, retirement nest egg, and estate plan.</p>
      <div class="hero-meta">
        <div class="hero-meta-item">
          <svg fill="currentColor" viewBox="0 0 20 20"><path d="M6 2a1 1 0 000 2h2v2H6a3 3 0 00-3 3v7a3 3 0 003 3h8a3 3 0 003-3V9a3 3 0 00-3-3h-2V4h2a1 1 0 100-2H6zm4 4V4H8v2h2z"/></svg>
          Updated February 2026
        </div>
        <div class="hero-meta-item">
          <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          {countyName}, {stateName}
        </div>
        <div class="hero-meta-item">
          <svg fill="currentColor" viewBox="0 0 20 20"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/></svg>
          Pop. 2.7 million
        </div>
      </div>
    </div>
    <div class="hero-stats">
      <div class="hero-stat featured">
        <div class="label">Life Expectancy</div>
        <div class="value">{countyAverage}</div>
        <div class="sub">years at birth</div>
      </div>
      <div class="hero-stat">
        <div class="label">vs. National Avg</div>
        <div class={`value ${diffClass}`}>{diffNumber >= 0 ? '+' : ''}{diffNumber.toFixed(2)} yrs</div>
        <div class="sub">above U.S. average</div>
      </div>
      <div class="hero-stat">
        <div class="label">At Age 65</div>
        <div class="value">{lifeAt65}</div>
        <div class="sub">years remaining</div>
      </div>
    </div>
  </div>
</div>

<!-- MAIN PAGE BODY -->
<div class="page-body">
<div class="main-content">

  <!-- SECTION 1: KEY STATS -->
  <div class="section fade-in">
    <div class="section-header">
      <div class="section-icon">
        <svg fill="currentColor" viewBox="0 0 20 20"><path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zm6-4a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zm6-3a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/></svg>
      </div>
      <div class="section-title">Longevity at a Glance</div>
    </div>

    <div class="stat-grid">
      <div class="stat-card good">
        <div class="card-label">Life Expectancy at Birth</div>
        <div class="card-value">{countyAverage}</div>
        <div class={`card-delta ${diffNumber >= 0 ? 'up' : 'down'}`}>
          {diffNumber >= 0 ? '↑' : '↓'} {Math.abs(diffNumber).toFixed(2)} yrs vs. national
        </div>
        <div class="card-sub">Source: CDC USALEEP / NCHS 2024</div>
      </div>
      <div class="stat-card good">
        <div class="card-label">Remaining Years at 65</div>
        <div class="card-value">{lifeAt65}</div>
        <div class="card-delta up">↑ 0.6 yrs vs. {stateName} avg</div>
        <div class="card-sub">Plan for retirement through ~age 85</div>
      </div>
      <div class="stat-card warn">
        <div class="card-label">Prob. Reaching Age 90</div>
        <div class="card-value">
          {typeof prob90 === 'number'
            ? `${prob90}%`
            : '—'}
        </div>

        {typeof prob90 === 'number' && (
          <div class="card-delta up">
            ↑ {Math.abs((prob90 - (s90National ?? 0))).toFixed(1)} pts vs. national
          </div>
        )}

        <div class="card-sub">
          {typeof prob90 === 'number'
            ? `1 in ${(100 / prob90).toFixed(1)} current 65-year-olds`
            : 'Probability data unavailable'}
        </div>
      </div>
    </div>

    <p class="body-text">{countyName} residents outlive the national average by roughly four months, a gap driven primarily by the county's large foreign-born population — a phenomenon known as the <strong>"immigrant paradox,"</strong> where immigrant communities maintain lower rates of smoking, obesity, and chronic disease relative to their socioeconomic peers. The county's warm climate and active outdoor culture contribute additional longevity benefits for the 55–75 cohort.</p>

    <p class="body-text">However, the county average masks significant internal variation. Census tracts in Coconut Grove and Coral Gables show life expectancy above <strong>84 years</strong>, while some tracts in Liberty City and Opa-locka fall below <strong>72 years</strong> — a 12-year gap within a single county driven primarily by income and healthcare access disparities.</p>
  </div>

  <!-- SECTION 2: SURVIVAL CURVE -->
  <div class="section fade-in">
    <div class="section-header">
      <div class="section-icon">
        <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 3a1 1 0 000 2v8a2 2 0 002 2h2.586l-1.293 1.293a1 1 0 101.414 1.414L10 15.414l2.293 2.293a1 1 0 001.414-1.414L12.414 15H15a2 2 0 002-2V5a1 1 0 100-2H3zm11 4a1 1 0 10-2 0v4a1 1 0 102 0V7zm-3 1a1 1 0 10-2 0v3a1 1 0 102 0V8zM8 9a1 1 0 00-2 0v2a1 1 0 102 0V9z" clip-rule="evenodd"/></svg>
      </div>
      <div class="section-title">Survival Probability — Age 65 Baseline</div>
    </div>

    <div class="chart-container">
      <div class="chart-title">Probability of a 65-Year-Old Surviving to Each Age</div>
      <div class="chart-sub">Compared to {stateName} state average and U.S. national average. Source: SSA Cohort Life Tables + USALEEP geographic scalar.</div>

      <div class="survival-bars">
        <div class="survival-row">
          <div class="survival-label" style="font-weight:700; color:var(--navy);">Survive to 75</div>
          <div></div>
          <div></div>
        </div>

        <div class="survival-row">
          <div class="survival-label">{countyName}</div>
          <div class="bar-track">
            <div class="bar-fill miami" style={`width:${Astro.props.s75County ?? 0}%`}>
              {Astro.props.s75County ?? 0}%
            </div>
          </div>
          <div class="survival-pct">{Astro.props.s75County ?? 0}%</div>
        </div>

        <div class="survival-row">
          <div class="survival-label">{stateName}</div>
          <div class="bar-track">
            <div class="bar-fill florida" style={`width:${Astro.props.s75State ?? 0}%`}>
              {Astro.props.s75State ?? 0}%
            </div>
          </div>
          <div class="survival-pct">{Astro.props.s75State ?? 0}%</div>
        </div>

        <div class="survival-row">
          <div class="survival-label">U.S. Average</div>
          <div class="bar-track">
            <div class="bar-fill national" style={`width:${Astro.props.s75National ?? 0}%`}>
              {Astro.props.s75National ?? 0}%
            </div>
          </div>
          <div class="survival-pct">{Astro.props.s75National ?? 0}%</div>
        </div>

        <div class="survival-row" style="margin-top:8px;">
          <div class="survival-label" style="font-weight:700; color:var(--navy);">Survive to 85</div>
          <div></div>
          <div></div>
        </div>

        <div class="survival-row">
          <div class="survival-label">{countyName}</div>
          <div class="bar-track">
            <div class="bar-fill miami" style={`width:${Astro.props.s85County ?? 0}%`}>
              {Astro.props.s85County ?? 0}%
            </div>
          </div>
          <div class="survival-pct">{Astro.props.s85County ?? 0}%</div>
        </div>

        <div class="survival-row">
          <div class="survival-label">{stateName}</div>
          <div class="bar-track">
            <div class="bar-fill florida" style={`width:${Astro.props.s85State ?? 0}%`}>
              {Astro.props.s85State ?? 0}%
            </div>
          </div>
          <div class="survival-pct">{Astro.props.s85State ?? 0}%</div>
        </div>

        <div class="survival-row">
          <div class="survival-label">U.S. Average</div>
          <div class="bar-track">
            <div class="bar-fill national" style={`width:${Astro.props.s85National ?? 0}%`}>
              {Astro.props.s85National ?? 0}%
            </div>
          </div>
          <div class="survival-pct">{Astro.props.s85National ?? 0}%</div>
        </div>

        <div class="survival-row" style="margin-top:8px;">
          <div class="survival-label" style="font-weight:700; color:var(--navy);">Survive to 95</div>
          <div></div>
          <div></div>
        </div>

        <div class="survival-row">
          <div class="survival-label">{countyName}</div>
          <div class="bar-track">
            <div class="bar-fill miami" style={`width:${Astro.props.s95County ?? 0}%`}>
              {Astro.props.s95County ?? 0}%
            </div>
          </div>
          <div class="survival-pct">{Astro.props.s95County ?? 0}%</div>
        </div>

        <div class="survival-row">
          <div class="survival-label">{stateName}</div>
          <div class="bar-track">
            <div class="bar-fill florida" style={`width:${Astro.props.s95State ?? 0}%`}>
              {Astro.props.s95State ?? 0}%
            </div>
          </div>
          <div class="survival-pct">{Astro.props.s95State ?? 0}%</div>
        </div>

        <div class="survival-row">
          <div class="survival-label">U.S. Average</div>
          <div class="bar-track">
            <div class="bar-fill national" style={`width:${Astro.props.s95National ?? 0}%`}>
              {Astro.props.s95National ?? 0}%
            </div>
          </div>
          <div class="survival-pct">{Astro.props.s95National ?? 0}%</div>
        </div>
      </div>

      <div class="chart-legend">
        <div class="legend-item"><div class="legend-dot" style="background:var(--teal)"></div> {countyName}</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--slate)"></div> {stateName} Average</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--navy)"></div> U.S. National Average</div>
      </div>
    </div>

    <p class="body-text">The key planning insight from this data: <strong>56% of 65-year-olds in {countyName} will reach age 85</strong> — meaning more than half of current retirees in this county will need to fund a retirement lasting 20+ years. Planning only to the national median creates a statistical coin-flip of running out of money.</p>
  </div>

  <!-- SECTION 3: FINANCIAL GAP -->
  <div class="section fade-in">
    <div class="section-header">
      <div class="section-icon">
        <svg fill="currentColor" viewBox="0 0 20 20"><path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/></svg>
      </div>
      <div class="section-title">The Financial Gap — What Living Longer Costs</div>
    </div>

    <div class="gap-box">
      <div class="gap-box-title">The Longevity Premium</div>
      <h3>In {countyName}, planning only to age 85 leaves a 16% chance you'll outlive your money</h3>
      <div class="gap-grid">
        <div class="gap-item">
          <div class="gi-label">Plan to Age 85 (20yr)</div>
          <div class="gi-value">$1,500,000</div>
        </div>
        <div class="gap-item">
          <div class="gi-label">Plan to Age 95 (30yr)</div>
          <div class="gi-value gold">$2,180,000</div>
        </div>
        <div class="gap-item">
          <div class="gi-label">Additional Capital Needed</div>
          <div class="gi-value gold">+$680,000</div>
        </div>
        <div class="gap-item">
          <div class="gi-label">Inflation Impact (3%/yr)</div>
          <div class="gi-value">$60K → $131K</div>
        </div>
      </div>
      <div class="gap-note">Assumes $72,000/year spending ({countyName} cost-adjusted), 4% withdrawal rate, 3% annual inflation. The last 10 years of a 30-year retirement cost 78% more than the first 10 years in real dollars due to inflation compounding.</div>
    </div>

    <p class="body-text">
    
The primary retirement planning risk in {countyName} is not just lifespan — it is inflation. A retiree spending $60,000 per year in 2026 will require approximately $131,000 per year by 2056 assuming 3% annual inflation. This compounding effect makes underestimating retirement length significantly more dangerous than most residents expect.    
    </p>
  </div>

  <!-- SECTION 4: SS STRATEGY -->
  <div class="section fade-in">
    <div class="section-header">
      <div class="section-icon">
        <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a8 8 0 100 16A8 8 0 0010 2zm1 12a1 1 0 11-2 0 1 1 0 012 0zm0-9a1 1 0 00-2 0v5a1 1 0 102 0V5z" clip-rule="evenodd"/></svg>
      </div>
      <div class="section-title">Social Security Strategy for {countyName} Residents</div>
    </div>

    <div class="ss-box">
      <div class="ss-verdict">
        <div class="verdict-badge">Delay to 70</div>
        <div class="verdict-text">Given that <strong>62% of 65-year-old {countyName} residents will live past age 82</strong> — the national Social Security breakeven age — delaying benefits to age 70 is the statistically optimal strategy for most residents in this county.</div>
      </div>
      <table class="ss-table">
        <thead>
          <tr>
            <th>Claim Age</th>
            <th>Monthly Benefit</th>
            <th>Annual Benefit</th>
            <th>Breakeven Age</th>
            <th>Recommendation</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Age 62 (Early)</td>
            <td>$1,700</td>
            <td>$20,400</td>
            <td>—</td>
            <td style="color:var(--red); font-weight:600;">Not Advised</td>
          </tr>
          <tr>
            <td>Age 67 (FRA)</td>
            <td>$2,400</td>
            <td>$28,800</td>
            <td>Age 80</td>
            <td style="color:var(--amber); font-weight:600;">Consider if Health Risk</td>
          </tr>
          <tr class="recommended">
            <td>Age 70 (Max) <span class="rec-tag">REC</span></td>
            <td>$3,072</td>
            <td>$36,864</td>
            <td>Age 82</td>
            <td style="color:var(--green); font-weight:600;">Optimal for {countyName}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <p class="body-text">Every year of delay past Full Retirement Age (67) adds <strong>8% permanently</strong> to your monthly benefit. For a {countyName} retiree with a 62% probability of living past the breakeven age of 82, this translates to a lifetime gain of approximately <strong>$87,000</strong> in cumulative additional benefits by delaying from 67 to 70.</p>
  </div>

  <!-- SECTION 5: HEALTH RISKS -->
  <div class="section fade-in">
    <div class="section-header">
      <div class="section-icon">
        <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
      </div>
      <div class="section-title">Leading Health Risks — Ages 55 to 75</div>
    </div>

    <div class="risk-list">
      <div class="risk-item">
        <div>
          <div class="risk-name">Heart Disease</div>
          <div class="risk-desc">Leading cause of death in the county — heart disease accounts for 24.1% of all deaths in the 55–75 cohort. Miami-Dade's rate is slightly below the {stateName} state average.</div>
        </div>
        <div class="risk-rate">
          <div class="rate-num">218.4</div>
          <div class="rate-label">per 100,000</div>
        </div>
        <div class="risk-bar-wrap">
          <div class="risk-bar" style="width:78%; background:var(--red);"></div>
        </div>
      </div>
      <div class="risk-item">
        <div>
          <div class="risk-name">Cancer (All Types)</div>
          <div class="risk-desc">Second-leading cause, with lung and colorectal cancers most prevalent in this age group. Miami-Dade's rate is 6% below the national benchmark.</div>
        </div>
        <div class="risk-rate">
          <div class="rate-num">168.2</div>
          <div class="rate-label">per 100,000</div>
        </div>
        <div class="risk-bar-wrap">
