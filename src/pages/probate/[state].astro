---
import { supabase } from '../../lib/supabase'

export async function getStaticPaths() {
  const { data } = await supabase
    .from('state_guides')
    .select('state_slug')

  return data.map(row => ({
    params: { state: row.state_slug }
  }))
}

const { state } = Astro.params

const { data: guide } = await supabase
  .from('state_guides')
  .select('*')
  .eq('state_slug', state)
  .single()

if (!guide) {
  throw new Error(`State guide not found: ${state}`)
}

const stateName = guide.state_name

const clean = (str) => {
  if (typeof str !== 'string') return str;

  try {
    // Attempt to properly re-decode broken UTF-8 (mojibake fix)
    str = decodeURIComponent(escape(str));
  } catch (e) {
    // If it fails, continue with original string
  }

  return str
    .replace(/â€”/g, '—')
    .replace(/â€“/g, '–')
    .replace(/â€™/g, '’')
    .replace(/â€œ/g, '“')
    .replace(/â€/g, '”')
    .replace(/Â§/g, '§')
    .replace(/Â/g, '');
};
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<style>
:root {
  --navy:         #0d1b2a;
  --navy-mid:     #1a2e45;
  --navy-light:   #243b55;
  --cream:        #f5f0e8;
  --cream-dark:   #ede6d6;
  --amber:        #c8821a;
  --amber-light:  #e8a840;
  --text-primary:   #1a1208;
  --text-secondary: #4a3f32;
  --text-muted:     #7a6e62;
  --white:        #ffffff;
  --rule:         #c8b89a;
  --rule-light:   rgba(200,184,154,0.35);
  --tap-min:      48px;
  --article-max:  720px;
  --sidebar-w:    300px;
  --gutter:       48px;

  /* Programmatic-specific additions */
  --green-tip:    #2d6a4a;
  --red-warn:     #8b2e20;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html {
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
  margin: 0;
  padding: 0;
}
body {
  margin: 0;
  padding: 0;
  background: var(--cream);
  color: var(--text-primary);
  font-family: 'Source Serif 4', Georgia, serif;
  font-size: 18px;
  line-height: 1.75;
  overflow-x: hidden;
}
img, svg { max-width: 100%; display: block; }
a { color: var(--amber); text-decoration: underline; text-underline-offset: 3px; }
a:hover { color: var(--amber-light); }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ══════════════════════════════════════════════════
   MASTHEAD
══════════════════════════════════════════════════ */
.masthead {
  background: var(--navy); padding: 0 var(--gutter);
  display: flex; align-items: stretch; justify-content: space-between;
  border-bottom: 3px solid var(--amber);
  position: sticky; top: 0; z-index: 200;
}
.masthead-brand { display: flex; align-items: center; gap: 14px; padding: 16px 0; text-decoration: none; }
.shield-mark { width: 32px; height: 38px; flex-shrink: 0; }
.brand-name { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1.22rem; color: var(--cream); letter-spacing: 0.02em; line-height: 1.1; }
.brand-tagline { font-family: 'DM Mono', monospace; font-size: 0.52rem; color: var(--amber-light); text-transform: uppercase; letter-spacing: 0.14em; margin-top: 2px; display: block; opacity: 0.85; }
nav.desktop-nav { display: flex; align-items: center; gap: 26px; }
nav.desktop-nav a { font-family: 'DM Mono', monospace; font-size: 0.67rem; text-transform: uppercase; letter-spacing: 0.11em; color: var(--cream-dark); text-decoration: none; opacity: 0.75; transition: opacity 0.2s, color 0.2s; border-bottom: 1px solid transparent; padding: 4px 0; }
nav.desktop-nav a:hover { opacity: 1; color: var(--amber-light); border-bottom-color: var(--amber-light); }
.nav-cta { background: var(--amber) !important; color: var(--navy) !important; opacity: 1 !important; padding: 10px 20px !important; border-bottom: none !important; text-decoration: none; }
.nav-cta:hover { background: var(--amber-light) !important; }
.hamburger { display: none; background: none; border: none; cursor: pointer; padding: 16px 0; flex-direction: column; gap: 5px; align-items: center; justify-content: center; min-height: var(--tap-min); }
.hamburger span { display: block; width: 22px; height: 2px; background: var(--cream); transition: transform 0.25s, opacity 0.25s; }
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
.mobile-nav { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: var(--navy); z-index: 199; flex-direction: column; align-items: flex-start; padding: 90px 32px 40px; gap: 0; overflow-y: auto; }
.mobile-nav.open { display: flex; }
.mobile-nav a { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 700; color: var(--cream); text-decoration: none; opacity: 0.8; padding: 16px 0; border-bottom: 1px solid rgba(200,184,154,0.12); width: 100%; min-height: var(--tap-min); display: flex; align-items: center; transition: opacity 0.2s, color 0.2s; }
.mobile-nav a:hover { opacity: 1; color: var(--amber-light); }
.mobile-nav .mobile-nav-cta { background: var(--amber); color: var(--navy) !important; opacity: 1 !important; padding: 18px 28px; margin-top: 24px; border-bottom: none; font-size: 0.8rem; font-family: 'DM Mono', monospace; text-transform: uppercase; letter-spacing: 0.12em; width: 100%; justify-content: center; }

/* ══════════════════════════════════════════════════
   BREADCRUMB (programmatic addition)
══════════════════════════════════════════════════ */
.breadcrumb-bar {
  background: var(--cream-dark);
  border-bottom: 1px solid var(--rule-light);
  padding: 10px var(--gutter);
}
.breadcrumb-inner {
  max-width: calc(var(--article-max) + var(--sidebar-w) + 64px);
  margin: 0 auto;
  display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
}
.breadcrumb-inner a, .breadcrumb-inner span {
  font-family: 'DM Mono', monospace; font-size: 0.58rem;
  text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--text-muted); text-decoration: none;
}
.breadcrumb-inner a:hover { color: var(--amber); }
.breadcrumb-sep { color: var(--rule); font-size: 0.7rem; }
.breadcrumb-current { color: var(--text-secondary); }

/* ══════════════════════════════════════════════════
   ARTICLE HERO
══════════════════════════════════════════════════ */
.article-hero {
  background: var(--navy);
  padding: 56px var(--gutter) 48px;
  position: relative; overflow: hidden;
}
.article-hero::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--amber) 0%, var(--amber-light) 50%, var(--amber) 100%);
}
.article-hero::before {
  content: ''; position: absolute; top: -80px; right: -80px;
  width: 440px; height: 440px;
  background: radial-gradient(circle, rgba(200,130,26,0.09) 0%, transparent 65%);
  pointer-events: none;
}
.hero-inner { max-width: calc(var(--article-max) + var(--sidebar-w) + 64px); margin: 0 auto; }

.article-meta-row {
  display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
  margin-bottom: 20px;
  opacity: 0; animation: fadeUp 0.6s ease 0.1s forwards;
}

/* ── Bucket badge — supports 1 or 2 buckets ── */
.bucket-badge {
  font-family: 'DM Mono', monospace; font-size: 0.58rem;
  text-transform: uppercase; letter-spacing: 0.15em;
  padding: 5px 12px; border: 1px solid var(--amber); color: var(--amber);
  white-space: nowrap;
}
.bucket-badge + .bucket-badge {
  border-color: rgba(200,130,26,0.45); color: rgba(232,168,64,0.75);
}
.category-label {
  font-family: 'DM Mono', monospace; font-size: 0.58rem;
  text-transform: uppercase; letter-spacing: 0.14em; color: rgba(245,240,232,0.45);
}
.meta-sep { color: rgba(200,184,154,0.3); font-size: 0.7rem; }

/* ── State / jurisdiction badge ── */
.jurisdiction-badge {
  font-family: 'DM Mono', monospace; font-size: 0.58rem;
  text-transform: uppercase; letter-spacing: 0.12em;
  padding: 5px 12px;
  background: rgba(200,130,26,0.12); color: var(--amber-light);
  border: 1px solid rgba(200,130,26,0.25);
  white-space: nowrap;
}

.article-headline {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.9rem, 3.6vw, 3.0rem);
  font-weight: 900; line-height: 1.1; letter-spacing: -0.015em;
  color: var(--cream); margin-bottom: 18px; max-width: 780px;
  opacity: 0; animation: fadeUp 0.65s ease 0.22s forwards;
}
.article-headline em { font-style: italic; color: var(--amber-light); }

/* Subheadline (deck) */
.article-deck {
  font-size: 1.02rem; color: rgba(245,240,232,0.70); line-height: 1.7;
  max-width: 620px; margin-bottom: 28px;
  opacity: 0; animation: fadeUp 0.65s ease 0.35s forwards;
}

.article-byline-row {
  display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
  border-top: 1px solid rgba(200,184,154,0.15); padding-top: 18px;
  opacity: 0; animation: fadeUp 0.65s ease 0.45s forwards;
}
.byline-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--navy-light); border: 1px solid rgba(200,184,154,0.25); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.byline-avatar svg { width: 18px; height: 18px; opacity: 0.5; }
.byline-text { display: flex; flex-direction: column; gap: 2px; }
.byline-name { font-family: 'DM Mono', monospace; font-size: 0.63rem; color: var(--cream-dark); text-transform: uppercase; letter-spacing: 0.1em; }
.byline-info { font-family: 'DM Mono', monospace; font-size: 0.56rem; color: rgba(245,240,232,0.38); letter-spacing: 0.06em; }
.read-time-chip { font-family: 'DM Mono', monospace; font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(245,240,232,0.45); padding: 6px 12px; border: 1px solid rgba(200,184,154,0.15); margin-left: auto; }

/* Data freshness badge */
.data-freshness {
  font-family: 'DM Mono', monospace; font-size: 0.54rem;
  text-transform: uppercase; letter-spacing: 0.1em;
  padding: 5px 10px; border: 1px solid rgba(45,106,74,0.4);
  color: #7bcca4; background: rgba(45,106,74,0.12);
  white-space: nowrap;
}

/* ══════════════════════════════════════════════════
   LAYOUT
══════════════════════════════════════════════════ */
.article-layout {
  max-width: calc(var(--article-max) + var(--sidebar-w) + 64px);
  margin: 0 auto;
  padding: 52px var(--gutter) 80px;
  display: grid;
  grid-template-columns: 1fr var(--sidebar-w);
  gap: 64px;
  align-items: start;
}

/* ══════════════════════════════════════════════════
   ARTICLE BODY
══════════════════════════════════════════════════ */
.article-body { min-width: 0; }
.article-body p { margin-bottom: 1.5em; color: var(--text-primary); }
.article-body p:first-child { font-size: 1.06rem; }
.article-body h2 {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem; font-weight: 700; line-height: 1.2;
  color: var(--navy); margin: 2.4em 0 0.7em;
  padding-bottom: 10px; border-bottom: 2px solid var(--cream-dark);
}
.article-body h2::before {
  content: ''; display: block; width: 32px; height: 2px;
  background: var(--amber); margin-bottom: 14px;
}
.article-body h3 { font-family: 'Playfair Display', serif; font-size: 1.18rem; font-weight: 700; font-style: italic; color: var(--navy); margin: 2em 0 0.6em; }
.article-body ul, .article-body ol { padding-left: 1.5em; margin-bottom: 1.5em; }
.article-body li { margin-bottom: 0.6em; }
.article-body strong { color: var(--navy); font-weight: 600; }
.article-body h2 + p::first-letter { font-family: 'Playfair Display', serif; font-size: 3.2rem; line-height: 0.85; font-weight: 900; float: left; margin: 0.06em 0.1em 0 0; color: var(--amber); }

/* Pull quote */
.pull-quote { margin: 2.4em 0; padding: 28px 32px; border-left: 4px solid var(--amber); background: var(--cream-dark); position: relative; }
.pull-quote::before { content: '\201C'; font-family: 'Playfair Display', serif; font-size: 5rem; line-height: 0.7; color: var(--amber); opacity: 0.35; position: absolute; top: 16px; left: 20px; pointer-events: none; }
.pull-quote p { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-style: italic; line-height: 1.55; color: var(--navy); margin: 0; padding-left: 20px; }
.pull-quote cite { display: block; margin-top: 12px; padding-left: 20px; font-family: 'DM Mono', monospace; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); font-style: normal; }

/* Callout */
.callout { margin: 2.4em 0; padding: 22px 26px; border: 1px solid var(--rule); background: var(--white); }
.callout-label { font-family: 'DM Mono', monospace; font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--amber); margin-bottom: 10px; display: block; }
.callout p { margin-bottom: 0; font-size: 0.94rem; color: var(--text-secondary); }
.callout.callout--warning { border-left: 4px solid var(--red-warn); }
.callout.callout--tip { border-left: 4px solid var(--green-tip); }
.callout.callout--warning .callout-label { color: #b94a3a; }
.callout.callout--tip .callout-label { color: var(--green-tip); }

/* Data highlight */
.data-highlight { margin: 2.8em 0; display: flex; gap: 0; border: 1px solid var(--rule); overflow: hidden; }
.data-highlight__stat { background: var(--navy); padding: 26px 28px; display: flex; flex-direction: column; justify-content: center; min-width: 150px; flex-shrink: 0; text-align: center; }
.data-highlight__number { font-family: 'Playfair Display', serif; font-size: 2.4rem; font-weight: 900; line-height: 1; color: var(--amber-light); display: block; }
.data-highlight__unit { font-family: 'DM Mono', monospace; font-size: 0.54rem; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(245,240,232,0.45); margin-top: 6px; display: block; }
.data-highlight__context { background: var(--cream-dark); padding: 26px 28px; display: flex; flex-direction: column; justify-content: center; }
.data-highlight__context p { margin: 0; font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6; }
.data-highlight__source { font-family: 'DM Mono', monospace; font-size: 0.54rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-top: 8px; display: block; }

/* ══════════════════════════════════════════════════
   KEY TAKEAWAYS — programmatic addition
   Maps to the boxed Key Takeaways sections in all 5 templates
══════════════════════════════════════════════════ */
.key-takeaways {
  margin: 3em 0;
  border: 2px solid var(--navy);
  background: var(--white);
  overflow: hidden;
}
.key-takeaways__header {
  background: var(--navy);
  padding: 14px 24px;
  display: flex; align-items: center; gap: 10px;
}
.key-takeaways__icon {
  width: 16px; height: 16px; flex-shrink: 0;
}
.key-takeaways__title {
  font-family: 'DM Mono', monospace; font-size: 0.62rem;
  text-transform: uppercase; letter-spacing: 0.16em;
  color: var(--amber-light);
}
.key-takeaways__body { padding: 20px 24px 24px; }
.key-takeaways__list { list-style: none; padding: 0; margin: 0 0 16px; }
.key-takeaways__list li {
  padding: 9px 0 9px 22px;
  border-bottom: 1px solid var(--rule-light);
  position: relative; font-size: 0.92rem;
  color: var(--text-secondary); line-height: 1.55;
}
.key-takeaways__list li:last-child { border-bottom: none; }
.key-takeaways__list li::before {
  content: '';
  position: absolute; left: 0; top: 16px;
  width: 8px; height: 8px;
  border-left: 2px solid var(--amber);
  border-bottom: 2px solid var(--amber);
  transform: rotate(-45deg);
}
.key-takeaways__source {
  font-family: 'DM Mono', monospace; font-size: 0.56rem;
  text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--text-muted); padding-top: 8px;
  border-top: 1px solid var(--rule-light);
}

/* ══════════════════════════════════════════════════
   INTERNAL LINKS BLOCK — programmatic addition
   The structured 3-link section at the bottom of each template
══════════════════════════════════════════════════ */
.internal-links-block {
  margin: 2.8em 0;
  border: 1px solid var(--rule);
  background: var(--cream-dark);
  padding: 20px 24px;
}
.internal-links__label {
  font-family: 'DM Mono', monospace; font-size: 0.58rem;
  text-transform: uppercase; letter-spacing: 0.15em;
  color: var(--amber); margin-bottom: 16px; display: block;
}
.internal-links__list { list-style: none; padding: 0; margin: 0; }
.internal-links__list li {
  padding: 8px 0;
  border-bottom: 1px solid var(--rule-light);
}
.internal-links__list li:last-child { border-bottom: none; }
.internal-links__direction {
  font-family: 'DM Mono', monospace; font-size: 0.54rem;
  text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--text-muted); margin-right: 8px;
}
.internal-links__list a {
  font-size: 0.9rem; color: var(--navy); text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 0.2s;
}
.internal-links__list a:hover { color: var(--amber); }

/* Article CTA */
.article-cta { margin: 3em 0; padding: 36px 36px 32px; background: var(--navy); position: relative; overflow: hidden; }
.article-cta::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--amber); }
.article-cta-eyebrow { font-family: 'DM Mono', monospace; font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--amber-light); margin-bottom: 12px; display: block; }
.article-cta h4 { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 700; color: var(--cream); margin-bottom: 10px; line-height: 1.3; }
.article-cta p { color: rgba(245,240,232,0.65); font-size: 0.9rem; margin-bottom: 20px; }
.btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--amber); color: var(--navy); font-family: 'DM Mono', monospace; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; padding: 14px 24px; text-decoration: none; border: none; cursor: pointer; transition: background 0.2s, transform 0.15s; min-height: var(--tap-min); }
.btn-primary:hover { background: var(--amber-light); transform: translateY(-1px); color: var(--navy); }

/* Disclaimer */
.article-disclaimer { margin-top: 3em; padding: 20px 24px; border-top: 1px solid var(--rule-light); font-family: 'DM Mono', monospace; font-size: 0.6rem; color: var(--text-muted); line-height: 1.7; letter-spacing: 0.03em; }
.article-disclaimer strong { color: var(--text-secondary); }

/* Share + tags */
.share-bar { margin-top: 2em; padding: 16px 0; border-top: 1px solid var(--rule-light); border-bottom: 1px solid var(--rule-light); display: flex; align-items: center; gap: 16px; }
.share-label { font-family: 'DM Mono', monospace; font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); }
.share-btn { font-family: 'DM Mono', monospace; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; padding: 7px 14px; border: 1px solid var(--rule); color: var(--text-secondary); text-decoration: none; background: none; cursor: pointer; transition: border-color 0.2s, color 0.2s; }
.share-btn:hover { border-color: var(--amber); color: var(--amber); }
.article-tags { margin-top: 2.5em; padding-top: 1.5em; border-top: 1px solid var(--rule-light); display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
.tags-label { font-family: 'DM Mono', monospace; font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); margin-right: 4px; }
.tag { font-family: 'DM Mono', monospace; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; padding: 5px 12px; border: 1px solid var(--rule); color: var(--text-muted); text-decoration: none; transition: border-color 0.2s, color 0.2s; }
.tag:hover { border-color: var(--amber); color: var(--amber); }

/* ══════════════════════════════════════════════════
   SIDEBAR
══════════════════════════════════════════════════ */
.article-sidebar { position: sticky; top: 88px; }

/* State data card — programmatic addition */
.state-data-card {
  border: 1px solid var(--rule);
  margin-bottom: 20px;
  background: var(--white);
  overflow: hidden;
}
.state-data-card__header {
  background: var(--navy); padding: 14px 20px;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 2px solid var(--amber);
}
.state-data-card__state {
  font-family: 'Playfair Display', serif; font-size: 1.1rem;
  font-weight: 700; color: var(--cream);
}
.state-data-card__type {
  font-family: 'DM Mono', monospace; font-size: 0.54rem;
  text-transform: uppercase; letter-spacing: 0.1em;
  color: rgba(245,240,232,0.45);
}
.state-data-card__rows { padding: 4px 0; }
.state-data-row {
  display: flex; justify-content: space-between; align-items: baseline;
  padding: 11px 20px; border-bottom: 1px solid var(--rule-light);
  gap: 16px;
}
.state-data-row:last-child { border-bottom: none; }
.state-data-label { font-family: 'DM Mono', monospace; font-size: 0.57rem; text-transform: uppercase; letter-spacing: 0.09em; color: var(--text-muted); flex-shrink: 0; }
.state-data-value { font-family: 'Playfair Display', serif; font-size: 0.98rem; font-weight: 700; color: var(--navy); text-align: right; }
.state-data-value.amber { color: var(--amber); }

