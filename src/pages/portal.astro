    .profile-pill {
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.08);
      color: rgba(255,255,255,.86);
      font-size: 12px;
      letter-spacing: .4px;
    }

    .profile-identity-card {
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 20px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      min-width: 0;
      box-sizing: border-box;
    }

    .profile-avatar-lg {
      width: 90px;
      height: 90px;
      border-radius: 50%;
