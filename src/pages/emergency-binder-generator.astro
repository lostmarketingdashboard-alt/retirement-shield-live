<div class="disclaimer">
  <p><strong>Important Disclosures:</strong> This emergency binder generator is provided for educational and organizational purposes only. It does not create legal documents and does not constitute legal, tax, financial, or insurance advice. State-specific reminders included in this output are high-level planning prompts only and may not reflect the latest legal changes or the specific facts of your household. Estate planning, probate, title, Medicaid, and incapacity rules vary by state and by circumstance. Retirement Shield is not a law firm and does not prepare legal documents. Review your binder with a licensed estate planning attorney in your state before relying on it for legal decisions. © 2026 Retirement Shield. All rights reserved.</p>
</div>

<script is:inline>
const stateOptions = [
  ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],['CA','California'],
  ['CO','Colorado'],['CT','Connecticut'],['DE','Delaware'],['FL','Florida'],['GA','Georgia'],
  ['HI','Hawaii'],['ID','Idaho'],['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],
  ['KY','Kentucky'],['LA','Louisiana'],['ME','Maine'],['MD','Maryland'],['MA','Massachusetts'],
  ['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],['MO','Missouri'],['MT','Montana'],
  ['NE','Nebraska'],['NV','Nevada'],['NH','New Hampshire'],['NJ','New Jersey'],['NM','New Mexico'],
  ['NY','New York'],['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
  ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],['SD','South Dakota'],
  ['TN','Tennessee'],['TX','Texas'],['UT','Utah'],['VT','Vermont'],['VA','Virginia'],['WA','Washington'],
  ['WV','West Virginia'],['WI','Wisconsin'],['WY','Wyoming']
];

const stateSpecificGuide = {
  FL: {
    note: 'Florida households should review homestead restrictions, probate exposure for titled assets, and whether a Lady Bird Deed or trust is already in place.',
    bullets: [
      ['warn', 'Review homestead title rules', 'Florida homestead rules can control who inherits the home and can limit what happens at death if the title plan is loose or outdated.'],
      ['warn', 'Confirm whether a Lady Bird Deed or trust exists', 'Florida is one of the few states where an enhanced life estate deed can be a powerful probate-avoidance and Medicaid-recovery planning tool.'],
      ['ok', 'Double-check beneficiary designations', 'IRAs, 401(k)s, annuities, and life insurance typically pass by beneficiary form, not by will.']
    ]
  },
  TX: {
    note: 'Texas families should pay close attention to homestead protections, transfer strategies for real estate, and whether all non-probate assets have named beneficiaries.',
    bullets: [
      ['warn', 'Verify deed and title structure on the residence', 'Real estate often creates the biggest administrative problem when the family assumes the will alone solves everything.'],
      ['ok', 'Check TOD designations and beneficiary forms', 'Texas offers several non-probate transfer routes, but only if paperwork has actually been completed.'],
      ['warn', 'Make sure incapacity documents are current', 'A durable power of attorney and medical directive matter just as much as the death-side plan.']
    ]
  },
  CA: {
    note: 'California families should review probate thresholds carefully and make sure larger estates are not relying on a will alone.',
    bullets: [
      ['warn', 'Assess probate exposure now', 'California probate can be expensive because fees are commonly tied to gross estate value rather than net equity.'],
      ['warn', 'Fund the trust if one exists', 'An unfunded trust often creates a false sense of security because the assets still need to be titled correctly.'],
      ['ok', 'Inventory all account beneficiary forms', 'Retirement accounts and insurance contracts should be reviewed alongside the trust documents.']
    ]
  },
  NY: {
    note: 'New York households should review fiduciary appointments, asset titling, and whether the family can locate originals quickly.',
    bullets: [
      ['warn', 'Review executor and agent designations', 'Named decision-makers should still be alive, willing, and practical for the job.'],
      ['warn', 'Separate probate assets from beneficiary assets', 'Families often overestimate what the will controls and underestimate how much passes by title or contract.'],
      ['ok', 'Keep the originals accessible', 'A good binder is valuable only if the surviving family knows exactly where the originals are.']
    ]
  },
  AZ: {
    note: 'Arizona families should review beneficiary designations, deed strategy, and any account that would otherwise funnel into probate.',
    bullets: [
      ['ok', 'Use beneficiary designations intentionally', 'Retirement accounts, life insurance, and payable-on-death accounts can keep administration much cleaner.'],
      ['warn', 'Review home transfer strategy', 'Homes still need clear title planning if the goal is a smoother handoff for the surviving spouse or children.'],
      ['warn', 'Confirm powers of attorney are signed and usable', 'Incapacity often creates the first crisis long before death does.']
    ]
  }
};

const stepCount = 4;
let currentStep = 1;
let latestSubmission = null;

const stateSelect = document.getElementById('stateSelect');
const placeholderOption = document.createElement('option');
placeholderOption.value = '';
placeholderOption.textContent = 'Select your state...';
placeholderOption.disabled = true;
placeholderOption.selected = true;
stateSelect.appendChild(placeholderOption);

stateOptions.forEach(([code, name]) => {
  const option = document.createElement('option');
  option.value = code;
  option.textContent = name;
  stateSelect.appendChild(option);
});

document.querySelectorAll('[data-radio-group]').forEach(group => {
  group.querySelectorAll('.radio-card').forEach(card => {
    card.addEventListener('click', () => {
      const input = card.querySelector('input');
      if (!input) return;
      group.querySelectorAll('.radio-card').forEach(el => el.classList.remove('selected'));
      card.classList.add('selected');
      input.checked = true;
    });
  });
});

function nextStep(step) {
  currentStep = step;
  document.querySelectorAll('.form-step').forEach(panel => panel.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');

  document.querySelectorAll('[data-step-indicator]').forEach((item, index) => {
    const num = index + 1;
    item.classList.toggle('active', num === step);
    item.classList.toggle('done', num < step);
  });

  document.getElementById('progressText').textContent = `Step ${step} of ${stepCount}`;
  document.getElementById('progressFill').style.width = `${(step / stepCount) * 100}%`;
  window.scrollTo({ top: document.getElementById('wizardSection').offsetTop - 76, behavior: 'smooth' });
}

function getSelectedValue(name) {
  return document.querySelector(`input[name="${name}"]:checked`)?.value ?? '';
}

function titleCaseState(code) {
  return stateOptions.find(([value]) => value === code)?.[1] ?? code;
}

function getUrgencyCopy(avgAge, householdType) {
  if (avgAge >= 75) {
    return {
      headline: 'This is no longer a someday task.',
      copy: 'In the later retirement years, the family handoff should be organized before a hospitalization, fall, or sudden loss forces the issue. The binder matters because clarity saves time at the exact moment time feels shortest.'
    };
  }
  if (avgAge >= 67) {
    return {
      headline: 'The right time is while everyone is still well enough to explain things.',
      copy: `For households in the early-to-mid retirement years, the risk is not just death. It is confusion during incapacity, rehab, or a financial emergency. A clear binder lowers friction for the ${householdType === 'married' ? 'surviving spouse' : 'adult children and helpers'} before the family is forced to improvise.`
    };
  }
  return {
    headline: 'Build it now while details are still easy to gather.',
    copy: 'Even when the household feels years away from a crisis, the easiest time to organize documents, passwords, titles, and instructions is before anyone is under pressure.'
  };
}

function parseLines(text, fallbackLabel) {
  const items = text
    .split(/(?:\r?\n|,|;)+/)
    .map(item => item.trim())
    .filter(Boolean);
  return items.length ? items : [fallbackLabel];
}

function buildChecklist(data) {
  const stateGuide = stateSpecificGuide[data.state] || {
    note: `${data.stateName} families should review wills, powers of attorney, beneficiary designations, and home title strategy before assuming the surviving spouse can handle everything without probate friction.`,
    bullets: [
      ['warn', 'Review how the home passes at death', 'The residence is usually the asset most likely to create delay, confusion, and court involvement if title planning is unfinished.'],
      ['warn', 'Confirm incapacity documents are current', 'Durable financial and healthcare documents matter because many family crises start before death.'],
      ['ok', 'Recheck beneficiary forms and contact lists', 'Accounts with named beneficiaries often transfer more cleanly than families expect, but only if the forms were actually updated.']
    ]
  };

  const result = [...stateGuide.bullets];

  result.push(
    data.willStatus === 'updated'
      ? ['ok', 'Will appears current', 'Keep the original easy to find and review it again after any move, death, marriage, or major purchase.']
      : data.willStatus === 'old'
        ? ['warn', 'Will exists but needs review', 'An older will can conflict with the household you have now even if it was valid when signed.']
        : ['miss', 'No confirmed will on file', `If no will exists, ${data.stateName} intestacy rules may control more of the outcome than the family expects.`]
  );

  result.push(
    data.trustStatus === 'yes'
      ? ['ok', 'Probate-avoidance planning is at least started', 'The next question is whether the deed, trust funding, and beneficiary forms were actually finished.']
      : ['warn', 'Home and titled assets still need a transfer strategy', data.homeStatus === 'renting' ? 'Without real estate the urgency may be lower, but titled assets still need a clean transfer plan.' : 'If the home is not in a trust or deed-based transfer plan, probate exposure is still worth reviewing.']
  );

  result.push(
    data.poaStatus === 'yes'
      ? ['ok', 'Durable power of attorney appears covered', 'That protects the family if incapacity arrives before death.']
      : ['miss', 'Durable financial power of attorney missing or uncertain', 'Families often discover this gap only after banks refuse to talk and the court process has to begin.']
  );

  result.push(
    data.healthStatus === 'yes'
      ? ['ok', 'Healthcare proxy and HIPAA planning appear covered', 'Make sure the named person knows where the documents are and what the preferences are.']
      : ['miss', 'Medical directive or HIPAA release needs attention', 'Hospitals do not run on family assumptions. The paperwork should be easy to locate.']
  );

  return {
    note: stateGuide.note,
    items: result
  };
}

function buildDocStatusCards(data) {
  return [
    {
      title: 'Will / trust package',
      text: data.willStatus === 'updated'
        ? 'A current will is indicated. Confirm the signed original is available and the named executor still makes sense.'
        : data.willStatus === 'old'
          ? 'The will exists but should be reviewed. Outdated names, addresses, and family structure create real confusion.'
          : 'No confirmed will is on file. The binder should flag this clearly for the family and the attorney.',
      tone: data.willStatus === 'updated' ? 'ok' : data.willStatus === 'old' ? 'warn' : 'miss'
    },
    {
      title: 'Financial authority',
      text: data.poaStatus === 'yes'
        ? 'A durable financial power of attorney appears to be in place.'
        : 'No confirmed durable power of attorney. This is one of the highest-friction gaps if incapacity happens first.',
      tone: data.poaStatus === 'yes' ? 'ok' : 'miss'
    },
    {
      title: 'Medical authority',
      text: data.healthStatus === 'yes'
        ? 'Healthcare directive and HIPAA planning appear to be covered.'
        : 'Medical agent paperwork is missing or uncertain. The binder should tell the family to resolve this before the next health event.',
      tone: data.healthStatus === 'yes' ? 'ok' : 'miss'
    },
    {
      title: 'Home / probate transfer',
      text: data.homeStatus === 'trust'
        ? 'The residence is already described as being in a trust or deed-based transfer plan.'
        : data.homeStatus === 'renting'
          ? 'No primary residence ownership issue was identified, which simplifies the first-pass checklist.'
          : 'The family should confirm title strategy on the home rather than assuming the will alone handles it.',
      tone: data.homeStatus === 'trust' || data.homeStatus === 'renting' ? 'ok' : 'warn'
    }
  ];
}

function buildBinderData() {
  const primaryName = document.getElementById('primaryName').value.trim() || 'Primary household member';
  const spouseName = document.getElementById('spouseName').value.trim();
  const state = document.getElementById('stateSelect').value;
  const stateName = titleCaseState(state);
  const county = document.getElementById('countyName').value.trim() || 'local county';
  const primaryAge = Number(document.getElementById('primaryAge').value || 0);
  const spouseAge = Number(document.getElementById('spouseAge').value || 0);
  const household = getSelectedValue('household');
  const willStatus = getSelectedValue('willStatus');
  const trustStatus = getSelectedValue('trustStatus');
  const poaStatus = getSelectedValue('poaStatus');
  const healthStatus = getSelectedValue('healthStatus');
  const documentLocation = document.getElementById('documentLocation').value.trim();
  const homeStatus = document.getElementById('homeStatus').value;
  const accountCount = document.getElementById('accountCount').value;
  const financialInstitutions = document.getElementById('financialInstitutions').value.trim();
  const digitalAccess = document.getElementById('digitalAccess').value.trim();
  const autopayList = document.getElementById('autopayList').value.trim();
  const keyLocations = document.getElementById('keyLocations').value.trim();
  const primaryContactName = document.getElementById('primaryContactName').value.trim() || 'Primary family contact';
  const primaryContactPhone = document.getElementById('primaryContactPhone').value.trim() || 'Phone not listed';
  const attorneyName = document.getElementById('attorneyName').value.trim() || 'Estate attorney / advisor';
  const attorneyPhone = document.getElementById('attorneyPhone').value.trim() || 'Phone not listed';
  const survivingSpouseInstructions = document.getElementById('survivingSpouseInstructions').value.trim();
  const familyMeetingDate = document.getElementById('familyMeetingDate').value.trim() || 'Next family review';

  const avgAge = spouseAge ? Math.round((primaryAge + spouseAge) / 2) : primaryAge;
  const urgency = getUrgencyCopy(avgAge, household);
  const checklist = buildChecklist({ state, stateName, willStatus, trustStatus, poaStatus, healthStatus, homeStatus });
  const docCards = buildDocStatusCards({ willStatus, poaStatus, healthStatus, homeStatus });

  return {
    primaryName,
    spouseName,
    state,
    stateName,
    county,
    primaryAge,
    spouseAge,
    avgAge,
    household,
    willStatus,
    trustStatus,
    poaStatus,
    healthStatus,
    documentLocation,
    homeStatus,
    accountCount,
    financialInstitutions,
    digitalAccess,
    autopayList,
    keyLocations,
    primaryContactName,
    primaryContactPhone,
    attorneyName,
    attorneyPhone,
    survivingSpouseInstructions,
    familyMeetingDate,
    urgency,
    checklist,
    docCards,
    householdLabel: spouseName && household !== 'solo' ? `${primaryName} & ${spouseName}` : primaryName
  };
}

function renderBinder(data) {
  latestSubmission = data;

  document.getElementById('binderTitle').textContent = `The “After I’m Gone” Emergency Binder for ${data.householdLabel}`;
  document.getElementById('binderSubtitle').textContent = `Prepared for a ${data.stateName} household with a surviving-${data.household === 'solo' ? 'family' : 'spouse'} focused checklist, account inventory, and location map.`;
  document.getElementById('metaHousehold').textContent = data.householdLabel;
  document.getElementById('metaState').textContent = `${data.stateName} · ${data.county}`;
  document.getElementById('metaDate').textContent = `Generated ${new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;
  document.getElementById('coverText').textContent = `This binder was built for ${data.householdLabel}. Keep it printed, tell ${data.primaryContactName} where it lives, and plan to review it again around ${data.familyMeetingDate}.`;
  document.getElementById('urgencyHeadline').textContent = data.urgency.headline;
  document.getElementById('urgencyCopy').textContent = data.urgency.copy;
  document.getElementById('stateChecklistCopy').textContent = data.checklist.note;
  document.getElementById('statePill').textContent = `${data.stateName} household`;
  document.getElementById('accountCountPill').textContent = `${data.accountCount} accounts`;

  const checklistList = document.getElementById('checklistList');
  checklistList.innerHTML = data.checklist.items.map(([tone, title, text]) => `
    <div class="checklist-item">
      <div class="checkmark ${tone}">${tone === 'ok' ? '✓' : tone === 'warn' ? '!' : '×'}</div>
      <div>
        <strong>${title}</strong>
        <p>${text}</p>
      </div>
    </div>
  `).join('');

  const docStatusGrid = document.getElementById('docStatusGrid');
  docStatusGrid.innerHTML = data.docCards.map(card => `
    <div class="doc-status-card">
      <strong>${card.title}</strong>
      <p>${card.text}</p>
      <div class="status-tag ${card.tone}">${card.tone === 'ok' ? 'Ready / documented' : card.tone === 'warn' ? 'Needs review' : 'Missing / urgent'}</div>
    </div>
  `).join('');

  const institutionRows = document.getElementById('institutionRows');
  const institutionItems = parseLines(data.financialInstitutions, 'Add your first institution here');
  institutionRows.innerHTML = institutionItems.slice(0, 6).map((item, index) => `
    <tr>
      <td data-label="Institution">${item}</td>
      <td data-label="Type">${index === 0 ? 'Banking' : index === 1 ? 'Retirement' : index === 2 ? 'Brokerage / investment' : 'Policy / account'}</td>
      <td data-label="Notes">Account number, owner, beneficiary, advisor contact</td>
    </tr>
  `).join('');

  const digitalRows = document.getElementById('digitalRows');
  const digitalItems = parseLines(data.digitalAccess, 'Add digital access notes here');
  digitalRows.innerHTML = digitalItems.slice(0, 6).map((item, index) => `
    <div class="list-row">
      <span>${index === 0 ? 'Primary access point' : index === 1 ? 'Password storage' : index === 2 ? 'Phone / device access' : index === 3 ? 'Cloud storage / scans' : 'Digital note'}</span>
      <span>${item}</span>
    </div>
  `).join('');

  const autopayRows = document.getElementById('autopayRows');
  const autopayItems = parseLines(data.autopayList, 'Add autopay and subscription notes here');
  autopayRows.innerHTML = autopayItems.slice(0, 7).map(item => `
    <div class="list-row">
      <span>Recurring bill / subscription</span>
      <span>${item}</span>
    </div>
  `).join('');

  const contactRows = document.getElementById('contactRows');
  contactRows.innerHTML = `
    <tr><td data-label="Role">First call</td><td data-label="Name">${data.primaryContactName}</td><td data-label="Phone / Notes">${data.primaryContactPhone}</td></tr>
    <tr><td data-label="Role">Estate attorney / advisor</td><td data-label="Name">${data.attorneyName}</td><td data-label="Phone / Notes">${data.attorneyPhone}</td></tr>
    <tr><td data-label="Role">Primary physician</td><td data-label="Name">________________________</td><td data-label="Phone / Notes">________________________</td></tr>
    <tr><td data-label="Role">CPA / tax preparer</td><td data-label="Name">________________________</td><td data-label="Phone / Notes">________________________</td></tr>
    <tr><td data-label="Role">Insurance agent</td><td data-label="Name">________________________</td><td data-label="Phone / Notes">________________________</td></tr>
    <tr><td data-label="Role">Funeral home / clergy / church contact</td><td data-label="Name">________________________</td><td data-label="Phone / Notes">________________________</td></tr>
  `;

  const mapDocumentRows = document.getElementById('mapDocumentRows');
  mapDocumentRows.innerHTML = `
    <div class="list-row"><span>Original legal documents</span><span>${data.documentLocation || 'Add exact location'}</span></div>
    <div class="list-row"><span>Primary binder storage spot</span><span>________________________________</span></div>
    <div class="list-row"><span>Digital scans / shared folder</span><span>${digitalItems[3] || digitalItems[0] || 'Add cloud storage details'}</span></div>
    <div class="list-row"><span>Safe deposit box / spare key</span><span>________________________________</span></div>
  `;

  const mapItemRows = document.getElementById('mapItemRows');
  const keyItems = parseLines(data.keyLocations, 'Add physical item locations here');
  mapItemRows.innerHTML = keyItems.slice(0, 5).map(item => `
    <div class="list-row">
      <span>Physical item location</span>
      <span>${item}</span>
    </div>
  `).join('');

  document.getElementById('survivingSpouseNote').textContent = data.survivingSpouseInstructions;
}

function runAnalysisAnimation(data) {
  document.getElementById('analysisSub').textContent = `Personalizing a ${data.stateName} binder for ${data.householdLabel}.`;
  const steps = ['analysisStep1', 'analysisStep2', 'analysisStep3', 'analysisStep4'];
  steps.forEach(id => document.getElementById(id).classList.remove('done'));
  steps.forEach((id, index) => {
    setTimeout(() => {
      document.getElementById(id).classList.add('done');
    }, (index + 1) * 380);
  });
}

async function saveEmergencyBinderReport(data) {
  const supabase = window.emergencyBinderSupabase;
  if (!supabase) return null;

  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const payload = {
    user_id: userId,
    full_name: data.primaryName,
    spouse_name: data.spouseName || null,
    household_label: data.householdLabel,
    household_type: data.household,
    state_code: data.state,
    state_name: data.stateName,
    county_name: data.county,
    primary_age: data.primaryAge || null,
    spouse_age: data.spouseAge || null,
    document_location: data.documentLocation || null,
    home_status: data.homeStatus,
    account_count_range: data.accountCount,
    primary_contact_name: data.primaryContactName,
    primary_contact_phone: data.primaryContactPhone,
    attorney_name: data.attorneyName,
    attorney_phone: data.attorneyPhone,
    family_review_date: data.familyMeetingDate || null,
    report_title: `The "After I'm Gone" Emergency Binder for ${data.householdLabel}`,
    report_payload: data
  };

  const { data: inserted, error } = await supabase
    .from('emergency_binder_reports')
    .insert(payload)
    .select('id')
    .single();

  if (error) {
    console.error('Failed to save Emergency Binder report:', error);
    return null;
  }

  return inserted;
}

function showGeneratedBinder(data) {
  renderBinder(data);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  runAnalysisAnimation(data);

  setTimeout(() => {
    document.getElementById('analysisSection').classList.remove('active');
    document.getElementById('binderSection').classList.add('active');
    document.getElementById('binderShell').classList.add('visible');
    document.getElementById('binderShell').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 1900);
}

function showHydratedBinder(data) {
  renderBinder(data);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('binderSection').classList.add('active');
  document.getElementById('binderShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedSubmission(report) {
  const payload = report?.report_payload;
  if (!payload) return false;

  const fieldMap = {
    primaryName: payload.primaryName,
    spouseName: payload.spouseName,
    countyName: payload.county,
    primaryAge: payload.primaryAge,
    spouseAge: payload.spouseAge,
    documentLocation: payload.documentLocation,
    homeStatus: payload.homeStatus,
    accountCount: payload.accountCount,
    financialInstitutions: payload.financialInstitutions,
    digitalAccess: payload.digitalAccess,
    autopayList: payload.autopayList,
    keyLocations: payload.keyLocations,
    primaryContactName: payload.primaryContactName,
    primaryContactPhone: payload.primaryContactPhone,
    attorneyName: payload.attorneyName,
    attorneyPhone: payload.attorneyPhone,
    survivingSpouseInstructions: payload.survivingSpouseInstructions,
    familyMeetingDate: payload.familyMeetingDate
  };

  Object.entries(fieldMap).forEach(([id, value]) => {
    const input = document.getElementById(id);
    if (input && value !== undefined && value !== null) input.value = value;
  });

  if (payload.state) {
    const select = document.getElementById('stateSelect');
    if (select) select.value = payload.state;
  }

  const radioGroups = ['household', 'willStatus', 'trustStatus', 'poaStatus', 'healthStatus'];
  radioGroups.forEach((name) => {
    const value = payload[name];
    if (!value) return;
    document.querySelectorAll(`input[name="${name}"]`).forEach((input) => {
      const checked = input.value === value;
      input.checked = checked;
      input.closest('.radio-card')?.classList.toggle('selected', checked);
    });
  });

  showHydratedBinder(payload);
  return true;
}

async function generateBinder() {
  const data = buildBinderData();
  await saveEmergencyBinderReport(data);
  showGeneratedBinder(data);
}

function editBinder() {
  document.getElementById('binderSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(4);
}

window.nextStep = nextStep;
window.generateBinder = generateBinder;
window.editBinder = editBinder;
window.hydrateEmergencyBinderSubmission = hydrateSavedSubmission;
</script>
