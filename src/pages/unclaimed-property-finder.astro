---
export const prerender = false;
export const ssr = false;
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Unclaimed Property Finder</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --navy:#0F1F3D;--navy-light:#1A2D52;--navy-mid:#152847;--gold:#C9A84C;--gold-light:#D4B96A;
  --gold-glow:rgba(201,168,76,0.12);--cream:#FAF7F0;--cream-dark:#F0EBE0;--white:#FFFFFF;
  --text-dark:#1A1A1A;--text-mid:#4A4A4A;--text-light:#7A7A7A;--green:#2E8B57;--amber:#D97706;--red:#B73E2E;
  --border:#E8E3D8;--shadow:0 2px 20px rgba(15,31,61,0.08)
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text-dark);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
.site-header{background:var(--navy);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;border-bottom:2px solid var(--gold)}
.logo{text-decoration:none}.logo-text{font-family:'Playfair Display',serif;color:var(--white);font-size:18px;font-weight:600}.logo-text span{color:var(--gold)}
.hero{background:var(--navy);padding:78px 24px 94px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 25% 18%, rgba(201,168,76,0.08) 0%, transparent 48%),radial-gradient(ellipse at 76% 74%, rgba(201,168,76,0.05) 0%, transparent 54%);pointer-events:none}
.hero-inner{position:relative;z-index:1;max-width:980px;margin:0 auto}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.22);border-radius:999px;padding:8px 18px;margin-bottom:28px;font-size:11px;font-weight:700;color:var(--gold);letter-spacing:1.2px;text-transform:uppercase}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,54px);font-weight:700;color:var(--white);line-height:1.12;margin-bottom:18px}
.hero h1 em{color:var(--gold);font-style:normal}
.hero-sub{font-size:18px;color:rgba(255,255,255,0.66);line-height:1.7;max-width:840px;margin:0 auto 38px;font-weight:300}
.hero-points{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
.hero-point{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.84);border-radius:999px;padding:10px 16px;font-size:13px}
.wizard-section,.analysis-section,.report-section{padding:52px 24px 30px}
.wizard-grid{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:340px minmax(0,1fr);gap:28px;align-items:start}
.sticky-sidebar{position:sticky;top:94px}
.sidebar-card,.form-card,.analysis-card,.report-shell,.disclaimer{background:var(--white);border:1px solid var(--border);border-radius:16px;box-shadow:var(--shadow)}
.sidebar-card{padding:28px}
.sidebar-label,.step-label,.section-kicker,.report-kicker{font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--gold)}
.sidebar-title{font-family:'Playfair Display',serif;font-size:28px;line-height:1.15;color:var(--navy);margin:8px 0 14px}
.sidebar-copy{font-size:14px;color:var(--text-mid);margin-bottom:22px}
.step-list{display:flex;flex-direction:column;gap:12px;margin-bottom:22px}
.step-item{display:grid;grid-template-columns:34px 1fr;gap:12px;align-items:start;padding:12px 14px;border-radius:12px;background:var(--cream);border:1px solid transparent}
.step-item.active{border-color:rgba(201,168,76,0.4);background:var(--gold-glow)}
.step-item.done .step-num{background:var(--gold);color:var(--navy)}
.step-num{width:34px;height:34px;border-radius:50%;background:var(--cream-dark);color:var(--navy);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700}
.step-title{font-size:14px;font-weight:700;color:var(--navy);line-height:1.35}.step-sub{font-size:12px;color:var(--text-light);margin-top:2px}
.sidebar-note{border-radius:14px;background:var(--navy);color:rgba(255,255,255,0.78);padding:18px;font-size:13px}.sidebar-note strong{color:var(--white);display:block;margin-bottom:6px}
.form-card{overflow:hidden}.form-header{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-light) 100%);padding:28px 30px}
.form-header-top{display:flex;justify-content:space-between;gap:16px;align-items:center;margin-bottom:18px}
.form-badge{display:inline-flex;align-items:center;gap:8px;padding:7px 14px;background:rgba(201,168,76,0.12);border:1px solid rgba(201,168,76,0.24);color:var(--gold);border-radius:999px;font-size:11px;font-weight:700;letter-spacing:1.1px;text-transform:uppercase}
.progress-inline{color:rgba(255,255,255,0.62);font-size:12px;font-weight:600}
.form-title{font-family:'Playfair Display',serif;color:var(--white);font-size:34px;line-height:1.1;margin-bottom:10px}
.form-sub{color:rgba(255,255,255,0.64);font-size:15px;max-width:760px}
.progress-bar{height:5px;background:rgba(255,255,255,0.1);border-radius:999px;margin-top:18px;overflow:hidden}
.progress-fill{height:100%;width:50%;background:linear-gradient(90deg,var(--gold),var(--gold-light));border-radius:999px;transition:width .35s ease}
.form-body{padding:30px}.form-step{display:none}.form-step.active{display:block}
.step-question{font-family:'Playfair Display',serif;font-size:28px;line-height:1.18;color:var(--navy);margin:8px 0}
.step-help{font-size:14px;color:var(--text-light);margin-bottom:24px;max-width:760px}
.field-grid,.metric-grid,.card-grid,.instruction-grid{display:grid;gap:18px}
.field-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
.metric-grid,.card-grid,.instruction-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
.field-group{margin-bottom:18px}.field-group.full{grid-column:1/-1}
.field-label{display:block;font-size:11px;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.9px;margin-bottom:8px}
.field-input,.field-select,.field-textarea{width:100%;border:1.5px solid var(--border);border-radius:10px;background:var(--cream);color:var(--text-dark);font-size:15px;font-family:'DM Sans',sans-serif;padding:14px 16px;outline:none;transition:border-color .2s,box-shadow .2s,background .2s}
.field-textarea{min-height:110px;resize:vertical}
.field-input:focus,.field-select:focus,.field-textarea:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,168,76,0.12);background:var(--white)}
.btn-row{display:flex;justify-content:space-between;gap:12px;margin-top:26px}
.btn-back,.btn-next,.btn-print,.btn-secondary,.link-btn{border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s ease;text-decoration:none;display:inline-flex;align-items:center;justify-content:center}
.btn-back,.btn-secondary{background:transparent;border:1.5px solid var(--border);color:var(--text-mid);padding:13px 18px}
.btn-next,.btn-print,.link-btn{background:var(--gold);color:var(--navy);padding:13px 20px}.btn-next:hover,.btn-print:hover,.link-btn:hover{background:var(--gold-light)}
.selection-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.selection-card{padding:18px;border-radius:14px;border:1.5px solid var(--border);background:var(--cream);cursor:pointer;transition:border-color .2s,transform .2s,background .2s}
.selection-card.selected{border-color:var(--gold);background:rgba(201,168,76,0.12);transform:translateY(-1px)}
.selection-card input{position:absolute;opacity:0;pointer-events:none}
.selection-card strong{display:block;color:var(--navy);font-size:15px;margin-bottom:6px}
.selection-card span{display:block;font-size:13px;color:var(--text-light);line-height:1.5}
.insight-band{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin-top:8px}
.insight-chip{border:1px solid var(--border);border-radius:14px;background:var(--cream);padding:16px}
.insight-chip strong{display:block;font-size:13px;color:var(--navy);margin-bottom:6px}.insight-chip span{font-size:13px;color:var(--text-light)}
.analysis-section,.report-section{display:none}.analysis-section.active,.report-section.active{display:block}
.analysis-card{max-width:920px;margin:0 auto;padding:42px 28px;text-align:center}
.analysis-orb{width:96px;height:96px;margin:0 auto 20px;border-radius:50%;background:radial-gradient(circle at 35% 35%,var(--gold-light),var(--gold));position:relative;box-shadow:0 0 0 16px rgba(201,168,76,0.08),0 0 0 32px rgba(201,168,76,0.04)}
.analysis-orb::after{content:'';position:absolute;inset:24px;border-radius:50%;background:var(--navy);opacity:.16}
.analysis-title{font-family:'Playfair Display',serif;font-size:34px;color:var(--navy);margin-bottom:8px}
.analysis-sub{font-size:15px;color:var(--text-light);margin-bottom:28px}
.analysis-steps{max-width:560px;margin:0 auto;display:flex;flex-direction:column;gap:12px}
.analysis-step{display:grid;grid-template-columns:38px 1fr;gap:14px;align-items:center;text-align:left;padding:14px 16px;border-radius:12px;background:var(--cream);border:1px solid var(--border)}
.analysis-indicator{width:38px;height:38px;border-radius:50%;background:var(--gold-glow);color:var(--gold);display:flex;align-items:center;justify-content:center;font-weight:700}
.analysis-step.done .analysis-indicator{background:var(--gold);color:var(--navy)}.analysis-text{font-size:14px;color:var(--text-mid)}
.report-shell{max-width:1080px;margin:0 auto;overflow:hidden}
.report-header{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-mid) 100%);padding:36px 32px 30px;color:var(--white)}
.report-title{font-family:'Playfair Display',serif;font-size:clamp(30px,4vw,44px);line-height:1.1;margin:10px 0 12px}
.report-subtitle{color:rgba(255,255,255,0.72);font-size:15px;max-width:800px}
.report-meta{margin-top:20px;display:flex;flex-wrap:wrap;gap:12px}
.report-meta-item,.pill{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:999px;padding:8px 14px;font-size:12px;color:rgba(255,255,255,0.8)}
.report-body{padding:28px;display:grid;gap:22px}
.hero-summary,.section-card{background:var(--white);border:1px solid var(--border);border-radius:16px}
.hero-summary{padding:28px;background:linear-gradient(135deg,rgba(15,31,61,0.03),rgba(201,168,76,0.08)),var(--white)}
.summary-lead{display:grid;grid-template-columns:1.05fr .95fr;gap:22px}
.summary-title{font-family:'Playfair Display',serif;font-size:34px;color:var(--navy);line-height:1.08;margin-bottom:10px}.summary-title em{color:var(--gold);font-style:normal}
.summary-copy{font-size:15px;color:var(--text-mid)}
.summary-benchmark{background:var(--navy);color:rgba(255,255,255,0.82);border-radius:16px;padding:22px}
.summary-benchmark .headline{font-family:'Playfair Display',serif;font-size:24px;color:var(--white);line-height:1.14;margin:8px 0 10px}
.metric-card,.info-card,.instruction-card{background:var(--cream);border:1px solid var(--border);border-radius:14px;padding:16px}
.metric-label,.info-label,.instruction-label{font-size:11px;text-transform:uppercase;letter-spacing:.9px;color:var(--text-light);font-weight:700;margin-bottom:6px}
.metric-value,.info-title{font-family:'Playfair Display',serif;font-size:30px;color:var(--navy);line-height:1.1;margin-bottom:6px}
.metric-sub,.info-copy,.instruction-copy{font-size:12px;color:var(--text-light)}
.section-card{padding:24px}
.section-head{display:flex;justify-content:space-between;align-items:end;gap:16px;margin-bottom:18px}
.section-title{font-family:'Playfair Display',serif;font-size:26px;color:var(--navy);line-height:1.15;margin-top:4px}
.section-copy{font-size:13px;color:var(--text-light);max-width:700px}
.pill{background:var(--cream);border-color:var(--border);color:var(--navy)}
.list-rows{display:flex;flex-direction:column;gap:12px}
.list-row{display:flex;justify-content:space-between;gap:18px;padding:12px 0;border-bottom:1px solid var(--border)}
.list-row:last-child{border-bottom:none}
.list-row span:first-child{font-size:13px;color:var(--text-light);text-transform:uppercase;letter-spacing:.9px;font-weight:700}
.list-row span:last-child{font-size:14px;color:var(--navy);font-weight:600;text-align:right}
.warning-banner{display:none;margin-top:16px;background:rgba(217,119,6,0.1);border:1px solid rgba(217,119,6,0.24);border-radius:14px;padding:14px 16px;color:#8A5200;font-size:13px}
.warning-banner.active{display:block}
.external-link{display:inline-flex;align-items:center;gap:8px;color:var(--navy);font-weight:700;text-decoration:none}
.report-actions{display:flex;justify-content:space-between;gap:12px;align-items:center;padding:0 28px 28px}
.report-note{font-size:12px;color:var(--text-light)}
.disclaimer{max-width:1080px;margin:0 auto 64px;padding:24px 28px 32px}.disclaimer p{font-size:11px;color:var(--text-light);line-height:1.7}.disclaimer strong{color:var(--text-mid)}
.fade-up{opacity:0;transform:translateY(16px);transition:opacity .45s ease,transform .45s ease}.fade-up.visible{opacity:1;transform:translateY(0)}
@media (max-width:980px){.wizard-grid,.field-grid,.metric-grid,.card-grid,.instruction-grid,.summary-lead,.selection-grid,.insight-band{grid-template-columns:1fr}.sticky-sidebar{position:static}}
@media (max-width:768px){.site-header{padding:14px 16px}.hero{padding:54px 20px 72px}.wizard-section,.analysis-section,.report-section{padding-left:16px;padding-right:16px}.sidebar-card,.form-body,.report-body,.section-card,.hero-summary,.analysis-card,.disclaimer{padding-left:20px;padding-right:20px}.form-header,.report-header{padding:28px 20px}.step-question,.section-title{font-size:23px}.summary-title{font-size:28px}.btn-row,.section-head,.report-actions,.form-header-top,.list-row{flex-direction:column;align-items:stretch}.list-row span:last-child{text-align:left}}
@media print{body{background:#fff}.site-header,.hero,.wizard-section,.analysis-section,.disclaimer,.report-actions{display:none!important}.report-section{display:block!important;padding:0!important}.report-shell,.section-card,.hero-summary,.metric-card,.info-card,.instruction-card{box-shadow:none!important;border-color:#ddd!important}.report-shell{max-width:none!important;border:none!important}.link-btn,.btn-secondary{display:none!important}}
</style>
</head>
<body>
<header class="site-header"><a href="/portal" class="logo"><div class="logo-text">Retirement <span>Shield</span></div></a></header>
<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge">State Search Tool</div>
    <h1>Unclaimed Property <em>Finder</em></h1>
    <p class="hero-sub">Americans are owed tens of billions in forgotten assets. This tool turns that statistic into a clean state-by-state search plan: the official database link, what names to search, what documents to gather, and how to move from search result to claim.</p>
    <div class="hero-points">
      <div class="hero-point">Official state search links</div>
      <div class="hero-point">Claim prep checklist</div>
      <div class="hero-point">Print-ready family handoff</div>
    </div>
  </div>
</section>

<section class="wizard-section" id="wizardSection">
  <div class="wizard-grid">
    <aside class="sticky-sidebar">
      <div class="sidebar-card">
        <div class="sidebar-label">Finder Builder</div>
        <div class="sidebar-title">This is the easiest “found money” search most families never do.</div>
        <div class="sidebar-copy">The goal is simple: point the household to the right state database, tell them whose names to run, and reduce the friction between “maybe there’s money” and “we filed the claim.”</div>
        <div class="step-list">
          <div class="step-item active"><div class="step-num">1</div><div><div class="step-title">State + Search Setup</div><div class="step-sub">Who to search and where to start</div></div></div>
          <div class="step-item"><div class="step-num">2</div><div><div class="step-title">Claim Preparation</div><div class="step-sub">Documents and family notes before filing</div></div></div>
        </div>
        <div class="sidebar-note"><strong>Curated-link ready</strong>This tool reads a state-link directory table for the official database URL and custom claim guidance. If a state row has not been loaded yet, it safely falls back to a generic state search prompt instead of inventing a link.</div>
      </div>
    </aside>

    <div class="form-card">
      <div class="form-header">
        <div class="form-header-top"><div class="form-badge">Retirement Shield Tool</div><div class="progress-inline" id="progressText">Step 1 of 2</div></div>
        <div class="form-title">Build a state-specific unclaimed property claim plan.</div>
        <div class="form-sub">We’ll combine the official state search directory, your state-guide backdrop, and a household-friendly claim checklist so this can live in Documents like the other tools.</div>
        <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
      </div>
      <div class="form-body">
        <div class="form-step active" id="step1">
          <div class="step-label">Step 1 of 2</div>
          <div class="step-question">Which state should the search start in, and whose names should be checked?</div>
          <div class="step-help">Most people should check their current state, any former state they lived in, and close family members whose mail or financial accounts may have gone dormant.</div>
          <div class="field-grid">
            <div class="field-group">
              <label class="field-label" for="fullName">Prepared For</label>
              <input class="field-input" id="fullName" type="text" placeholder="e.g. Margaret Thomas">
            </div>
            <div class="field-group">
              <label class="field-label" for="stateSelect">Primary State</label>
              <select class="field-select" id="stateSelect"></select>
            </div>
            <div class="field-group full">
              <label class="field-label">Search Targets</label>
              <div class="selection-grid">
                <label class="selection-card"><input type="checkbox" value="self"><strong>My Name</strong><span>Search your current legal name and common variations.</span></label>
                <label class="selection-card"><input type="checkbox" value="spouse"><strong>Spouse / Partner</strong><span>Check current and prior names if relevant.</span></label>
                <label class="selection-card"><input type="checkbox" value="parent"><strong>Parent</strong><span>Adult children often find dormant property for a parent.</span></label>
                <label class="selection-card"><input type="checkbox" value="deceased_relative"><strong>Deceased Relative</strong><span>Estate claims often require extra proof and court paperwork.</span></label>
                <label class="selection-card"><input type="checkbox" value="prior_state"><strong>Prior State</strong><span>Search old states of residence, work, or property ownership too.</span></label>
                <label class="selection-card"><input type="checkbox" value="business"><strong>Old Business / LLC</strong><span>Dormant refunds and checks may sit under prior business names.</span></label>
              </div>
            </div>
          </div>
          <div class="insight-band">
            <div class="insight-chip"><strong>Why this converts</strong><span>This is practical, immediate, and easy to share with a spouse, parent, or adult child.</span></div>
            <div class="insight-chip"><strong>Best behavior</strong><span>Run the state search today, then print the plan so the household knows how to finish a claim later.</span></div>
            <div class="insight-chip"><strong>What the report does</strong><span>It gives the correct destination, claim prep notes, and family-search prompts in one saved document.</span></div>
          </div>
          <div class="btn-row"><div></div><button class="btn-next" type="button" onclick="nextStep(2)">Continue →</button></div>
        </div>

        <div class="form-step" id="step2">
          <div class="step-label">Step 2 of 2</div>
          <div class="step-question">What claim friction should we plan for?</div>
          <div class="step-help">This lets the report highlight the right proof checklist and family notes before anyone clicks into the state portal.</div>
          <div class="field-grid">
            <div class="field-group">
              <label class="field-label" for="proofSelect">Proof Situation</label>
              <select class="field-select" id="proofSelect">
                <option value="">Select one</option>
                <option value="basic">I have basic ID and current address proof</option>
                <option value="estate">This may require estate documents</option>
                <option value="multiple">I may need old addresses or name-change proof</option>
                <option value="unknown">Not sure yet</option>
              </select>
            </div>
            <div class="field-group">
              <label class="field-label" for="priorStates">Other States To Check</label>
              <input class="field-input" id="priorStates" type="text" placeholder="e.g. Florida, Texas, Illinois">
            </div>
            <div class="field-group full">
              <label class="field-label" for="notes">Family Search Notes</label>
              <textarea class="field-textarea" id="notes" placeholder="Optional: maiden names, prior business names, deceased relatives, old addresses, former employers..."></textarea>
            </div>
          </div>
          <div class="warning-banner" id="warningBanner"></div>
          <div class="btn-row"><button class="btn-back" type="button" onclick="nextStep(1)">← Back</button><button class="btn-next" type="button" onclick="generateUnclaimedPropertyReport()">Generate My Finder Report →</button></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="analysis-section" id="analysisSection">
  <div class="analysis-card">
    <div class="analysis-orb"></div>
    <div class="analysis-title">Building Your Unclaimed Property Report</div>
    <div class="analysis-sub">Loading the state guide backdrop, matching the state search directory, and shaping a claim-prep checklist the family can actually use.</div>
    <div class="analysis-steps">
      <div class="analysis-step" id="analysisStep1"><div class="analysis-indicator">1</div><div class="analysis-text">Loading state guide context...</div></div>
      <div class="analysis-step" id="analysisStep2"><div class="analysis-indicator">2</div><div class="analysis-text">Loading the state unclaimed property search directory...</div></div>
      <div class="analysis-step" id="analysisStep3"><div class="analysis-indicator">3</div><div class="analysis-text">Building the search and claim-prep instructions...</div></div>
      <div class="analysis-step" id="analysisStep4"><div class="analysis-indicator">4</div><div class="analysis-text">Saving the report into Portal Documents and Tools...</div></div>
    </div>
  </div>
</section>

<section class="report-section" id="reportSection">
  <div class="report-shell fade-up" id="reportShell">
    <div class="report-header">
      <div class="report-kicker">State Search + Claim Checklist</div>
      <div class="report-title" id="reportTitle">Unclaimed Property Finder</div>
      <div class="report-subtitle" id="reportSubtitle">A saved search plan showing where to look, whose names to run, and what to prepare before a claim starts.</div>
      <div class="report-meta">
        <div class="report-meta-item" id="metaState">State —</div>
        <div class="report-meta-item" id="metaTargets">Targets —</div>
        <div class="report-meta-item" id="metaDate">Generated —</div>
      </div>
    </div>
