---
export const prerender = false;
export const ssr = false;
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Shield Brief — Your Monthly Retirement Intelligence Report</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --navy:#0F1F3D;--navy-light:#1A2D52;--navy-mid:#152847;--gold:#C9A84C;--gold-light:#D4B96A;
  --gold-glow:rgba(201,168,76,0.12);--cream:#FAF7F0;--cream-dark:#F0EBE0;--white:#FFFFFF;
  --text-dark:#1A1A1A;--text-mid:#4A4A4A;--text-light:#7A7A7A;--green:#2E8B57;--amber:#D97706;
  --red:#B73E2E;--border:#E8E3D8;--shadow:0 2px 20px rgba(15,31,61,0.08)
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text-dark);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
.site-header{background:var(--navy);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;border-bottom:2px solid var(--gold)}
.logo{text-decoration:none}.logo-text{font-family:'Playfair Display',serif;color:var(--white);font-size:18px;font-weight:600}.logo-text span{color:var(--gold)}
.hero{background:var(--navy);padding:78px 24px 94px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 25% 18%, rgba(201,168,76,0.08) 0%, transparent 48%),radial-gradient(ellipse at 76% 74%, rgba(201,168,76,0.05) 0%, transparent 54%);pointer-events:none}
.hero-inner{position:relative;z-index:1;max-width:980px;margin:0 auto}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.22);border-radius:999px;padding:8px 18px;margin-bottom:28px;font-size:11px;font-weight:700;color:var(--gold);letter-spacing:1.2px;text-transform:uppercase}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(32px,5vw,54px);font-weight:700;color:var(--white);line-height:1.12;margin-bottom:18px}
.hero h1 em{color:var(--gold);font-style:normal}
.hero-sub{font-size:18px;color:rgba(255,255,255,0.66);line-height:1.7;max-width:850px;margin:0 auto 38px;font-weight:300}
.hero-points{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
.hero-point{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.84);border-radius:999px;padding:10px 16px;font-size:13px}
.wizard-section,.analysis-section,.report-section{padding:52px 24px 30px}
.wizard-grid{max-width:1180px;margin:0 auto;display:grid;grid-template-columns:340px minmax(0,1fr);gap:28px;align-items:start}
.sticky-sidebar{position:sticky;top:94px}
.sidebar-card,.form-card,.analysis-card,.report-shell,.disclaimer{background:var(--white);border:1px solid var(--border);border-radius:16px;box-shadow:var(--shadow)}
.sidebar-card{padding:28px}
.sidebar-label,.step-label,.section-kicker,.report-kicker{font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--gold)}
.sidebar-title{font-family:'Playfair Display',serif;font-size:28px;line-height:1.15;color:var(--navy);margin:8px 0 14px}
.sidebar-copy{font-size:14px;color:var(--text-mid);margin-bottom:22px}
.step-list{display:flex;flex-direction:column;gap:12px;margin-bottom:22px}
.step-item{display:grid;grid-template-columns:34px 1fr;gap:12px;align-items:start;padding:12px 14px;border-radius:12px;background:var(--cream);border:1px solid transparent}
.step-item.active{border-color:rgba(201,168,76,0.4);background:var(--gold-glow)}
.step-item.done .step-num{background:var(--gold);color:var(--navy)}
.step-num{width:34px;height:34px;border-radius:50%;background:var(--cream-dark);color:var(--navy);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700}
.step-title{font-size:14px;font-weight:700;color:var(--navy);line-height:1.35}
.step-sub{font-size:12px;color:var(--text-light);margin-top:2px}
.sidebar-note{border-radius:14px;background:var(--navy);color:rgba(255,255,255,0.78);padding:18px;font-size:13px}.sidebar-note strong{color:var(--white);display:block;margin-bottom:6px}
.form-card{overflow:hidden}.form-header{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-light) 100%);padding:28px 30px}
.form-header-top{display:flex;justify-content:space-between;gap:16px;align-items:center;margin-bottom:18px}
.form-badge{display:inline-flex;align-items:center;gap:8px;padding:7px 14px;background:rgba(201,168,76,0.12);border:1px solid rgba(201,168,76,0.24);color:var(--gold);border-radius:999px;font-size:11px;font-weight:700;letter-spacing:1.1px;text-transform:uppercase}
.progress-inline{color:rgba(255,255,255,0.62);font-size:12px;font-weight:600}
.form-title{font-family:'Playfair Display',serif;color:var(--white);font-size:34px;line-height:1.1;margin-bottom:10px}
.form-sub{color:rgba(255,255,255,0.64);font-size:15px;max-width:760px}
.progress-bar{height:5px;background:rgba(255,255,255,0.1);border-radius:999px;margin-top:18px;overflow:hidden}
.progress-fill{height:100%;width:50%;background:linear-gradient(90deg,var(--gold),var(--gold-light));border-radius:999px;transition:width .35s ease}
.form-body{padding:30px}.form-step{display:none}.form-step.active{display:block}
.step-question{font-family:'Playfair Display',serif;font-size:28px;line-height:1.18;color:var(--navy);margin:8px 0}
.step-help{font-size:14px;color:var(--text-light);margin-bottom:24px;max-width:760px}
.field-grid,.metric-grid,.section-grid,.bullet-grid,.monitor-grid,.watch-grid{display:grid;gap:18px}
.field-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
.metric-grid,.bullet-grid,.monitor-grid,.watch-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
.section-grid{grid-template-columns:1.1fr .9fr}
.field-group{margin-bottom:18px}.field-group.full{grid-column:1/-1}
.field-label{display:block;font-size:11px;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:.9px;margin-bottom:8px}
.field-input,.field-select{width:100%;border:1.5px solid var(--border);border-radius:10px;background:var(--cream);color:var(--text-dark);font-size:15px;font-family:'DM Sans',sans-serif;padding:14px 16px;outline:none;transition:border-color .2s,box-shadow .2s,background .2s}
.field-input:focus,.field-select:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,168,76,0.12);background:var(--white)}
.btn-row{display:flex;justify-content:space-between;gap:12px;margin-top:26px}
.btn-back,.btn-next,.btn-print,.btn-secondary{border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s ease}
.btn-back,.btn-secondary{background:transparent;border:1.5px solid var(--border);color:var(--text-mid);padding:13px 18px}
.btn-next,.btn-print{background:var(--gold);color:var(--navy);padding:13px 20px}.btn-next:hover,.btn-print:hover{background:var(--gold-light)}
.segment-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.segment-card{padding:18px;border-radius:14px;border:1.5px solid var(--border);background:var(--cream);cursor:pointer;transition:border-color .2s,transform .2s,background .2s}
.segment-card.selected{border-color:var(--gold);background:rgba(201,168,76,0.12);transform:translateY(-1px)}
.segment-card input{position:absolute;opacity:0;pointer-events:none}
.segment-card strong{display:block;color:var(--navy);font-size:15px;margin-bottom:6px}
.segment-card span{display:block;font-size:13px;color:var(--text-light);line-height:1.5}
.insight-band{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin-top:8px}
.insight-chip{border:1px solid var(--border);border-radius:14px;background:var(--cream);padding:16px}
.insight-chip strong{display:block;font-size:13px;color:var(--navy);margin-bottom:6px}
.insight-chip span{font-size:13px;color:var(--text-light)}
.analysis-section,.report-section{display:none}.analysis-section.active,.report-section.active{display:block}
.analysis-card{max-width:920px;margin:0 auto;padding:42px 28px;text-align:center}
.analysis-orb{width:96px;height:96px;margin:0 auto 20px;border-radius:50%;background:radial-gradient(circle at 35% 35%,var(--gold-light),var(--gold));position:relative;box-shadow:0 0 0 16px rgba(201,168,76,0.08),0 0 0 32px rgba(201,168,76,0.04)}
.analysis-orb::after{content:'';position:absolute;inset:24px;border-radius:50%;background:var(--navy);opacity:.16}
.analysis-title{font-family:'Playfair Display',serif;font-size:34px;color:var(--navy);margin-bottom:8px}
.analysis-sub{font-size:15px;color:var(--text-light);margin-bottom:28px}
.analysis-steps{max-width:560px;margin:0 auto;display:flex;flex-direction:column;gap:12px}
.analysis-step{display:grid;grid-template-columns:38px 1fr;gap:14px;align-items:center;text-align:left;padding:14px 16px;border-radius:12px;background:var(--cream);border:1px solid var(--border)}
.analysis-indicator{width:38px;height:38px;border-radius:50%;background:var(--gold-glow);color:var(--gold);display:flex;align-items:center;justify-content:center;font-weight:700}
.analysis-step.done .analysis-indicator{background:var(--gold);color:var(--navy)}.analysis-text{font-size:14px;color:var(--text-mid)}
.report-shell{max-width:1080px;margin:0 auto;overflow:hidden}
.report-header{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-mid) 100%);padding:36px 32px 30px;color:var(--white)}
.report-title{font-family:'Playfair Display',serif;font-size:clamp(30px,4vw,44px);line-height:1.1;margin:10px 0 12px}
.report-subtitle{color:rgba(255,255,255,0.72);font-size:15px;max-width:800px}
.report-meta{margin-top:20px;display:flex;flex-wrap:wrap;gap:12px}
.report-meta-item,.pill{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:999px;padding:8px 14px;font-size:12px;color:rgba(255,255,255,0.8)}
.report-body{padding:28px;display:grid;gap:22px}
.hero-summary,.section-card{background:var(--white);border:1px solid var(--border);border-radius:16px}
.hero-summary{padding:28px;background:linear-gradient(135deg,rgba(15,31,61,0.03),rgba(201,168,76,0.08)),var(--white)}
.summary-lead{display:grid;grid-template-columns:1.05fr .95fr;gap:22px}
.summary-title{font-family:'Playfair Display',serif;font-size:34px;color:var(--navy);line-height:1.08;margin-bottom:10px}.summary-title em{color:var(--gold);font-style:normal}
.summary-copy{font-size:15px;color:var(--text-mid)}
.summary-benchmark{background:var(--navy);color:rgba(255,255,255,0.82);border-radius:16px;padding:22px}
.summary-benchmark .headline{font-family:'Playfair Display',serif;font-size:24px;color:var(--white);line-height:1.14;margin:8px 0 10px}
.metric-card,.monitor-card,.watch-card{background:var(--cream);border:1px solid var(--border);border-radius:14px;padding:16px}
.metric-label,.monitor-label,.watch-label{font-size:11px;text-transform:uppercase;letter-spacing:.9px;color:var(--text-light);font-weight:700;margin-bottom:6px}
.metric-value{font-family:'Playfair Display',serif;font-size:30px;color:var(--navy);line-height:1;margin-bottom:6px}
.metric-sub,.monitor-copy,.watch-copy{font-size:12px;color:var(--text-light)}
.section-card{padding:24px}
.section-head{display:flex;justify-content:space-between;align-items:end;gap:16px;margin-bottom:18px}
.section-title{font-family:'Playfair Display',serif;font-size:26px;color:var(--navy);line-height:1.15;margin-top:4px}
.section-copy{font-size:13px;color:var(--text-light);max-width:700px}
.pill{background:var(--cream);border-color:var(--border);color:var(--navy)}
.weather-callout{background:var(--cream);border:1px solid var(--border);border-left:4px solid var(--gold);border-radius:14px;padding:18px;font-size:14px;color:var(--text-mid)}
.local-facts{display:flex;flex-direction:column;gap:12px}
.list-row{display:flex;justify-content:space-between;gap:18px;padding:12px 0;border-bottom:1px solid var(--border)}
.list-row:last-child{border-bottom:none}
.list-row span:first-child{font-size:13px;color:var(--text-light);text-transform:uppercase;letter-spacing:.9px;font-weight:700}
.list-row span:last-child{font-size:14px;color:var(--navy);font-weight:600;text-align:right}
.bullet-list{display:flex;flex-direction:column;gap:12px}
.bullet-item{display:flex;gap:10px;align-items:flex-start;padding-top:10px;border-top:1px solid var(--border)}
.bullet-item:first-child{padding-top:0;border-top:none}
.bullet-dot{width:22px;height:22px;border-radius:50%;background:var(--gold-glow);color:var(--gold);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;margin-top:1px}
.bullet-text{font-size:14px;color:var(--text-mid)}
.warning-banner{display:none;margin-top:16px;background:rgba(217,119,6,0.1);border:1px solid rgba(217,119,6,0.24);border-radius:14px;padding:14px 16px;color:#8A5200;font-size:13px}
.warning-banner.active{display:block}
.report-actions{display:flex;justify-content:space-between;gap:12px;align-items:center;padding:0 28px 28px}
.report-note{font-size:12px;color:var(--text-light)}
.disclaimer{max-width:1080px;margin:0 auto 64px;padding:24px 28px 32px}.disclaimer p{font-size:11px;color:var(--text-light);line-height:1.7}.disclaimer strong{color:var(--text-mid)}
.fade-up{opacity:0;transform:translateY(16px);transition:opacity .45s ease,transform .45s ease}.fade-up.visible{opacity:1;transform:translateY(0)}
@media (max-width:980px){.wizard-grid,.field-grid,.metric-grid,.section-grid,.bullet-grid,.monitor-grid,.watch-grid,.summary-lead,.segment-grid,.insight-band{grid-template-columns:1fr}.sticky-sidebar{position:static}}
@media (max-width:768px){.site-header{padding:14px 16px}.hero{padding:54px 20px 72px}.wizard-section,.analysis-section,.report-section{padding-left:16px;padding-right:16px}.sidebar-card,.form-body,.report-body,.section-card,.hero-summary,.analysis-card,.disclaimer{padding-left:20px;padding-right:20px}.form-header,.report-header{padding:28px 20px}.step-question,.section-title{font-size:23px}.summary-title{font-size:28px}.btn-row,.section-head,.report-actions,.form-header-top,.list-row{flex-direction:column;align-items:stretch}.list-row span:last-child{text-align:left}}
@media print{body{background:#fff}.site-header,.hero,.wizard-section,.analysis-section,.disclaimer,.report-actions{display:none!important}.report-section{display:block!important;padding:0!important}.report-shell,.section-card,.hero-summary,.metric-card,.monitor-card,.watch-card{box-shadow:none!important;border-color:#ddd!important}.report-shell{max-width:none!important;border:none!important}.section-card{break-inside:avoid;page-break-inside:avoid}}
</style>
</head>
<body>
<header class="site-header"><a href="/portal" class="logo"><div class="logo-text">Retirement <span>Shield</span></div></a></header>

<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge">Monthly Intelligence Tool</div>
    <h1>The Shield <em>Brief</em></h1>
    <p class="hero-sub">A monthly retirement intelligence report calibrated to the retiree’s planning lens, state, and county. This is not generic market commentary. It is a personal briefing on the rates, inflation, policy, estate, and healthcare signals that actually matter after the accumulation phase.</p>
    <div class="hero-points">
      <div class="hero-point">County and state-specific framing</div>
      <div class="hero-point">Segment-calibrated monthly analysis</div>
      <div class="hero-point">Print-ready PDF saved to the portal</div>
    </div>
  </div>
</section>

<section class="wizard-section" id="wizardSection">
  <div class="wizard-grid">
    <aside class="sticky-sidebar">
      <div class="sidebar-card">
        <div class="sidebar-label">Brief Builder</div>
        <div class="sidebar-title">This is the monthly note retirees actually need.</div>
        <div class="sidebar-copy">The point is to turn broad data into “what changed for someone like me in my county, my state, and my planning lane?”</div>
        <div class="step-list">
          <div class="step-item active" data-step-indicator="1"><div class="step-num">1</div><div><div class="step-title">Location</div><div class="step-sub">State and county drive the local lens</div></div></div>
          <div class="step-item" data-step-indicator="2"><div class="step-num">2</div><div><div class="step-title">Planning Lens</div><div class="step-sub">Choose the segment the brief should emphasize</div></div></div>
        </div>
        <div class="sidebar-note"><strong>Live-data aware</strong>This brief uses external macro feeds plus the existing county and state tables already in the product. If a feed is missing, the report still renders and says so clearly.</div>
      </div>
    </aside>

    <div class="form-card">
      <div class="form-header">
        <div class="form-header-top"><div class="form-badge">Retirement Shield Tool</div><div class="progress-inline" id="progressText">Step 1 of 2</div></div>
        <div class="form-title">Put this month in retirement terms.</div>
        <div class="form-sub">We’ll build a monthly PDF-style briefing around your geography and the planning angle you care about most: longevity, tax efficiency, or legacy transfer.</div>
        <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
      </div>
      <div class="form-body">
        <div class="form-step active" id="step1">
          <div class="step-label">Step 1 of 2</div>
          <div class="step-question">Where should the brief be anchored?</div>
          <div class="step-help">County and state shape the local context, not just the market data. That lets the report feel like a real briefing instead of a mass-market newsletter.</div>
          <div class="field-grid">
            <div class="field-group">
              <label class="field-label" for="fullName">Prepared For</label>
              <input class="field-input" id="fullName" type="text" placeholder="e.g. Margaret Thomas">
            </div>
            <div class="field-group">
              <label class="field-label" for="stateSelect">State</label>
              <select class="field-select" id="stateSelect"></select>
            </div>
            <div class="field-group full">
              <label class="field-label" for="countySelect">County</label>
              <select class="field-select" id="countySelect" disabled>
                <option value="">Select your county…</option>
              </select>
            </div>
          </div>
          <div class="insight-band">
            <div class="insight-chip"><strong>What this pulls</strong><span>Rates, inflation, Treasury context, market monitor quotes, county population, longevity framing, and state planning overlay.</span></div>
            <div class="insight-chip"><strong>What this is not</strong><span>Not a personalized investment recommendation and not generic CNBC-style recap copy.</span></div>
            <div class="insight-chip"><strong>Why it helps</strong><span>It converts abstract macro noise into a monthly retirement weather forecast for the part of retirement you actually live in.</span></div>
          </div>
          <div class="btn-row"><div></div><button class="btn-next" type="button" onclick="nextStep(2)">Continue →</button></div>
        </div>

        <div class="form-step" id="step2">
          <div class="step-label">Step 2 of 2</div>
          <div class="step-question">Which planning lens should lead the brief?</div>
          <div class="step-help">If your quiz segment is already clear in your head, use that. If not, pick the lens that feels most urgent right now.</div>
          <div class="segment-grid">
            <label class="segment-card">
              <input type="radio" name="segment" value="longevity">
              <strong>Longevity Worrier</strong>
              <span>Healthcare cost trend, county longevity framing, and the “how long does this have to last?” angle.</span>
            </label>
            <label class="segment-card">
              <input type="radio" name="segment" value="tax">
              <strong>Tax-Aware Optimizer</strong>
              <span>IRMAA pressure, rate backdrop, and whether this month is friendly or unfriendly to tax management.</span>
            </label>
            <label class="segment-card">
              <input type="radio" name="segment" value="legacy">
              <strong>Legacy Builder</strong>
              <span>State probate and transfer friction, death-tax context, and estate-watch framing.</span>
            </label>
          </div>
          <div class="warning-banner" id="warningBanner"></div>
          <div class="btn-row"><button class="btn-back" type="button" onclick="nextStep(1)">← Back</button><button class="btn-next" type="button" onclick="generateShieldBrief()">Generate My Monthly Brief →</button></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="analysis-section" id="analysisSection">
  <div class="analysis-card">
    <div class="analysis-orb"></div>
    <div class="analysis-title">Building Your Monthly Brief</div>
    <div class="analysis-sub">Pulling macro data, county context, market monitor quotes, and state planning overlays into one retiree-specific briefing.</div>
    <div class="analysis-steps">
      <div class="analysis-step" id="analysisStep1"><div class="analysis-indicator">1</div><div class="analysis-text">Loading county population and state-planning context...</div></div>
      <div class="analysis-step" id="analysisStep2"><div class="analysis-indicator">2</div><div class="analysis-text">Pulling rates, inflation, and Treasury data for the monthly weather forecast...</div></div>
      <div class="analysis-step" id="analysisStep3"><div class="analysis-indicator">3</div><div class="analysis-text">Applying the selected planning lens to decide what matters most this month...</div></div>
      <div class="analysis-step" id="analysisStep4"><div class="analysis-indicator">4</div><div class="analysis-text">Saving the finished report into Portal Documents and Tools...</div></div>
    </div>
  </div>
</section>

<section class="report-section" id="reportSection">
  <div class="report-shell fade-up" id="reportShell">
    <div class="report-header">
      <div class="report-kicker">Monthly Retirement Intelligence Report</div>
      <div class="report-title" id="reportTitle">The Shield Brief</div>
      <div class="report-subtitle" id="reportSubtitle">A county-aware, state-aware, segment-aware monthly briefing for retirees.</div>
      <div class="report-meta">
        <div class="report-meta-item" id="metaLocation">Location —</div>
        <div class="report-meta-item" id="metaSegment">Segment —</div>
        <div class="report-meta-item" id="metaMonth">Month —</div>
      </div>
    </div>

    <div class="report-body">
      <div class="hero-summary">
        <div class="summary-lead">
          <div>
            <div class="section-kicker">Headline</div>
            <div class="summary-title" id="summaryTitle">This month’s retirement weather is now on <em>one page</em>.</div>
            <div class="summary-copy" id="summaryCopy">Summary appears here.</div>
          </div>
          <div class="summary-benchmark">
            <div class="section-kicker" style="color:rgba(255,255,255,0.6);">Primary Angle</div>
            <div class="headline" id="benchmarkHeadline">Segment headline</div>
            <div id="benchmarkCopy">Segment summary appears here.</div>
          </div>
        </div>
        <div class="metric-grid" style="margin-top:22px;">
          <div class="metric-card"><div class="metric-label">Inflation</div><div class="metric-value" id="inflationValue">—</div><div class="metric-sub" id="inflationSub">Broad CPI year-over-year</div></div>
          <div class="metric-card"><div class="metric-label">Medical Inflation</div><div class="metric-value" id="medicalValue">—</div><div class="metric-sub" id="medicalSub">Healthcare cost pressure</div></div>
          <div class="metric-card"><div class="metric-label">Treasury Backdrop</div><div class="metric-value" id="treasuryValue">—</div><div class="metric-sub" id="treasurySub">Average marketable rate context</div></div>
        </div>
      </div>

      <div class="section-card">
        <div class="section-head">
          <div><div class="section-kicker">Retirement Weather Forecast</div><div class="section-title">What this month actually means</div><div class="section-copy">This is the plain-English top line meant for retirees, not for people still in the accumulation phase.</div></div>
          <div class="pill" id="weatherPill">Forecast</div>
        </div>
        <div class="weather-callout" id="weatherForecast">Forecast appears here.</div>
      </div>

      <div class="section-card">
        <div class="section-head">
          <div><div class="section-kicker">Local Context</div><div class="section-title">Why your county and state change the read</div><div class="section-copy">The same inflation print can feel very different depending on your longevity lens, local population footprint, and state-planning environment.</div></div>
          <div class="pill" id="locationPill">Local</div>
        </div>
        <div class="section-grid">
          <div class="local-facts">
            <div class="list-row"><span>County population</span><span id="countyPopulationValue">—</span></div>
            <div class="list-row"><span>County life expectancy</span><span id="lifeExpectancyValue">—</span></div>
            <div class="list-row"><span>Probate backdrop</span><span id="probateContextValue">—</span></div>
            <div class="list-row"><span>State death-tax posture</span><span id="taxContextValue">—</span></div>
          </div>
          <div class="weather-callout" id="localCopy">Local copy appears here.</div>
        </div>
      </div>

      <div class="section-card">
        <div class="section-head">
          <div><div class="section-kicker">Segment Intelligence</div><div class="section-title" id="segmentSectionTitle">What matters most for this planning lens</div><div class="section-copy">This is the customized section that changes based on the retiree’s primary concern.</div></div>
          <div class="pill" id="segmentPill">Segment</div>
        </div>
        <div class="bullet-list" id="segmentBullets"></div>
      </div>

      <div class="section-card">
        <div class="section-head">
          <div><div class="section-kicker">Market Monitor</div><div class="section-title">Quick market and income anchors</div><div class="section-copy">These are context blocks, not recommendations. The goal is to show what happened in the broad market and dividend-oriented monitor set.</div></div>
          <div class="pill">Monitor</div>
        </div>
        <div class="monitor-grid" id="marketMonitorGrid"></div>
      </div>

      <div class="section-card">
        <div class="section-head">
          <div><div class="section-kicker">State Watch</div><div class="section-title">Legacy and law watchlist</div><div class="section-copy">If your state has tracked watch items in the database, they appear here. Otherwise the report falls back to current state-guide posture.</div></div>
          <div class="pill" id="stateWatchPill">Watch</div>
        </div>
        <div class="watch-grid" id="stateWatchGrid"></div>
      </div>
    </div>

    <div class="report-actions">
      <div class="report-note">Saved reports reopen from Portal Documents and print cleanly as a monthly PDF briefing.</div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <button class="btn-secondary" type="button" onclick="editShieldBrief()">Edit Inputs</button>
        <button class="btn-print" type="button" onclick="window.print()">Print / Save PDF</button>
      </div>
    </div>
  </div>
</section>

<div class="disclaimer">
  <p><strong>Important Disclosures:</strong> The Shield Brief is provided for educational purposes only and does not constitute legal, tax, investment, insurance, or financial advice. Economic and market data are pulled from third-party public and commercial feeds and may be delayed, revised, unavailable, or incomplete at the time of report generation. State-specific planning context is high-level and should not be treated as legal advice or a substitute for attorney review. Retirement Shield is not a law firm and does not provide personalized investment recommendations. © 2026 Retirement Shield. All rights reserved.</p>
</div>

<script>
const STATE_OPTIONS = [
  ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],['CA','California'],['CO','Colorado'],
  ['CT','Connecticut'],['DE','Delaware'],['FL','Florida'],['GA','Georgia'],['HI','Hawaii'],['ID','Idaho'],
  ['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],['KY','Kentucky'],['LA','Louisiana'],
  ['ME','Maine'],['MD','Maryland'],['MA','Massachusetts'],['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],
  ['MO','Missouri'],['MT','Montana'],['NE','Nebraska'],['NV','Nevada'],['NH','New Hampshire'],['NJ','New Jersey'],
  ['NM','New Mexico'],['NY','New York'],['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
  ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],['SD','South Dakota'],
  ['TN','Tennessee'],['TX','Texas'],['UT','Utah'],['VT','Vermont'],['VA','Virginia'],['WA','Washington'],
  ['WV','West Virginia'],['WI','Wisconsin'],['WY','Wyoming'],['DC','District of Columbia']
];

STATE_OPTIONS.forEach(([code, name]) => {
  const option = document.createElement('option');
  option.value = code;
  option.textContent = name;
  document.getElementById('stateSelect').appendChild(option);
});

document.querySelectorAll('.segment-card').forEach((card) => {
  card.addEventListener('click', () => {
    const input = card.querySelector('input');
    if (!input) return;
    input.checked = true;
    syncSegments();
  });
});

let currentStep = 1;

function syncSegments() {
  document.querySelectorAll('.segment-card').forEach((card) => {
    const input = card.querySelector('input');
    card.classList.toggle('selected', Boolean(input?.checked));
  });
}

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach((section) => section.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');
  document.querySelectorAll('.step-item').forEach((item, index) => {
    item.classList.remove('active','done');
    if (index + 1 < step) item.classList.add('done');
    if (index + 1 === step) item.classList.add('active');
  });
  currentStep = step;
  document.getElementById('progressText').textContent = `Step ${step} of 2`;
  document.getElementById('progressFill').style.width = `${(step / 2) * 100}%`;
}

async function onStateChange(value) {
  const countySelect = document.getElementById('countySelect');
  countySelect.innerHTML = '<option value="">Select your county…</option>';
  countySelect.disabled = true;

  if (!value) return;

  const stateName = STATE_OPTIONS.find(([code]) => code === value)?.[1] || '';
  const normalizedState = stateName.toLowerCase().trim().replace(/\s+/g, '-');
  const supabase = window.shieldBriefSupabase;
  if (!supabase) return;

  const { data, error } = await supabase
    .from('county_population')
    .select('county')
    .eq('state', normalizedState)
    .order('county', { ascending: true });

  if (error) {
    console.error('County fetch error:', error);
    return;
  }

  countySelect.innerHTML = `
    <option value="">Select your county…</option>
    ${(data || []).map((row) => `<option value="${row.county}">${row.county}</option>`).join('')}
  `;
  countySelect.disabled = false;
}

function getFormData() {
  const stateCode = document.getElementById('stateSelect').value;
  return {
    fullName: document.getElementById('fullName').value.trim() || 'Retirement Shield Client',
    stateCode,
    stateName: STATE_OPTIONS.find(([code]) => code === stateCode)?.[1] || '',
    county: document.getElementById('countySelect').value,
    segment: document.querySelector('input[name="segment"]:checked')?.value || ''
  };
}

function validateData(data) {
  if (!data.stateCode) return 'Choose a state.';
  if (!data.county) return 'Choose a county.';
  if (!data.segment) return 'Choose the planning lens for this brief.';
  return '';
}

function percentLabel(value, digits = 1) {
  if (value == null) return 'review needed';
  return `${Number(value).toFixed(digits)}%`;
}

function renderSegmentBullets(items) {
  const wrap = document.getElementById('segmentBullets');
  wrap.innerHTML = items.map((item, index) => `
    <div class="bullet-item">
      <div class="bullet-dot">${index + 1}</div>
      <div class="bullet-text">${item}</div>
    </div>
  `).join('');
}

function populateMonitor(items) {
  const wrap = document.getElementById('marketMonitorGrid');
  if (!items?.length) {
    wrap.innerHTML = `
      <div class="monitor-card">
        <div class="monitor-label">Market monitor</div>
        <div class="metric-value">Feed</div>
        <div class="monitor-copy">Live market quote blocks were unavailable for this run, so the brief is leaning on macro and state context instead.</div>
      </div>
    `;
    return;
  }

  wrap.innerHTML = items.map((item) => `
    <div class="monitor-card">
      <div class="monitor-label">${item.name || item.symbol}</div>
      <div class="metric-value">${item.price != null ? `$${Number(item.price).toFixed(2)}` : '—'}</div>
      <div class="monitor-copy">${item.changePct != null ? `${Number(item.changePct).toFixed(2)}% on the latest quote pull.` : 'Change not available.'}</div>
    </div>
  `).join('');
}

function populateWatchItems(items, stateGuide) {
  const wrap = document.getElementById('stateWatchGrid');
  if (items?.length) {
    wrap.innerHTML = items.map((item) => `
      <div class="watch-card">
        <div class="watch-label">${item.category || 'State watch'} · ${item.effective_date || 'Current'}</div>
        <div class="metric-value">${item.headline || 'State item'}</div>
        <div class="watch-copy">${item.summary || ''}</div>
      </div>
    `).join('');
    return;
  }

  wrap.innerHTML = `
    <div class="watch-card">
      <div class="watch-label">Probate posture</div>
      <div class="metric-value">${stateGuide?.probateCostDisplay || 'Review'}</div>
      <div class="watch-copy">${stateGuide?.probateTimelineDisplay || 'No dedicated state watch row is loaded yet, so the brief is using the standing state-guide posture.'}</div>
    </div>
    <div class="watch-card">
      <div class="watch-label">State tax posture</div>
      <div class="metric-value">${stateGuide?.stateEstateTax && stateGuide.stateEstateTax !== 'None' ? stateGuide.stateEstateTax : stateGuide?.stateInheritanceTax && stateGuide.stateInheritanceTax !== 'None' ? stateGuide.stateInheritanceTax : 'None / low'}</div>
      <div class="watch-copy">No manual state law-change rows are loaded yet for this state, so death-tax context is falling back to the current guide snapshot.</div>
    </div>
    <div class="watch-card">
      <div class="watch-label">Transfer tools</div>
      <div class="metric-value">${stateGuide?.ladyBirdAvailable ? stateGuide.ladyBirdDisplay : stateGuide?.todDisplay || 'Review'}</div>
      <div class="watch-copy">Title and beneficiary coordination remain the practical transfer issue even when no live law-change item is loaded.</div>
    </div>
  `;
}

function populateReport(report) {
  const stateGuide = report.stateGuide || null;
  const warnings = Array.isArray(report.warnings) ? report.warnings : [];
  document.getElementById('reportTitle').textContent = `The Shield Brief for ${report.fullName}`;
  document.getElementById('reportSubtitle').textContent = `Your ${report.monthLabel} retirement intelligence report for ${report.county}, ${report.stateName}, calibrated to the ${report.segmentLabel} lens.`;
  document.getElementById('metaLocation').textContent = `${report.county}, ${report.stateName}`;
  document.getElementById('metaSegment').textContent = report.segmentLabel;
  document.getElementById('metaMonth').textContent = report.monthLabel;
  document.getElementById('summaryTitle').innerHTML = `${report.monthLabel} in <em>retirement terms</em>.`;
  document.getElementById('summaryCopy').textContent = `This month’s brief is anchored to ${report.county}, ${report.stateName} and written through the ${report.segmentLabel} lens so the macro summary maps back to the retiree’s actual concerns.`;
  document.getElementById('benchmarkHeadline').textContent = report.segmentSection?.headline || report.segmentLabel;
  document.getElementById('benchmarkCopy').textContent = report.segmentSection?.summary || 'Segment summary not available.';
  document.getElementById('inflationValue').textContent = percentLabel(report.macro?.inflationYoY);
  document.getElementById('medicalValue').textContent = percentLabel(report.macro?.medicalInflationYoY);
  document.getElementById('treasuryValue').textContent = percentLabel(report.macro?.marketableAvgRate, 2);
  document.getElementById('weatherPill').textContent = warnings.length ? `${warnings.length} feed note${warnings.length === 1 ? '' : 's'}` : 'Live stack';
  document.getElementById('weatherForecast').textContent = report.macro?.weatherForecast || 'Forecast unavailable.';
  document.getElementById('locationPill').textContent = `${report.county}, ${report.stateCode}`;
  document.getElementById('countyPopulationValue').textContent = report.countyPopulation != null ? Number(report.countyPopulation).toLocaleString('en-US') : 'Review needed';
  document.getElementById('lifeExpectancyValue').textContent = report.lifeExpectancy != null ? `${Number(report.lifeExpectancy).toFixed(1)} years` : 'Review needed';
  document.getElementById('probateContextValue').textContent = stateGuide ? `${stateGuide.probateCostDisplay} · ${stateGuide.probateTimelineDisplay}` : 'Review needed';
  document.getElementById('taxContextValue').textContent = stateGuide ? `${stateGuide.stateEstateTax || 'Unknown'} / ${stateGuide.stateInheritanceTax || 'Unknown'}` : 'Review needed';
  document.getElementById('localCopy').textContent = report.segment === 'longevity'
    ? `${report.county} gives the monthly healthcare and longevity section a local anchor instead of forcing you to read national averages as if they were personal facts.`
    : report.segment === 'tax'
      ? `${report.county} and ${report.stateName} matter because tax drag and retirement frictions are always lived locally, even when the rate story is national.`
      : `${report.stateName} transfer friction, probate drag, and title tools matter more to the legacy lens than broad market narration ever will.`;
  document.getElementById('segmentSectionTitle').textContent = report.segmentSection?.headline || 'Segment intelligence';
  document.getElementById('segmentPill').textContent = report.segmentLabel;
  renderSegmentBullets(report.segmentSection?.bullets || []);
  populateMonitor(report.marketMonitor || []);
  populateWatchItems(report.stateWatchItems || [], stateGuide);

  const warningBanner = document.getElementById('warningBanner');
  if (warnings.length) {
    warningBanner.classList.add('active');
    warningBanner.textContent = warnings.join(' ');
  } else {
    warningBanner.classList.remove('active');
    warningBanner.textContent = '';
  }
}

async function saveShieldBrief(report, formData) {
  const supabase = window.shieldBriefSupabase;
  if (!supabase) return null;
  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const payload = {
    user_id: userId,
    full_name: report.fullName,
    state_code: report.stateCode,
    state_name: report.stateName,
    county_name: report.county,
    county_population: report.countyPopulation,
    quiz_segment: report.segment,
    segment_label: report.segmentLabel,
    generated_month: report.monthLabel,
    inflation_yoy: report.macro?.inflationYoY ?? null,
    medical_inflation_yoy: report.macro?.medicalInflationYoY ?? null,
    fed_funds_rate: report.macro?.fedFundsCurrent ?? null,
    treasury_rate: report.macro?.marketableAvgRate ?? null,
    report_title: `The Shield Brief for ${report.fullName}`,
    report_payload: {
      ...report,
      formData
    }
  };

  const { error } = await supabase
    .from('shield_brief_reports')
    .insert(payload);

  if (error) {
    console.error('Failed to save Shield Brief report:', error);
  }
}

function showGeneratedBrief() {
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  const steps = ['analysisStep1','analysisStep2','analysisStep3','analysisStep4'];
  let delay = 0;
  steps.forEach((id, index) => {
    delay += 450;
    setTimeout(() => {
      document.getElementById(id).classList.add('done');
      if (index === steps.length - 1) {
        setTimeout(() => {
          document.getElementById('analysisSection').classList.remove('active');
          document.getElementById('reportSection').classList.add('active');
          const shell = document.getElementById('reportShell');
          shell.classList.add('visible');
          shell.scrollIntoView({ behavior: 'smooth', block: 'start' });
          document.querySelectorAll('.fade-up').forEach((el, i) => setTimeout(() => el.classList.add('visible'), i * 80));
        }, 400);
      }
    }, delay);
  });
}

function showHydratedBrief() {
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('reportSection').classList.add('active');
  document.getElementById('reportShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedSubmission(reportRow) {
  const payload = reportRow?.report_payload;
  if (!payload) return false;
  const formData = payload.formData || {};
  document.getElementById('fullName').value = formData.fullName || payload.fullName || '';
  document.getElementById('stateSelect').value = formData.stateCode || payload.stateCode || '';
  if (document.getElementById('stateSelect').value) {
    await onStateChange(document.getElementById('stateSelect').value);
  }
  document.getElementById('countySelect').value = formData.county || payload.county || '';
  document.querySelectorAll('input[name="segment"]').forEach((input) => {
    input.checked = input.value === (formData.segment || payload.segment);
  });
  syncSegments();
  populateReport(payload);
  showHydratedBrief();
  return true;
}

async function generateShieldBrief() {
  const formData = getFormData();
  const validationError = validateData(formData);
  if (validationError) {
    alert(validationError);
    return;
  }

  const response = await fetch('/api/shield-brief/monthly', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(formData)
  });

  const payload = await response.json().catch(() => null);
  if (!response.ok || !payload?.report) {
    alert(payload?.error || 'Unable to build the monthly brief right now.');
    return;
  }

  populateReport(payload.report);
  await saveShieldBrief(payload.report, formData);
  showGeneratedBrief();
}

function editShieldBrief() {
  document.getElementById('reportSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(2);
}

document.getElementById('stateSelect').addEventListener('change', (event) => onStateChange(event.target.value));

window.nextStep = nextStep;
window.generateShieldBrief = generateShieldBrief;
window.editShieldBrief = editShieldBrief;
window.hydrateShieldBriefSubmission = hydrateSavedSubmission;
window.onShieldBriefStateChange = onStateChange;
window.SHIELD_BRIEF_STATE_OPTIONS = STATE_OPTIONS;
</script>

<script type="module">
import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'

const supabase = createClient(
  "https://nyiturqeotdxucfdurzu.supabase.co",
  "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im55aXR1cnFlb3RkeHVjZmR1cnp1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIxMzI0ODgsImV4cCI6MjA4NzcwODQ4OH0.CvYju6UTaCGD_Zd-8FVTcB-yW9YVG_jQtwkd0l7mIV0",
  {
    auth: {
      persistSession: true,
      autoRefreshToken: true,
      detectSessionInUrl: true,
      flowType: 'pkce'
    }
  }
)

window.shieldBriefSupabase = supabase;

const params = new URLSearchParams(window.location.search);
const utm = params.get('utm');
const reportMode = params.get('report');

if (utm && reportMode === 'latest' && window.hydrateShieldBriefSubmission) {
  const { data: report } = await supabase
    .from('shield_brief_reports')
    .select('*')
    .eq('user_id', utm)
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle();

  if (report) {
    await window.hydrateShieldBriefSubmission(report);
  }
} else if (utm) {
  const { data: profile } = await supabase
    .from('profiles')
    .select('full_name,state,county')
    .eq('id', utm)
    .maybeSingle();

  if (profile?.full_name) {
    const nameInput = document.getElementById('fullName');
    if (nameInput && !nameInput.value) nameInput.value = profile.full_name;
  }

  const stateOptions = window.SHIELD_BRIEF_STATE_OPTIONS || [];
  const matchedState = stateOptions.find(([, name]) => String(profile?.state || '').toLowerCase() === name.toLowerCase());
  if (matchedState) {
    document.getElementById('stateSelect').value = matchedState[0];
    await window.onShieldBriefStateChange?.(matchedState[0]);
  }

  if (profile?.county) {
    const countySelect = document.getElementById('countySelect');
    countySelect.value = profile.county;
  }
}
</script>
