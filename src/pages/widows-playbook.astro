---
export const prerender = false;
export const ssr = false;
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Widow's Playbook — Retirement Shield</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --navy: #0F1F3D;
  --navy-light: #1A2D52;
  --navy-mid: #152847;
  --gold: #C9A84C;
  --gold-light: #D4B96A;
  --gold-pale: #F5EDD6;
  --gold-glow: rgba(201, 168, 76, 0.12);
  --cream: #FAF7F0;
  --cream-dark: #F0EBE0;
  --white: #FFFFFF;
  --text-dark: #1A1A1A;
  --text-mid: #4A4A4A;
  --text-light: #7A7A7A;
  --red: #C0392B;
  --red-bg: #FDF2F0;
  --green: #27AE60;
  --green-bg: #F0FDF4;
  --amber: #E67E22;
  --amber-bg: #FFF8F0;
  --blue: #2980B9;
  --blue-bg: #EBF5FB;
  --border: #E8E3D8;
  --shadow: 0 2px 20px rgba(15, 31, 61, 0.08);
  --shadow-lg: 0 8px 40px rgba(15, 31, 61, 0.12);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--text-dark);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ═══════════════════════════════════════
   HEADER
   ═══════════════════════════════════════ */
.site-header {
  background: var(--navy);
  padding: 0 32px;
  min-height: 72px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2px solid var(--gold);
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 14px;
  cursor: pointer;
  text-decoration: none;
}

.shield-icon {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: inset 0 0 0 1px rgba(15,31,61,0.08);
}

.shield-icon::before {
  content: '';
  width: 14px;
  height: 16px;
  background: var(--navy);
  clip-path: polygon(50% 0%, 92% 18%, 86% 72%, 50% 100%, 14% 72%, 8% 18%);
}

.brand {
  font-family: 'Playfair Display', serif;
  color: var(--white);
  font-size: 22px;
  font-weight: 600;
}

.brand span { color: var(--gold); }

.nav-links {
  display: flex;
  gap: 28px;
  list-style: none;
}

.nav-links a {
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  transition: color 0.2s;
}

.nav-links a:hover { color: var(--gold); }

/* ═══════════════════════════════════════
   STEP 1: INTAKE FORM
   ═══════════════════════════════════════ */
.intake-section {
  background: var(--navy);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 24px;
  position: relative;
  overflow: hidden;
}

.intake-section::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse at 20% 30%, rgba(201,168,76,0.05) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 70%, rgba(201,168,76,0.03) 0%, transparent 50%);
  pointer-events: none;
}

.intake-container {
  position: relative;
  z-index: 1;
  max-width: 560px;
  width: 100%;
}

.intake-header { text-align: center; margin-bottom: 40px; }

.intake-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(201,168,76,0.1);
  border: 1px solid rgba(201,168,76,0.2);
  border-radius: 100px;
  padding: 8px 20px;
  margin-bottom: 24px;
  font-size: 11px;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: 1.5px;
  text-transform: uppercase;
}

.intake-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 5vw, 44px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.15;
  margin-bottom: 16px;
}

.intake-title em {
  font-style: italic;
  color: var(--gold);
}

.intake-sub {
  font-size: 16px;
  color: rgba(255,255,255,0.5);
  line-height: 1.65;
  max-width: 460px;
  margin: 0 auto;
  font-weight: 300;
}

/* Form card */
.form-card {
  background: var(--white);
  border-radius: 12px;
  padding: 36px;
  box-shadow: 0 8px 40px rgba(0,0,0,0.3);
}

.form-progress {
  display: flex;
  gap: 4px;
  margin-bottom: 28px;
}

.progress-dot {
  flex: 1;
  height: 3px;
  background: var(--cream-dark);
  border-radius: 2px;
  transition: background 0.3s;
}

.progress-dot.active { background: var(--gold); }
.progress-dot.done { background: var(--navy); }

.form-step { display: none; }
.form-step.active { display: block; }

.step-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--text-light);
  margin-bottom: 6px;
}

.step-question {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 600;
  color: var(--navy);
  margin-bottom: 24px;
  line-height: 1.3;
}

/* Form elements */
.field-group { margin-bottom: 20px; }

.field-label {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: var(--text-mid);
  margin-bottom: 6px;
}

.field-input {
  width: 100%;
  padding: 14px 16px;
  border: 1.5px solid var(--border);
  border-radius: 6px;
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  color: var(--text-dark);
  background: var(--cream);
  transition: border-color 0.2s;
  outline: none;
}

.field-input:focus { border-color: var(--gold); }

.field-help {
  margin-top: 8px;
  font-size: 12px;
  color: var(--text-light);
}

.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

:global(#sourceSpecificFields) {
  margin-top: 18px;
  width: 100%;
  max-width: 340px;
}

:global(#sourceSpecificFields .field-label) {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: var(--text-mid);
  margin-bottom: 6px;
  line-height: 1.35;
}

:global(#sourceSpecificFields .field-row) {
  display: block;
}

:global(#sourceSpecificFields .field-group) {
  margin-bottom: 14px;
}

:global(#sourceSpecificFields .field-input) {
  width: 100%;
  max-width: 340px;
  padding: 12px 14px;
  border: 1.5px solid var(--border);
  border-radius: 6px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: var(--text-dark);
  background: var(--cream);
  transition: border-color 0.2s, box-shadow 0.2s;
  outline: none;
  min-height: 0;
  height: 48px;
  line-height: 1.2;
}

:global(#sourceSpecificFields .field-input:focus) {
  border-color: var(--gold);
  box-shadow: none;
}

:global(#sourceSpecificFields .field-input::placeholder) {
  color: var(--text-light);
}

:global(#sourceSpecificFields .field-help) {
  margin-top: 8px;
  max-width: 340px;
  font-size: 11px;
  color: var(--text-light);
  line-height: 1.55;
}

:global(#sourceSpecificFields .ss-input-label) {
  display: block;
  font-size: 11px;
  font-weight: 600;
  color: var(--text-mid);
  margin-bottom: 5px;
  letter-spacing: 0.4px;
  text-transform: uppercase;
}

select.field-input {
  appearance: none;
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%237A7A7A' stroke-width='1.5' fill='none'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: right 14px center;
  padding-right: 36px;
}

/* Radio cards */
.radio-group {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.radio-card {
  padding: 14px 16px;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
  text-align: center;
  background: var(--cream);
}

.radio-card:hover { border-color: var(--gold); }

.radio-card.selected {
  border-color: var(--gold);
  background: var(--gold-glow);
}

.radio-card input { display: none; }

.radio-card-icon { font-size: 22px; margin-bottom: 4px; }

.radio-card-text {
  font-size: 13px;
  font-weight: 600;
  color: var(--navy);
}

.radio-card-sub {
  font-size: 11px;
  color: var(--text-light);
  margin-top: 2px;
}

/* Buttons */
.btn-row {
  display: flex;
  gap: 12px;
  margin-top: 28px;
}

.btn-back {
  padding: 14px 24px;
  border: 1.5px solid var(--border);
  border-radius: 6px;
  background: transparent;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: var(--text-mid);
  cursor: pointer;
  transition: all 0.2s;
}

.btn-back:hover { border-color: var(--text-mid); }

.btn-next {
  flex: 1;
  padding: 14px 24px;
  border: none;
  border-radius: 6px;
  background: var(--gold);
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--navy);
  cursor: pointer;
  transition: all 0.2s;
}

.btn-next:hover { background: var(--gold-light); }

.form-footer {
  text-align: center;
  margin-top: 20px;
  font-size: 11px;
  color: rgba(255,255,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.form-footer svg { width: 12px; height: 12px; fill: rgba(255,255,255,0.3); }

/* ═══════════════════════════════════════
   STEP 2: ANALYZING
   ═══════════════════════════════════════ */
.analyzing-section {
  display: none;
  background: var(--navy);
  padding: 100px 32px 120px;
  text-align: center;
  min-height: 100vh;
}

.analyzing-content { max-width: 480px; margin: 0 auto; }

.heart-monitor {
  width: 200px;
  height: 100px;
  margin: 0 auto 48px;
  position: relative;
}

.heart-monitor svg {
  width: 100%;
  height: 100%;
}

.monitor-line {
  fill: none;
  stroke: var(--gold);
  stroke-width: 2;
  stroke-linecap: round;
  stroke-dasharray: 600;
  stroke-dashoffset: 600;
  animation: drawLine 3s ease-in-out infinite;
}

@keyframes drawLine {
  0% { stroke-dashoffset: 600; }
  50% { stroke-dashoffset: 0; }
  100% { stroke-dashoffset: -600; }
}

.monitor-glow {
  fill: none;
  stroke: rgba(201,168,76,0.2);
  stroke-width: 8;
  stroke-linecap: round;
  stroke-dasharray: 600;
  stroke-dashoffset: 600;
  animation: drawLine 3s ease-in-out infinite;
}

.analyzing-title {
  font-family: 'Playfair Display', serif;
  font-size: 24px;
  color: var(--white);
  margin-bottom: 8px;
}

.analyzing-sub {
  font-size: 14px;
  color: var(--gold);
  margin-bottom: 48px;
  font-weight: 500;
}

.analysis-steps { text-align: left; }

.a-step {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  opacity: 0.25;
  transition: opacity 0.4s;
}

.a-step.active { opacity: 1; }
.a-step.done { opacity: 0.55; }

.a-step-ind {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid rgba(201,168,76,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s;
}

.a-step.active .a-step-ind { border-color: var(--gold); background: rgba(201,168,76,0.08); }
.a-step.done .a-step-ind { border-color: var(--green); background: rgba(39,174,96,0.12); }

.spinner {
  width: 14px; height: 14px;
  border: 2px solid rgba(201,168,76,0.2);
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  display: none;
}

.a-step.active .spinner { display: block; }

.check-svg {
  display: none;
  width: 12px; height: 12px;
  fill: none;
  stroke: var(--green);
  stroke-width: 3;
}

.a-step.done .check-svg { display: block; }

.a-step-text { font-size: 14px; color: rgba(255,255,255,0.6); }
.a-step.active .a-step-text { color: var(--white); }

@keyframes spin { to { transform: rotate(360deg); } }

/* ═══════════════════════════════════════
   STEP 3: THE REPORT
   ═══════════════════════════════════════ */
.report-section { display: none; }

/* Report header — darker, more serious */
.report-header {
  background: linear-gradient(180deg, #0A1628 0%, var(--navy) 100%);
  padding: 64px 32px 52px;
  position: relative;
}

.report-header::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent 0%, var(--gold) 20%, var(--gold) 80%, transparent 100%);
}

.rh-inner { max-width: 900px; margin: 0 auto; }

.rh-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.rh-label::before {
  content: '';
  width: 28px;
  height: 1px;
  background: var(--gold);
}

.rh-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(26px, 4vw, 40px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.2;
  margin-bottom: 6px;
}

.rh-title em { font-style: italic; color: var(--gold); }

.rh-address {
  font-size: 15px;
  color: rgba(255,255,255,0.45);
  margin-bottom: 28px;
}

.rh-meta {
  display: flex;
  gap: 28px;
  flex-wrap: wrap;
  font-size: 12px;
  color: rgba(255,255,255,0.35);
}

.rh-meta strong { color: rgba(255,255,255,0.6); font-weight: 500; }

/* Report body */
.report-body {
  max-width: 900px;
  margin: 0 auto;
  padding: 48px 32px 80px;
}

/* Income drop hero */
.income-drop-hero {
  background: var(--white);
  border-radius: 12px;
  padding: 36px;
  box-shadow: var(--shadow-lg);
  margin-bottom: 48px;
  position: relative;
  overflow: hidden;
}

.income-drop-hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0; width: 100%; height: 4px;
  background: linear-gradient(90deg, var(--red), var(--amber));
}

.idh-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 8px;
}

.idh-title {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  font-weight: 600;
  color: var(--navy);
  margin-bottom: 24px;
}

.income-bars {
  display: flex;
  align-items: flex-end;
  gap: 24px;
  height: 200px;
  padding: 0 20px;
  margin-bottom: 24px;
}

.income-bar-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}

.bar-amount {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 8px;
}

.bar-amount.reduced { color: var(--red); }

.bar-visual {
  width: 100%;
  max-width: 120px;
  border-radius: 6px 6px 0 0;
  transition: height 1s ease-out;
  position: relative;
}

.bar-visual.before {
  background: linear-gradient(180deg, var(--gold), #B8942F);
  height: 0;
}

.bar-visual.after {
  background: linear-gradient(180deg, var(--red), #962D22);
  height: 0;
}

.bar-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-light);
  margin-top: 10px;
  text-align: center;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.drop-callout {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 16px;
  background: var(--red-bg);
  border-radius: 8px;
  border: 1px solid rgba(192,57,43,0.12);
}

.drop-arrow {
  width: 40px;
  height: 40px;
  background: rgba(192,57,43,0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: var(--red);
  font-weight: 700;
}

.drop-text {
  font-size: 14px;
  color: var(--text-mid);
}

.drop-text strong {
  color: var(--red);
  font-size: 22px;
  font-weight: 700;
  font-family: 'Playfair Display', serif;
}

.drop-text span { display: block; font-size: 12px; color: var(--text-light); }

/* Sections */
.report-block { margin-bottom: 40px; }

.block-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}

.block-icon {
  width: 36px; height: 36px;
  background: var(--gold-glow);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.block-icon svg { width: 18px; height: 18px; fill: var(--gold); }
.block-icon.danger { background: rgba(192,57,43,0.08); }
.block-icon.danger svg { fill: var(--red); }
.block-icon.blue { background: rgba(41,128,185,0.08); }
.block-icon.blue svg { fill: var(--blue); }

.block-title {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  font-weight: 600;
  color: var(--navy);
}

/* Data grid */
.data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

.data-item {
  background: var(--white);
  border-radius: 8px;
  padding: 20px 22px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  border: 1px solid var(--border);
}

.data-item.full { grid-column: 1 / -1; }

.data-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: var(--text-light);
  margin-bottom: 5px;
}

.data-value {
  font-size: 22px;
  font-weight: 700;
  color: var(--navy);
  font-family: 'Playfair Display', serif;
}

.data-note {
  font-size: 12px;
  color: var(--text-light);
  margin-top: 4px;
  line-height: 1.55;
}

/* Alert cards */
.alert-card {
  border-radius: 8px;
  padding: 18px 22px;
  display: flex;
  gap: 14px;
  align-items: flex-start;
  margin-bottom: 10px;
}

.alert-card.danger { background: var(--red-bg); border: 1px solid rgba(192,57,43,0.12); }
.alert-card.warning { background: var(--amber-bg); border: 1px solid rgba(230,126,34,0.12); }
.alert-card.safe { background: var(--green-bg); border: 1px solid rgba(39,174,96,0.12); }
.alert-card.info { background: var(--blue-bg); border: 1px solid rgba(41,128,185,0.12); }

.alert-icon {
  width: 30px; height: 30px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 15px;
  font-weight: 700;
}

.alert-card.danger .alert-icon { background: rgba(192,57,43,0.1); color: var(--red); }
.alert-card.warning .alert-icon { background: rgba(230,126,34,0.1); color: var(--amber); }
.alert-card.safe .alert-icon { background: rgba(39,174,96,0.1); color: var(--green); }
.alert-card.info .alert-icon { background: rgba(41,128,185,0.1); color: var(--blue); }

.alert-title { font-size: 14px; font-weight: 700; margin-bottom: 3px; }
.alert-card.danger .alert-title { color: var(--red); }
.alert-card.warning .alert-title { color: var(--amber); }
.alert-card.safe .alert-title { color: var(--green); }
.alert-card.info .alert-title { color: var(--blue); }

.alert-text { font-size: 13px; color: var(--text-mid); line-height: 1.55; }

/* 72-hour checklist */
.checklist-card {
  background: var(--white);
  border-radius: 12px;
  padding: 32px;
  box-shadow: var(--shadow);
  margin-bottom: 16px;
}

.checklist-card h4 {
  font-family: 'Playfair Display', serif;
  font-size: 16px;
  color: var(--navy);
  margin-bottom: 4px;
}

.checklist-card .period {
  font-size: 12px;
  color: var(--text-light);
  margin-bottom: 16px;
  text-transform: uppercase;
  font-weight: 600;
  letter-spacing: 0.5px;
}

.check-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid rgba(0,0,0,0.04);
}

.check-item:last-child { border-bottom: none; }

.check-box {
  width: 20px; height: 20px;
  border: 2px solid var(--border);
  border-radius: 4px;
  flex-shrink: 0;
  margin-top: 1px;
}

.check-text { font-size: 14px; color: var(--text-mid); }
.check-text strong { color: var(--navy); font-weight: 600; }
.check-text .why {
  display: block;
  font-size: 12px;
  color: var(--text-light);
  margin-top: 2px;
  font-style: italic;
}

/* Timeline visual */
.ss-timeline {
  background: var(--white);
  border-radius: 12px;
  padding: 32px;
  box-shadow: var(--shadow);
  margin-bottom: 20px;
}

.ss-timeline h4 {
  font-family: 'Playfair Display', serif;
  font-size: 16px;
  color: var(--navy);
  margin-bottom: 20px;
}

.timeline-row {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
}

.timeline-dot {
  width: 12px; height: 12px;
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
}

.timeline-dot::after {
  content: '';
  position: absolute;
  top: 12px;
  left: 5px;
  width: 2px;
  height: 28px;
  background: var(--border);
}

.timeline-row:last-child .timeline-dot::after { display: none; }

.tl-content { flex: 1; }

.tl-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--navy);
}

.tl-detail {
  font-size: 12px;
  color: var(--text-light);
}

.tl-amount {
  font-family: 'Playfair Display', serif;
  font-weight: 700;
  font-size: 16px;
}

/* Bottom CTA */
.cta-card {
  background: var(--navy);
  border-radius: 12px;
  padding: 44px 40px;
  text-align: center;
  position: relative;
  overflow: hidden;
  margin-top: 48px;
}

.cta-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
}

.cta-eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 16px;
}

.cta-headline {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 600;
  color: var(--white);
  line-height: 1.4;
  max-width: 540px;
  margin: 0 auto 10px;
}

.cta-headline em { font-style: italic; color: var(--gold); }

.cta-sub {
  font-size: 14px;
  color: rgba(255,255,255,0.45);
  margin-bottom: 28px;
  max-width: 480px;
  margin-left: auto;
  margin-right: auto;
}

.cta-buttons {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
}

.cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 15px 32px;
  border-radius: 6px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  text-decoration: none;
  transition: all 0.2s;
  border: none;
}

.cta-btn.primary {
  background: var(--gold);
  color: var(--navy);
}

.cta-btn.primary:hover { background: var(--gold-light); }

.cta-btn.secondary {
  background: transparent;
  color: var(--white);
  border: 1.5px solid rgba(255,255,255,0.2);
}

.cta-btn.secondary:hover { border-color: var(--gold); color: var(--gold); }

.cta-btn svg { width: 16px; height: 16px; }

/* Disclaimer */
.report-disclaimer {
  max-width: 900px;
  margin: 0 auto;
  padding: 28px 32px 48px;
  border-top: 1px solid var(--border);
}

.disclaimer-text {
  font-size: 11px;
  color: var(--text-light);
  line-height: 1.7;
}

.disclaimer-text strong { color: var(--text-mid); }

/* Fade */
.fade-up {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}

.fade-up.visible { opacity: 1; transform: translateY(0); }

/* Responsive */
@media (max-width: 768px) {
  .site-header { padding: 14px 16px; min-height: 0; }
  .brand { font-size: 18px; }
  .intake-section { padding: 32px 16px; }
  .form-card { padding: 24px 20px; }
  .field-row { grid-template-columns: 1fr; }
  .radio-group { grid-template-columns: 1fr 1fr; }
  .data-grid { grid-template-columns: 1fr; }
  .income-bars { gap: 16px; height: 160px; padding: 0; }
  .report-body { padding: 32px 20px 60px; }
  .report-header { padding: 40px 20px 36px; }
  .cta-card { padding: 32px 20px; }
  .cta-buttons { flex-direction: column; align-items: center; }
}
</style>
</head>
