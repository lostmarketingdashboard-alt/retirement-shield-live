/* ══════════════════════════════════════════════════
   MARGARET QUOTE
══════════════════════════════════════════════════ */
.margaret-section { background: var(--navy); padding: 80px 48px; position: relative; overflow: hidden; }
.margaret-section::after {
  content: '67'; position: absolute; font-family: 'Playfair Display', serif;
  font-size: 26rem; font-weight: 900; color: rgba(255,255,255,0.022);
