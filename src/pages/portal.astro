    .btn-delete {
      background: #b84040;
      border: none;
      color: white;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all .2s ease;
    }

    .btn-delete:hover {
      background: #932f2f;
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgba(0,0,0,.15);
