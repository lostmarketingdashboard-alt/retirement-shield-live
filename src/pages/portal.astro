      width: 100%;
      border: none;
      border-radius: 999px;
      padding: 14px 18px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      color: var(--white);
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
      box-shadow: 0 14px 30px rgba(13,27,42,0.2);
      transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
    }

    .launch-tool-btn:hover {
      transform: translateY(-2px);
      filter: brightness(1.05);
      box-shadow: 0 18px 36px rgba(13,27,42,0.24);
    }

    .launch-tool-btn.completed {
      background: linear-gradient(135deg, #2d6a4f 0%, #40916c 100%);
      box-shadow: 0 14px 30px rgba(45,106,79,0.22);
    }

    .launch-tool-btn.completed:hover {
      box-shadow: 0 18px 36px rgba(45,106,79,0.28);
    }

    .launch-tool-btn:active {
      transform: translateY(0);
    }

    .tool-restart-btn {
      appearance: none;
      -webkit-appearance: none;
      border: 1px solid rgba(26,46,69,0.18);
      background: linear-gradient(135deg, #d88924 0%, #e8a840 100%);
      color: var(--white);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      padding: 8px 14px;
      font-size: 12px;
      font-weight: 700;
      line-height: 1;
      cursor: pointer;
      transition: all .2s ease;
      font-family: 'DM Sans', sans-serif;
      box-shadow: 0 10px 22px rgba(216,137,36,0.22);
      flex-shrink: 0;
      margin-left: auto;
    }

    .tool-restart-btn:hover {
      border-color: #c8821a;
      color: var(--white);
      background: linear-gradient(135deg, #c8821a 0%, #d88924 100%);
      transform: translateY(-1px);
      box-shadow: 0 14px 26px rgba(216,137,36,0.28);
    }

