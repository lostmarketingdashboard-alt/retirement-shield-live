    .portal-search:focus {
      border-color: rgba(200,130,26,.45);
      box-shadow: 0 0 0 4px rgba(200,130,26,.10);
      background: var(--white);
    }

    .portal-search::placeholder {
      color: var(--text-muted);
    }

    .doc-body p {
      font-size: 15px;
      line-height: 1.6;
      color: var(--text-secondary);
    }

    .doc-actions {
      margin-top: 28px;
    }

    .view-pdf-btn {
      background: var(--amber);
      color: var(--white);
      border: none;
      padding: 14px 28px;
      border-radius: 40px;
      font-weight: 600;
      cursor: pointer;
      font-size: 14px;
      transition: all .2s ease;
    }

    .view-pdf-btn:hover {
      background: var(--amber-light);
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(200,130,26,.3);
    }

    .view-pdf-btn:disabled {
