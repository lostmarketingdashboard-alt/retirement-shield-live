---
export const prerender = false;
export const ssr = false;
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Inflation Erosion Visualizer</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --navy: #0F1F3D;
  --navy-light: #1A2D52;
  --navy-mid: #152847;
  --gold: #C9A84C;
  --gold-light: #D4B96A;
  --gold-glow: rgba(201,168,76,0.12);
  --cream: #FAF7F0;
  --cream-dark: #F0EBE0;
  --white: #FFFFFF;
  --text-dark: #1A1A1A;
  --text-mid: #4A4A4A;
  --text-light: #7A7A7A;
  --green: #27AE60;
  --green-bg: #F0FDF4;
  --amber: #E67E22;
  --amber-bg: #FFF8F0;
  --red: #C0392B;
  --red-bg: #FDF2F0;
  --border: #E8E3D8;
  --shadow: 0 2px 20px rgba(15,31,61,0.08);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--text-dark);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

.site-header {
  background: var(--navy);
  padding: 14px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2px solid var(--gold);
}

.logo { text-decoration: none; }
.logo-text {
  font-family: 'Playfair Display', serif;
  color: var(--white);
  font-size: 18px;
  font-weight: 600;
}
.logo-text span { color: var(--gold); }

.hero {
  background: var(--navy);
  padding: 78px 24px 94px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 25% 18%, rgba(201,168,76,0.08) 0%, transparent 48%),
    radial-gradient(ellipse at 76% 74%, rgba(201,168,76,0.05) 0%, transparent 54%);
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 920px;
  margin: 0 auto;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(201,168,76,0.1);
  border: 1px solid rgba(201,168,76,0.22);
  border-radius: 999px;
  padding: 8px 18px;
  margin-bottom: 28px;
  font-size: 11px;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: 1.2px;
  text-transform: uppercase;
}

.hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 5vw, 54px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.12;
  margin-bottom: 18px;
}

.hero h1 em { color: var(--gold); font-style: normal; }

.hero-sub {
  font-size: 18px;
  color: rgba(255,255,255,0.66);
  line-height: 1.7;
  max-width: 760px;
  margin: 0 auto 38px;
  font-weight: 300;
}

.hero-points {
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}

.hero-point {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.84);
  border-radius: 999px;
  padding: 10px 16px;
  font-size: 13px;
}

.wizard-section,
.analysis-section,
.report-section {
  padding: 52px 24px 30px;
}

.wizard-grid {
  max-width: 1180px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 340px minmax(0, 1fr);
  gap: 28px;
  align-items: start;
}

.sticky-sidebar { position: sticky; top: 94px; }

.sidebar-card,
.form-card,
.analysis-card,
.report-shell,
.disclaimer {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 16px;
  box-shadow: var(--shadow);
}

.sidebar-card { padding: 28px; }

.sidebar-label,
.step-label,
.section-kicker,
.report-kicker {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--gold);
}

.sidebar-title {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  line-height: 1.15;
  color: var(--navy);
  margin: 8px 0 14px;
}

.sidebar-copy {
  font-size: 14px;
  color: var(--text-mid);
  margin-bottom: 22px;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 22px;
}

.step-item {
  display: grid;
  grid-template-columns: 34px 1fr;
  gap: 12px;
  align-items: start;
  padding: 12px 14px;
  border-radius: 12px;
  background: var(--cream);
  border: 1px solid transparent;
}

.step-item.active {
  border-color: rgba(201,168,76,0.4);
  background: var(--gold-glow);
}

.step-item.done .step-num {
  background: var(--gold);
  color: var(--navy);
}

.step-num {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: var(--cream-dark);
  color: var(--navy);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
}

.step-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--navy);
  line-height: 1.35;
}

.step-sub {
  font-size: 12px;
  color: var(--text-light);
  margin-top: 2px;
}

.sidebar-note {
  border-radius: 14px;
  background: var(--navy);
  color: rgba(255,255,255,0.78);
  padding: 18px;
  font-size: 13px;
}

.sidebar-note strong {
  color: var(--white);
  display: block;
  margin-bottom: 6px;
}

.form-card { overflow: hidden; }

.form-header {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
  padding: 28px 30px;
}

.form-header-top {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: center;
  margin-bottom: 18px;
}

.form-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 14px;
  background: rgba(201,168,76,0.12);
  border: 1px solid rgba(201,168,76,0.24);
  color: var(--gold);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.1px;
  text-transform: uppercase;
}

.progress-inline {
  color: rgba(255,255,255,0.62);
  font-size: 12px;
  font-weight: 600;
}

.form-title {
  font-family: 'Playfair Display', serif;
  color: var(--white);
  font-size: 34px;
  line-height: 1.1;
  margin-bottom: 10px;
}

.form-sub {
  color: rgba(255,255,255,0.64);
  font-size: 15px;
  max-width: 760px;
}

.progress-bar {
  height: 5px;
  background: rgba(255,255,255,0.1);
  border-radius: 999px;
  margin-top: 18px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  width: 33.33%;
  background: linear-gradient(90deg, var(--gold), var(--gold-light));
  border-radius: 999px;
  transition: width 0.35s ease;
}

.form-body { padding: 30px; }
.form-step { display: none; }
.form-step.active { display: block; }

.step-question {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  line-height: 1.18;
  color: var(--navy);
  margin: 8px 0;
}

.step-help {
  font-size: 14px;
  color: var(--text-light);
  margin-bottom: 24px;
  max-width: 720px;
}

.field-grid,
.insight-grid,
.metric-grid,
.compare-grid {
  display: grid;
  gap: 18px;
}

.field-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.insight-grid,
.metric-grid,
.compare-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }

.field-group { margin-bottom: 18px; }
.field-group.full { grid-column: 1 / -1; }

.field-label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.9px;
  margin-bottom: 8px;
}

.field-input,
.field-select,
.field-textarea {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  background: var(--cream);
  color: var(--text-dark);
  font-size: 15px;
  font-family: 'DM Sans', sans-serif;
  padding: 14px 16px;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
}

.field-input:focus,
.field-select:focus,
.field-textarea:focus {
  border-color: var(--gold);
  box-shadow: 0 0 0 3px rgba(201,168,76,0.12);
  background: var(--white);
}

.field-textarea {
  min-height: 120px;
  resize: vertical;
}

.field-note {
  margin-top: 7px;
  font-size: 12px;
  color: var(--text-light);
}

.btn-row {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-top: 26px;
}

.btn-back,
.btn-next,
.btn-print,
.btn-secondary {
  border: none;
  border-radius: 10px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-back,
.btn-secondary {
  background: transparent;
  border: 1.5px solid var(--border);
  color: var(--text-mid);
  padding: 13px 18px;
}

.btn-next,
.btn-print {
  background: var(--gold);
  color: var(--navy);
  padding: 13px 20px;
}

.btn-next:hover,
.btn-print:hover {
  background: var(--gold-light);
}

.analysis-section,
.report-section { display: none; }
.analysis-section.active,
.report-section.active { display: block; }

.analysis-card {
  max-width: 920px;
  margin: 0 auto;
  padding: 42px 28px;
  text-align: center;
}

.analysis-orb {
  width: 96px;
  height: 96px;
  margin: 0 auto 20px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, var(--gold-light), var(--gold));
  position: relative;
  box-shadow: 0 0 0 16px rgba(201,168,76,0.08), 0 0 0 32px rgba(201,168,76,0.04);
}

.analysis-orb::after {
  content: '';
  position: absolute;
  inset: 24px;
  border-radius: 50%;
  background: var(--navy);
  opacity: 0.16;
}

.analysis-title {
  font-family: 'Playfair Display', serif;
  font-size: 34px;
  color: var(--navy);
  margin-bottom: 8px;
}

.analysis-sub {
  font-size: 15px;
  color: var(--text-light);
  margin-bottom: 28px;
}

.analysis-steps {
  max-width: 560px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.analysis-step {
  display: grid;
  grid-template-columns: 38px 1fr;
  gap: 14px;
  align-items: center;
  text-align: left;
  padding: 14px 16px;
  border-radius: 12px;
  background: var(--cream);
  border: 1px solid var(--border);
}

.analysis-indicator {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: var(--gold-glow);
  color: var(--gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.analysis-step.done .analysis-indicator {
  background: var(--gold);
  color: var(--navy);
}

.analysis-text {
  font-size: 14px;
  color: var(--text-mid);
}

.report-shell {
  max-width: 1080px;
  margin: 0 auto;
  overflow: hidden;
}

.report-header {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
  padding: 36px 32px 30px;
  color: var(--white);
}

.report-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(30px, 4vw, 44px);
  line-height: 1.1;
  margin: 10px 0 12px;
}

.report-subtitle {
  color: rgba(255,255,255,0.72);
  font-size: 15px;
  max-width: 780px;
}

.report-meta {
  margin-top: 20px;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.report-meta-item,
.pill {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 999px;
  padding: 8px 14px;
  font-size: 12px;
  color: rgba(255,255,255,0.8);
  white-space: normal;
  overflow-wrap: anywhere;
}

.report-body {
  padding: 28px;
  display: grid;
  gap: 22px;
}

.hero-summary,
.section-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 16px;
}

.hero-summary {
  padding: 28px;
  background: linear-gradient(135deg, rgba(15,31,61,0.03), rgba(201,168,76,0.08)), var(--white);
}

.hero-grid {
  display: grid;
  grid-template-columns: 1.05fr 0.95fr;
  gap: 22px;
}

.summary-title {
  font-family: 'Playfair Display', serif;
  font-size: 34px;
  color: var(--navy);
  line-height: 1.08;
  margin-bottom: 10px;
}

.summary-title em { color: var(--gold); font-style: normal; }

.summary-copy {
  font-size: 15px;
  color: var(--text-mid);
}

.summary-benchmark {
  background: var(--navy);
  color: rgba(255,255,255,0.82);
  border-radius: 16px;
  padding: 22px;
}

.summary-benchmark .headline {
  font-family: 'Playfair Display', serif;
  font-size: 24px;
  color: var(--white);
  line-height: 1.14;
  margin: 8px 0 10px;
}

.metric-card,
.compare-card {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px;
}

.metric-label,
.compare-card .label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.9px;
  color: var(--text-light);
  font-weight: 700;
  margin-bottom: 6px;
}

.metric-value,
.compare-card .value {
  font-family: 'Playfair Display', serif;
  font-size: 30px;
  color: var(--navy);
  line-height: 1;
  margin-bottom: 6px;
}

.metric-sub,
.compare-card .sub {
  font-size: 12px;
  color: var(--text-light);
}

.section-card { padding: 24px; }

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: end;
  gap: 16px;
  margin-bottom: 18px;
}

.section-title {
  font-family: 'Playfair Display', serif;
  font-size: 26px;
  color: var(--navy);
  line-height: 1.15;
  margin-top: 4px;
}

.section-copy {
  font-size: 13px;
  color: var(--text-light);
  max-width: 650px;
}

.pill {
  background: var(--cream);
  border-color: var(--border);
  color: var(--navy);
}

.chart-wrap {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px;
}

.chart-legend {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  margin-top: 16px;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--text-mid);
}

.legend-line {
  width: 28px;
  height: 3px;
  border-radius: 999px;
}

.callout {
  background: var(--cream);
  border: 1px solid var(--border);
  border-left: 4px solid var(--gold);
  border-radius: 14px;
  padding: 18px;
  font-size: 14px;
  color: var(--text-mid);
}

.report-actions {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: center;
  padding: 0 28px 28px;
}

.report-note {
  font-size: 12px;
  color: var(--text-light);
}

.disclaimer {
  max-width: 1080px;
  margin: 0 auto 64px;
  padding: 24px 28px 32px;
}

.disclaimer p {
  font-size: 11px;
  color: var(--text-light);
  line-height: 1.7;
}

.disclaimer strong { color: var(--text-mid); }

.fade-up {
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.45s ease, transform 0.45s ease;
}

.fade-up.visible {
  opacity: 1;
  transform: translateY(0);
}

@media (max-width: 980px) {
  .wizard-grid,
  .field-grid,
  .insight-grid,
  .metric-grid,
  .compare-grid,
  .hero-grid {
    grid-template-columns: 1fr;
  }
  .sticky-sidebar { position: static; }
}

@media (max-width: 768px) {
  .site-header { padding: 14px 16px; }
  .hero { padding: 54px 20px 72px; }
  .wizard-section,
  .analysis-section,
  .report-section { padding-left: 16px; padding-right: 16px; }
  .sidebar-card,
  .form-body,
  .report-body,
  .section-card,
  .hero-summary,
  .analysis-card,
  .disclaimer { padding-left: 20px; padding-right: 20px; }
  .form-header,
  .report-header { padding: 28px 20px; }
  .step-question,
  .section-title { font-size: 23px; }
  .summary-title { font-size: 28px; }
  .btn-row,
  .section-head,
  .report-actions,
  .form-header-top {
    flex-direction: column;
    align-items: stretch;
  }
  .report-actions > div:last-child { width: 100%; }
  .report-actions > div:last-child button { width: 100%; }
}

@media print {
  body { background: #fff; }
  .site-header,
  .hero,
  .wizard-section,
  .analysis-section,
  .report-actions,
  .disclaimer { display: none !important; }
  .report-section { display: block !important; padding: 0 !important; }
  .report-shell {
    max-width: none !important;
    border: none !important;
    box-shadow: none !important;
  }
  .hero-summary,
  .section-card {
    break-inside: avoid;
    page-break-inside: avoid;
  }
}
</style>
</head>
<body>
<header class="site-header">
  <a href="/portal" class="logo">
    <div class="logo-text">Retirement <span>Shield</span></div>
  </a>
</header>

<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge">Inflation + Longevity Tool</div>
    <h1>The Inflation <em>Erosion</em> Visualizer</h1>
    <p class="hero-sub">Answer the question retirees actually feel in their stomach: “What will my monthly budget really cost when I’m 85?” This tool projects future spending needs year by year and extends the curve through the user’s likely longevity horizon.</p>
    <div class="hero-points">
      <div class="hero-point">Personalized inflation curve</div>
      <div class="hero-point">County longevity framing</div>
      <div class="hero-point">Screenshot-shareable chart + saved report</div>
    </div>
  </div>
</section>

<section class="wizard-section" id="wizardSection">
  <div class="wizard-grid">
    <aside class="sticky-sidebar">
      <div class="sidebar-card">
        <div class="sidebar-label">Erosion Builder</div>
        <div class="sidebar-title">Inflation does not need to spike once to hurt. It just needs time.</div>
        <div class="sidebar-copy">This report makes the erosion visible year by year so the user can see how much longer they may need to fund a much larger monthly budget.</div>

        <div class="step-list">
          <div class="step-item active" data-step-indicator="1">
            <div class="step-num">1</div>
            <div>
              <div class="step-title">Profile & Longevity</div>
              <div class="step-sub">Name, county, state, and age</div>
            </div>
          </div>
          <div class="step-item" data-step-indicator="2">
            <div class="step-num">2</div>
            <div>
              <div class="step-title">Budget Inputs</div>
              <div class="step-sub">Current monthly budget and category notes</div>
            </div>
          </div>
          <div class="step-item" data-step-indicator="3">
            <div class="step-num">3</div>
            <div>
              <div class="step-title">Inflation View</div>
              <div class="step-sub">Target age, inflation assumptions, and report framing</div>
            </div>
          </div>
        </div>

        <div class="sidebar-note">
          <strong>Prototype note</strong>
          This version uses bundled CPI-style assumptions and state longevity benchmarks so the whole product flow is live before the FRED integration is wired.
        </div>
      </div>
    </aside>

    <div class="form-card">
      <div class="form-header">
        <div class="form-header-top">
          <div class="form-badge">Retirement Shield Tool</div>
          <div class="progress-inline" id="progressText">Step 1 of 3</div>
        </div>
        <div class="form-title">See what today’s budget becomes later in retirement.</div>
        <div class="form-sub">Enter the current monthly budget, then we’ll project its inflation-adjusted future cost to age 85 and through the user’s likely planning horizon.</div>
        <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
      </div>

      <div class="form-body">
        <div class="form-step active" id="step1">
          <div class="step-label">Step 1 of 3</div>
          <div class="step-question">Whose future budget are we visualizing?</div>
          <div class="step-help">These inputs set the report identity and the longevity horizon used to extend the chart.</div>

          <div class="field-grid">
            <div class="field-group">
              <label class="field-label" for="fullName">Your Name</label>
              <input class="field-input" id="fullName" type="text" placeholder="e.g. Margaret">
            </div>
            <div class="field-group">
