  ],
  joint: [
    { min: 0, max: 218000, partB: 202.90, partD: 0, label: 'Base premium tier' },
    { min: 218000, max: 274000, partB: 284.10, partD: 14.50, label: 'IRMAA tier 1' },
    { min: 274000, max: 342000, partB: 405.80, partD: 37.50, label: 'IRMAA tier 2' },
    { min: 342000, max: 410000, partB: 527.50, partD: 60.40, label: 'IRMAA tier 3' },
    { min: 410000, max: 750000, partB: 649.20, partD: 83.30, label: 'IRMAA tier 4' },
    { min: 750000, max: Infinity, partB: 689.90, partD: 91.00, label: 'Top IRMAA tier' }
  ],
  separate: [
    { min: 0, max: 109000, partB: 202.90, partD: 0, label: 'Base premium tier' },
    { min: 109000, max: 391000, partB: 649.20, partD: 83.30, label: 'IRMAA separate-filer tier' },
    { min: 391000, max: Infinity, partB: 689.90, partD: 91.00, label: 'Top separate-filer tier' }
  ],
  drugOnlyFactor: {
    base: 121.60,
    14.50: 202.70,
    37.50: 324.30,
    60.40: 445.90,
    83.30: 567.50,
    91.00: 608.10
  }
};

const STATE_OPTIONS = [
  ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],['CA','California'],
  ['CO','Colorado'],['CT','Connecticut'],['DE','Delaware'],['FL','Florida'],['GA','Georgia'],
  ['HI','Hawaii'],['ID','Idaho'],['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],
  ['KY','Kentucky'],['LA','Louisiana'],['ME','Maine'],['MD','Maryland'],['MA','Massachusetts'],
  ['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],['MO','Missouri'],['MT','Montana'],
  ['NE','Nebraska'],['NV','Nevada'],['NH','New Hampshire'],['NJ','New Jersey'],['NM','New Mexico'],
  ['NY','New York'],['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
  ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],['SD','South Dakota'],
  ['TN','Tennessee'],['TX','Texas'],['UT','Utah'],['VT','Vermont'],['VA','Virginia'],['WA','Washington'],
  ['WV','West Virginia'],['WI','Wisconsin'],['WY','Wyoming']
];

let latestIrmaaPayload = null;

const stateSelect = document.getElementById('stateName');
const placeholderOption = document.createElement('option');
placeholderOption.value = '';
placeholderOption.textContent = 'Select your state...';
placeholderOption.disabled = true;
placeholderOption.selected = true;
stateSelect.appendChild(placeholderOption);

STATE_OPTIONS.forEach(([, name]) => {
  const option = document.createElement('option');
  option.value = name;
  option.textContent = name;
  stateSelect.appendChild(option);
});

function formatMoney(value) {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(value || 0);
}

function parseMoney(value) {
  const parsed = Number(String(value || '').replace(/[^0-9.]/g, ''));
  return Number.isFinite(parsed) ? parsed : 0;
}

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach((panel) => panel.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');
  document.querySelectorAll('[data-step-indicator]').forEach((item, index) => {
    const num = index + 1;
    item.classList.toggle('active', num === step);
    item.classList.toggle('done', num < step);
  });
  document.getElementById('progressText').textContent = `Step ${step} of 3`;
  document.getElementById('progressFill').style.width = `${(step / 3) * 100}%`;
  window.scrollTo({ top: document.getElementById('wizardSection').offsetTop - 76, behavior: 'smooth' });
}

function getBracket(status, magi) {
  const table = IRMAA_2026[status] || IRMAA_2026.individual;
  return table.find((row) => magi <= row.max) || table[table.length - 1];
}

function getPremiumForCoverage(bracket, coverage) {
  if (coverage === 'drug_only') {
    const key = String(bracket.partD.toFixed(2));
    return IRMAA_2026.drugOnlyFactor[key] ?? IRMAA_2026.drugOnlyFactor.base;
  }
  return bracket.partB;
}

function getNextThreshold(status, magi) {
  const table = IRMAA_2026[status] || IRMAA_2026.individual;
  const currentIndex = table.findIndex((row) => magi <= row.max);
  if (currentIndex === -1 || currentIndex === table.length - 1) return null;
  return table[currentIndex].max;
}

function evaluateScenario(status, magi, coverage) {
  const bracket = getBracket(status, magi);
  const nextThreshold = getNextThreshold(status, magi);
  const partBPremium = getPremiumForCoverage(bracket, coverage);
  const roomBeforeNext = nextThreshold ? Math.max(0, nextThreshold - magi) : 0;
  return {
    magi,
    bracket,
    nextThreshold,
    partBPremium,
    partDPremium: bracket.partD,
    roomBeforeNext
  };
}

function buildIrmaaPayload() {
  const fullName = document.getElementById('fullName').value.trim();
  const stateName = document.getElementById('stateName').value.trim();
  const countyName = document.getElementById('countyName').value.trim();
  const filingStatus = document.getElementById('filingStatus').value;
  const premiumYear = Number(document.getElementById('premiumYear').value || 2026);
  const magi = parseMoney(document.getElementById('magi').value);
  const partBEnrollment = document.getElementById('partBEnrollment').value;
  const notes = document.getElementById('notes').value.trim();
  const rothConversion = parseMoney(document.getElementById('rothConversion').value);
  const homeSaleGain = parseMoney(document.getElementById('homeSaleGain').value);
  const timingQuestion = document.getElementById('timingQuestion').value.trim();

  const currentScenario = evaluateScenario(filingStatus, magi, partBEnrollment);
  const rothScenario = evaluateScenario(filingStatus, magi + rothConversion, partBEnrollment);
  const saleScenario = evaluateScenario(filingStatus, magi + homeSaleGain, partBEnrollment);

  const lookbackYear = premiumYear - 2;
  const narrative = `For ${premiumYear} Medicare premiums, the normal lookback year is ${lookbackYear}. Based on a MAGI of about ${formatMoney(magi)}, this household currently falls in ${currentScenario.bracket.label}. ${rothConversion ? `A Roth conversion of ${formatMoney(rothConversion)} would move the tested MAGI to ${formatMoney(magi + rothConversion)}.` : ''} ${homeSaleGain ? `A taxable home sale or capital gain of ${formatMoney(homeSaleGain)} would move the tested MAGI to ${formatMoney(magi + homeSaleGain)}.` : ''} ${timingQuestion ? timingQuestion : 'That means income decisions made in the lookback year can change Medicare premiums later, not immediately.'}`;

  return {
    fullName,
    stateName,
    countyName,
    filingStatus,
    premiumYear,
    lookbackYear,
    magi,
    partBEnrollment,
    notes,
    rothConversion,
    homeSaleGain,
    timingQuestion,
    currentScenario,
    rothScenario,
    saleScenario,
    narrative
  };
}

function renderIrmaaReport(payload) {
  latestIrmaaPayload = payload;
  document.getElementById('reportTitle').textContent = `IRMAA Guard for ${payload.fullName || 'Your Household'}`;
  document.getElementById('reportSubtitle').textContent = `A ${payload.premiumYear} Medicare surcharge review showing the current tier, what-if scenarios, and the ${payload.lookbackYear} lookback-year implication.`;
  document.getElementById('metaName').textContent = `Prepared for ${payload.fullName || '—'}`;
  document.getElementById('metaLocation').textContent = `${payload.countyName || 'County not entered'}${payload.stateName ? ` · ${payload.stateName}` : ''}`;
  document.getElementById('metaDate').textContent = `Generated ${new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;

  document.getElementById('summaryCopy').textContent = payload.notes || payload.narrative;
  document.getElementById('benchmarkHeadline').textContent = `You are currently in ${payload.currentScenario.bracket.label}`;
  document.getElementById('benchmarkCopy').textContent = `At the tested MAGI of ${formatMoney(payload.magi)}, the monthly Part B premium is ${formatMoney(payload.currentScenario.partBPremium)} and the Part D IRMAA is ${formatMoney(payload.currentScenario.partDPremium)}.`;
  document.getElementById('partBValue').textContent = formatMoney(payload.currentScenario.partBPremium);
  document.getElementById('partDValue').textContent = formatMoney(payload.currentScenario.partDPremium);
  document.getElementById('roomValue').textContent = payload.currentScenario.nextThreshold ? formatMoney(payload.currentScenario.roomBeforeNext) : 'Top tier';
  document.getElementById('scenarioPill').textContent = `${payload.premiumYear} premiums · ${payload.lookbackYear} lookback`;

  const scenarios = [
    {
      label: 'Current MAGI',
      value: payload.currentScenario,
      tone: payload.currentScenario.roomBeforeNext > 20000 ? 'safe' : payload.currentScenario.roomBeforeNext > 0 ? 'watch' : 'risk',
      sub: 'Current tested income'
    },
    {
      label: 'With Roth Conversion',
      value: payload.rothScenario,
      tone: payload.rothScenario.partBPremium === payload.currentScenario.partBPremium ? 'safe' : 'watch',
      sub: payload.rothConversion ? `Adds ${formatMoney(payload.rothConversion)}` : 'No Roth conversion entered'
    },
    {
      label: 'With Home Sale / Gain',
      value: payload.saleScenario,
      tone: payload.saleScenario.partBPremium === payload.currentScenario.partBPremium ? 'safe' : 'risk',
      sub: payload.homeSaleGain ? `Adds ${formatMoney(payload.homeSaleGain)}` : 'No gain entered'
    }
  ];

  document.getElementById('scenarioGrid').innerHTML = scenarios.map((scenario) => `
    <div class="scenario-card ${scenario.tone}">
      <div class="scenario-label">${scenario.label}</div>
      <div class="scenario-value">${formatMoney(scenario.value.partBPremium)}</div>
      <div class="scenario-sub">${scenario.sub}</div>
      <div class="scenario-list">
        <div class="scenario-list-item"><span>Tested MAGI</span><span>${formatMoney(scenario.value.magi)}</span></div>
        <div class="scenario-list-item"><span>Part D IRMAA</span><span>${formatMoney(scenario.value.partDPremium)}</span></div>
        <div class="scenario-list-item"><span>Tier</span><span>${scenario.value.bracket.label}</span></div>
      </div>
    </div>
  `).join('');

  document.getElementById('compareGrid').innerHTML = [
    {
      label: 'Current MAGI',
      value: formatMoney(payload.magi),
      sub: `Normal ${payload.premiumYear} lookback year: ${payload.lookbackYear}`
    },
    {
      label: 'Next threshold',
      value: payload.currentScenario.nextThreshold ? formatMoney(payload.currentScenario.nextThreshold) : 'Top tier',
      sub: payload.currentScenario.nextThreshold ? 'Approximate MAGI line for the next 2026 IRMAA jump' : 'No higher IRMAA threshold above this point'
    },
    {
      label: 'Annual Part B impact',
      value: formatMoney(payload.currentScenario.partBPremium * 12),
      sub: 'Current annualized Part B premium at this tier'
    }
  ].map((item) => `
    <div class="compare-card">
      <div class="label">${item.label}</div>
      <div class="value">${item.value}</div>
      <div class="sub">${item.sub}</div>
    </div>
  `).join('');

  document.getElementById('irmaaCallout').textContent = payload.narrative;
}

function runAnalysisAnimation(payload) {
  document.getElementById('analysisSub').textContent = `Checking ${payload.premiumYear} IRMAA placement for ${payload.fullName || 'your household'} using the ${payload.lookbackYear} lookback year.`;
  ['analysisStep1','analysisStep2','analysisStep3','analysisStep4'].forEach((id, index) => {
    const el = document.getElementById(id);
    el.classList.remove('done');
    setTimeout(() => el.classList.add('done'), (index + 1) * 360);
  });
}

async function saveIrmaaReport(payload) {
  const supabase = window.irmaaGuardSupabase;
  if (!supabase) return null;
  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const insertPayload = {
    user_id: userId,
    full_name: payload.fullName || null,
    state_name: payload.stateName || null,
    county_name: payload.countyName || null,
    filing_status: payload.filingStatus || null,
    premium_year: payload.premiumYear,
    lookback_year: payload.lookbackYear,
    magi: payload.magi,
    part_b_coverage_type: payload.partBEnrollment || null,
    roth_conversion_amount: payload.rothConversion,
    home_sale_gain_amount: payload.homeSaleGain,
    current_part_b_premium: payload.currentScenario.partBPremium,
    current_part_d_irmaa: payload.currentScenario.partDPremium,
    current_tier_label: payload.currentScenario.bracket.label,
    report_title: `IRMAA Guard for ${payload.fullName || 'Your Household'}`,
    report_payload: payload
  };

  const { error } = await supabase
    .from('irmaa_guard_reports')
    .insert(insertPayload);

  if (error) {
    console.error('Failed to save IRMAA Guard report:', error);
  }
}

function showGeneratedIrmaaReport(payload) {
  renderIrmaaReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  runAnalysisAnimation(payload);

  setTimeout(() => {
    document.getElementById('analysisSection').classList.remove('active');
    document.getElementById('reportSection').classList.add('active');
    document.getElementById('reportShell').classList.add('visible');
    document.getElementById('reportShell').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 1800);
}

function showHydratedIrmaaReport(payload) {
  renderIrmaaReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('reportSection').classList.add('active');
  document.getElementById('reportShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedIrmaaReport(report) {
  const payload = report?.report_payload;
  if (!payload) return false;
  const fields = {
    fullName: payload.fullName,
    stateName: payload.stateName,
    countyName: payload.countyName,
    magi: payload.magi,
    notes: payload.notes,
    rothConversion: payload.rothConversion,
    homeSaleGain: payload.homeSaleGain,
    timingQuestion: payload.timingQuestion
  };
  Object.entries(fields).forEach(([id, value]) => {
    const input = document.getElementById(id);
    if (input && value !== undefined && value !== null) input.value = String(value);
  });
  if (payload.filingStatus) document.getElementById('filingStatus').value = payload.filingStatus;
  if (payload.partBEnrollment) document.getElementById('partBEnrollment').value = payload.partBEnrollment;
  if (payload.premiumYear) document.getElementById('premiumYear').value = String(payload.premiumYear);

  showHydratedIrmaaReport(payload);
  return true;
}

async function generateIrmaaReport() {
  const payload = buildIrmaaPayload();
  await saveIrmaaReport(payload);
  showGeneratedIrmaaReport(payload);
}

function editIrmaaReport() {
  document.getElementById('reportSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(3);
}

window.nextStep = nextStep;
window.generateIrmaaReport = generateIrmaaReport;
window.editIrmaaReport = editIrmaaReport;
window.hydrateIrmaaReport = hydrateSavedIrmaaReport;
</script>
