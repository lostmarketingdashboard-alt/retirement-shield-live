---
export const prerender = true;
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<style is:global>
  :root {
    --navy: #0F1F3D;
    --navy-mid: #1B2A4A;
    --navy-light: #243559;
    --gold: #C9A84C;
    --gold-light: #E2C97E;
    --gold-muted: #F5EDD3;
    --text: #1A1A2E;
    --text-mid: #4A4A6A;
    --text-light: #6B6B88;
    --bg: #FAFAF8;
    --bg-warm: #F7F4EF;
    --border: #E4DDD0;
    --white: #FFFFFF;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; font-size: 16px; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
  }

  /* ── TOP BAR ── */
  .topbar {
    background: var(--navy);
    padding: 0 40px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 2px solid var(--gold);
  }
  .topbar-brand {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 0.02em;
    text-decoration: none;
  }
  .topbar-brand span { color: var(--gold); }
  .topbar-nav { display: flex; gap: 24px; }
  .topbar-nav a {
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .topbar-nav a:hover, .topbar-nav a.active { color: var(--gold); }

  /* ── HERO ── */
  .hero {
    background: var(--navy);
    padding: 64px 40px 52px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 320px; height: 320px;
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 50%;
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: -40px; left: 60px;
    width: 200px; height: 200px;
    border: 1px solid rgba(201,168,76,0.08);
    border-radius: 50%;
  }
  .hero-inner { max-width: 760px; position: relative; z-index: 1; }
  .hero-label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(201,168,76,0.4);
    padding: 5px 12px;
    border-radius: 2px;
    margin-bottom: 20px;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2.6rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 16px;
  }
  .hero-meta {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.03em;
  }
  .hero-meta strong { color: rgba(255,255,255,0.7); font-weight: 500; }

  /* ── LAYOUT ── */
  .layout {
    max-width: 1160px;
    margin: 0 auto;
    padding: 56px 40px;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 64px;
    align-items: start;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    position: sticky;
    top: 80px;
  }
  .sidebar-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .toc { list-style: none; }
  .toc li { margin-bottom: 2px; }
  .toc a {
    display: block;
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--text-light);
    text-decoration: none;
    padding: 5px 10px 5px 0;
    border-left: 2px solid transparent;
    transition: all 0.2s;
    line-height: 1.4;
  }
  .toc a:hover { color: var(--navy); border-left-color: var(--gold); padding-left: 8px; }
  .toc a.active { color: var(--navy); font-weight: 600; border-left-color: var(--gold); padding-left: 8px; }

  /* ── CONTENT ── */
  .content { min-width: 0; }

  .alert-box {
    background: var(--gold-muted);
    border-left: 4px solid var(--gold);
    padding: 18px 22px;
    margin-bottom: 40px;
    border-radius: 0 4px 4px 0;
  }
  .alert-box p {
    font-size: 0.9rem;
    font-style: italic;
    color: #5A4A1A;
    line-height: 1.65;
  }
  .alert-box strong { font-style: normal; color: #3D3010; }

  .section {
    margin-bottom: 52px;
    padding-bottom: 52px;
    border-bottom: 1px solid var(--border);
  }
  .section:last-child { border-bottom: none; }

  .section-num {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
    display: block;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.55rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 20px;
    line-height: 1.3;
  }

  h3 {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--navy-mid);
    margin: 28px 0 12px;
    letter-spacing: 0.01em;
  }

  p {
    font-size: 0.95rem;
    color: var(--text-mid);
    margin-bottom: 16px;
    line-height: 1.75;
  }

  ul {
    list-style: none;
    margin: 0 0 20px 0;
    padding: 0;
  }
  ul li {
    font-size: 0.92rem;
    color: var(--text-mid);
    padding: 7px 0 7px 22px;
    position: relative;
    line-height: 1.65;
    border-bottom: 1px solid rgba(228,221,208,0.5);
  }
  ul li:last-child { border-bottom: none; }
  ul li::before {
    content: '';
    position: absolute;
    left: 0; top: 16px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gold);
  }

  .contact-block {
    background: var(--navy);
    color: var(--white);
    padding: 28px 32px;
    border-radius: 4px;
    margin-top: 8px;
  }
  .contact-block strong {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    display: block;
    margin-bottom: 10px;
    color: var(--gold-light);
  }
  .contact-block p { color: rgba(255,255,255,0.7); margin-bottom: 6px; font-size: 0.88rem; }
  .contact-block a { color: var(--gold-light); text-decoration: none; }
  .contact-block a:hover { text-decoration: underline; }

  /* ── FOOTER ── */
  footer {
    background: var(--navy);
    color: rgba(255,255,255,0.45);
    text-align: center;
    padding: 32px 40px;
    font-size: 0.78rem;
    border-top: 1px solid rgba(201,168,76,0.2);
    line-height: 1.8;
  }
  footer a { color: rgba(201,168,76,0.7); text-decoration: none; }

  /* ── BACK TO TOP ── */
  .back-top {
    position: fixed;
    bottom: 32px; right: 32px;
    width: 44px; height: 44px;
    background: var(--navy);
    border: 1px solid var(--gold);
    color: var(--gold);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    font-size: 1.1rem;
    border-radius: 2px;
    opacity: 0;
    transition: opacity 0.3s;
    z-index: 50;
    text-decoration: none;
  }
  .back-top.visible { opacity: 1; }
  .back-top:hover { background: var(--gold); color: var(--navy); }

  @media (max-width: 900px) {
    .layout { grid-template-columns: 1fr; gap: 0; padding: 40px 24px; }
    .sidebar { display: none; }
    .hero { padding: 48px 24px 40px; }
    .hero h1 { font-size: 2rem; }
    .topbar { padding: 0 24px; }
    .topbar-nav { display: none; }
  }
</style>

<nav class="topbar">
  <a class="topbar-brand" href="/">Retirement <span>Shield</span></a>
  <div class="topbar-nav">
    <a href="/privacy-policy" class="active">Privacy Policy</a>
    <a href="/terms-of-use">Terms of Use</a>
    <a href="/disclaimer">Disclaimer</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <span class="hero-label">Legal & Compliance</span>
    <h1>Privacy Policy</h1>
    <p class="hero-meta">
      <strong>Effective Date:</strong> March 12, 2026 &nbsp;|&nbsp;
      <strong>Last Updated:</strong> March 12, 2026 &nbsp;|&nbsp;
      retirementshield.com
    </p>
  </div>
</div>

<div class="layout">
  <aside class="sidebar">
    <p class="sidebar-label">Contents</p>
    <ul class="toc">
      <li><a href="#intro">Overview</a></li>
      <li><a href="#s1">1. Information We Collect</a></li>
      <li><a href="#s2">2. How We Use Your Information</a></li>
      <li><a href="#s3">3. How We Share Your Information</a></li>
      <li><a href="#s4">4. Data Retention</a></li>
      <li><a href="#s5">5. Data Security</a></li>
      <li><a href="#s6">6. Cookies & Tracking</a></li>
      <li><a href="#s7">7. California Residents</a></li>
      <li><a href="#s8">8. Your Choices & Opt-Out</a></li>
      <li><a href="#s9">9. Children's Privacy</a></li>
      <li><a href="#s10">10. Third-Party Links</a></li>
      <li><a href="#s11">11. GLBA Notice</a></li>
      <li><a href="#s12">12. Changes to This Policy</a></li>
      <li><a href="#s13">13. Contact Us</a></li>
    </ul>
  </aside>

  <main class="content">
    <!-- KEEP ALL EXISTING CONTENT SECTIONS EXACTLY AS THEY ARE HERE -->
    <div id="intro" class="section">
      <p>Retirement Shield, LLC ("Retirement Shield," "we," "us," or "our") is committed to protecting your personal information. This Privacy Policy explains how we collect, use, share, and safeguard information when you visit retirementshield.com, complete our quizzes or calculators, sign up for our newsletter, purchase products, or otherwise interact with our platform (collectively, the "Services").</p>
      <p>This policy applies to all users of the Services. If you do not agree with any part of this policy, please do not use our Services.</p>
    </div>

    <div id="s1" class="section">
      <span class="section-num">Section 01</span>
      <h2>Information We Collect</h2>

      <h3>A. Information You Provide Directly</h3>
      <ul>
        <li>Name, email address, phone number, and mailing address</li>
        <li>Age, date of birth, and state of residence</li>
        <li>Responses to quiz and assessment questions (e.g., retirement timeline, estimated assets, income needs, estate planning concerns)</li>
        <li>Payment information processed securely through our third-party payment processor (we do not store full payment card numbers)</li>
        <li>Communications you send to us, including support requests and feedback</li>
      </ul>

      <h3>B. Information Collected Automatically</h3>
      <ul>
        <li>IP address, browser type, device identifiers, and operating system</li>
        <li>Pages visited, links clicked, time on site, and referring URLs</li>
        <li>Quiz and calculator interaction data (entries, completion rates, responses)</li>
        <li>Cookie and tracking pixel data (see Section 6)</li>
      </ul>

      <h3>C. Information from Third Parties</h3>
      <ul>
        <li>Analytics providers (e.g., Google Analytics, Meta Pixel)</li>
        <li>Advertising partners and data enrichment services, to the extent you have consented to their data collection practices</li>
        <li>If you connect a third-party account, we may receive information from that platform consistent with your privacy settings there</li>
      </ul>
    </div>

    <div id="s2" class="section">
      <span class="section-num">Section 02</span>
      <h2>How We Use Your Information</h2>
      <p>We use the information we collect to:</p>
      <ul>
        <li>Deliver, personalize, and improve the Services</li>
        <li>Send you educational newsletters, guides, planning checklists, and other content you have requested</li>
        <li>Process purchases and subscriptions and send transactional communications</li>
        <li>Segment your profile to route relevant educational content and licensed specialist introductions appropriate to your situation</li>
        <li>Fulfill obligations under any referral or coordination arrangement, subject to your explicit consent</li>
        <li>Comply with legal obligations and enforce our Terms of Use</li>
        <li>Analyze platform usage, conduct research, and improve our editorial and product offerings</li>
        <li>Send promotional communications — you may opt out at any time (see Section 8)</li>
      </ul>
      <div class="alert-box">
        <p><strong>IMPORTANT:</strong> We do not sell your personal information to third parties for their independent marketing use. We do share information with service providers and referral partners on a limited, purpose-specific basis as described in Section 3.</p>
      </div>
    </div>

    <div id="s3" class="section">
      <span class="section-num">Section 03</span>
      <h2>How We Share Your Information</h2>

      <h3>A. Service Providers</h3>
      <p>We share information with companies that help us operate the Services, including email delivery providers (beehiiv), CRM platforms (GoHighLevel), payment processors (Stripe), web hosting and analytics providers, and calendar scheduling services. These parties are contractually obligated to use your information only as directed by us.</p>

      <h3>B. Professional Referral Partners</h3>
      <p>If you request an introduction to a licensed estate planning attorney, financial advisor, insurance professional, or other specialist through our platform, we will share relevant information (name, contact details, and a summary of your planning profile) with that partner solely for the purpose of facilitating that introduction. We do not share your information with referral partners without your explicit consent, which is obtained via a consent checkbox on all referral and lead capture forms.</p>
      <p>Our referral partners operate independently and under their own professional and ethical obligations. Retirement Shield is not responsible for the services, advice, or conduct of any referred professional.</p>

      <h3>C. Legal and Safety Disclosures</h3>
      <p>We may disclose information if required by law, court order, or governmental authority, or when we believe disclosure is necessary to protect the rights, property, or safety of Retirement Shield, our users, or the public.</p>

      <h3>D. Business Transfers</h3>
      <p>In the event of a merger, acquisition, reorganization, or sale of assets, your information may be transferred as part of that transaction. We will notify you via email or prominent notice on our website of any such change and any choices you may have.</p>
    </div>

    <div id="s4" class="section">
      <span class="section-num">Section 04</span>
      <h2>Data Retention</h2>
      <p>We retain personal information for as long as necessary to provide the Services, comply with legal obligations, resolve disputes, and enforce our agreements. Educational subscriber data is retained for the duration of your subscription plus three years. Referral lead data submitted to professional partners is retained for one year unless you request deletion. You may request deletion of your data at any time (see Section 8).</p>
    </div>

    <div id="s5" class="section">
      <span class="section-num">Section 05</span>
      <h2>Data Security</h2>
      <p>We implement industry-standard technical and organizational measures to protect your personal information, including SSL/TLS encryption for data in transit, secure password hashing, role-based access controls, and regular security reviews. However, no method of transmission over the internet or electronic storage is completely secure. We cannot guarantee absolute security.</p>
      <p>If you suspect unauthorized access to your account or personal information, contact us immediately at <a href="mailto:legal@retirementshield.com">legal@retirementshield.com</a>.</p>
    </div>

    <div id="s6" class="section">
      <span class="section-num">Section 06</span>
      <h2>Cookies and Tracking Technologies</h2>
      <p>We use cookies, pixels, and similar technologies to:</p>
      <ul>
        <li>Maintain session state and authentication</li>
        <li>Remember preferences and quiz progress</li>
        <li>Analyze traffic and user behavior (Google Analytics, Meta Pixel)</li>
        <li>Serve relevant advertising on third-party platforms</li>
      </ul>
      <p>You may control cookie preferences through your browser settings. Opting out of analytics or advertising cookies does not affect your ability to use core platform features. A cookie consent banner is displayed on your first visit and records your preferences.</p>
    </div>

    <div id="s7" class="section">
      <span class="section-num">Section 07</span>
      <h2>California Residents — CCPA/CPRA Rights</h2>
      <p>If you are a California resident, you have the following rights under the California Consumer Privacy Act (CCPA) as amended by the California Privacy Rights Act (CPRA):</p>
      <ul>
        <li><strong>Right to Know:</strong> Request disclosure of the categories and specific pieces of personal information we have collected about you</li>
        <li><strong>Right to Delete:</strong> Request deletion of your personal information, subject to certain exceptions</li>
        <li><strong>Right to Correct:</strong> Request correction of inaccurate personal information</li>
        <li><strong>Right to Opt Out of Sale or Sharing:</strong> We do not sell personal information. We do share data with analytics and advertising partners for purposes that may constitute "sharing" under CCPA — you may opt out by adjusting cookie preferences or contacting us</li>
        <li><strong>Right to Limit Use of Sensitive Personal Information:</strong> We do not process sensitive personal information for purposes other than those permitted by law</li>
        <li><strong>Right to Non-Discrimination:</strong> We will not discriminate against you for exercising any of these rights</li>
      </ul>
      <p>To exercise your rights, contact us at <a href="mailto:legal@retirementshield.com">legal@retirementshield.com</a> with the subject line "California Privacy Request." We will respond within 45 days as required by law.</p>
    </div>

    <div id="s8" class="section">
      <span class="section-num">Section 08</span>
      <h2>Your Choices and Opt-Out Rights</h2>
      <ul>
        <li><strong>Email Unsubscribe:</strong> Every marketing email includes an unsubscribe link. You may also email us at legal@retirementshield.com to be removed from our mailing list</li>
        <li><strong>Data Deletion:</strong> Request deletion of your account and personal data by emailing legal@retirementshield.com</li>
        <li><strong>Cookie Opt-Out:</strong> Adjust preferences via the cookie consent banner or your browser settings</li>
        <li><strong>Do Not Track:</strong> We honor browser-level Do Not Track signals to the extent technically feasible</li>
      </ul>
    </div>

    <div id="s9" class="section">
      <span class="section-num">Section 09</span>
      <h2>Children's Privacy</h2>
      <p>Our Services are designed for adults aged 55 and older and are not directed to individuals under the age of 18. We do not knowingly collect personal information from anyone under 18. If we become aware that we have collected information from a person under 18, we will delete it promptly.</p>
    </div>

    <div id="s10" class="section">
      <span class="section-num">Section 10</span>
      <h2>Third-Party Links</h2>
      <p>Our Services may contain links to third-party websites, tools, or resources. We are not responsible for the privacy practices or content of those third parties. We encourage you to review the privacy policies of any third-party sites you visit.</p>
    </div>

    <div id="s11" class="section">
      <span class="section-num">Section 11</span>
      <h2>Gramm-Leach-Bliley Act (GLBA) Notice</h2>
      <p>To the extent we receive nonpublic personal financial information in connection with our educational products and referral services, we collect and use such information only to provide the Services you have requested. We do not share nonpublic personal financial information with unaffiliated third parties except as permitted or required by law and as described in this policy. We maintain administrative, technical, and physical safeguards that comply with applicable federal standards.</p>
    </div>

    <div id="s12" class="section">
      <span class="section-num">Section 12</span>
      <h2>Changes to This Policy</h2>
      <p>We may update this Privacy Policy from time to time. When we do, we will post the revised policy on this page with an updated effective date and, where material changes are involved, notify you by email or by a prominent notice on our website. Your continued use of the Services after the effective date of the revised policy constitutes your acceptance of the changes.</p>
    </div>

    <div id="s13" class="section">
      <span class="section-num">Section 13</span>
      <h2>Contact Us</h2>
      <p>If you have any questions, concerns, or requests regarding this Privacy Policy, please contact us at:</p>
      <div class="contact-block">
        <strong>Retirement Shield, LLC</strong>
        <p>Email: <a href="mailto:legal@retirementshield.com">legal@retirementshield.com</a></p>
        <p>Website: <a href="https://retirementshield.com">https://retirementshield.com</a></p>
      </div>
    </div>
  </main>
</div>

<footer>
  <p>© 2026 Retirement Shield, LLC. All rights reserved.</p>
  <p style="margin-top:6px;">
    <a href="/privacy-policy">Privacy Policy</a> ·
    <a href="/terms-of-use">Terms of Use</a> ·
    <a href="/disclaimer">Full Disclaimer</a> ·
    <a href="mailto:legal@retirementshield.com">legal@retirementshield.com</a>
  </p>
  <p style="margin-top:8px; font-size:0.72rem; color:rgba(255,255,255,0.25);">
    This document is for informational purposes only and does not constitute legal advice.
  </p>
</footer>

<a href="#" class="back-top" id="backTop" title="Back to top">↑</a>

<script>
  const backTop = document.getElementById('backTop');
  window.addEventListener('scroll', () => {
    if (backTop) backTop.classList.toggle('visible', window.scrollY > 400);
  });
</script>
