}
.margaret-inner { max-width: 720px; }
.pullquote {
  font-family: 'Playfair Display', serif; font-size: clamp(1.3rem, 2.3vw, 2rem);
  font-weight: 400; font-style: italic; color: var(--cream); line-height: 1.42;
  margin-bottom: 18px; padding-left: 24px; border-left: 4px solid var(--amber);
}
.pullquote-attr {
  font-family: 'DM Mono', monospace; font-size: 0.63rem; text-transform: uppercase;
  letter-spacing: 0.14em; color: var(--amber-light); padding-left: 24px; margin-bottom: 28px; display: block;
}
