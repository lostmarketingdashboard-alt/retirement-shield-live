    :root {
      --navy: #0d1b2a;
      --navy-mid: #1a2e45;
      --navy-light: #243b55;
      --cream: #f5f0e8;
      --cream-dark: #ede6d6;
      --amber: #c8821a;
      --amber-light: #e8a840;
      --text-primary: #1a1208;
      --text-secondary: #4a3f32;
      --text-muted: #7a6e62;
      --white: #ffffff;
      --rule: #c8b89a;
      --rule-light: rgba(200,184,154,0.35);
    }

    body {
      margin: 0;
      font-family: 'DM Sans', sans-serif;
      background: var(--cream-dark);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    /* NAV */

    .portal-nav {
      background: var(--navy);
      height: 72px;
      padding: 0 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      box-sizing: border-box;
    }

    .nav-left {
      display: flex;
      align-items: center;
      gap: 14px;
      cursor: pointer;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 18px;
      flex-shrink: 0;
    }

    .user-menu {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 6px 14px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 999px;
      transition: all .2s ease;
      max-width: 100%;
    }

    .user-menu:hover {
      background: rgba(255,255,255,0.08);
      border-color: var(--amber);
    }

    .badge {
      white-space: nowrap;
    }

    @media (max-width: 900px) {
      .badge {
        display: none;
      }

      .user-info {
        display: none;
      }

      .portal-nav {
        padding: 0 20px;
      }
    }

    .user-info {
      display: flex;
      flex-direction: column;
      line-height: 1.1;
    }

    .user-name {
      color: var(--white);
      font-size: 14px;
      font-weight: 500;
    }

    .user-role {
      font-size: 11px;
      color: var(--amber-light);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .logout-btn {
      background: transparent;
      border: 1px solid rgba(255,255,255,0.2);
      color: rgba(255,255,255,0.8);
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 12px;
      cursor: pointer;
      transition: all .2s ease;
    }

    .logout-btn:hover {
      border-color: var(--amber);
      color: var(--amber-light);
      background: rgba(200,130,26,.1);
    }

    .brand {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--white);
    }

    .brand span {
      color: var(--amber);
    }

    .badge {
      border: 1px solid var(--amber);
      color: var(--amber-light);
      background: rgba(200,130,26,.15);
      padding: 6px 16px;
      border-radius: 40px;
      font-size: 12px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .avatar {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: linear-gradient(135deg,var(--navy-mid),var(--navy-light));
      border: 2px solid var(--amber);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: var(--amber-light);
      font-size: 14px;
      box-shadow: 0 0 0 3px rgba(200,130,26,0.15);
      flex-shrink: 0;
    }

    /* HERO SECTION */

    .hero {
      background: linear-gradient(135deg,var(--navy) 0%,var(--navy-mid) 60%,var(--navy-light) 100%);
      padding: 80px 48px 60px;
      position: relative;
    }

    .hero-inner {
      max-width: 1100px;
      margin: 0 auto;
    }

    .hero-label {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--amber);
      font-size: 13px;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .hero-label .line {
      width: 28px;
      height: 2px;
      background: var(--amber);
    }

    .hero-card {
      background: var(--cream);
      border-radius: 20px;
      padding: 40px 48px;
      display: flex;
      gap: 48px;
      align-items: center;
      box-shadow: 0 20px 60px rgba(0,0,0,.15);
    }

    .progress-ring {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      border: 10px solid var(--rule-light);
      border-top: 10px solid var(--amber);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .progress-value {
      font-family: 'Playfair Display', serif;
      font-size: 34px;
      font-weight: 700;
      color: var(--navy);
    }

    .progress-label {
      font-size: 12px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .hero-main h1 {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      margin: 0 0 8px;
    }

    .subtext {
      color: var(--text-muted);
      margin-bottom: 16px;
    }

    .status-badges span {
      padding: 6px 16px;
      border-radius: 40px;
      font-size: 13px;
      margin-right: 10px;
      border: 1px solid;
    }

    .badge-complete {
      color: #2d6a4f;
      border-color: #2d6a4f;
      background: rgba(45,106,79,.1);
    }

    .badge-progress {
      color: var(--amber);
      border-color: var(--amber);
      background: rgba(200,130,26,.1);
    }

    .badge-queued {
      color: var(--text-muted);
      border-color: var(--rule);
      background: rgba(200,184,154,.15);
    }

    .review-box {
      background: var(--cream-dark);
      padding: 28px 36px;
      border-radius: 16px;
      min-width: 240px;
      text-align: center;
    }

    .review-label {
      font-size: 12px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 6px;
    }

    .review-date {
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      font-weight: 700;
    }

    .review-sub {
      font-size: 13px;
      color: var(--text-muted);
    }

    /* TABS SECTION */

    .tabs-wrap {
      max-width: 1100px;
      margin: 60px auto 0;
      padding: 0 48px;
    }

    .tabs {
      display: flex;
      gap: 48px;
      align-items: center;
    }

    .tab {
      background: none;
      border: none;
      font-family: 'DM Sans', sans-serif;
      font-size: 18px;
      color: var(--text-muted);
      cursor: pointer;
      padding: 16px 0;
      position: relative;
      transition: color .2s ease;
    }

    .tab:hover {
      color: var(--text-primary);
    }

    .tab.active {
      color: var(--navy);
      font-weight: 600;
    }

    .tab-underline {
      height: 2px;
      background: var(--rule-light);
      margin-top: -2px;
      width: 100%;
    }

    .tab.active::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 100%;
      height: 3px;
      background: var(--amber);
      border-radius: 2px;
    }

    @media (max-width: 900px) {
      .tabs-wrap {
        padding: 0 20px;
      }

      .tabs {
        gap: 24px;
        overflow-x: auto;
      }

      .tab {
        font-size: 16px;
        white-space: nowrap;
      }
    }

    /* CONTENT */

    .portal-root {
      background: var(--cream-dark);
    }

    .content-wrap {
      max-width: 1100px;
      margin: 40px auto 80px;
      padding: 0 48px;
    }

    .card {
      background: var(--white);
      border-radius: 14px;
      padding: 24px;
      border: 1px solid var(--rule-light);
      margin-bottom: 16px;
      box-shadow: 0 4px 20px rgba(0,0,0,.06);
    }

    .portal-footer {
      background: var(--navy);
      padding: 32px;
      text-align: center;
      font-size: 12px;
      color: rgba(255,255,255,.4);
    }


    /* ACTION PLAN CARDS */

    .plan-card {
      background: var(--white);
      border-radius: 16px;
      border: 1px solid var(--rule-light);
      margin-bottom: 20px;
      overflow: hidden;
      transition: all .25s ease;
      box-shadow: 0 6px 24px rgba(0,0,0,.05);
    }

    .plan-card.complete .plan-number {
      background: #2d6a4f;
    }

    .plan-card.progress .plan-number {
      background: var(--amber);
    }

    .plan-card.queued .plan-number {
      background: var(--rule);
      color: var(--text-muted);
    }

    .plan-header {
      padding: 22px 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      transition: background .2s ease;
    }

    .plan-header:hover {
      background: rgba(0,0,0,0.02);
    }

    .plan-left {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .plan-number {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: var(--white);
      font-size: 15px;
      transition: all .2s ease;
    }

    .plan-left h3 {
      margin: 0;
      font-size: 18px;
      font-weight: 600;
    }

    .plan-category {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .plan-status {
      font-size: 12px;
      padding: 6px 14px;
      border-radius: 40px;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }

    .plan-card.complete .plan-status {
      background: rgba(45,106,79,.1);
      color: #2d6a4f;
    }

    .plan-card.progress .plan-status {
      background: rgba(200,130,26,.1);
      color: var(--amber);
    }

    .plan-card.queued .plan-status {
      background: rgba(200,184,154,.2);
      color: var(--text-muted);
    }

    .plan-body {
      padding: 0 28px 28px;
      display: none;
      border-top: 1px solid var(--rule-light);
      background: rgba(0,0,0,0.01);
      animation: fadeIn .25s ease;
    }

    .plan-card.open .plan-body {
      display: block;
    }

    .subtasks {
      margin-top: 18px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .subtask {
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
    }

    .subtask input {
      width: 18px;
      height: 18px;
      accent-color: var(--amber);
      cursor: pointer;
    }

    /* Custom Subtask Checkbox Styling */

    .subtask {
      position: relative;
      cursor: pointer;
      font-size: 16px;
      gap: 14px;
    }

    .subtask input {
      display: none;
    }

    .custom-check {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 2px solid #cfd6dc;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .2s ease;
      flex-shrink: 0;
    }

    .subtask.done .custom-check {
      background: #2d6a4f;
      border-color: #2d6a4f;
    }

    .subtask.done .custom-check::after {
      content: '✓';
      color: white;
      font-size: 14px;
      font-weight: 700;
    }

    .task-label {
      transition: all .2s ease;
    }

    .subtask.done .task-label {
      text-decoration: line-through;
      color: #6b7280;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-4px); }
      to { opacity: 1; transform: translateY(0); }
    }



    /* DOCUMENTS TAB */

    .doc-card {
      background: var(--white);
      border-radius: 20px;
      padding: 36px;
      border: 1px solid var(--rule-light);
      box-shadow: 0 20px 60px rgba(0,0,0,.08);
      max-width: 95%;
