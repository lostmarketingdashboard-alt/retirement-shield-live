---
export const prerender = false;
export const ssr = false;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Client Portal</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
  <div id="app"></div>

  <script type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'

    const supabase = createClient(
      "https://nyiturqeotdxucfdurzu.supabase.co",
      "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im55aXR1cnFlb3RkeHVjZmR1cnp1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIxMzI0ODgsImV4cCI6MjA4NzcwODQ4OH0.CvYju6UTaCGD_Zd-8FVTcB-yW9YVG_jQtwkd0l7mIV0",
      {
        auth: {
          persistSession: true,
          autoRefreshToken: true,
          detectSessionInUrl: true,
          flowType: 'pkce'
        }
      }
    )

    document.addEventListener('DOMContentLoaded', async () => {
      const { data: { session } } = await supabase.auth.getSession()

      if (!session || !session.user) {
        window.location.href = '/login'
        return
      }

      const user = session.user

      const { data: profile, error } = await supabase
        .from('profiles')
        .select('*')
        .eq('id', user.id)
        .single()

      if (error || !profile) {
        window.location.href = '/login'
        return
      }

      initializePortal(user, profile)
    })

    function initializePortal(user, profile) {
      const initials = profile.full_name
        ? profile.full_name.split(' ').map(n => n[0]).join('').slice(0,2).toUpperCase()
        : 'RS'

      const app = document.getElementById('app')

      app.innerHTML = `
        <div class="portal-root">

          <nav class="portal-nav">
            <div class="nav-left" onclick="window.location.href='/'">
              <div class="shield-icon"></div>
              <span class="brand">Retirement <span>Shield</span></span>
            </div>

            <div class="nav-right">
              <span class="badge">${profile.role.toUpperCase()} PORTAL</span>

              <div class="user-menu">
                <div class="avatar">${initials}</div>
                <div class="user-info">
                  <span class="user-name">${profile.full_name}</span>
                  <span class="user-role">${profile.role}</span>
                </div>
                <button id="logoutBtn" class="logout-btn">Sign Out</button>
              </div>
            </div>
          </nav>

          <section class="hero">
            <div class="hero-inner">
              <div class="hero-label">
                <span class="line"></span>
                Your Retirement Action Plan
              </div>

              <div class="hero-card">
                <div class="progress-wrap">
                  <div class="progress-ring">
                    <div class="progress-value">65%</div>
                    <div class="progress-label">Complete</div>
                  </div>
                </div>

                <div class="hero-main">
                  <h1>${profile.full_name ? profile.full_name.split(' ').slice(-1)[0] + ' Family Plan' : 'Your Family Plan'}</h1>
                  <p class="subtext">Prepared following your consultation with Lewis on February 18, 2026</p>

                  <div class="status-badges">
                    <span class="badge-complete">1 Completed</span>
                    <span class="badge-progress">2 In Progress</span>
                    <span class="badge-queued">2 Queued</span>
                  </div>
                </div>

                <div class="review-box">
                  <div class="review-label">Next Plan Review</div>
                  <div class="review-date">August 2026</div>
                  <div class="review-sub">6-month check-in</div>
                </div>
              </div>
            </div>
          </section>

          <div class="tabs-wrap">
            <div class="tabs">
              ${profile.role === 'admin' ? `
                <button class="tab active" data-tab="users">Users</button>
                <button class="tab" data-tab="tasks">Action Tasks</button>
              ` : `
                <button class="tab active" data-tab="action">Action Plan</button>
                <button class="tab" data-tab="team">Your Team</button>
                <button class="tab" data-tab="timeline">Timeline</button>
                <button class="tab" data-tab="documents">Documents</button>
              `}
            </div>
            <div class="tab-underline"></div>
          </div>

          <div class="content-wrap">
            <div id="portalContent"></div>
          </div>

          <footer class="portal-footer">
            © 2026 <strong>Retirement Shield</strong> · Educational use only
          </footer>

        </div>
      `

      document.getElementById('logoutBtn').addEventListener('click', async () => {
        await supabase.auth.signOut()
        window.location.href = '/'
      })

      const contentDiv = document.getElementById('portalContent')

      if (profile.role === 'user') {

        let actionPlan = [];

        async function loadActionPlan() {

          // 1. Load global templates
          const { data: templates } = await supabase
            .from('action_plan_templates')
            .select('*')
            .order('created_at', { ascending: true });

          if (!templates) {
            actionPlan = [];
            return;
          }

          const enrichedPlans = [];

          for (const template of templates) {

            // 2. Load template subtasks
            const { data: subtasks } = await supabase
              .from('action_plan_template_subtasks')
              .select('*')
              .eq('template_id', template.id)
              .order('created_at', { ascending: true });

            // 3. Load user progress for those subtasks
            const { data: progress } = await supabase
              .from('user_subtask_progress')
              .select('*')
              .eq('user_id', user.id);

            const mergedSubtasks = (subtasks || []).map(st => {
              const match = progress?.find(p => p.subtask_id === st.id);
              return {
                id: st.id,
                label: st.label,
                done: match ? match.done : false
              };
            });

            // 4. Auto-calc status from subtasks
            let status = 'queued';
            if (mergedSubtasks.length) {
              if (mergedSubtasks.every(s => s.done)) status = 'complete';
              else if (mergedSubtasks.some(s => s.done)) status = 'progress';
            }

            enrichedPlans.push({
              id: template.id,
              title: template.title,
              category: template.category,
              details: template.details,
              status,
              subtasks: mergedSubtasks
            });
          }

          actionPlan = enrichedPlans;
        }

        function calculateStats() {
          const completed = actionPlan.filter(a => a.status === 'complete').length
          const inProgress = actionPlan.filter(a => a.status === 'progress').length
          const queued = actionPlan.filter(a => a.status === 'queued').length
          return { completed, inProgress, queued }
        }

        async function renderPlan() {
          const stats = calculateStats()

          document.querySelector('.badge-complete').innerText = `${stats.completed} Completed`
          document.querySelector('.badge-progress').innerText = `${stats.inProgress} In Progress`
          document.querySelector('.badge-queued').innerText = `${stats.queued} Queued`

          // Preserve which card is open
          const openCard = document.querySelector('.plan-card.open')
          const openId = openCard ? openCard.dataset.id : null

          contentDiv.innerHTML = actionPlan.map(item => `
            <div class="plan-card ${item.status}" data-id="${item.id}">
              <div class="plan-header">
                <div class="plan-left">
                  <div class="plan-number">${item.id.toString().slice(0,4)}</div>
                  <div>
                    <h3>${item.title}</h3>
                    <div class="plan-category">${item.category ?? ''}</div>
                  </div>
                </div>
                <div class="plan-status">${item.status.replace('_',' ')}</div>
              </div>
              <div class="plan-body">
                <p>${item.details ?? ''}</p>
                ${item.subtasks.length > 0 ? `
                  <div class="subtasks">
                    ${item.subtasks.map((s, i) => `
                      <label class="subtask ${s.done ? 'done' : ''}">
                        <input type="checkbox" data-parent="${item.id}" data-index="${i}" ${s.done ? 'checked' : ''}>
                        <span class="custom-check"></span>
                        <span class="task-label">${s.label}</span>
                      </label>
                    `).join('')}
                  </div>
                ` : ''}
              </div>
            </div>
          `).join('')

          attachEvents()

          if (openId) {
            const restored = document.querySelector(`.plan-card[data-id="${openId}"]`)
            if (restored) restored.classList.add('open')
          }
        }

        // --- DOCUMENTS TAB FUNCTIONALITY ---
        function renderDocuments() {
          contentDiv.innerHTML = `
            <div class="doc-card">
              <div class="doc-header">
                <div class="doc-icon">📄</div>
                <div>
                  <h3>Estate Planning Assessment</h3>
                  <div class="doc-meta">Generated March 4, 2026 · Personalized Strategy Report</div>
                </div>
              </div>

              <div class="doc-body">
                <p>
                  This comprehensive estate planning report outlines your trust structure,
                  beneficiary designations, asset protection positioning, and retirement
                  income coordination strategy.
                </p>
              </div>

              <div class="doc-actions">
                <button class="view-pdf-btn" id="viewPdfBtn">View My PDF</button>
              </div>
            </div>
          `
          const pdfBtn = document.getElementById('viewPdfBtn')
          if (pdfBtn) {
            pdfBtn.addEventListener('click', () => {
              window.location.href = `/EstatePlanningAssessmentpdf/${user.id}`
            })
          }
        }

        function renderTeam() {
          contentDiv.innerHTML = `
            <div class="doc-card">
              <div class="doc-header">
                <div class="doc-icon">👥</div>
                <div>
                  <h3>Your Advisory Team</h3>
                  <div class="doc-meta">Professional coordination overview</div>
                </div>
              </div>

              <div class="doc-body">
                <p>
                  No advisory team has been assigned to your plan yet.
                  Once your legal, tax, or insurance professionals are
                  connected to your strategy, they will appear here.
                </p>
              </div>
            </div>
          `
        }

        function renderTimeline() {
          contentDiv.innerHTML = `
            <div class="doc-card">
              <div class="doc-header">
                <div class="doc-icon">🗓️</div>
                <div>
                  <h3>Implementation Timeline</h3>
                  <div class="doc-meta">Execution milestones & review schedule</div>
                </div>
              </div>

              <div class="doc-body">
                <p>
                  No implementation timeline has been generated yet.
                  Once your retirement action steps are formally scheduled,
                  milestone tracking and progress deadlines will appear here.
                </p>
              </div>
            </div>
          `
        }

        function attachEvents() {
          document.querySelectorAll('.plan-header').forEach(h => {
            h.onclick = () => {
              const card = h.parentElement
              const isOpen = card.classList.contains('open')

              // Close all cards first
              document.querySelectorAll('.plan-card').forEach(c => c.classList.remove('open'))

              // If it was not open before, open it
              if (!isOpen) {
                card.classList.add('open')
              }
            }
          })

          document.querySelectorAll('.subtask input').forEach(cb => {
            cb.onchange = async (e) => {
              const parentId = e.target.dataset.parent;
              const index = Number(e.target.dataset.index);

              const planItem = actionPlan.find(a => a.id === parentId);
              const subtask = planItem.subtasks[index];

              subtask.done = e.target.checked;

              await supabase
                .from('user_subtask_progress')
                .upsert({
                  user_id: user.id,
                  subtask_id: subtask.id,
                  done: subtask.done
                }, { onConflict: 'user_id,subtask_id' });

              renderPlan();
            }
          })
        }

        (async () => {
          await loadActionPlan();
          renderPlan();
        })();

        const tabs = document.querySelectorAll('.tab')

        tabs.forEach(tab => {
          tab.addEventListener('click', async () => {
            tabs.forEach(t => t.classList.remove('active'))
            tab.classList.add('active')

            const type = tab.dataset.tab

            if (type === 'action') {
              await loadActionPlan();
              renderPlan();
            }
            if (type === 'documents') renderDocuments()
            if (type === 'team') renderTeam()
            if (type === 'timeline') renderTimeline()
          })
        })
      }

      // --- ADMIN USERS TAB LOGIC ---
      if (profile.role === 'admin') {

        async function renderUsers() {
          const { data: users } = await supabase
            .from('profiles')
            .select('*')
            .order('created_at', { ascending: false })

          contentDiv.innerHTML = `
            <div class="doc-card">
              <div class="doc-header">
                <div class="doc-icon">👥</div>
                <div>
                  <h3>All Registered Users</h3>
                  <div class="doc-meta">Manage roles and permissions</div>
                </div>
              </div>

              <div class="doc-body">
                ${users.map(u => `
                  <div class="card user-card" data-user="${u.id}" style="margin-bottom:14px;">
                    <div class="user-row" style="display:flex; justify-content:space-between; align-items:center; cursor:pointer;">
                      <div>
                        <strong>${u.full_name ?? 'No Name'}</strong>
                        <div style="font-size:13px; color:var(--text-muted);">
                          ${u.email ?? ''}
                        </div>
                      </div>

                      <div style="display:flex; align-items:center; gap:10px;">
                        <select data-user="${u.id}" class="role-select" style="padding:6px 12px; border-radius:8px;">
                          <option value="user" ${u.role === 'user' ? 'selected' : ''}>User</option>
                          <option value="admin" ${u.role === 'admin' ? 'selected' : ''}>Admin</option>
                        </select>

                        <button 
                          data-delete="${u.id}" 
                          class="delete-user-btn"
                          style="
                            background:#b84040;
                            color:white;
                            border:none;
                            padding:6px 14px;
                            border-radius:8px;
                            cursor:pointer;
                            font-size:12px;
                          ">
                          Delete
                        </button>
                      </div>
                    </div>
                    <div class="user-answers" style="display:none; margin-top:18px;"></div>
                  </div>
                `).join('')}
              </div>
            </div>
          `

          document.querySelectorAll('.role-select').forEach(select => {
            select.addEventListener('change', async (e) => {
              const userId = e.target.dataset.user
              const newRole = e.target.value

              await supabase
                .from('profiles')
                .update({ role: newRole })
                .eq('id', userId)

              renderUsers()
            })
          })

          document.querySelectorAll('.delete-user-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {
              const userId = e.target.dataset.delete

              const confirmed = confirm("Are you sure you want to permanently delete this user? This action cannot be undone.")

              if (!confirmed) return

              const { error } = await supabase
                .from('profiles')
                .delete()
                .eq('id', userId)

              if (error) {
                alert("Error deleting user.")
                console.error(error)
                return
              }

              renderUsers()
            })
          })

          // User row expand/collapse and show quiz answers
          document.querySelectorAll('.user-card').forEach(card => {
            card.querySelector('.user-row').addEventListener('click', async (e) => {

              // Prevent click from firing when clicking buttons/select
              if (e.target.closest('select') || e.target.closest('button')) return

              const userId = card.dataset.user
              const answersContainer = card.querySelector('.user-answers')

              // Toggle close if already open
              if (answersContainer.style.display === 'block') {
                answersContainer.style.display = 'none'
                answersContainer.innerHTML = ''
                return
              }

              // Close other open cards
              document.querySelectorAll('.user-answers').forEach(a => {
                a.style.display = 'none'
                a.innerHTML = ''
              })

              const { data, error } = await supabase
                .from('quiz_submissions')
                .select('answers')
                .eq('user_id', userId)
                .order('created_at', { ascending: false })
                .limit(1)
                .single()

              if (error || !data) {
                answersContainer.innerHTML = '<p style="color:red;">No quiz submission found.</p>'
                answersContainer.style.display = 'block'
                return
              }

              const answers = data.answers || {}

              answersContainer.innerHTML = `
                <table style="
                  width:100%;
                  border-collapse:collapse;
                  margin-top:10px;
                  font-size:14px;
                ">
                  ${Object.entries(answers).map(([key, value]) => `
                    <tr>
                      <td style="padding:8px; border:1px solid var(--rule-light); font-weight:600;">
                        ${key}
                      </td>
                      <td style="padding:8px; border:1px solid var(--rule-light);">
                        ${value}
                      </td>
                    </tr>
                  `).join('')}
                </table>
              `

              answersContainer.style.display = 'block'
            })
          })
        }

        // --- Action Tasks Tab ---
        async function renderActionTasks() {

          // --- Step 1: Add edit mode state ---
          let editingTemplateId = null;

          // Load existing templates
          const { data: templates } = await supabase
            .from('action_plan_templates')
            .select('*')
            .order('created_at', { ascending: true });

          contentDiv.innerHTML = `
            <div class="doc-card">
              <h3>Create Global Action Plan Template</h3>

              <input id="newTitle" placeholder="Title"
                style="width:100%;margin-bottom:10px;padding:10px;border-radius:8px;border:1px solid #ddd;">

              <input id="newCategory" placeholder="Category"
                style="width:100%;margin-bottom:14px;padding:10px;border-radius:8px;border:1px solid #ddd;">

              <div id="subtaskContainer"></div>

              <button id="addSubtaskBtn"
                style="margin-bottom:14px;background:#eee;border:none;padding:8px 14px;border-radius:6px;cursor:pointer;">
                + Add Checklist Item
              </button>

              <button id="createPlanBtn" class="view-pdf-btn">
                Create Template
              </button>
            </div>

            <div class="doc-card" style="margin-top:30px;">
              <h3>Existing Action Plan Templates</h3>

              <table style="width:100%;border-collapse:collapse;font-size:14px;">
                <thead>
                  <tr>
                    <th style="text-align:left;padding:8px;border-bottom:1px solid var(--rule-light);">Title</th>
                    <th style="text-align:left;padding:8px;border-bottom:1px solid var(--rule-light);">Category</th>
                    <th style="text-align:right;padding:8px;border-bottom:1px solid var(--rule-light);">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  ${(templates || []).map(t => `
                    <tr>
                      <td style="padding:8px;border-bottom:1px solid var(--rule-light);">${t.title}</td>
                      <td style="padding:8px;border-bottom:1px solid var(--rule-light);">${t.category ?? ''}</td>
                      <td style="padding:8px;border-bottom:1px solid var(--rule-light);text-align:right;">
                        <button data-edit="${t.id}" class="edit-template-btn" style="margin-right:8px;">Edit</button>
                        <button data-delete="${t.id}" style="background:#b84040;color:white;border:none;padding:6px 12px;border-radius:6px;">Delete</button>
                      </td>
                    </tr>
                  `).join('')}
                </tbody>
              </table>
            </div>
          `;

          // -------- Checklist logic --------
          const subtaskContainer = document.getElementById('subtaskContainer');
          const addSubtaskBtn = document.getElementById('addSubtaskBtn');

          function addSubtaskInput(value = '') {
            const wrapper = document.createElement('div');
            wrapper.style.display = 'flex';
            wrapper.style.gap = '8px';
            wrapper.style.marginBottom = '8px';

            wrapper.innerHTML = `
              <input type="text"
                class="subtask-input"
                placeholder="Checklist item"
                value="${value}"
                style="flex:1;padding:8px;border-radius:6px;border:1px solid #ddd;">
              <button class="remove-subtask"
                style="background:#b84040;color:white;border:none;padding:6px 10px;border-radius:6px;cursor:pointer;">
                ✕
              </button>
            `;

            wrapper.querySelector('.remove-subtask').addEventListener('click', () => {
              wrapper.remove();
            });

            subtaskContainer.appendChild(wrapper);
          }

          addSubtaskBtn.addEventListener('click', () => addSubtaskInput());

          // --- Step 3: Unified create/edit handler ---
          const createBtn = document.getElementById('createPlanBtn');
          createBtn.addEventListener('click', async () => {

            const title = document.getElementById('newTitle').value.trim();
            const category = document.getElementById('newCategory').value.trim();

            if (!title) return alert("Title required.");

            // --- EDIT MODE ---
            if (editingTemplateId) {

              await supabase
                .from('action_plan_templates')
                .update({ title, category })
                .eq('id', editingTemplateId);

              await supabase
                .from('action_plan_template_subtasks')
                .delete()
                .eq('template_id', editingTemplateId);

              const subtaskInputs = document.querySelectorAll('.subtask-input');
              const subtasks = [];

              subtaskInputs.forEach(input => {
                if (input.value.trim()) {
                  subtasks.push({
                    template_id: editingTemplateId,
                    label: input.value.trim()
                  });
                }
              });

              if (subtasks.length) {
                await supabase.from('action_plan_template_subtasks').insert(subtasks);
              }

              editingTemplateId = null;
              createBtn.innerText = "Create Template";
            }

            // --- CREATE MODE ---
            else {

              const { data: template, error } = await supabase
                .from('action_plan_templates')
                .insert({ title, category })
                .select()
                .single();

              if (error) return alert("Error creating template.");

              const subtaskInputs = document.querySelectorAll('.subtask-input');
              const subtasks = [];

              subtaskInputs.forEach(input => {
                if (input.value.trim()) {
                  subtasks.push({
                    template_id: template.id,
                    label: input.value.trim()
                  });
                }
              });

              if (subtasks.length) {
                await supabase.from('action_plan_template_subtasks').insert(subtasks);
              }
            }

            // Reset form
            document.getElementById('newTitle').value = '';
            document.getElementById('newCategory').value = '';
            subtaskContainer.innerHTML = '';

            renderActionTasks();
          });

          // -------- DELETE TEMPLATE --------
          document.querySelectorAll('[data-delete]').forEach(btn => {
            btn.addEventListener('click', async (e) => {

              const id = e.target.dataset.delete;
              if (!confirm("Delete this template?")) return;

              await supabase.from('action_plan_template_subtasks').delete().eq('template_id', id);
              await supabase.from('action_plan_templates').delete().eq('id', id);

              renderActionTasks();
            });
          });

          // -------- EDIT TEMPLATE --------
          document.querySelectorAll('.edit-template-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {

              const id = e.target.dataset.edit;

              // Load template
              const { data: template } = await supabase
                .from('action_plan_templates')
                .select('*')
                .eq('id', id)
                .single();

              if (!template) return alert("Template not found.");

              // Load subtasks
              const { data: subtasks } = await supabase
                .from('action_plan_template_subtasks')
                .select('*')
                .eq('template_id', id)
                .order('created_at', { ascending: true });

              // Populate form
              document.getElementById('newTitle').value = template.title || '';
              document.getElementById('newCategory').value = template.category || '';

              const subtaskContainer = document.getElementById('subtaskContainer');
              subtaskContainer.innerHTML = '';

              (subtasks || []).forEach(st => {
                addSubtaskInput(st.label);
              });

              // Step 4: Set edit mode state & button label
              editingTemplateId = id;
              createBtn.innerText = "Save Changes";
            });
          });

        }

        renderUsers()

        const tabs = document.querySelectorAll('.tab')

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('active'))
            tab.classList.add('active')

            if (tab.dataset.tab === 'users') {
              renderUsers()
            }
            if (tab.dataset.tab === 'tasks') {
              renderActionTasks()
            }
          })
        })
      }
    }
  </script>

  <style is:global>

  /* =========================
   MOBILE OPTIMISATION
========================== */

@media (max-width: 768px) {

  body {
    overflow-x: hidden;
  }

  /* NAV */
  .portal-nav {
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
    height: auto;
    padding: 16px 16px 20px;
    gap: 12px;
    position: relative;
    z-index: 50;
  }

  .nav-right {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }

  .nav-left {
    width: 100%;
    justify-content: center;
  }

  .brand {
    font-size: 18px;
    text-align: center;
  }

  .user-menu {
    width: 100%;
    justify-content: space-between;
    padding: 8px 14px;
  }

  .logout-btn {
    padding: 6px 10px;
    font-size: 11px;
  }

  .hero {
    padding-top: 40px;
  }

  /* HERO */
  .hero {
    padding: 40px 20px 30px;
    margin-top: 0;
  }

  .hero-card {
    flex-direction: column;
    gap: 28px;
    padding: 28px 20px;
    text-align: center;
  }

  .progress-ring {
    width: 110px;
    height: 110px;
    border-width: 8px;
  }

  .progress-value {
    font-size: 26px;
  }

  .hero-main h1 {
    font-size: 22px;
    line-height: 1.3;
  }

  .status-badges {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
  }

  .status-badges span {
    width: 100%;
    text-align: center;
  }

  .review-box {
    width: 100%;
    padding: 20px;
  }

  /* TABS */
  .tabs-wrap {
    margin-top: 30px;
    padding: 0 20px;
  }

  .tabs {
    overflow-x: auto;
    gap: 24px;
  }

  /* CONTENT WRAP */
  .content-wrap {
    padding: 0 20px;
    margin: 30px auto 60px;
  }

  /* ACTION PLAN */
  .plan-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .plan-left {
    gap: 12px;
  }

  .plan-number {
    width: 36px;
    height: 36px;
    font-size: 13px;
  }

  .plan-left h3 {
    font-size: 16px;
  }

  .plan-status {
    align-self: flex-start;
  }

  /* DOCUMENTS */
  .doc-card {
    padding: 24px 20px;
    max-width: 100%;
  }

  .doc-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
  }

  .doc-icon {
    width: 56px;
    height: 56px;
    font-size: 26px;
  }

  .view-pdf-btn {
    width: 100%;
  }

  /* ADMIN USERS */
  .user-row {
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 12px !important;
  }

  .role-select,
  .delete-user-btn {
    width: 100%;
  }

}

    :root {
      --navy: #0d1b2a;
      --navy-mid: #1a2e45;
      --navy-light: #243b55;
      --cream: #f5f0e8;
      --cream-dark: #ede6d6;
      --amber: #c8821a;
      --amber-light: #e8a840;
      --text-primary: #1a1208;
      --text-secondary: #4a3f32;
      --text-muted: #7a6e62;
      --white: #ffffff;
      --rule: #c8b89a;
      --rule-light: rgba(200,184,154,0.35);
    }

    body {
      margin: 0;
      font-family: 'DM Sans', sans-serif;
      background: var(--cream-dark);
      color: var(--text-primary);
      overflow-x: hidden;
    }

    /* NAV */

    .portal-nav {
      background: var(--navy);
      height: 72px;
      padding: 0 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      box-sizing: border-box;
    }

    .nav-left {
      display: flex;
      align-items: center;
      gap: 14px;
      cursor: pointer;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 18px;
      flex-shrink: 0;
    }

    .user-menu {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 6px 14px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 999px;
      transition: all .2s ease;
      max-width: 100%;
    }

    .user-menu:hover {
      background: rgba(255,255,255,0.08);
      border-color: var(--amber);
    }

    .badge {
      white-space: nowrap;
    }

    @media (max-width: 900px) {
      .badge {
        display: none;
      }

      .user-info {
        display: none;
      }

      .portal-nav {
        padding: 0 20px;
      }
    }

    .user-info {
      display: flex;
      flex-direction: column;
      line-height: 1.1;
    }

    .user-name {
      color: var(--white);
      font-size: 14px;
      font-weight: 500;
    }

    .user-role {
      font-size: 11px;
      color: var(--amber-light);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .logout-btn {
      background: transparent;
      border: 1px solid rgba(255,255,255,0.2);
      color: rgba(255,255,255,0.8);
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 12px;
      cursor: pointer;
      transition: all .2s ease;
    }

    .logout-btn:hover {
      border-color: var(--amber);
      color: var(--amber-light);
      background: rgba(200,130,26,.1);
    }

    .brand {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--white);
    }

    .brand span {
      color: var(--amber);
    }

    .badge {
      border: 1px solid var(--amber);
      color: var(--amber-light);
      background: rgba(200,130,26,.15);
      padding: 6px 16px;
      border-radius: 40px;
      font-size: 12px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .avatar {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: linear-gradient(135deg,var(--navy-mid),var(--navy-light));
      border: 2px solid var(--amber);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: var(--amber-light);
      font-size: 14px;
      box-shadow: 0 0 0 3px rgba(200,130,26,0.15);
      flex-shrink: 0;
    }

    /* HERO SECTION */

    .hero {
      background: linear-gradient(135deg,var(--navy) 0%,var(--navy-mid) 60%,var(--navy-light) 100%);
      padding: 80px 48px 60px;
      position: relative;
    }

    .hero-inner {
      max-width: 1100px;
      margin: 0 auto;
    }

    .hero-label {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--amber);
      font-size: 13px;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .hero-label .line {
      width: 28px;
      height: 2px;
      background: var(--amber);
    }

    .hero-card {
      background: var(--cream);
      border-radius: 20px;
      padding: 40px 48px;
      display: flex;
      gap: 48px;
      align-items: center;
      box-shadow: 0 20px 60px rgba(0,0,0,.15);
    }

    .progress-ring {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      border: 10px solid var(--rule-light);
      border-top: 10px solid var(--amber);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .progress-value {
      font-family: 'Playfair Display', serif;
      font-size: 34px;
      font-weight: 700;
      color: var(--navy);
    }

    .progress-label {
      font-size: 12px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .hero-main h1 {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      margin: 0 0 8px;
    }

    .subtext {
      color: var(--text-muted);
      margin-bottom: 16px;
    }

    .status-badges span {
      padding: 6px 16px;
      border-radius: 40px;
      font-size: 13px;
      margin-right: 10px;
      border: 1px solid;
    }

    .badge-complete {
      color: #2d6a4f;
      border-color: #2d6a4f;
      background: rgba(45,106,79,.1);
    }

    .badge-progress {
      color: var(--amber);
      border-color: var(--amber);
      background: rgba(200,130,26,.1);
    }

    .badge-queued {
      color: var(--text-muted);
      border-color: var(--rule);
      background: rgba(200,184,154,.15);
    }

    .review-box {
      background: var(--cream-dark);
      padding: 28px 36px;
      border-radius: 16px;
      min-width: 240px;
      text-align: center;
    }

    .review-label {
      font-size: 12px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 6px;
    }

    .review-date {
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      font-weight: 700;
    }

    .review-sub {
      font-size: 13px;
      color: var(--text-muted);
    }

    /* TABS SECTION */

    .tabs-wrap {
      max-width: 1100px;
      margin: 60px auto 0;
      padding: 0 48px;
    }

    .tabs {
      display: flex;
      gap: 48px;
      align-items: center;
    }

    .tab {
      background: none;
      border: none;
      font-family: 'DM Sans', sans-serif;
      font-size: 18px;
      color: var(--text-muted);
      cursor: pointer;
      padding: 16px 0;
      position: relative;
      transition: color .2s ease;
    }

    .tab:hover {
      color: var(--text-primary);
    }

    .tab.active {
      color: var(--navy);
      font-weight: 600;
    }

    .tab-underline {
      height: 2px;
      background: var(--rule-light);
      margin-top: -2px;
      width: 100%;
    }

    .tab.active::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 100%;
      height: 3px;
      background: var(--amber);
      border-radius: 2px;
    }

    @media (max-width: 900px) {
      .tabs-wrap {
        padding: 0 20px;
      }

      .tabs {
        gap: 24px;
        overflow-x: auto;
      }

      .tab {
        font-size: 16px;
        white-space: nowrap;
      }
    }

    /* CONTENT */

    .portal-root {
      background: var(--cream-dark);
    }

    .content-wrap {
      max-width: 1100px;
      margin: 40px auto 80px;
      padding: 0 48px;
    }

    .card {
      background: var(--white);
      border-radius: 14px;
      padding: 24px;
      border: 1px solid var(--rule-light);
      margin-bottom: 16px;
      box-shadow: 0 4px 20px rgba(0,0,0,.06);
    }

    .portal-footer {
      background: var(--navy);
      padding: 32px;
      text-align: center;
      font-size: 12px;
      color: rgba(255,255,255,.4);
    }


    /* ACTION PLAN CARDS */

    .plan-card {
      background: var(--white);
      border-radius: 16px;
      border: 1px solid var(--rule-light);
      margin-bottom: 20px;
      overflow: hidden;
      transition: all .25s ease;
      box-shadow: 0 6px 24px rgba(0,0,0,.05);
    }

    .plan-card.complete .plan-number {
      background: #2d6a4f;
    }

    .plan-card.progress .plan-number {
      background: var(--amber);
    }

    .plan-card.queued .plan-number {
      background: var(--rule);
      color: var(--text-muted);
    }

    .plan-header {
      padding: 22px 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      transition: background .2s ease;
    }

    .plan-header:hover {
      background: rgba(0,0,0,0.02);
    }

    .plan-left {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .plan-number {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: var(--white);
      font-size: 15px;
      transition: all .2s ease;
    }

    .plan-left h3 {
      margin: 0;
      font-size: 18px;
      font-weight: 600;
    }

    .plan-category {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .plan-status {
      font-size: 12px;
      padding: 6px 14px;
      border-radius: 40px;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }

    .plan-card.complete .plan-status {
      background: rgba(45,106,79,.1);
      color: #2d6a4f;
    }

    .plan-card.progress .plan-status {
      background: rgba(200,130,26,.1);
      color: var(--amber);
    }

    .plan-card.queued .plan-status {
      background: rgba(200,184,154,.2);
      color: var(--text-muted);
    }

    .plan-body {
      padding: 0 28px 28px;
      display: none;
      border-top: 1px solid var(--rule-light);
      background: rgba(0,0,0,0.01);
      animation: fadeIn .25s ease;
    }

    .plan-card.open .plan-body {
      display: block;
    }

    .subtasks {
      margin-top: 18px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .subtask {
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
    }

    .subtask input {
      width: 18px;
      height: 18px;
      accent-color: var(--amber);
      cursor: pointer;
    }

    /* Custom Subtask Checkbox Styling */

    .subtask {
      position: relative;
      cursor: pointer;
      font-size: 16px;
      gap: 14px;
    }

    .subtask input {
      display: none;
    }

    .custom-check {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 2px solid #cfd6dc;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .2s ease;
      flex-shrink: 0;
    }

    .subtask.done .custom-check {
      background: #2d6a4f;
      border-color: #2d6a4f;
    }

    .subtask.done .custom-check::after {
      content: '✓';
      color: white;
      font-size: 14px;
      font-weight: 700;
    }

    .task-label {
      transition: all .2s ease;
    }

    .subtask.done .task-label {
      text-decoration: line-through;
      color: #6b7280;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-4px); }
      to { opacity: 1; transform: translateY(0); }
    }



    /* DOCUMENTS TAB */

    .doc-card {
      background: var(--white);
      border-radius: 20px;
      padding: 36px;
      border: 1px solid var(--rule-light);
      box-shadow: 0 20px 60px rgba(0,0,0,.08);
      max-width: 95%;
    }

    .doc-header {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 20px;
    }

    .doc-icon {
      font-size: 34px;
      background: rgba(200,130,26,.1);
      width: 70px;
      height: 70px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .doc-header h3 {
      margin: 0;
      font-size: 22px;
      font-family: 'Playfair Display', serif;
    }

    .doc-meta {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 6px;
    }

    .doc-body p {
      font-size: 15px;
      line-height: 1.6;
      color: var(--text-secondary);
    }

    .doc-actions {
      margin-top: 28px;
    }

    .view-pdf-btn {
      background: var(--amber);
      color: var(--white);
      border: none;
      padding: 14px 28px;
      border-radius: 40px;
      font-weight: 600;
      cursor: pointer;
      font-size: 14px;
      transition: all .2s ease;
    }

    .view-pdf-btn:hover {
      background: var(--amber-light);
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(200,130,26,.3);
    }
</style>
</body>
</html>
