---
export const prerender = false;
import { createClient } from '@supabase/supabase-js';

const { userid } = Astro.params;

// Use service role key on server (NOT exposed to client)
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
  {
    auth: { persistSession: false }
  }
);

// Fetch latest quiz submission for this user
const { data, error } = await supabase
  .from('quiz_submissions')
  .select('answers, created_at')
  .eq('user_id', userid)
  .order('created_at', { ascending: false })
  .limit(1)
  .single();

console.log('USERID PARAM:', userid);
console.log('SUPABASE ERROR:', error);
console.log('RAW ROW:', data);

// If RLS blocks or no row found, this will help us see it clearly
if (!data) {
  console.log('No submission found for this user.');
}

const answers = data?.answers ?? {};
console.log('PARSED ANSWERS:', answers);

// Basic dynamic scoring logic
let score = 100;
let gaps = [];

if (answers.will !== 'recent') {
  score -= 15;
  gaps.push({ label: 'Will — Outdated or Missing', severity: 'critical', color: 'red' });
}

if (!answers.trust) {
  score -= 15;
  gaps.push({ label: 'No trust structure in place', severity: 'critical', color: 'red' });
}

if (!answers.beneficiary) {
  score -= 10;
  gaps.push({ label: 'Beneficiary designations not reviewed', severity: 'critical', color: 'red' });
}

if (!answers.poa) {
  score -= 10;
  gaps.push({ label: 'Power of attorney missing', severity: 'warning', color: 'yellow' });
}

if (!answers.healthcare) {
  score -= 10;
  gaps.push({ label: 'No healthcare directive', severity: 'critical', color: 'red' });
}

if (!answers.ltc) {
  score -= 10;
  gaps.push({ label: 'Medicaid exposure not assessed', severity: 'warning', color: 'yellow' });
}

if (!answers.insurance) {
  score -= 10;
  gaps.push({ label: 'Life insurance structure not reviewed', severity: 'warning', color: 'yellow' });
}

score = Math.max(score, 0);
const gapCount = gaps.length;
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Estate Planning Assessment Report</title>
</head>

<style is:global>
  :root {
    --navy: #0d1b2a;
    --navy-mid: #162032;
    --navy-light: #1e2f45;
    --gold: #c9a84c;
    --gold-light: #e8c96a;
    --gold-pale: #f5e8c0;
    --cream: #faf7f0;
    --cream-dark: #f0ead8;
    --red: #b84040;
    --red-light: #d94f4f;
    --green: #2d6a4f;
    --green-light: #52b788;
    --text-dark: #1a1a1a;
    --text-mid: #3d3d3d;
    --text-light: #6b6b6b;
    --border: #d4c9a8;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--cream);
    color: var(--text-dark);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    line-height: 1.7;
  }

  /* COVER PAGE */
  .cover {
    background: var(--navy);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    page-break-after: always;
  }

  .cover-texture {
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(ellipse at 20% 80%, rgba(201,168,76,0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(201,168,76,0.06) 0%, transparent 50%),
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 40px,
        rgba(255,255,255,0.01) 40px,
        rgba(255,255,255,0.01) 41px
      );
  }

  .export-btn {
  background: transparent;
  border: 1px solid rgba(201,168,76,0.5);
  color: var(--gold);
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 8px 16px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.export-btn:hover {
  background: var(--gold);
  color: var(--navy);
}

@media print {

  /* Hide export button */
  .export-btn {
    display: none !important;
  }

  /* Force exact color rendering */
  html, body {
    background: var(--cream) !important;
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
  }

  * {
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
  }

  /* Force dark sections to KEEP their backgrounds */
  .cover {
    background: var(--navy) !important;
  }

  .score-card,
  .case-study,
  .cta-card,
  .alert-box {
    background: var(--navy) !important;
  }

  /* Preserve gradients and textures */
  .cover-texture {
    display: block !important;
  }

  /* Remove any browser lightening */
  body {
    filter: none !important;
  }
}

  .cover-top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 32px 56px;
    border-bottom: 1px solid rgba(201,168,76,0.2);
    position: relative;
    z-index: 2;
    animation: fadeDown 0.8s ease both;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-shield {
    width: 36px;
    height: 42px;
    position: relative;
  }

  .logo-shield svg {
    width: 100%;
    height: 100%;
  }

  .logo-text {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--cream);
    letter-spacing: 0.05em;
  }

  .logo-text span {
    color: var(--gold);
  }

  .cover-badge {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--gold);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border: 1px solid rgba(201,168,76,0.3);
    padding: 6px 14px;
  }

  .cover-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 56px;
    position: relative;
    z-index: 2;
    animation: fadeUp 1s ease 0.3s both;
  }

  .cover-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .cover-eyebrow::before {
    content: '';
    display: block;
    width: 40px;
    height: 1px;
    background: var(--gold);
  }

  .cover-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(42px, 6vw, 72px);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    max-width: 780px;
    margin-bottom: 8px;
  }

  .cover-title em {
    color: var(--gold);
    font-style: italic;
  }

  .cover-subtitle {
    font-size: 18px;
    color: rgba(250,247,240,0.6);
    font-weight: 300;
    max-width: 520px;
    margin-top: 24px;
    line-height: 1.6;
  }

  .cover-divider {
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), transparent);
    margin: 40px 0;
  }

  .cover-stats {
    display: flex;
    gap: 56px;
    margin-top: 0;
  }

  .cover-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cover-stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
  }

  .cover-stat-label {
    font-size: 11px;
    color: rgba(250,247,240,0.5);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .cover-bottom {
    padding: 32px 56px;
    border-top: 1px solid rgba(201,168,76,0.15);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    z-index: 2;
    animation: fadeUp 1s ease 0.6s both;
  }

  .cover-bottom-left {
    font-size: 12px;
    color: rgba(250,247,240,0.35);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.05em;
  }

  .cover-warning {
    background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.2);
    padding: 10px 20px;
    font-size: 10px;
    color: rgba(250,247,240,0.5);
    max-width: 360px;
    text-align: right;
    line-height: 1.5;
  }

  .cover-large-number {
    position: absolute;
    right: 56px;
    bottom: 100px;
    font-family: 'Playfair Display', serif;
    font-size: 280px;
    font-weight: 700;
    color: rgba(201,168,76,0.04);
    line-height: 1;
    z-index: 1;
    user-select: none;
    letter-spacing: -0.05em;
  }

  /* MAIN CONTENT */
  .report-body {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 40px 80px;
  }

  /* INTRO SECTION */
  .intro-section {
    padding: 80px 0 60px;
    border-bottom: 1px solid var(--border);
    animation: fadeUp 0.8s ease 0.2s both;
  }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
    max-width: 60px;
  }

  .intro-lead {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--text-dark);
    max-width: 720px;
    margin-bottom: 28px;
  }

  .intro-lead strong {
    color: var(--navy);
    font-weight: 700;
  }

  .intro-body {
    font-size: 15px;
    color: var(--text-mid);
    max-width: 680px;
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .alert-box {
    background: var(--navy);
    border-left: 4px solid var(--gold);
    padding: 24px 28px;
    margin: 40px 0;
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .alert-icon {
    font-size: 24px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .alert-text {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    color: var(--cream);
    line-height: 1.6;
    font-style: italic;
  }

  .alert-text strong {
    color: var(--gold);
    font-style: normal;
  }

  /* SCORE CARD */
  .score-section {
    padding: 60px 0;
    border-bottom: 1px solid var(--border);
  }

  .score-card {
    background: var(--navy);
    padding: 48px;
    position: relative;
    overflow: hidden;
    margin-top: 32px;
  }

  .score-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light), transparent);
  }

  .score-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 48px;
    align-items: start;
  }

  .score-circle-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .score-circle {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    border: 3px solid rgba(201,168,76,0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    background: rgba(201,168,76,0.05);
  }

  .score-circle::before {
    content: '';
    position: absolute;
    inset: 6px;
    border-radius: 50%;
    border: 1px solid rgba(201,168,76,0.15);
  }

  .score-num {
    font-family: 'Playfair Display', serif;
    font-size: 52px;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
  }

  .score-denom {
    font-size: 12px;
    color: rgba(250,247,240,0.4);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.1em;
  }

  .score-label {
    font-size: 11px;
    color: var(--gold);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .score-details {
    padding-top: 4px;
  }

  .score-headline {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    color: var(--cream);
    margin-bottom: 20px;
    line-height: 1.4;
  }

  .score-headline em {
    color: var(--gold);
    font-style: italic;
  }

  .gap-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .gap-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: rgba(250,247,240,0.75);
  }

  .gap-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .gap-dot.red { background: var(--red-light); }
  .gap-dot.yellow { background: var(--gold); }
  .gap-dot.green { background: var(--green-light); }

  .gap-status {
    margin-left: auto;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    padding: 3px 10px;
  }

  .gap-status.critical {
    color: var(--red-light);
    border: 1px solid rgba(184,64,64,0.3);
    background: rgba(184,64,64,0.08);
  }

  .gap-status.warning {
    color: var(--gold);
    border: 1px solid rgba(201,168,76,0.3);
    background: rgba(201,168,76,0.08);
  }

  .gap-status.ok {
    color: var(--green-light);
    border: 1px solid rgba(82,183,136,0.3);
    background: rgba(82,183,136,0.08);
  }

  /* GAP SECTIONS */
  .gap-section {
    padding: 64px 0 48px;
    border-bottom: 1px solid var(--border);
    animation: fadeUp 0.6s ease both;
  }

  .gap-header {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 24px;
    align-items: start;
    margin-bottom: 32px;
  }

  .gap-number {
    font-family: 'Playfair Display', serif;
    font-size: 64px;
    font-weight: 700;
    color: var(--cream-dark);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .gap-title-block {
    padding-top: 8px;
  }

  .gap-category {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 8px;
  }

  .gap-title {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--navy);
    line-height: 1.25;
    margin-bottom: 6px;
  }

  .gap-severity {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 5px 12px;
  }

  .gap-severity.critical {
    background: rgba(184,64,64,0.08);
    color: var(--red);
    border: 1px solid rgba(184,64,64,0.2);
  }

  .gap-severity.high {
    background: rgba(201,168,76,0.08);
    color: #8a6d1a;
    border: 1px solid rgba(201,168,76,0.25);
  }

  .gap-severity::before {
    content: '●';
    font-size: 8px;
  }

  .gap-body {
    font-size: 15px;
    color: var(--text-mid);
    line-height: 1.85;
    margin-bottom: 24px;
    padding-left: 84px;
  }

  .stat-callout {
    background: var(--cream-dark);
    border-left: 3px solid var(--gold);
    padding: 20px 24px;
    margin: 28px 0 28px 84px;
    display: flex;
    gap: 20px;
    align-items: baseline;
  }

  .stat-big {
    font-family: 'Playfair Display', serif;
    font-size: 42px;
    font-weight: 700;
    color: var(--navy);
    line-height: 1;
    flex-shrink: 0;
  }

  .stat-desc {
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.5;
  }

  .what-happens-box {
    background: rgba(184,64,64,0.05);
    border: 1px solid rgba(184,64,64,0.15);
    padding: 24px 28px;
    margin: 0 0 0 84px;
  }

  .what-happens-title {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 12px;
  }

  .what-happens-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .what-happens-list li {
    font-size: 14px;
    color: var(--text-mid);
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .what-happens-list li::before {
    content: '→';
    color: var(--red);
    font-size: 12px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* CASE STUDY */
  .case-study {
    background: var(--navy);
    padding: 36px 40px;
    margin: 32px 0 0 84px;
    position: relative;
    overflow: hidden;
  }

  .case-study::before {
    content: '"';
    position: absolute;
    top: -20px;
    left: 24px;
    font-family: 'Playfair Display', serif;
    font-size: 160px;
    color: rgba(201,168,76,0.06);
    line-height: 1;
    pointer-events: none;
  }

  .case-study-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 14px;
  }

  .case-study-text {
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    color: var(--cream);
    line-height: 1.65;
    font-style: italic;
  }

  .case-study-text strong {
    color: var(--gold);
    font-style: normal;
  }

  .case-study-source {
    font-size: 12px;
    color: rgba(250,247,240,0.35);
    margin-top: 16px;
    font-family: 'DM Mono', monospace;
  }

  /* CHECKLIST */
  .checklist-section {
    padding: 64px 0;
    border-bottom: 1px solid var(--border);
  }

  .checklist-intro {
    font-size: 15px;
    color: var(--text-mid);
    max-width: 640px;
    margin: 20px 0 36px;
    line-height: 1.75;
  }

  .checklist-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .checklist-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    border: 1px solid var(--border);
    background: white;
    transition: all 0.2s;
    cursor: pointer;
  }

  .checklist-item:hover {
    border-color: var(--gold);
    background: var(--gold-pale);
  }

  .check-box {
    width: 22px;
    height: 22px;
    border: 2px solid var(--border);
    flex-shrink: 0;
    position: relative;
    transition: all 0.2s;
  }

  .checklist-item:hover .check-box {
    border-color: var(--gold);
  }

  .checklist-item input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .checklist-item input[type="checkbox"]:checked ~ .check-visual {
    background: var(--navy);
    border-color: var(--navy);
  }

  .check-visual {
    width: 22px;
    height: 22px;
    border: 2px solid var(--border);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
  }

  .check-visual.checked {
    background: var(--navy);
    border-color: var(--navy);
  }

  .check-visual.checked::after {
    content: '✓';
    color: var(--gold);
    font-size: 13px;
    font-weight: 700;
  }

  .check-label {
    font-size: 14px;
    color: var(--text-dark);
    line-height: 1.4;
  }

  .check-label span {
    display: block;
    font-size: 11px;
    color: var(--text-light);
    margin-top: 2px;
  }

  /* CTA SECTION */
  .cta-section {
    padding: 72px 0 0;
  }

  .cta-card {
    background: var(--navy);
    padding: 56px 56px 48px;
    position: relative;
    overflow: hidden;
  }

  .cta-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light), rgba(201,168,76,0.3));
  }

  .cta-card::after {
    content: 'RETIREMENT SHIELD';
    position: absolute;
    bottom: -20px;
    right: 32px;
    font-family: 'Playfair Display', serif;
    font-size: 100px;
    font-weight: 700;
    color: rgba(201,168,76,0.04);
    letter-spacing: -0.02em;
    pointer-events: none;
  }

  .cta-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }

  .cta-title {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.25;
    max-width: 560px;
    margin-bottom: 20px;
  }

