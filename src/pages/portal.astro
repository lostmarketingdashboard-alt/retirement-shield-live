        async function renderActionTasks() {
          // --- Step 1: Add edit mode state ---
          let editingTemplateId = null;

          // Load existing templates
          const { data: templates } = await supabase
            .from('action_plan_templates')
            .select('*')
            .order('created_at', { ascending: true });

          contentDiv.innerHTML = `
            <div class="doc-card">
              <h3>Create Global Action Plan Template</h3>

              <input id="newTitle" placeholder="Title"
                style="width:100%;margin-bottom:10px;padding:10px;border-radius:8px;border:1px solid #ddd;">

              <input id="newCategory" placeholder="Category"
                style="width:100%;margin-bottom:14px;padding:10px;border-radius:8px;border:1px solid #ddd;">

              <div id="subtaskContainer"></div>

              <button id="addSubtaskBtn"
                style="margin-bottom:14px;background:#eee;border:none;padding:8px 14px;border-radius:6px;cursor:pointer;">
