    f.style.width = '0';
    setTimeout(() => { f.style.width = w; }, 300);
  });
});

// Unlock logic
const form = document.getElementById('unlock-form');
if (form) {
  form.addEventListener('submit', function(e) {
    e.preventDefault();

    const name = document.getElementById('first-name').value;
    const email = document.getElementById('email').value;

    if (!name || !email) return;

    const WEBHOOK_URL = 'https://services.leadconnectorhq.com/hooks/t6CIiDKX4tJt5AYWbWxc/webhook-trigger/bd920e7d-38f2-435e-9e2f-6cea929cec07';

    try {
      fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          full_name: name,
          email: email,
          state: "${stateName}",
          page: window.location.href,
          source: 'State Guide Unlock'
        })
      });
    } catch (err) {
      console.error('Webhook failed:', err);
    }

    document.getElementById('gated-section').classList.add('unlocked');
    document.getElementById('gate-overlay').style.display = 'none';

    document.querySelector('.gated-content').style.filter = 'none';
    document.querySelector('.gated-content').style.pointerEvents = 'auto';
    document.querySelector('.gated-content').style.userSelect = 'auto';

    // Persist unlock
    localStorage.setItem('guide_unlocked', 'true');
  });

  // Auto unlock if previously unlocked
  if (localStorage.getItem('guide_unlocked') === 'true') {
    document.getElementById('gate-overlay').style.display = 'none';
    document.querySelector('.gated-content').style.filter = 'none';
    document.querySelector('.gated-content').style.pointerEvents = 'auto';
    document.querySelector('.gated-content').style.userSelect = 'auto';
  }
}
</script>