  background:var(--cream);
  color:var(--text);
}

/* NAV */
nav{
  background: var(--navy);
  border-bottom:1px solid var(--border);
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:18px 32px;
}

.nav-logo{
  font-family:'Playfair Display',serif;
  font-size:20px;
  font-weight:600;
  color:white;
  text-decoration:none !important;
  display:inline-block;
}

.nav-logo:hover{
  opacity:.9;
}

.nav-logo span{
  color:var(--gold);
  text-decoration:none !important;
}

.nav-links{
  list-style:none;
  display:flex;
  gap:28px;
  align-items:center;
}

.nav-links a{
  text-decoration:none;
  color: white;
  font-size:14px;
}

.nav-links a:hover{
  color:var(--gold);
}

.nav-cta{
  padding:10px 18px;
  background:var(--gold);
  color:white !important;
  border-radius:4px;
}

.nav-cta:hover{
  opacity:.9;
}

/* HEADER */
.header{
  background:var(--navy);
  color:white;
  padding:64px 32px;
}

.header h1{
  font-family:'Playfair Display',serif;
  font-size:38px;
  margin-bottom:12px;
}

.header p{
  opacity:.75;
  max-width:600px;
  line-height:1.6;
}

/* BODY */
.container{
  padding:64px 32px;
  max-width:1100px;
  margin:0 auto;
}

.section-title{
  font-family:'Playfair Display',serif;
  font-size:24px;
  margin-bottom:24px;
}

.states-grid,
.counties-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(180px,1fr));
  gap:16px;
}

.state-btn,
.county-link{
  padding:16px;
  border:1px solid var(--border);
  background:white;
  cursor:pointer;
  font-size:14px;
  transition:.2s;
  text-align:center;
  text-decoration:none;
  color:var(--text);
}

.state-btn:hover,
.county-link:hover{
  border-color:var(--gold);
  background:#fffdf6;
}

#countiesSection{
  margin-top:48px;
  display:none;
}
@media (max-width: 768px) {
  .nav-links {
    display: none;
  }

  nav {
    justify-content: center;
    padding: 18px 16px;
  }

  .nav-logo {
    font-size: 18px;
  }
}
</style>

</head>

<body>

 <!-- NEWSLETTER MODAL -->
  <div id="newsletterModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:9999; align-items:center; justify-content:center; padding:20px; overflow:auto;">
