modal.querySelectorAll('textarea').forEach(field => {
  const key = field.dataset.field;
  let value = field.value.trim();

  if (!value) return;

  // BOOLEAN FIELDS
  if (key === 'mission_test_pass' || key === 'compliance_reviewed') {
    const lower = value.toLowerCase();

    if (lower === 'true' || lower === 't' || lower === '1') value = true;
    else if (lower === 'false' || lower === 'f' || lower === '0') value = false;
    else {
      alert(`${key} must be true or false`);
      throw new Error("Invalid boolean");
    }
  }

  // NUMBER FIELD
  if (key === 'word_count') {
    const num = Number(value);
    if (isNaN(num)) {
      alert("word_count must be a number");
      throw new Error("Invalid number");
    }
    value = num;
  }

  // JSON FIELDS
  if (key === 'faq_data' || key === 'data_highlights') {
    try {
      value = JSON.parse(value);
    } catch {
      value = [{ note: value }];
    }
  }

  updatedData[key] = value;
});

                const { error } = await supabase
                  .from('articles')
