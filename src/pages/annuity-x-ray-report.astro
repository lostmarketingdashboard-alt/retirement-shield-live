<script is:inline>
const FALLBACK_BENCHMARKS = {
  asOfDate: '2026-04-15',
  source: 'Bundled fallback assumptions',
  marketableAvgRate: 4.1,
  treasury: { oneYear: 4.0, threeYear: 4.1, fiveYear: 4.2, tenYear: 4.35 },
  cdBenchmarks: { oneYear: 4.35, threeYear: 4.4, fiveYear: 4.4 },
  bondLadder: { shortIntermediateBlend: 3.95, longBlend: 4.15 }
};

let latestAnnuityPayload = null;

function formatMoney(value) {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(value || 0);
}

function formatPercent(value) {
  return `${Number(value || 0).toFixed(1)}%`;
}

function parseMoney(value) {
  const parsed = Number(String(value || '').replace(/[^0-9.]/g, ''));
  return Number.isFinite(parsed) ? parsed : 0;
}

function parsePercent(value, fallback = 0) {
  const parsed = Number(String(value || '').replace(/[^0-9.-]/g, ''));
  return Number.isFinite(parsed) ? parsed : fallback;
}

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach((panel) => panel.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');
  document.querySelectorAll('[data-step-indicator]').forEach((item, index) => {
    const num = index + 1;
    item.classList.toggle('active', num === step);
    item.classList.toggle('done', num < step);
  });
  document.getElementById('progressText').textContent = `Step ${step} of 3`;
  document.getElementById('progressFill').style.width = `${(step / 3) * 100}%`;
  window.scrollTo({ top: document.getElementById('wizardSection').offsetTop - 76, behavior: 'smooth' });
}

async function loadBenchmarks() {
  try {
    const response = await fetch('/api/annuity-xray/benchmarks');
    if (!response.ok) throw new Error('Benchmark fetch failed');
    const payload = await response.json();
    return payload.benchmarks || FALLBACK_BENCHMARKS;
  } catch {
    return FALLBACK_BENCHMARKS;
  }
}

function nearestBenchmarkRate(benchmarks, yearsRemaining) {
  if (yearsRemaining <= 1) return { label: '1-Year Treasury', rate: benchmarks.treasury.oneYear };
  if (yearsRemaining <= 3) return { label: '3-Year Treasury', rate: benchmarks.treasury.threeYear };
  return { label: '5-Year Treasury', rate: benchmarks.treasury.fiveYear };
}

function buildFlags(payload) {
  const flags = [];
  if (payload.netEffectiveYield < payload.matchedTreasury.rate) {
    flags.push({
      tone: payload.netEffectiveYield + 1 < payload.matchedTreasury.rate ? 'risk' : 'watch',
      title: 'Underperforming matched Treasury',
      text: `The contract’s net yield of ${formatPercent(payload.netEffectiveYield)} trails the matched ${payload.matchedTreasury.label.toLowerCase()} benchmark of ${formatPercent(payload.matchedTreasury.rate)}.`
    });
  } else {
    flags.push({
      tone: 'good',
      title: 'Competitive vs Treasury baseline',
      text: `The current net yield is at or above the matched Treasury comparison, which lowers the chance that the contract is obviously lagging simple outside options.`
    });
  }

  if (payload.totalFeePct >= 2) {
    flags.push({
      tone: 'risk',
      title: 'Heavy fee stack',
      text: `The disclosed fee stack totals ${formatPercent(payload.totalFeePct)}, which is large enough to materially change what the contract is really earning.`
    });
  } else if (payload.totalFeePct >= 1) {
    flags.push({
      tone: 'watch',
      title: 'Meaningful ongoing fees',
      text: `The fee stack totals ${formatPercent(payload.totalFeePct)}. That may be reasonable in some cases, but it needs to be justified by guarantees the owner actually values.`
    });
  }

  if (payload.surrenderYearsRemaining >= 5 || payload.surrenderCharge >= 7) {
    flags.push({
      tone: 'risk',
      title: 'Lockup risk is still real',
      text: `There are ${payload.surrenderYearsRemaining} years left in the surrender schedule with a current charge of ${formatPercent(payload.surrenderCharge)}. That can trap the owner even when the economics look weak.`
    });
  } else if (payload.surrenderYearsRemaining > 0) {
    flags.push({
      tone: 'watch',
      title: 'Surrender friction remains',
      text: `The contract still has a live surrender charge, so the real question is not just yield. It is whether the lockup is worth tolerating for the remaining period.`
    });
  }

  if (payload.confidenceLevel === 'uncertain') {
    flags.push({
      tone: 'watch',
      title: 'Opacity is part of the risk',
      text: 'When the owner does not feel they understand the contract, that itself is a planning issue. Complexity often hides the true tradeoff.'
    });
  }

  return flags.slice(0, 6);
}

function buildNarrative(payload) {
  const spread = payload.netEffectiveYield - payload.matchedTreasury.rate;
  const relation = spread >= 0 ? 'ahead of' : 'behind';
  return `After the disclosed fee stack, the contract is earning about ${formatPercent(payload.netEffectiveYield)} net. That is ${formatPercent(Math.abs(spread))} ${relation} the matched ${payload.matchedTreasury.label.toLowerCase()} benchmark and translates to roughly ${formatMoney(payload.opportunityCostAnnual)} of annual opportunity cost on a contract value of ${formatMoney(payload.contractValue)}. ${payload.notes ? payload.notes : 'The real issue is not whether annuities are always bad. It is whether this specific contract is paying enough to justify its complexity and lockup.'}`;
}

async function buildAnnuityPayload() {
  const fullName = document.getElementById('fullName').value.trim();
  const annuityType = document.getElementById('annuityType').value;
  const valueMode = document.getElementById('valueMode').value;
  const contractValue = parseMoney(document.getElementById('contractValue').value);
  const rawRateOrPayout = parsePercent(document.getElementById('rateOrPayout').value, 0);
  const surrenderYearsRemaining = Number(document.getElementById('surrenderYearsRemaining').value || 0);
  const mortalityExpenseFee = parsePercent(document.getElementById('mortalityExpenseFee').value, 0);
  const riderFee = parsePercent(document.getElementById('riderFee').value, 0);
  const adminFee = parsePercent(document.getElementById('adminFee').value, 0);
  const surrenderCharge = parsePercent(document.getElementById('surrenderCharge').value, 0);
  const feeNotes = document.getElementById('feeNotes').value.trim();
  const liquidityNeed = document.getElementById('liquidityNeed').value;
  const confidenceLevel = document.getElementById('confidenceLevel').value;
  const notes = document.getElementById('notes').value.trim();

  const grossEffectiveYield = valueMode === 'annual_payout'
    ? (contractValue > 0 ? (parseMoney(document.getElementById('rateOrPayout').value) / contractValue) * 100 : 0)
    : rawRateOrPayout;

  const benchmarks = await loadBenchmarks();
  const matchedTreasury = nearestBenchmarkRate(benchmarks, surrenderYearsRemaining || 1);
  const matchedCd = surrenderYearsRemaining <= 1 ? benchmarks.cdBenchmarks.oneYear : surrenderYearsRemaining <= 3 ? benchmarks.cdBenchmarks.threeYear : benchmarks.cdBenchmarks.fiveYear;
  const ladderRate = surrenderYearsRemaining <= 3 ? benchmarks.bondLadder.shortIntermediateBlend : benchmarks.bondLadder.longBlend;
  const totalFeePct = mortalityExpenseFee + riderFee + adminFee;
  const netEffectiveYield = Math.max(grossEffectiveYield - totalFeePct, -10);
  const opportunityGapPct = Math.max(matchedTreasury.rate - netEffectiveYield, 0);
  const opportunityCostAnnual = contractValue * (opportunityGapPct / 100);
  const lockupCost = contractValue * (surrenderCharge / 100);
  const annualFeeDrag = contractValue * (totalFeePct / 100);

  const payload = {
    fullName,
    annuityType,
    valueMode,
    contractValue,
    rawRateOrPayout: valueMode === 'annual_payout' ? parseMoney(document.getElementById('rateOrPayout').value) : rawRateOrPayout,
    grossEffectiveYield,
    mortalityExpenseFee,
    riderFee,
    adminFee,
    totalFeePct,
    surrenderYearsRemaining,
    surrenderCharge,
    feeNotes,
    liquidityNeed,
    confidenceLevel,
    notes,
    benchmarks,
    matchedTreasury,
    matchedCd,
    ladderRate,
    netEffectiveYield,
    opportunityGapPct,
    opportunityCostAnnual,
    annualFeeDrag,
    lockupCost
  };

  payload.flags = buildFlags(payload);
  payload.narrative = buildNarrative(payload);
  return payload;
}

function renderAnnuityReport(payload) {
  latestAnnuityPayload = payload;

  document.getElementById('reportTitle').textContent = `The Annuity X-Ray Report for ${payload.fullName || 'Your Contract'}`;
  document.getElementById('reportSubtitle').textContent = `A saved annuity benchmark comparison showing effective yield, fee drag, and surrender friction for a ${payload.annuityType} contract.`;
  document.getElementById('metaName').textContent = `Prepared for ${payload.fullName || '—'}`;
  document.getElementById('metaType').textContent = `${payload.annuityType[0].toUpperCase() + payload.annuityType.slice(1)} annuity · ${payload.valueMode === 'annual_payout' ? 'payout mode' : 'credited-rate mode'}`;
  document.getElementById('metaDate').textContent = `Generated ${new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;

  document.getElementById('summaryTitle').innerHTML = `Net effective yield: <em>${formatPercent(payload.netEffectiveYield)}</em>.`;
  document.getElementById('summaryCopy').textContent = payload.narrative;
  document.getElementById('benchmarkHeadline').textContent = `Matched Treasury benchmark: ${formatPercent(payload.matchedTreasury.rate)}`;
  document.getElementById('benchmarkCopy').textContent = `Current benchmark set dated ${payload.benchmarks.asOfDate} shows about ${formatPercent(payload.matchedTreasury.rate)} for the matched Treasury comparison, ${formatPercent(payload.matchedCd)} for a modeled CD alternative, and ${formatPercent(payload.ladderRate)} for a simple bond-ladder proxy.`;

  document.getElementById('netYieldValue').textContent = formatPercent(payload.netEffectiveYield);
  document.getElementById('netYieldSub').textContent = `${formatPercent(payload.grossEffectiveYield)} gross less ${formatPercent(payload.totalFeePct)} fees`;
  document.getElementById('oppCostValue').textContent = formatMoney(payload.opportunityCostAnnual);
  document.getElementById('oppCostSub').textContent = `${formatPercent(payload.opportunityGapPct)} behind ${payload.matchedTreasury.label.toLowerCase()}`;
  document.getElementById('lockupValue').textContent = formatMoney(payload.lockupCost);
  document.getElementById('lockupSub').textContent = `${formatPercent(payload.surrenderCharge)} current surrender charge`;

  document.getElementById('comparisonPill').textContent = `${payload.benchmarks.source}`;
  document.getElementById('feePill').textContent = `${formatPercent(payload.totalFeePct)} total disclosed fees`;
  document.getElementById('flagPill').textContent = `${payload.flags.length} active flags`;

  document.getElementById('compareGrid').innerHTML = [
    { label: 'Your Contract', value: formatPercent(payload.netEffectiveYield), sub: 'Net effective yield after disclosed fees' },
    { label: payload.matchedTreasury.label, value: formatPercent(payload.matchedTreasury.rate), sub: 'Risk-free Treasury baseline closest to the lockup horizon' },
    { label: 'Modeled CD Rate', value: formatPercent(payload.matchedCd), sub: 'Illustrative CD comparison using current benchmark spreads' },
    { label: 'Simple Bond Ladder', value: formatPercent(payload.ladderRate), sub: 'Illustrative short/intermediate ladder proxy' },
    { label: 'Annual Fee Drag', value: formatMoney(payload.annualFeeDrag), sub: 'Dollar effect of disclosed ongoing fees' },
    { label: 'Contract Value', value: formatMoney(payload.contractValue), sub: 'Approximate value entered into the x-ray' }
  ].map((item) => `
    <div class="compare-card">
      <div class="label">${item.label}</div>
      <div class="value ${String(item.value).includes('$') ? 'small' : ''}">${item.value}</div>
      <div class="sub">${item.sub}</div>
    </div>
  `).join('');

  document.getElementById('feeGrid').innerHTML = [
    { label: 'Mortality & Expense', value: formatPercent(payload.mortalityExpenseFee), sub: `${formatMoney(payload.contractValue * (payload.mortalityExpenseFee / 100))} per year on this contract size` },
    { label: 'Rider Fees', value: formatPercent(payload.riderFee), sub: `${formatMoney(payload.contractValue * (payload.riderFee / 100))} per year if disclosed accurately` },
    { label: 'Admin Fees', value: formatPercent(payload.adminFee), sub: `${formatMoney(payload.contractValue * (payload.adminFee / 100))} annual administrative drag` }
  ].map((item) => `
    <div class="compare-card">
      <div class="label">${item.label}</div>
      <div class="value">${item.value}</div>
      <div class="sub">${item.sub}</div>
    </div>
  `).join('');

  document.getElementById('flagGrid').innerHTML = payload.flags.map((flag) => `
    <div class="flag-card ${flag.tone}">
      <div class="flag-label">${flag.tone === 'good' ? 'Supportive' : flag.tone === 'watch' ? 'Watch closely' : 'Pressure point'}</div>
      <strong>${flag.title}</strong>
      <div class="flag-sub">${flag.text}</div>
    </div>
  `).join('');

  document.getElementById('annuityCallout').textContent = payload.feeNotes
    ? `${payload.narrative} Additional contract note: ${payload.feeNotes}`
    : payload.narrative;
}

function runAnalysisAnimation(payload) {
  document.getElementById('analysisSub').textContent = `Running the annuity x-ray for ${payload.fullName || 'your contract'}.`;
  ['analysisStep1','analysisStep2','analysisStep3','analysisStep4'].forEach((id, index) => {
    const el = document.getElementById(id);
    el.classList.remove('done');
    setTimeout(() => el.classList.add('done'), (index + 1) * 360);
  });
}

async function saveAnnuityReport(payload) {
  const supabase = window.annuityXraySupabase;
  if (!supabase) return null;
  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const insertPayload = {
    user_id: userId,
    full_name: payload.fullName || null,
    annuity_type: payload.annuityType,
    input_mode: payload.valueMode,
    contract_value: payload.contractValue,
    gross_effective_yield_pct: payload.grossEffectiveYield,
    net_effective_yield_pct: payload.netEffectiveYield,
    mortality_expense_fee_pct: payload.mortalityExpenseFee,
    rider_fee_pct: payload.riderFee,
    admin_fee_pct: payload.adminFee,
    total_fee_pct: payload.totalFeePct,
    surrender_years_remaining: payload.surrenderYearsRemaining,
    surrender_charge_pct: payload.surrenderCharge,
    annual_fee_drag: payload.annualFeeDrag,
    matched_treasury_label: payload.matchedTreasury.label,
    matched_treasury_rate_pct: payload.matchedTreasury.rate,
    modeled_cd_rate_pct: payload.matchedCd,
    modeled_bond_ladder_rate_pct: payload.ladderRate,
    opportunity_cost_annual: payload.opportunityCostAnnual,
    lockup_cost_estimate: payload.lockupCost,
    report_title: `The Annuity X-Ray Report for ${payload.fullName || 'Your Contract'}`,
    report_payload: payload
  };

  const { error } = await supabase
    .from('annuity_xray_reports')
    .insert(insertPayload);

  if (error) {
    console.error('Failed to save Annuity X-Ray report:', error);
  }
}

function showGeneratedAnnuityReport(payload) {
  renderAnnuityReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  runAnalysisAnimation(payload);

  setTimeout(() => {
    document.getElementById('analysisSection').classList.remove('active');
    document.getElementById('reportSection').classList.add('active');
    document.getElementById('reportShell').classList.add('visible');
    document.getElementById('reportShell').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 1800);
}

function showHydratedAnnuityReport(payload) {
  renderAnnuityReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('reportSection').classList.add('active');
  document.getElementById('reportShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedAnnuityReport(report) {
  const payload = report?.report_payload;
  if (!payload) return false;

  const fieldMap = {
    fullName: payload.fullName,
    contractValue: payload.contractValue,
    rateOrPayout: payload.rawRateOrPayout,
    surrenderYearsRemaining: payload.surrenderYearsRemaining,
    mortalityExpenseFee: payload.mortalityExpenseFee,
    riderFee: payload.riderFee,
    adminFee: payload.adminFee,
    surrenderCharge: payload.surrenderCharge,
    feeNotes: payload.feeNotes,
    notes: payload.notes
  };

  Object.entries(fieldMap).forEach(([id, value]) => {
    const input = document.getElementById(id);
    if (input && value !== undefined && value !== null) input.value = String(value);
  });

  if (payload.annuityType) document.getElementById('annuityType').value = payload.annuityType;
  if (payload.valueMode) document.getElementById('valueMode').value = payload.valueMode;
  if (payload.liquidityNeed) document.getElementById('liquidityNeed').value = payload.liquidityNeed;
  if (payload.confidenceLevel) document.getElementById('confidenceLevel').value = payload.confidenceLevel;

  showHydratedAnnuityReport(payload);
  return true;
}

async function generateAnnuityReport() {
  const payload = await buildAnnuityPayload();
  await saveAnnuityReport(payload);
  showGeneratedAnnuityReport(payload);
}

function editAnnuityReport() {
  document.getElementById('reportSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(3);
}

window.nextStep = nextStep;
window.generateAnnuityReport = generateAnnuityReport;
window.editAnnuityReport = editAnnuityReport;
window.hydrateAnnuityXrayReport = hydrateSavedAnnuityReport;
</script>

<script type="module">
import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'

