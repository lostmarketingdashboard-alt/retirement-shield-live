---
export const prerender = false;
export const ssr = false;
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The "After I'm Gone" Emergency Binder Generator — Retirement Shield</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --navy: #0F1F3D;
  --navy-light: #1A2D52;
  --navy-mid: #152847;
  --gold: #C9A84C;
  --gold-light: #D4B96A;
  --gold-pale: #F5EDD6;
  --gold-glow: rgba(201, 168, 76, 0.12);
  --cream: #FAF7F0;
  --cream-dark: #F0EBE0;
  --white: #FFFFFF;
  --text-dark: #1A1A1A;
  --text-mid: #4A4A4A;
  --text-light: #7A7A7A;
  --red: #C0392B;
  --red-bg: #FDF2F0;
  --green: #27AE60;
  --green-bg: #F0FDF4;
  --amber: #E67E22;
  --amber-bg: #FFF8F0;
  --border: #E8E3D8;
  --shadow: 0 2px 20px rgba(15, 31, 61, 0.08);
  --shadow-lg: 0 8px 40px rgba(15, 31, 61, 0.12);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--text-dark);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

.site-header {
  background: var(--navy);
  padding: 14px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2px solid var(--gold);
}

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}

.logo-text {
  font-family: 'Playfair Display', serif;
  color: var(--white);
  font-size: 18px;
  font-weight: 600;
}

.logo-text span { color: var(--gold); }

.hero {
  background: var(--navy);
  padding: 78px 24px 96px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 25% 20%, rgba(201,168,76,0.08) 0%, transparent 50%),
    radial-gradient(ellipse at 74% 76%, rgba(201,168,76,0.05) 0%, transparent 55%);
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 860px;
  margin: 0 auto;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(201,168,76,0.1);
  border: 1px solid rgba(201,168,76,0.24);
  border-radius: 100px;
  padding: 8px 18px;
  margin-bottom: 28px;
  font-size: 11px;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: 1.3px;
  text-transform: uppercase;
}

.hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 5vw, 54px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.12;
  margin-bottom: 18px;
}

.hero h1 em {
  font-style: normal;
  color: var(--gold);
}

.hero-sub {
  font-size: 18px;
  color: rgba(255,255,255,0.64);
  line-height: 1.7;
  max-width: 700px;
  margin: 0 auto 40px;
  font-weight: 300;
}

.hero-points {
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}

.hero-point {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.82);
  border-radius: 999px;
  padding: 10px 16px;
  font-size: 13px;
}

.wizard-section {
  padding: 56px 24px 28px;
}

.wizard-shell {
  max-width: 1160px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 340px minmax(0, 1fr);
  gap: 28px;
  align-items: start;
}

.sticky-sidebar {
  position: sticky;
  top: 96px;
}

.sidebar-card,
.form-card,
.binder-shell,
.analysis-card,
.disclaimer {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 16px;
  box-shadow: var(--shadow);
}

.sidebar-card {
  padding: 28px;
}

.sidebar-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 8px;
}

.sidebar-title {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  line-height: 1.15;
  color: var(--navy);
  margin-bottom: 14px;
}

.sidebar-copy {
  font-size: 14px;
  color: var(--text-mid);
  margin-bottom: 22px;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 22px;
}

.step-item {
  display: grid;
  grid-template-columns: 34px 1fr;
  gap: 12px;
  align-items: start;
  padding: 12px 14px;
  border-radius: 12px;
  background: var(--cream);
  border: 1px solid transparent;
}

.step-item.active {
  border-color: rgba(201,168,76,0.4);
  background: var(--gold-glow);
}

.step-item.done .step-num {
  background: var(--gold);
  color: var(--navy);
}

.step-num {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: var(--cream-dark);
  color: var(--navy);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 13px;
}

.step-kicker {
  font-size: 11px;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-bottom: 2px;
}

.step-headline {
  font-size: 14px;
  font-weight: 700;
  color: var(--navy);
  line-height: 1.35;
}

.step-sub {
  font-size: 12px;
  color: var(--text-light);
  margin-top: 2px;
}

.sidebar-note {
  background: var(--navy);
  color: rgba(255,255,255,0.75);
  border-radius: 14px;
  padding: 18px;
  font-size: 13px;
}

.sidebar-note strong {
  color: var(--white);
  display: block;
  margin-bottom: 6px;
}

.form-card {
  overflow: hidden;
}

.form-header {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
  padding: 28px 30px;
}

.form-header-top {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: center;
  margin-bottom: 18px;
}

.form-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 14px;
  background: rgba(201,168,76,0.12);
  border: 1px solid rgba(201,168,76,0.22);
  color: var(--gold);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
}

.progress-inline {
  color: rgba(255,255,255,0.6);
  font-size: 12px;
  font-weight: 600;
}

.form-title {
  font-family: 'Playfair Display', serif;
  font-size: 34px;
  line-height: 1.12;
  color: var(--white);
  margin-bottom: 10px;
}

.form-sub {
  color: rgba(255,255,255,0.62);
  font-size: 15px;
  max-width: 720px;
}

.progress-bar {
  height: 5px;
  background: rgba(255,255,255,0.1);
  border-radius: 999px;
  overflow: hidden;
  margin-top: 18px;
}

.progress-fill {
  height: 100%;
  width: 25%;
  background: linear-gradient(90deg, var(--gold), var(--gold-light));
  border-radius: 999px;
  transition: width 0.35s ease;
}

.form-body {
  padding: 30px;
}

.form-step { display: none; }
.form-step.active { display: block; }

.step-label {
  font-size: 12px;
  font-weight: 700;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 1.1px;
  margin-bottom: 8px;
}

.step-question {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  color: var(--navy);
  line-height: 1.2;
  margin-bottom: 8px;
}

.step-help {
  font-size: 14px;
  color: var(--text-light);
  margin-bottom: 24px;
  max-width: 680px;
}

.field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.field-group {
  margin-bottom: 18px;
}

.field-group.full { grid-column: 1 / -1; }

.field-label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.9px;
  margin-bottom: 8px;
}

.field-input,
.field-textarea,
.field-select {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  background: var(--cream);
  color: var(--text-dark);
  font-size: 15px;
  font-family: 'DM Sans', sans-serif;
  padding: 14px 16px;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
}

.field-input:focus,
.field-textarea:focus,
.field-select:focus {
  border-color: var(--gold);
  box-shadow: 0 0 0 3px rgba(201,168,76,0.12);
  background: var(--white);
}

.field-textarea {
  min-height: 110px;
  resize: vertical;
}

.field-note {
  margin-top: 7px;
  font-size: 12px;
  color: var(--text-light);
}

.radio-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.radio-card {
  border: 1.5px solid var(--border);
  border-radius: 12px;
  background: var(--cream);
  padding: 16px;
  cursor: pointer;
  transition: all 0.2s ease;
  display: block;
}

.radio-card:hover,
.radio-card.selected {
  border-color: var(--gold);
  background: var(--gold-glow);
}

.radio-card input { display: none; }

.radio-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 4px;
}

.radio-sub {
  font-size: 12px;
  color: var(--text-light);
  line-height: 1.45;
}

.insight-band {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  margin-top: 18px;
}

.insight-chip {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px;
}

.insight-chip strong {
  display: block;
  font-size: 13px;
  color: var(--navy);
  margin-bottom: 4px;
}

.insight-chip span {
  display: block;
  font-size: 12px;
  color: var(--text-light);
}

.btn-row {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-top: 26px;
}

.btn-back,
.btn-next,
.btn-print,
.btn-secondary {
  border: none;
  border-radius: 10px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-back,
.btn-secondary {
  background: transparent;
  border: 1.5px solid var(--border);
  color: var(--text-mid);
  padding: 14px 18px;
}

.btn-back:hover,
.btn-secondary:hover {
  border-color: var(--text-light);
}

.btn-next,
.btn-print {
  background: var(--gold);
  color: var(--navy);
  padding: 14px 22px;
}

.btn-next:hover,
.btn-print:hover {
  background: var(--gold-light);
}

.analysis-section,
.binder-section {
  display: none;
  padding: 18px 24px 34px;
}

.analysis-section.active,
.binder-section.active {
  display: block;
}

.analysis-card {
  max-width: 920px;
  margin: 0 auto;
  padding: 42px 28px;
  text-align: center;
}

.analysis-orb {
  width: 96px;
  height: 96px;
  margin: 0 auto 20px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, var(--gold-light), var(--gold));
  position: relative;
  box-shadow: 0 0 0 16px rgba(201,168,76,0.08), 0 0 0 32px rgba(201,168,76,0.04);
}

.analysis-orb::after {
  content: '';
  position: absolute;
  inset: 24px;
  border-radius: 50%;
  background: var(--navy);
  opacity: 0.16;
}

.analysis-title {
  font-family: 'Playfair Display', serif;
  font-size: 34px;
  color: var(--navy);
  margin-bottom: 8px;
}

.analysis-sub {
  font-size: 15px;
  color: var(--text-light);
  margin-bottom: 28px;
}

.analysis-steps {
  max-width: 560px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.analysis-step {
  display: grid;
  grid-template-columns: 38px 1fr;
  gap: 14px;
  align-items: center;
  text-align: left;
  padding: 14px 16px;
  border-radius: 12px;
  background: var(--cream);
  border: 1px solid var(--border);
}

.analysis-indicator {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: var(--gold-glow);
  color: var(--gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.analysis-step.done .analysis-indicator {
  background: var(--gold);
  color: var(--navy);
}

.analysis-text {
  font-size: 14px;
  color: var(--text-mid);
}

.binder-shell {
  max-width: 1040px;
  margin: 0 auto;
  overflow: hidden;
}

.binder-header {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
  padding: 36px 32px 32px;
  color: var(--white);
}

.binder-kicker {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 10px;
}

.binder-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(30px, 4vw, 44px);
  line-height: 1.1;
  margin-bottom: 12px;
}

.binder-subtitle {
  color: rgba(255,255,255,0.7);
  font-size: 15px;
  max-width: 760px;
}

.binder-meta {
  margin-top: 22px;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.binder-meta-item {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 999px;
  padding: 9px 14px;
  font-size: 12px;
  color: rgba(255,255,255,0.78);
  white-space: normal;
  overflow-wrap: anywhere;
}

.gate-wrap {
  padding: 22px 26px;
  border-bottom: 1px solid var(--border);
  background: linear-gradient(180deg, #fffdf8 0%, #faf6ea 100%);
}

.gate-card {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: 20px;
  align-items: center;
}

.gate-title {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  color: var(--navy);
  line-height: 1.15;
  margin-bottom: 8px;
}

.gate-copy {
  font-size: 14px;
  color: var(--text-mid);
}

.gate-form {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px;
}

.gate-stack {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.gate-consent {
  display: flex;
  gap: 10px;
  align-items: flex-start;
  font-size: 12px;
  color: var(--text-light);
}

.gate-consent input {
  margin-top: 3px;
}

.gate-status {
  font-size: 12px;
  font-weight: 600;
  min-height: 18px;
  color: var(--text-light);
}

.gate-status.success { color: var(--green); }
.gate-status.error { color: var(--red); }

.binder-body {
  padding: 28px;
  display: grid;
  gap: 22px;
}

.cover-card,
.section-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 16px;
}

.cover-card {
  padding: 28px;
  background:
    linear-gradient(135deg, rgba(15,31,61,0.03), rgba(201,168,76,0.08)),
    var(--white);
}

.cover-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 24px;
}

.cover-title {
  font-family: 'Playfair Display', serif;
  font-size: 34px;
  color: var(--navy);
  line-height: 1.1;
  margin-bottom: 10px;
}

.cover-title em { color: var(--gold); font-style: normal; }

.cover-text {
  font-size: 15px;
  color: var(--text-mid);
  max-width: 680px;
}

.urgency-card {
  border-radius: 16px;
  background: var(--navy);
  color: rgba(255,255,255,0.82);
  padding: 22px;
}

.urgency-card .label {
  font-size: 11px;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 700;
  margin-bottom: 8px;
}

.urgency-card .headline {
  font-family: 'Playfair Display', serif;
  font-size: 24px;
  color: var(--white);
  line-height: 1.18;
  margin-bottom: 10px;
}

.section-card {
  padding: 24px;
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: end;
  margin-bottom: 18px;
}

.section-kicker {
  font-size: 11px;
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: 1.2px;
  font-weight: 700;
  margin-bottom: 4px;
}

.section-title {
  font-family: 'Playfair Display', serif;
  font-size: 26px;
  line-height: 1.15;
  color: var(--navy);
}

.section-copy {
  font-size: 13px;
  color: var(--text-light);
  max-width: 650px;
}

.pill {
  border-radius: 999px;
  padding: 8px 12px;
  background: var(--cream);
  border: 1px solid var(--border);
  font-size: 12px;
  font-weight: 700;
  color: var(--navy);
  white-space: normal;
  overflow-wrap: anywhere;
}

.checklist-list {
  display: grid;
  gap: 12px;
}

.checklist-item {
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 14px;
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px;
  background: var(--cream);
}

.checkmark {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 14px;
}

.checkmark.ok { background: var(--green-bg); color: var(--green); }
.checkmark.warn { background: var(--amber-bg); color: var(--amber); }
.checkmark.miss { background: var(--red-bg); color: var(--red); }

.checklist-item strong {
  display: block;
  font-size: 15px;
  color: var(--navy);
  margin-bottom: 4px;
}

.checklist-item p {
  font-size: 13px;
  color: var(--text-mid);
}

.two-col {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.inventory-card,
.map-card,
.contact-card,
.doc-status-card {
  border: 1px solid var(--border);
  border-radius: 14px;
  background: var(--cream);
  padding: 18px;
}

.mini-title {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 700;
  color: var(--text-light);
  margin-bottom: 10px;
}

.inventory-table,
.contact-table {
  width: 100%;
  border-collapse: collapse;
}

.inventory-table th,
.inventory-table td,
.contact-table th,
.contact-table td {
  text-align: left;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
  vertical-align: top;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.inventory-table th,
.contact-table th {
  font-size: 11px;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.9px;
}

.inventory-table tr:last-child td,
.contact-table tr:last-child td { border-bottom: none; }

.doc-status-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.doc-status-card strong {
  display: block;
  font-size: 15px;
  color: var(--navy);
  margin-bottom: 6px;
}

.doc-status-card p {
  font-size: 13px;
  color: var(--text-mid);
}

.status-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 10px;
  font-size: 12px;
  font-weight: 700;
}

.status-tag.ok { color: var(--green); }
.status-tag.warn { color: var(--amber); }
.status-tag.miss { color: var(--red); }

.list-block {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.list-row {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
  align-items: flex-start;
}

.list-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.list-row span:first-child {
  font-size: 13px;
