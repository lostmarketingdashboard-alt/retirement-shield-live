    .profile-card-head {
      margin-bottom: 22px;
    }

    .profile-form {
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .profile-form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      width: 100%;
      min-width: 0;
