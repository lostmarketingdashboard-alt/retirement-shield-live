  </div>
</section>

<div class="disclaimer">
  <p><strong>Important Disclosures:</strong> This checklist is for educational and organizational purposes only and does not constitute legal, tax, financial, insurance, funeral, or medical advice. State rules for probate filings, creditor notice, certified death certificate ordering, account access, and related post-death administration can change and may vary based on county procedure, asset type, and family facts. Retirement Shield is not a law firm, does not prepare legal documents, and does not provide legal advice. Review this plan with a licensed estate planning or probate attorney in your state before relying on it for legal deadlines. © 2026 Retirement Shield. All rights reserved.</p>
</div>

<script>
const STATE_OPTIONS = [
  ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],['CA','California'],['CO','Colorado'],
  ['CT','Connecticut'],['DE','Delaware'],['FL','Florida'],['GA','Georgia'],['HI','Hawaii'],['ID','Idaho'],
  ['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],['KY','Kentucky'],['LA','Louisiana'],
  ['ME','Maine'],['MD','Maryland'],['MA','Massachusetts'],['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],
  ['MO','Missouri'],['MT','Montana'],['NE','Nebraska'],['NV','Nevada'],['NH','New Hampshire'],['NJ','New Jersey'],
  ['NM','New Mexico'],['NY','New York'],['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
  ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],['SD','South Dakota'],
  ['TN','Tennessee'],['TX','Texas'],['UT','Utah'],['VT','Vermont'],['VA','Virginia'],['WA','Washington'],
  ['WV','West Virginia'],['WI','Wisconsin'],['WY','Wyoming'],['DC','District of Columbia']
];

STATE_OPTIONS.forEach(([code, name]) => {
  const option = document.createElement('option');
  option.value = code;
  option.textContent = name;
  document.getElementById('stateSelect').appendChild(option);
});

document.querySelectorAll('.doc-card').forEach((card) => {
  const input = card.querySelector('input');
  const sync = () => card.classList.toggle('selected', input.checked);
  card.addEventListener('click', () => setTimeout(sync, 0));
  input.addEventListener('change', sync);
});

let currentStep = 1;

function slugify(value) {
  return String(value || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach((section) => section.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');
  document.querySelectorAll('.step-item').forEach((item, index) => {
    item.classList.remove('active','done');
    if (index + 1 < step) item.classList.add('done');
    if (index + 1 === step) item.classList.add('active');
  });
  currentStep = step;
  document.getElementById('progressText').textContent = `Step ${step} of 2`;
  document.getElementById('progressFill').style.width = `${(step / 2) * 100}%`;
}

function getInputData() {
  return {
    fullName: document.getElementById('fullName').value.trim() || 'Retirement Shield Client',
    stateCode: document.getElementById('stateSelect').value,
    stateName: STATE_OPTIONS.find(([code]) => code === document.getElementById('stateSelect').value)?.[1] || '',
    hasWill: document.getElementById('hasWill').checked,
    hasTrust: document.getElementById('hasTrust').checked,
    hasPoa: document.getElementById('hasPoa').checked,
    hasHealthcareProxy: document.getElementById('hasHealthcareProxy').checked,
    hasBeneficiaryDesignations: document.getElementById('hasBeneficiaryDesignations').checked,
    hasFuneralPreplan: document.getElementById('hasFuneralPreplan').checked,
    hasDigitalInventory: document.getElementById('hasDigitalInventory').checked
  };
}

function validateInput(data) {
  if (!data.stateCode) return 'Choose a state.';
  return '';
}

async function loadStateGuide(supabase, stateCode) {
  if (!supabase || !stateCode) return null;
  const stateName = STATE_OPTIONS.find(([code]) => code === stateCode)?.[1];
  if (!stateName) return null;
  const { data } = await supabase
    .from('state_guides')
    .select('state_name,probate_cost_display,probate_timeline_display,homestead_display,lady_bird_display,lady_bird_deed_available,tod_display,tod_deed_available,state_estate_tax,state_inheritance_tax')
    .eq('state_slug', slugify(stateName))
    .maybeSingle();
  return data || null;
}

async function loadStateRules(supabase, stateCode) {
  if (!supabase || !stateCode) return null;
  const { data } = await supabase
    .from('after_death_checklist_state_rules')
    .select('*')
    .eq('state_code', stateCode)
    .eq('is_active', true)
    .order('updated_at', { ascending: false })
    .limit(1)
    .maybeSingle();
  return data || null;
}

function defaultStateRules(stateName, stateCode) {
  return {
    death_certificate_copies: '10-15 certified copies',
    will_deadline: `${stateName} filing deadline should be confirmed with local probate counsel immediately after death.`,
    creditor_window: `${stateName} creditor notice timing varies by probate procedure and county practice.`,
    probate_urgency: `${stateName} probate procedure and original-will handling should be reviewed quickly if titled assets remain outside a trust.`,
    account_access: 'Banks, insurers, and transfer agents will usually require a certified death certificate plus beneficiary or court paperwork before retitling assets.',
    funeral_note: 'If no funeral pre-plan exists, the family should locate written preferences immediately so Monday-morning decisions are not being made emotionally.',
    rule_label: `${stateCode} fallback`
  };
}

function readinessScore(data) {
  const checks = [
    data.hasWill,
    data.hasTrust,
    data.hasPoa,
    data.hasHealthcareProxy,
    data.hasBeneficiaryDesignations,
    data.hasFuneralPreplan,
    data.hasDigitalInventory
  ];
  const completed = checks.filter(Boolean).length;
  return Math.round((completed / checks.length) * 100);
}

function pickTopGaps(data) {
  const gaps = [];
  if (!data.hasDigitalInventory) gaps.push(['No digital account inventory', 'Even when the legal documents are decent, families still get stuck on phones, laptops, password resets, autopay, and two-factor authentication.']);
  if (!data.hasBeneficiaryDesignations) gaps.push(['Beneficiary designations need review', 'Retirement accounts, annuities, and life insurance usually pass outside the will. If the forms are stale, the family can lose time and money immediately.']);
  if (!data.hasWill && !data.hasTrust) gaps.push(['No clear death-side plan', 'Without a will or trust, the family falls straight into default state administration and cannot rely on “everyone knows what was intended.”']);
  if (!data.hasWill) gaps.push(['Will location is a bottleneck', 'If the original will cannot be found quickly, the probate timeline often gets slower and more expensive at the exact moment the family wants clarity.']);
  if (!data.hasTrust) gaps.push(['Probate exposure remains high', 'Without a trust or coordinated titling plan, the house and titled assets may still need formal probate handling.']);
  if (!data.hasFuneralPreplan) gaps.push(['Funeral decisions are still live', 'The family may be forced to make expensive and emotional decisions in the first 24-48 hours without written preferences.']);
  if (!data.hasHealthcareProxy) gaps.push(['Medical decision paper trail is weak', 'If there is no healthcare proxy or HIPAA release, hospitals may not be as easy to work with during the final medical event.']);
  if (!data.hasPoa) gaps.push(['Incapacity paperwork is thin', 'A missing durable POA often becomes visible before death, when bills and account management still have to continue.']);
  return gaps.slice(0, 3);
}

function buildTimelineItems(data, guide, rules) {
  const in72 = [
    ['Secure the household and pause impulsive decisions', 'Get immediate family aligned, lock down the house, preserve original documents, and avoid transferring or removing property before the paperwork picture is clear.'],
    ['Order certified death certificates', `Ask the funeral home to order ${rules.death_certificate_copies}. Every bank, insurer, and government agency will ask for originals.`],
    ['Locate the controlling documents', data.hasWill || data.hasTrust ? 'Pull the will, trust package, beneficiary forms, and binder immediately so the family knows what actually controls which assets.' : 'Because there is no confirmed will or trust, the family should assume the state default process may control more than expected.'],
    ['Notify the right people first', data.hasFuneralPreplan ? 'Use the pre-plan instructions to coordinate funeral, burial, or cremation without guesswork.' : rules.funeral_note]
  ];

  const in30 = [
    ['File or deliver the original will on time', rules.will_deadline],
    ['Open the right administration lane', data.hasTrust ? 'Review which assets are already trust-owned and which still require beneficiary or probate handling.' : rules.probate_urgency],
    ['Start account and benefit notifications', `${rules.account_access} Social Security, pensions, insurers, and custodians should be contacted in a deliberate sequence rather than randomly.`],
    ['Map bills, subscriptions, and autopay', data.hasDigitalInventory ? 'Use the digital inventory to stop fraud, keep essential bills paid, and close the accounts that no longer make sense.' : 'Because no digital inventory is confirmed, the family should build a live list of banks, cards, utilities, logins, autopay, and subscriptions before accounts start drifting.']
  ];

  const in12 = [
    ['Close out creditor and court deadlines', rules.creditor_window],
    ['Retitle and re-register what changed hands', data.hasBeneficiaryDesignations ? 'Confirm that beneficiary-driven assets actually landed where expected and that no stale designation created a surprise.' : 'Beneficiary designations should be reviewed line by line because the will does not control those assets.'],
    ['Rebuild the surviving household plan', 'Once the immediate administration ends, update the surviving spouse or adult child plan so the same confusion does not recur in the next generation.'],
    ['Refresh the binder', 'Any lesson learned from the loss should be folded back into the emergency binder, account map, and contact sheet while the details are still fresh.']
  ];

  return { in72, in30, in12 };
}

function buildModel(data, guide, stateRuleRecord) {
  const baseRules = stateRuleRecord?.rules_payload || {};
  const rules = { ...defaultStateRules(data.stateName, data.stateCode), ...baseRules };
  const score = readinessScore(data);
  const gaps = pickTopGaps(data);
  while (gaps.length < 3) {
    gaps.push(['Coordination review', 'The family should still rehearse where the binder is, who is first call, and what accounts or titles are most likely to slow administration.']);
  }
  const biggestGap = gaps[0][0];
  const benchmarkCopy = gaps[0][1];
  const timeline = buildTimelineItems(data, guide, rules);
  return {
    score,
    rules,
    gaps,
    biggestGap,
    benchmarkCopy,
    timeline,
    readinessLabel: score >= 80 ? 'Strong' : score >= 55 ? 'Mixed' : 'Fragile'
  };
}

function renderTimeline(targetId, items) {
  const wrap = document.getElementById(targetId);
  wrap.innerHTML = items.map((item, index) => `
    <div class="timeline-item">
      <div class="timeline-dot">${index + 1}</div>
      <div class="timeline-text">
        <strong>${item[0]}</strong>
        <span>${item[1]}</span>
      </div>
    </div>
  `).join('');
}

function populateReport(data, guide, stateRuleRecord, model) {
  const date = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  document.getElementById('reportTitle').textContent = `The 72-Hour Checklist for ${data.fullName}`;
  document.getElementById('reportSubtitle').textContent = `A ${data.stateName} after-death action plan built from the documents already in place and the deadlines the family should not miss.`;
  document.getElementById('metaState').textContent = `${data.stateName} · ${stateRuleRecord ? stateRuleRecord.rule_version : 'fallback state rules'}`;
  document.getElementById('metaReadiness').textContent = `${model.readinessLabel} readiness · ${model.score}/100`;
  document.getElementById('metaDate').textContent = `Generated ${date}`;
  document.getElementById('summaryTitle').innerHTML = `${model.readinessLabel} family readiness for the first <em>72 hours</em>.`;
  document.getElementById('summaryCopy').textContent = `This plan assumes the surviving family needs a calm sequence, not a legal memo. In ${data.stateName}, the strongest friction points are the original documents, account access, and any state filing windows that start immediately after death.`;
  document.getElementById('benchmarkHeadline').textContent = model.biggestGap;
  document.getElementById('benchmarkCopy').textContent = model.benchmarkCopy;
  document.getElementById('readinessScore').textContent = `${model.score}/100`;
  document.getElementById('readinessSub').textContent = `${[
    data.hasWill && 'will',
    data.hasTrust && 'trust',
    data.hasPoa && 'POA',
    data.hasHealthcareProxy && 'healthcare proxy',
    data.hasBeneficiaryDesignations && 'beneficiaries',
    data.hasFuneralPreplan && 'funeral pre-plan',
    data.hasDigitalInventory && 'digital inventory'
  ].filter(Boolean).join(', ') || 'No confirmed documents yet'}`;
  document.getElementById('certificateValue').textContent = model.rules.death_certificate_copies;
  document.getElementById('certificateSub').textContent = 'Order more than the family thinks it needs';
  document.getElementById('deadlineValue').textContent = model.rules.will_deadline;
  document.getElementById('deadlineSub').textContent = 'Original will and probate urgency reminder';
  document.getElementById('statePill').textContent = guide?.probate_timeline_display || 'State overlay';
  document.getElementById('stateDeathCertificates').textContent = model.rules.death_certificate_copies;
  document.getElementById('stateWillDeadline').textContent = model.rules.will_deadline;
  document.getElementById('stateCreditorWindow').textContent = model.rules.creditor_window;
  document.getElementById('stateProbateWindow').textContent = guide?.probate_cost_display && guide?.probate_timeline_display ? `${guide.probate_cost_display} · ${guide.probate_timeline_display}` : model.rules.probate_urgency;
  renderTimeline('timeline72', model.timeline.in72);
  renderTimeline('timeline30', model.timeline.in30);
  renderTimeline('timeline12', model.timeline.in12);
  document.getElementById('gapPill').textContent = `${7 - Math.round(model.score / 100 * 7)} active gaps`.replace('-0', '0');
  document.getElementById('gapOneTitle').textContent = model.gaps[0][0];
  document.getElementById('gapOneCopy').textContent = model.gaps[0][1];
  document.getElementById('gapTwoTitle').textContent = model.gaps[1][0];
  document.getElementById('gapTwoCopy').textContent = model.gaps[1][1];
  document.getElementById('gapThreeTitle').textContent = model.gaps[2][0];
  document.getElementById('gapThreeCopy').textContent = model.gaps[2][1];

  const warning = document.getElementById('fallbackWarning');
  if (stateRuleRecord) {
    warning.classList.remove('active');
    warning.textContent = '';
  } else {
    warning.classList.add('active');
    warning.textContent = `${data.stateName} does not have a dedicated row in after_death_checklist_state_rules yet, so this plan is using safe fallback wording plus the broader state guide overlay. Add a state row for exact death-certificate, filing, and creditor-window phrasing.`;
  }
}

async function saveAfterDeathPlan(data, guide, stateRuleRecord, model) {
  const supabase = window.afterDeathChecklistSupabase;
  if (!supabase) return null;
  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const payload = {
    user_id: userId,
    full_name: data.fullName,
    state_code: data.stateCode,
    state_name: data.stateName,
    has_will: data.hasWill,
    has_trust: data.hasTrust,
    has_poa: data.hasPoa,
    has_healthcare_proxy: data.hasHealthcareProxy,
    has_beneficiary_designations: data.hasBeneficiaryDesignations,
    has_funeral_preplan: data.hasFuneralPreplan,
    has_digital_inventory: data.hasDigitalInventory,
    readiness_score: model.score,
    death_certificate_copies: model.rules.death_certificate_copies,
    will_deadline: model.rules.will_deadline,
    creditor_window: model.rules.creditor_window,
    state_rule_version: stateRuleRecord?.rule_version || null,
    state_rule_snapshot: stateRuleRecord || null,
    report_title: `The 72-Hour Checklist for ${data.fullName}`,
    report_payload: { ...data, guide, stateRuleRecord, model }
  };

  const { error } = await supabase
    .from('after_death_checklist_reports')
    .insert(payload);

  if (error) {
    console.error('Failed to save 72-Hour Checklist report:', error);
  }
}

function showGeneratedPlan() {
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  const steps = ['analysisStep1','analysisStep2','analysisStep3','analysisStep4'];
  let delay = 0;
  steps.forEach((id, index) => {
    delay += 450;
    setTimeout(() => {
      document.getElementById(id).classList.add('done');
      if (index === steps.length - 1) {
        setTimeout(() => {
          document.getElementById('analysisSection').classList.remove('active');
          document.getElementById('reportSection').classList.add('active');
          const shell = document.getElementById('reportShell');
          shell.classList.add('visible');
          shell.scrollIntoView({ behavior: 'smooth', block: 'start' });
          document.querySelectorAll('.fade-up').forEach((el, i) => setTimeout(() => el.classList.add('visible'), i * 80));
        }, 400);
      }
    }, delay);
  });
}

function showHydratedPlan() {
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('reportSection').classList.add('active');
  document.getElementById('reportShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedSubmission(report) {
  const payload = report?.report_payload;
  if (!payload) return false;
  document.getElementById('fullName').value = payload.fullName || '';
  document.getElementById('stateSelect').value = payload.stateCode || '';
  document.getElementById('hasWill').checked = Boolean(payload.hasWill);
  document.getElementById('hasTrust').checked = Boolean(payload.hasTrust);
  document.getElementById('hasPoa').checked = Boolean(payload.hasPoa);
  document.getElementById('hasHealthcareProxy').checked = Boolean(payload.hasHealthcareProxy);
  document.getElementById('hasBeneficiaryDesignations').checked = Boolean(payload.hasBeneficiaryDesignations);
  document.getElementById('hasFuneralPreplan').checked = Boolean(payload.hasFuneralPreplan);
  document.getElementById('hasDigitalInventory').checked = Boolean(payload.hasDigitalInventory);
  document.querySelectorAll('.doc-card').forEach((card) => {
    const input = card.querySelector('input');
    card.classList.toggle('selected', input.checked);
  });
  populateReport(payload, payload.guide || null, payload.stateRuleRecord || null, payload.model);
  showHydratedPlan();
  return true;
}

async function generateAfterDeathPlan() {
  const data = getInputData();
  const validationError = validateInput(data);
  if (validationError) {
    alert(validationError);
    return;
  }
  const supabase = window.afterDeathChecklistSupabase;
  const [guide, stateRuleRecord] = await Promise.all([
    loadStateGuide(supabase, data.stateCode),
    loadStateRules(supabase, data.stateCode)
  ]);
  const model = buildModel(data, guide, stateRuleRecord);
  populateReport(data, guide, stateRuleRecord, model);
  await saveAfterDeathPlan(data, guide, stateRuleRecord, model);
  showGeneratedPlan();
}

function editAfterDeathPlan() {
  document.getElementById('reportSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(2);
}

window.nextStep = nextStep;
window.generateAfterDeathPlan = generateAfterDeathPlan;
window.editAfterDeathPlan = editAfterDeathPlan;
window.hydrateAfterDeathChecklistSubmission = hydrateSavedSubmission;
</script>

