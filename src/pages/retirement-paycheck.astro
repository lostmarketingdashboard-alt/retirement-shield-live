---
export const prerender = false;
export const ssr = false;
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Your Retirement Paycheck — The Dividend Income X-Ray</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --navy: #0F1F3D;
  --navy-light: #1A2D52;
  --navy-mid: #152847;
  --gold: #C9A84C;
  --gold-light: #D4B96A;
  --gold-pale: #F5EDD6;
  --gold-glow: rgba(201, 168, 76, 0.12);
  --cream: #FAF7F0;
  --cream-dark: #F0EBE0;
  --white: #FFFFFF;
  --text-dark: #1A1A1A;
  --text-mid: #4A4A4A;
  --text-light: #7A7A7A;
  --green: #27AE60;
  --green-bg: #F0FDF4;
  --amber: #E67E22;
  --amber-bg: #FFF8F0;
  --red: #C0392B;
  --red-bg: #FDF2F0;
  --border: #E8E3D8;
  --shadow: 0 2px 20px rgba(15, 31, 61, 0.08);
  --shadow-lg: 0 8px 40px rgba(15, 31, 61, 0.12);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--text-dark);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

.site-header {
  background: var(--navy);
  padding: 14px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2px solid var(--gold);
}

.logo {
  text-decoration: none;
}

.logo-text {
  font-family: 'Playfair Display', serif;
  color: var(--white);
  font-size: 18px;
  font-weight: 600;
}

.logo-text span { color: var(--gold); }

.hero {
  background: var(--navy);
  padding: 78px 24px 94px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(201,168,76,0.08) 0%, transparent 48%),
    radial-gradient(ellipse at 78% 72%, rgba(201,168,76,0.05) 0%, transparent 54%);
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 880px;
  margin: 0 auto;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(201,168,76,0.1);
  border: 1px solid rgba(201,168,76,0.22);
  border-radius: 999px;
  padding: 8px 18px;
  margin-bottom: 28px;
  font-size: 11px;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: 1.2px;
  text-transform: uppercase;
}

.hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 5vw, 54px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.12;
  margin-bottom: 18px;
}

.hero h1 em {
  color: var(--gold);
  font-style: normal;
}

.hero-sub {
  font-size: 18px;
  color: rgba(255,255,255,0.66);
  line-height: 1.7;
  max-width: 730px;
  margin: 0 auto 38px;
  font-weight: 300;
}

.hero-points {
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}

.hero-point {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.84);
  border-radius: 999px;
  padding: 10px 16px;
  font-size: 13px;
}

.wizard-section,
.analysis-section,
.report-section {
  padding: 52px 24px 30px;
}

.wizard-grid {
  max-width: 1180px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 340px minmax(0, 1fr);
  gap: 28px;
  align-items: start;
}

.sticky-sidebar {
  position: sticky;
  top: 94px;
}

.sidebar-card,
.form-card,
.analysis-card,
.report-shell,
.disclaimer {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 16px;
  box-shadow: var(--shadow);
}

.sidebar-card { padding: 28px; }

.sidebar-label,
.step-label,
.section-kicker,
.report-kicker {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--gold);
}

.sidebar-title {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  line-height: 1.15;
  color: var(--navy);
  margin: 8px 0 14px;
}

.sidebar-copy {
  font-size: 14px;
  color: var(--text-mid);
  margin-bottom: 22px;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 22px;
}

.step-item {
  display: grid;
  grid-template-columns: 34px 1fr;
  gap: 12px;
  align-items: start;
  padding: 12px 14px;
  border-radius: 12px;
  background: var(--cream);
  border: 1px solid transparent;
}

.step-item.active {
  border-color: rgba(201,168,76,0.4);
  background: var(--gold-glow);
}

.step-item.done .step-num {
  background: var(--gold);
  color: var(--navy);
}

.step-num {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: var(--cream-dark);
  color: var(--navy);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
}

.step-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--navy);
  line-height: 1.35;
}

.step-sub {
  font-size: 12px;
  color: var(--text-light);
  margin-top: 2px;
}

.sidebar-note {
  border-radius: 14px;
  background: var(--navy);
  color: rgba(255,255,255,0.78);
  padding: 18px;
  font-size: 13px;
}

.sidebar-note strong {
  color: var(--white);
  display: block;
  margin-bottom: 6px;
}

.form-card { overflow: hidden; }

.form-header {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
  padding: 28px 30px;
}

.form-header-top {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: center;
  margin-bottom: 18px;
}

.form-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 14px;
  background: rgba(201,168,76,0.12);
  border: 1px solid rgba(201,168,76,0.24);
  color: var(--gold);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.1px;
  text-transform: uppercase;
}

.progress-inline {
  color: rgba(255,255,255,0.62);
  font-size: 12px;
  font-weight: 600;
}

.form-title {
  font-family: 'Playfair Display', serif;
  color: var(--white);
  font-size: 34px;
  line-height: 1.1;
  margin-bottom: 10px;
}

.form-sub {
  color: rgba(255,255,255,0.64);
  font-size: 15px;
  max-width: 760px;
}

.progress-bar {
  height: 5px;
  background: rgba(255,255,255,0.1);
  border-radius: 999px;
  margin-top: 18px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  width: 33.33%;
  background: linear-gradient(90deg, var(--gold), var(--gold-light));
  border-radius: 999px;
  transition: width 0.35s ease;
}

.form-body {
  padding: 30px;
}

.form-step { display: none; }
.form-step.active { display: block; }

.step-question {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  line-height: 1.18;
  color: var(--navy);
  margin: 8px 0;
}

.step-help {
  font-size: 14px;
  color: var(--text-light);
  margin-bottom: 24px;
  max-width: 720px;
}

.field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.field-group { margin-bottom: 18px; }
.field-group.full { grid-column: 1 / -1; }

.field-label {
  display: block;
  font-size: 11px;
  font-weight: 700;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.9px;
  margin-bottom: 8px;
}

.field-input,
.field-select,
.field-textarea {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  background: var(--cream);
  color: var(--text-dark);
  font-size: 15px;
  font-family: 'DM Sans', sans-serif;
  padding: 14px 16px;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
}

.field-input:focus,
.field-select:focus,
.field-textarea:focus {
  border-color: var(--gold);
  box-shadow: 0 0 0 3px rgba(201,168,76,0.12);
  background: var(--white);
}

.field-textarea {
  min-height: 120px;
  resize: vertical;
}

.field-note {
  margin-top: 7px;
  font-size: 12px;
  color: var(--text-light);
}

.holdings-shell {
  border: 1px solid var(--border);
  border-radius: 14px;
  background: var(--cream);
  padding: 16px;
}

.holding-row {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  gap: 12px;
  align-items: end;
  margin-bottom: 12px;
}

.holding-row:last-child { margin-bottom: 0; }

.holding-row-actions {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-top: 14px;
  flex-wrap: wrap;
}

.holdings-supported {
  font-size: 12px;
  color: var(--text-light);
  margin-top: 14px;
}

.insight-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.insight-card {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px;
}

.insight-card strong {
  display: block;
  font-size: 13px;
  color: var(--navy);
  margin-bottom: 4px;
}

.insight-card span {
  display: block;
  font-size: 12px;
  color: var(--text-light);
}

.btn-row {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-top: 26px;
}

.btn-back,
.btn-next,
.btn-add,
.btn-ghost,
.btn-print,
.btn-secondary {
  border: none;
  border-radius: 10px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-back,
.btn-ghost,
.btn-secondary {
  background: transparent;
  border: 1.5px solid var(--border);
  color: var(--text-mid);
  padding: 12px 18px;
}

.btn-next,
.btn-add,
.btn-print {
  background: var(--gold);
  color: var(--navy);
  padding: 13px 20px;
}

.btn-next:hover,
.btn-add:hover,
.btn-print:hover {
  background: var(--gold-light);
}

.analysis-section,
.report-section { display: none; }
.analysis-section.active,
.report-section.active { display: block; }

.analysis-card {
  max-width: 920px;
  margin: 0 auto;
  padding: 42px 28px;
  text-align: center;
}

.analysis-orb {
  width: 96px;
  height: 96px;
  margin: 0 auto 20px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, var(--gold-light), var(--gold));
  position: relative;
  box-shadow: 0 0 0 16px rgba(201,168,76,0.08), 0 0 0 32px rgba(201,168,76,0.04);
}

.analysis-orb::after {
  content: '';
  position: absolute;
  inset: 24px;
  border-radius: 50%;
  background: var(--navy);
  opacity: 0.16;
}

.analysis-title {
  font-family: 'Playfair Display', serif;
  font-size: 34px;
  color: var(--navy);
  margin-bottom: 8px;
}

.analysis-sub {
  font-size: 15px;
  color: var(--text-light);
  margin-bottom: 28px;
}

.analysis-steps {
  max-width: 560px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.analysis-step {
  display: grid;
  grid-template-columns: 38px 1fr;
  gap: 14px;
  align-items: center;
  text-align: left;
  padding: 14px 16px;
  border-radius: 12px;
  background: var(--cream);
  border: 1px solid var(--border);
}

.analysis-indicator {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: var(--gold-glow);
  color: var(--gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.analysis-step.done .analysis-indicator {
  background: var(--gold);
  color: var(--navy);
}

.analysis-text {
  font-size: 14px;
  color: var(--text-mid);
}

.report-shell {
  max-width: 1060px;
  margin: 0 auto;
  overflow: hidden;
}

.report-header {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
  padding: 36px 32px 30px;
  color: var(--white);
}

.report-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(30px, 4vw, 44px);
  line-height: 1.1;
  margin: 10px 0 12px;
}

.report-subtitle {
  color: rgba(255,255,255,0.72);
  font-size: 15px;
  max-width: 780px;
}

.report-meta {
  margin-top: 20px;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.report-meta-item {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 999px;
  padding: 8px 14px;
  font-size: 12px;
  color: rgba(255,255,255,0.8);
  white-space: normal;
  overflow-wrap: anywhere;
}

.report-body {
  padding: 28px;
  display: grid;
  gap: 22px;
}

.hero-summary,
.section-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 16px;
}

.hero-summary {
  padding: 28px;
  background: linear-gradient(135deg, rgba(15,31,61,0.03), rgba(201,168,76,0.08)), var(--white);
}

.hero-grid,
.two-col,
.three-col,
.calendar-grid,
.safety-grid {
  display: grid;
  gap: 18px;
}

.hero-grid {
  grid-template-columns: 1.1fr 0.9fr;
}

.summary-title {
  font-family: 'Playfair Display', serif;
  font-size: 34px;
  color: var(--navy);
  line-height: 1.08;
  margin-bottom: 10px;
}

.summary-title em { color: var(--gold); font-style: normal; }

.summary-copy {
  font-size: 15px;
  color: var(--text-mid);
}

.benchmark-card {
  background: var(--navy);
  color: rgba(255,255,255,0.82);
  border-radius: 16px;
  padding: 22px;
}

.benchmark-card .headline {
  font-family: 'Playfair Display', serif;
  font-size: 24px;
  color: var(--white);
  line-height: 1.14;
  margin: 8px 0 10px;
}

.summary-metrics {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14px;
  margin-top: 22px;
}

.metric-card {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px;
}

.metric-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.9px;
  color: var(--text-light);
  font-weight: 700;
  margin-bottom: 6px;
}

.metric-value {
  font-family: 'Playfair Display', serif;
  font-size: 30px;
  color: var(--navy);
  line-height: 1;
  margin-bottom: 6px;
}

.metric-sub {
  font-size: 12px;
  color: var(--text-light);
}

.section-card { padding: 24px; }

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: end;
  gap: 16px;
  margin-bottom: 18px;
}

.section-title {
  font-family: 'Playfair Display', serif;
  font-size: 26px;
  color: var(--navy);
  line-height: 1.15;
  margin-top: 4px;
}

.section-copy {
  font-size: 13px;
  color: var(--text-light);
  max-width: 650px;
}

.pill {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 8px 12px;
  font-size: 12px;
  font-weight: 700;
  color: var(--navy);
  white-space: normal;
  overflow-wrap: anywhere;
}

.calendar-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.month-card {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px;
}

.month-name {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 700;
  color: var(--text-light);
  margin-bottom: 8px;
}

.month-amount {
  font-family: 'Playfair Display', serif;
  font-size: 30px;
  color: var(--navy);
  line-height: 1;
  margin-bottom: 10px;
}

.month-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.month-list-item {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  font-size: 13px;
  color: var(--text-mid);
}

.month-list-item span:last-child {
  font-weight: 700;
  color: var(--navy);
}

.safety-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.safety-card {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px;
}

.safety-header {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: start;
  margin-bottom: 12px;
}

.ticker-name {
  font-size: 18px;
  font-weight: 700;
  color: var(--navy);
}

.ticker-sub {
  font-size: 12px;
  color: var(--text-light);
}

.safety-badge {
  border-radius: 999px;
  padding: 6px 10px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
}

.safety-badge.safe { background: var(--green-bg); color: var(--green); }
.safety-badge.watch { background: var(--amber-bg); color: var(--amber); }
.safety-badge.risk { background: var(--red-bg); color: var(--red); }

.safety-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.stat-box {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 12px;
}

.stat-box .label {
  font-size: 11px;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-bottom: 4px;
}

.stat-box .value {
  font-size: 18px;
  font-weight: 700;
  color: var(--navy);
}

.holdings-table {
  width: 100%;
  border-collapse: collapse;
}

.holdings-table th,
.holdings-table td {
  text-align: left;
  padding: 11px 0;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
  vertical-align: top;
  overflow-wrap: anywhere;
}

.holdings-table th {
  font-size: 11px;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.9px;
}

.holdings-table tr:last-child td { border-bottom: none; }

.callout {
  background: var(--cream);
  border: 1px solid var(--border);
  border-left: 4px solid var(--gold);
  border-radius: 14px;
  padding: 18px;
  font-size: 14px;
  color: var(--text-mid);
}

.report-actions {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: center;
  padding: 0 28px 28px;
}

.report-note {
  font-size: 12px;
  color: var(--text-light);
}

.disclaimer {
  max-width: 1060px;
  margin: 0 auto 64px;
  padding: 24px 28px 32px;
}

.disclaimer p {
  font-size: 11px;
  color: var(--text-light);
  line-height: 1.7;
}

.disclaimer strong { color: var(--text-mid); }

.fade-up {
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.45s ease, transform 0.45s ease;
}

.fade-up.visible {
  opacity: 1;
  transform: translateY(0);
}

@media (max-width: 980px) {
  .wizard-grid,
  .hero-grid,
  .field-grid,
  .summary-metrics,
  .calendar-grid,
  .safety-grid,
  .insight-grid,
  .two-col,
  .three-col {
    grid-template-columns: 1fr;
  }

  .sticky-sidebar { position: static; }
}

@media (max-width: 768px) {
  .site-header { padding: 14px 16px; }
  .hero { padding: 54px 20px 72px; }
  .wizard-section,
  .analysis-section,
  .report-section { padding-left: 16px; padding-right: 16px; }
  .sidebar-card,
  .form-body,
  .report-body,
  .section-card,
  .hero-summary,
