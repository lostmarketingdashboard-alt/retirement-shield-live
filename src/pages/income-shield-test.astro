<script is:inline>
const STATE_OPTIONS = [
  ['AL','Alabama'],['AK','Alaska'],['AZ','Arizona'],['AR','Arkansas'],['CA','California'],
  ['CO','Colorado'],['CT','Connecticut'],['DE','Delaware'],['FL','Florida'],['GA','Georgia'],
  ['HI','Hawaii'],['ID','Idaho'],['IL','Illinois'],['IN','Indiana'],['IA','Iowa'],['KS','Kansas'],
  ['KY','Kentucky'],['LA','Louisiana'],['ME','Maine'],['MD','Maryland'],['MA','Massachusetts'],
  ['MI','Michigan'],['MN','Minnesota'],['MS','Mississippi'],['MO','Missouri'],['MT','Montana'],
  ['NE','Nebraska'],['NV','Nevada'],['NH','New Hampshire'],['NJ','New Jersey'],['NM','New Mexico'],
  ['NY','New York'],['NC','North Carolina'],['ND','North Dakota'],['OH','Ohio'],['OK','Oklahoma'],
  ['OR','Oregon'],['PA','Pennsylvania'],['RI','Rhode Island'],['SC','South Carolina'],['SD','South Dakota'],
  ['TN','Tennessee'],['TX','Texas'],['UT','Utah'],['VT','Vermont'],['VA','Virginia'],['WA','Washington'],
  ['WV','West Virginia'],['WI','Wisconsin'],['WY','Wyoming']
];

const SURVIVOR_REDUCTION = {
  couple: 0.18,
  solo: 0.02
};

const REBALANCE_LABELS = {
  stability: 'Maximize income stability',
  growth: 'Preserve more growth potential',
  legacy: 'Balance income and legacy goals'
};

let latestShieldPayload = null;

const stateSelect = document.getElementById('stateSelect');
const placeholderOption = document.createElement('option');
placeholderOption.value = '';
placeholderOption.textContent = 'Select your state...';
placeholderOption.disabled = true;
placeholderOption.selected = true;
stateSelect.appendChild(placeholderOption);

STATE_OPTIONS.forEach(([code, name]) => {
  const option = document.createElement('option');
  option.value = code;
  option.textContent = name;
  stateSelect.appendChild(option);
});

function formatMoney(value) {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(value || 0);
}

function parseMoney(value) {
  const parsed = Number(String(value || '').replace(/[^0-9.]/g, ''));
  return Number.isFinite(parsed) ? parsed : 0;
}

function parsePercent(value, fallback = 0) {
  const parsed = Number(String(value || '').replace(/[^0-9.-]/g, ''));
  return Number.isFinite(parsed) ? parsed : fallback;
}

function stateName(code) {
  return STATE_OPTIONS.find(([v]) => v === code)?.[1] ?? code;
}

function nextStep(step) {
  document.querySelectorAll('.form-step').forEach((panel) => panel.classList.remove('active'));
  document.getElementById(`step${step}`).classList.add('active');
  document.querySelectorAll('[data-step-indicator]').forEach((item, index) => {
    const num = index + 1;
    item.classList.toggle('active', num === step);
    item.classList.toggle('done', num < step);
  });
  document.getElementById('progressText').textContent = `Step ${step} of 3`;
  document.getElementById('progressFill').style.width = `${(step / 3) * 100}%`;
  window.scrollTo({ top: document.getElementById('wizardSection').offsetTop - 76, behavior: 'smooth' });
}

function buildIncomeSourceMap() {
  return {
    social_security: parseMoney(document.getElementById('socialSecurityIncome').value),
    pension: parseMoney(document.getElementById('pensionIncome').value),
    dividends: parseMoney(document.getElementById('dividendIncome').value),
    bonds: parseMoney(document.getElementById('bondIncome').value),
    rental: parseMoney(document.getElementById('rentalIncome').value),
    annuity: parseMoney(document.getElementById('annuityIncome').value),
    part_time: parseMoney(document.getElementById('partTimeIncome').value),
    other: parseMoney(document.getElementById('otherIncome').value)
  };
}

function sumValues(object) {
  return Object.values(object).reduce((sum, value) => sum + value, 0);
}

function scenarioCardTone(gap) {
  if (gap >= 0) return 'safe';
  if (gap >= -1000) return 'watch';
  return 'risk';
}

function buildIncomeShieldPayload() {
  const fullName = document.getElementById('fullName').value.trim();
  const stateCode = document.getElementById('stateSelect').value;
  const stateFullName = stateName(stateCode);
  const countyName = document.getElementById('countyName').value.trim();
  const householdType = document.getElementById('householdType').value;
  const riskPriority = document.getElementById('riskPriority').value;
  const monthlySpending = parseMoney(document.getElementById('monthlySpending').value);
  const healthShockIncrease = parsePercent(document.getElementById('healthShockIncrease').value, 22);
  const inflationShockRate = parsePercent(document.getElementById('inflationShockRate').value, 6);
  const rebalancingGoal = document.getElementById('rebalancingGoal').value;
  const portfolioNotes = document.getElementById('portfolioNotes').value.trim();
  const incomeSources = buildIncomeSourceMap();
  const totalIncome = sumValues(incomeSources);
  const currentGap = totalIncome - monthlySpending;

  const scenarios = [
    {
      key: 'market_crash',
      name: 'Stock market crash',
      income: totalIncome - (incomeSources.dividends * 0.30),
      spending: monthlySpending,
      note: 'Assumes a 30% dividend-income reduction across the equity-income sleeve.'
    },
    {
      key: 'rising_rates',
      name: 'Rising interest rates',
      income: totalIncome + (incomeSources.bonds * 0.10),
      spending: monthlySpending,
      note: 'Assumes lower bond prices but modestly better reinvestment income.'
    },
    {
      key: 'spouse_death',
      name: 'Spouse death',
      income: totalIncome - (incomeSources.social_security * (SURVIVOR_REDUCTION[householdType] || 0.1)) - (incomeSources.pension * 0.20),
      spending: monthlySpending * 0.92,
      note: 'Models a reduced Social Security stream and a partial pension drop after one spouse is gone.'
    },
    {
      key: 'health_crisis',
      name: 'Health crisis',
      income: totalIncome - (incomeSources.part_time * 0.70) - (incomeSources.rental * 0.10),
      spending: monthlySpending * (1 + healthShockIncrease / 100),
      note: 'Assumes work income falls, rental friction rises, and spending increases under care pressure.'
    },
    {
      key: 'high_inflation',
      name: 'High inflation',
      income: totalIncome,
      spending: monthlySpending * (1 + inflationShockRate / 100),
      note: 'Models purchasing power erosion without an equal increase in every income source.'
    }
  ].map((scenario) => {
    const gap = scenario.income - scenario.spending;
    return {
      ...scenario,
      gap,
      tone: scenarioCardTone(gap)
    };
  });

  const worstScenario = [...scenarios].sort((a, b) => a.gap - b.gap)[0];

  const compare = [
    {
      label: 'Total monthly income',
      value: totalIncome,
      sub: 'All listed income sources before any stress event'
    },
    {
      label: 'Most severe stressed income',
      value: Math.min(...scenarios.map((s) => s.income)),
      sub: 'Lowest projected monthly income across the five scenarios'
    },
    {
      label: 'Largest stressed shortfall',
      value: Math.abs(Math.min(...scenarios.map((s) => s.gap))),
      sub: 'How far below spending the plan falls in the worst scenario'
    }
  ];

  const sourceShares = Object.entries(incomeSources).map(([key, value]) => ({
    key,
    value,
    share: totalIncome ? value / totalIncome : 0
  })).sort((a, b) => b.value - a.value);

  const rebalance = [];

  if (sourceShares[0]?.share >= 0.45) {
    rebalance.push({
      tone: 'warn',
      title: 'Income concentration is high',
      text: `${sourceShares[0].key.replace('_', ' ')} makes up about ${Math.round(sourceShares[0].share * 100)}% of total monthly income. A shock to one source would hit the whole system hard.`
    });
  } else {
    rebalance.push({
      tone: 'good',
      title: 'Income concentration looks more balanced',
      text: 'No single income source appears to dominate the retirement paycheck to an extreme degree.'
    });
  }

  if (incomeSources.annuity === 0 && rebalancingGoal === 'stability') {
    rebalance.push({
      tone: 'warn',
      title: 'Stability goal but limited contractual income',
      text: 'For a stability-first household, the current mix may rely too heavily on market-sensitive or interruption-prone sources.'
    });
  } else {
    rebalance.push({
      tone: 'good',
      title: 'Contractual income support',
      text: 'The current system includes at least some income sources that are less directly tied to market shocks.'
    });
  }

  if (worstScenario.key === 'spouse_death') {
    rebalance.push({
      tone: 'bad',
      title: 'Spouse-death vulnerability is the main weakness',
      text: 'The biggest system failure appears after one spouse is gone, which can point to survivor-income, insurance, and title/planning gaps.'
    });
  } else if (worstScenario.key === 'health_crisis') {
    rebalance.push({
      tone: 'bad',
      title: 'Health-cost vulnerability is the main weakness',
      text: 'The biggest system break appears when healthcare spending rises and flexible work or property income becomes harder to maintain.'
    });
  } else {
    rebalance.push({
      tone: 'warn',
      title: 'Market and inflation sensitivity still matter',
      text: 'Even if the worst case is not catastrophic, the system still shows sensitivity to growth and purchasing-power shocks.'
    });
  }

  const narrative = `Current monthly income is about ${formatMoney(totalIncome)} against spending of ${formatMoney(monthlySpending)}, leaving a ${currentGap >= 0 ? 'surplus' : 'shortfall'} of ${formatMoney(Math.abs(currentGap))}. The worst stress test is "${worstScenario.name}," where the income gap shifts to ${formatMoney(Math.abs(worstScenario.gap))} ${worstScenario.gap >= 0 ? 'above' : 'below'} current spending. ${portfolioNotes ? portfolioNotes : 'This suggests the income system should be reviewed as a whole rather than one account at a time.'}`;

  return {
    fullName,
    stateCode,
    stateName: stateFullName,
    countyName,
    householdType,
    riskPriority,
    monthlySpending,
    healthShockIncrease,
    inflationShockRate,
    rebalancingGoal,
    portfolioNotes,
    incomeSources,
    totalIncome,
    currentGap,
    scenarios,
    worstScenario,
    compare,
    rebalance,
    narrative
  };
}

function renderIncomeShieldReport(payload) {
  latestShieldPayload = payload;
  document.getElementById('reportTitle').textContent = `The Income Shield for ${payload.fullName || 'Your Household'}`;
  document.getElementById('reportSubtitle').textContent = `A retirement income resilience report for ${payload.countyName || 'your county'}${payload.stateName ? `, ${payload.stateName}` : ''}, showing what happens when major threats hit the paycheck system.`;
  document.getElementById('metaName').textContent = `Prepared for ${payload.fullName || '—'}`;
  document.getElementById('metaLocation').textContent = `${payload.countyName || 'County not entered'} · ${payload.stateName || 'State not entered'} income stress test`;
  document.getElementById('metaDate').textContent = `Generated ${new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;

  document.getElementById('summaryCopy').textContent = payload.portfolioNotes || payload.narrative;
  document.getElementById('benchmarkHeadline').textContent = `The worst scenario right now is: ${payload.worstScenario.name}`;
  document.getElementById('benchmarkCopy').textContent = `${payload.worstScenario.note} Under that stress, the projected monthly income gap becomes ${payload.worstScenario.gap >= 0 ? 'a surplus of' : 'a shortfall of'} ${formatMoney(Math.abs(payload.worstScenario.gap))}.`;
  document.getElementById('totalIncomeValue').textContent = formatMoney(payload.totalIncome);
  document.getElementById('spendingValue').textContent = formatMoney(payload.monthlySpending);
  document.getElementById('gapValue').textContent = `${payload.currentGap >= 0 ? '+' : '-'}${formatMoney(Math.abs(payload.currentGap))}`;
  document.getElementById('totalIncomeSub').textContent = 'All listed monthly income sources combined';
  document.getElementById('spendingSub').textContent = 'Current household outflow entered into the model';
  document.getElementById('gapSub').textContent = payload.currentGap >= 0 ? 'Current income surplus before stress hits' : 'Current shortfall before stress hits';
  document.getElementById('scenarioPill').textContent = `${payload.scenarios.length} scenario view`;

  document.getElementById('scenarioGrid').innerHTML = payload.scenarios.map((scenario) => `
    <div class="scenario-card ${scenario.tone}">
      <div class="scenario-label">${scenario.name}</div>
      <div class="scenario-value">${scenario.gap >= 0 ? '+' : '-'}${formatMoney(Math.abs(scenario.gap))}</div>
      <div class="scenario-sub">${scenario.gap >= 0 ? 'Projected monthly surplus' : 'Projected monthly shortfall'}</div>
      <div class="scenario-list">
        <div class="scenario-list-item"><span>Income under stress</span><span>${formatMoney(scenario.income)}</span></div>
        <div class="scenario-list-item"><span>Spending under stress</span><span>${formatMoney(scenario.spending)}</span></div>
      </div>
    </div>
  `).join('');

  document.getElementById('compareGrid').innerHTML = payload.compare.map((item) => `
    <div class="compare-card">
      <div class="label">${item.label}</div>
      <div class="value">${formatMoney(item.value)}</div>
      <div class="sub">${item.sub}</div>
    </div>
  `).join('');

  document.getElementById('rebalanceGrid').innerHTML = payload.rebalance.map((item) => `
    <div class="rebalance-card">
      <div class="rebalance-badge ${item.tone}">${item.tone === 'good' ? 'Supportive' : item.tone === 'warn' ? 'Needs review' : 'Priority alert'}</div>
      <strong>${item.title}</strong>
      <span>${item.text}</span>
    </div>
  `).join('');

  document.getElementById('shieldCallout').textContent = payload.narrative;
}

function runAnalysisAnimation(payload) {
  document.getElementById('analysisSub').textContent = `Stress testing income sources for ${payload.fullName || 'your household'} in ${payload.stateName || 'your state'}.`;
  ['analysisStep1','analysisStep2','analysisStep3','analysisStep4'].forEach((id, index) => {
    const el = document.getElementById(id);
    el.classList.remove('done');
    setTimeout(() => el.classList.add('done'), (index + 1) * 360);
  });
}

async function saveIncomeShieldReport(payload) {
  const supabase = window.incomeShieldSupabase;
  if (!supabase) return null;
  const { data: { session } } = await supabase.auth.getSession();
  const userId = session?.user?.id || new URLSearchParams(window.location.search).get('utm');
  if (!userId) return null;

  const insertPayload = {
    user_id: userId,
    full_name: payload.fullName || null,
    state_code: payload.stateCode || null,
    state_name: payload.stateName || null,
    county_name: payload.countyName || null,
    household_type: payload.householdType || null,
    risk_priority: payload.riskPriority || null,
    monthly_spending: payload.monthlySpending,
    total_monthly_income: payload.totalIncome,
    current_gap: payload.currentGap,
    worst_scenario_key: payload.worstScenario.key,
    worst_scenario_gap: payload.worstScenario.gap,
    rebalancing_goal: payload.rebalancingGoal || null,
    report_title: `The Income Shield for ${payload.fullName || 'Your Household'}`,
    report_payload: payload
  };

  const { error } = await supabase
    .from('income_shield_reports')
    .insert(insertPayload);

  if (error) {
    console.error('Failed to save Income Shield report:', error);
  }
}

function showGeneratedIncomeShieldReport(payload) {
  renderIncomeShieldReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.add('active');
  runAnalysisAnimation(payload);

  setTimeout(() => {
    document.getElementById('analysisSection').classList.remove('active');
    document.getElementById('reportSection').classList.add('active');
    document.getElementById('reportShell').classList.add('visible');
    document.getElementById('reportShell').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 1800);
}

function showHydratedIncomeShieldReport(payload) {
  renderIncomeShieldReport(payload);
  document.getElementById('wizardSection').style.display = 'none';
  document.getElementById('analysisSection').classList.remove('active');
  document.getElementById('reportSection').classList.add('active');
  document.getElementById('reportShell').classList.add('visible');
  window.scrollTo({ top: 0, behavior: 'auto' });
}

async function hydrateSavedIncomeShieldReport(report) {
  const payload = report?.report_payload;
  if (!payload) return false;

  const fields = {
    fullName: payload.fullName,
    countyName: payload.countyName,
    socialSecurityIncome: payload.incomeSources?.social_security,
    pensionIncome: payload.incomeSources?.pension,
    dividendIncome: payload.incomeSources?.dividends,
    bondIncome: payload.incomeSources?.bonds,
    rentalIncome: payload.incomeSources?.rental,
    annuityIncome: payload.incomeSources?.annuity,
    partTimeIncome: payload.incomeSources?.part_time,
    otherIncome: payload.incomeSources?.other,
    monthlySpending: payload.monthlySpending,
    healthShockIncrease: payload.healthShockIncrease,
    inflationShockRate: payload.inflationShockRate,
    portfolioNotes: payload.portfolioNotes
  };

  Object.entries(fields).forEach(([id, value]) => {
    const input = document.getElementById(id);
    if (input && value !== undefined && value !== null) input.value = String(value);
  });

  if (payload.stateCode) document.getElementById('stateSelect').value = payload.stateCode;
  if (payload.householdType) document.getElementById('householdType').value = payload.householdType;
  if (payload.riskPriority) document.getElementById('riskPriority').value = payload.riskPriority;
  if (payload.rebalancingGoal) document.getElementById('rebalancingGoal').value = payload.rebalancingGoal;

  showHydratedIncomeShieldReport(payload);
  return true;
}

async function generateIncomeShieldReport() {
  const payload = buildIncomeShieldPayload();
  await saveIncomeShieldReport(payload);
  showGeneratedIncomeShieldReport(payload);
}

function editIncomeShieldReport() {
  document.getElementById('reportSection').classList.remove('active');
  document.getElementById('wizardSection').style.display = 'block';
  nextStep(3);
}

window.nextStep = nextStep;
window.generateIncomeShieldReport = generateIncomeShieldReport;
window.editIncomeShieldReport = editIncomeShieldReport;
window.hydrateIncomeShieldReport = hydrateSavedIncomeShieldReport;
</script>
