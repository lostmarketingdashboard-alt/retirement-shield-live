    .profile-field {
      display: flex;
      flex-direction: column;
      gap: 8px;
      min-width: 0;
    }

    .profile-field-full {
      grid-column: 1 / -1;
    }

    .profile-label {
      font-size: 11px;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      color: var(--text-muted);
      font-weight: 700;
