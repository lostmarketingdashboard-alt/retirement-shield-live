---
const { slug } = Astro.params;

const url = `${import.meta.env.PUBLIC_STRAPI_URL}/api/articles?filters[slug][$eq]=${slug}&populate=*`;

let article = null;
let fetchError = null;

try {
  const res = await fetch(url);

  if (!res.ok) {
    throw new Error(`Strapi error: ${res.status}`);
  }

  const json = await res.json();
  const items = Array.isArray(json?.data) ? json.data : [];
  article = items[0] ?? null;
} catch (err) {
  console.error('Blog slug fetch failed:', err);
  fetchError = err;
}

const formatDate = (dateStr) => {
  if (!dateStr) return null
  const d = new Date(dateStr)
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  })
}
---


<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{article.meta_title || article.headline}</title>
  <meta name="description" content={article.meta_description || ''} />

  {article.og_image_url && (
    <meta property="og:image" content={article.og_image_url} />
  )}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<style>


  :root {
   
    --gold:#c9973a;
    --slate:#4a5568;
    --light-bg:#f7f8fc;
    --white:#ffffff;
    --border:#e2e8f0;
    --text:#1a202c;
    --text-muted:#718096;
  --navy: #0d1b2a;
  --navy-mid: #1a2e45;
  --navy-light: #243b55;
  --cream: #f5f0e8;
  --cream-dark: #ede6d6;
  --amber: #c8821a;
  --amber-light: #e8a840;
  --text-primary: #1a1208;
  --text-secondary: #4a3f32;
  --text-muted: #7a6e62;
  --white: #ffffff;
  --rule: #c8b89a;
  --rule-light: rgba(200,184,154,0.35);
  --tap-min: 48px; /* WCAG minimum tap target */
}

  html,body{margin:0;padding:0;background:var(--light-bg);font-family:'DM Sans',sans-serif;color:var(--text)}

  header{
    background:var(--navy);
    padding:18px 32px;
    display:flex;
    justify-content:space-between;
    align-items:center;
  }

  .logo{
    font-family:'Playfair Display',serif;
    color:white;
    font-size:20px;
    font-weight:600;
    text-decoration:none;
  }

  .logo span{color:var(--gold)}

  .container{
    max-width:880px;
    margin:0 auto;
    padding:60px 24px 100px;
  }

  .eyebrow{
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:1.5px;
    color:var(--gold);
    margin-bottom:12px;
  }

  h1{
    font-family:'Playfair Display',serif;
    font-size:42px;
    line-height:1.2;
    margin-bottom:18px;
  }

  .subheadline{
    font-size:18px;
    color:var(--slate);
    margin-bottom:28px;
  }

  .meta{
    font-size:13px;
    color:var(--text-muted);
    margin-bottom:40px;
  }

  .meta span{margin-right:16px}

  .section{
    background:white;
    padding:32px;
    border-radius:16px;
    border:1px solid var(--border);
    margin-bottom:24px;
  }

  .section h2{
    font-family:'Playfair Display',serif;
    font-size:26px;
    margin-bottom:14px;
  }

  .section p{
    line-height:1.75;
    font-size:16px;
    margin-bottom:14px;
    color:var(--slate);
  }

  .key-takeaways{
    background:#f0f4fb;
    border-left:4px solid var(--navy);
    padding:20px;
    border-radius:10px;
  }

  .tags{
    margin-top:30px;
    display:flex;
    flex-wrap:wrap;
    gap:8px;
  }

  .tag{
    background:#eef2fa;
    padding:6px 12px;
    border-radius:20px;
    font-size:12px;
    color:var(--navy);
    font-weight:600;
  }

  footer{
    background:var(--navy);
    color:rgba(255,255,255,0.6);
    text-align:center;
    padding:24px;
    font-size:12px;
  }

  /* ══════════════════════════════════════════════════
   MASTHEAD — DESKTOP
══════════════════════════════════════════════════ */
.masthead {
  background: var(--navy);
  padding: 0 48px;
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  border-bottom: 3px solid var(--amber);
  position: sticky;
  top: 0;
  z-index: 200;
}
.masthead-brand {
  display: flex; align-items: center; gap: 14px; padding: 16px 0; text-decoration: none;
}
.shield-mark { width: 34px; height: 40px; flex-shrink: 0; }
.brand-name {
  font-family: 'Playfair Display', serif; font-weight: 700; font-size: 1.28rem;
  color: var(--cream); letter-spacing: 0.02em; line-height: 1.1;
}
.brand-tagline {
  font-family: 'DM Mono', monospace; font-size: 0.55rem; color: var(--amber-light);
  text-transform: uppercase; letter-spacing: 0.14em; margin-top: 2px; display: block; opacity: 0.85;
}
nav.desktop-nav { display: flex; align-items: center; gap: 28px; }
nav.desktop-nav a {
  font-family: 'DM Mono', monospace; font-size: 0.68rem; text-transform: uppercase;
  letter-spacing: 0.11em; color: var(--cream-dark); text-decoration: none;
  opacity: 0.75; transition: opacity 0.2s, color 0.2s; border-bottom: 1px solid transparent;
  padding: 4px 0;
}
nav.desktop-nav a:hover { opacity: 1; color: var(--amber-light); border-bottom-color: var(--amber-light); }
.nav-cta {
  background: var(--amber); color: var(--navy) !important; opacity: 1 !important;
  padding: 10px 20px !important; border-bottom: none !important; transition: background 0.2s !important;
}
.nav-cta:hover { background: var(--amber-light) !important; }

/* Hamburger — hidden on desktop */
.hamburger {
  display: none; background: none; border: none; cursor: pointer;
  padding: 16px 0; flex-direction: column; gap: 5px; align-items: center; justify-content: center;
}
.hamburger span {
  display: block; width: 22px; height: 2px; background: var(--cream);
  transition: transform 0.25s, opacity 0.25s;
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile nav drawer */
.mobile-nav {
  display: none;
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: var(--navy); z-index: 199;
  flex-direction: column; align-items: flex-start;
  padding: 90px 32px 40px;
  gap: 0;
  overflow-y: auto;
}
.mobile-nav.open { display: flex; }
.mobile-nav a {
  font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700;
  color: var(--cream); text-decoration: none; opacity: 0.8;
  padding: 16px 0; border-bottom: 1px solid rgba(200,184,154,0.12);
  width: 100%; transition: opacity 0.2s, color 0.2s;
  min-height: var(--tap-min); display: flex; align-items: center;
}
.mobile-nav a:hover, .mobile-nav a:active { opacity: 1; color: var(--amber-light); }
.mobile-nav .mobile-nav-cta {
  background: var(--amber); color: var(--navy) !important; opacity: 1 !important;
  padding: 18px 28px; margin-top: 24px; border-bottom: none;
  font-size: 0.8rem; font-family: 'DM Mono', monospace; font-weight: 400;
  text-transform: uppercase; letter-spacing: 0.12em; width: 100%; justify-content: center;
}


body {
  margin:0;
  background:#f7f8fc;
  font-family:'DM Sans',sans-serif;
  color:var(--text);
}

.container {
  max-width:880px;
  margin:0 auto;
  padding:60px 24px 100px;
}

h1 {
  font-family:'Playfair Display',serif;
  font-size:42px;
  line-height:1.2;
  margin-bottom:18px;
}

.subheadline {
  font-size:18px;
  color:var(--slate);
  margin-bottom:28px;
}

.meta {
  font-size:13px;
  color:#718096;
  margin-bottom:40px;
}

.section {
  background:white;
  padding:32px;
  border-radius:16px;
  border:1px solid var(--border);
  margin-bottom:24px;
}

.section p {
  line-height:1.75;
  font-size:16px;
  color:var(--slate);
}

.cover {
  margin-bottom: 28px;
}

.cover img {
  width: 100%;
  border-radius: 16px;
  object-fit: cover;
  max-height: 420px;
}
/* NAV */
nav{
  background: var(--navy);
  border-bottom:1px solid var(--border);
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:18px 32px;
}

.nav-logo{
  font-family:'Playfair Display',serif;
  font-size:20px;
  font-weight:600;
  color:white;
  text-decoration:none !important;
  display:inline-block;
}

.nav-logo:hover{
  opacity:.9;
}

.nav-logo span{
  color:var(--gold);
  text-decoration:none !important;
}

.nav-links{
  list-style:none;
  display:flex;
  gap:28px;
  align-items:center;
}

.nav-links a{
  text-decoration:none;
  color: white;
  font-size:14px;
}

.nav-links a:hover{
  color:var(--gold);
}

.nav-cta{
  padding:10px 18px;
  background:var(--gold);
  color:white !important;
  border-radius:4px;
}

.nav-cta:hover{
  opacity:.9;
}

/* HEADER */
.header{
  background:var(--navy);
  color:white;
  padding:64px 32px;
}

.header h1{
  font-family:'Playfair Display',serif;
  font-size:38px;
  margin-bottom:12px;
}

/* New mode switch button style */
.mode-switch-btn{
  appearance:none;
  -webkit-appearance:none;
  border:1px solid var(--border);
  padding:14px 22px;
  background:var(--navy);
  color:white;
  font-size:14px;
  letter-spacing:.5px;
  cursor:pointer;
  transition:.25s ease;
  border-radius:4px;
  display:inline-block;
  font-family:'DM Sans',sans-serif;
}

.mode-switch-btn:hover{
  background:var(--gold);
  border-color:var(--gold);
  color:white;
}

.header p{
  opacity:.75;
  max-width:600px;
  line-height:1.6;
}

/* BODY */
.container{
  padding:64px 32px;
  max-width:1100px;
  margin:0 auto;
}

.section-title{
  font-family:'Playfair Display',serif;
  font-size:24px;
  margin-bottom:24px;
}

.states-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(180px,1fr));
  gap:16px;
}

.state-btn,
.county-link{
  padding:16px;
  border:1px solid var(--border);
  background:white;
  cursor:pointer;
  font-size:14px;
  transition:.2s;
  text-align:center;
  text-decoration:none;
  color:var(--text);
}

.state-btn:hover,
.county-link:hover{
  border-color:var(--gold);
  background:#fffdf6;
}

.guide-toggle{
  padding:12px 18px;
  border:1px solid var(--border);
  background:white;
  cursor:pointer;
  font-size:14px;
  transition:.2s;
}

.guide-toggle:hover{
  border-color:var(--gold);
}

.active-toggle{
  background:var(--gold);
  color:white;
  border-color:var(--gold);
}

@media (max-width: 768px) {
  .nav-links {
    display: none;
  }

  nav {
    justify-content: center;
    padding: 18px 16px;
  }

  .nav-logo {
    font-size: 18px;
  }
}
</style>


<!-- NAV -->
<nav>
  <a href="/" class="nav-logo">Retirement<span>Shield</span></a>
  <ul class="nav-links">
    <li><a href="/lifeexpectancycalculator">Life Expectancy</a></li>
    <li><a href="/quiz">Estate Planning</a></li>
    <!-- <li><a href="#">Calculators</a></li> -->
    <li><a href="#" onclick="openNewsletterModal(event)">Newsletter</a></li>
    <li><a href="/quiz" class="nav-cta">Free Assessment</a></li>
  </ul>
</nav>


<div class="container">

  {!article && (
    <div>
      <h1>Article not found</h1>
      {fetchError && <p>Something went wrong loading this article.</p>}
    </div>
  )}

  {article && (
    <>
      <h1>{article.title}</h1>

      {article.cover && (article.cover.url || article.cover.data?.attributes?.url) && (
        <div class="cover">
          <img
            src={`${import.meta.env.PUBLIC_STRAPI_URL}${article.cover.url || article.cover.data?.attributes?.url}`}
            alt={article.title}
          />
        </div>
      )}

      <div class="meta">
        {formatDate(article.publishedAt) && (
          <span>Published {formatDate(article.publishedAt)}</span>
        )}
      </div>

      <div class="section">
        {(article.excerpt || article.description) && (
          <div class="subheadline">
            {article.excerpt || article.description}
          </div>
        )}

        {article.content && <div set:html={article.content}></div>}
      </div>
    </>
  )}

</div>