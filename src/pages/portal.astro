      background: rgba(45,106,79,.08);
      border-color: rgba(45,106,79,.22);
      color: #2d6a4f;
    }

    .profile-alert.error {
      background: rgba(177,48,48,.08);
      border-color: rgba(177,48,48,.18);
      color: #9b2c2c;
