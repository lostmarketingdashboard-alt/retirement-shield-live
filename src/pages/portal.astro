    .profile-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.25fr) minmax(0, .95fr);
      gap: 24px;
      align-items: start;
      width: 100%;
      min-width: 0;
    }

    .profile-card {
      max-width: 100%;
      min-width: 0;
