function parseCurrency(value) {
  const digits = String(value || '').replace(/[^\d.]/g, '');
  const parsed = Number.parseFloat(digits);
  return Number.isFinite(parsed) ? parsed : 0;
}

function formatCurrency(value, decimals = 0) {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    minimumFractionDigits: decimals,
    maximumFractionDigits: decimals
  }).format(value);
}

function formatCurrencyCompact(value) {
  return `${formatCurrency(value)}/mo`;
}

function formatCurrencyInput(event) {
  const numeric = parseCurrency(event.target.value);
  event.target.value = numeric ? formatCurrency(numeric) : '';
}

function getSelectedState() {
  const stateSelect = document.getElementById('stateSelect');
  return {
    code: stateSelect.value || '',
    name: stateSelect.options[stateSelect.selectedIndex]?.text || ''
  };
}

function getSelectedValue(name) {
  return document.querySelector(`input[name="${name}"]:checked`)?.value || '';
}

function clamp(value, min, max) {
  return Math.min(Math.max(value, min), max);
}

const DEFAULT_FEDERAL_RULES = {
  source_label: 'SSA survivor guidance · state probate dataset · Medicaid dataset',
  social_security: {
    lump_sum_death_benefit: 255
  },
  medicaid: {
    default_asset_limit: 2000,
    default_lookback_months: 60
  }
};

function interpolateTemplate(template, values) {
  return String(template || '').replace(/\{\{(\w+)\}\}/g, (_, key) => values[key] ?? '');
}

async function loadWidowsRules(stateCode, stateName) {
  const supabase = window.widowsPlaybookSupabase;
  const fallback = {
    federal: DEFAULT_FEDERAL_RULES,
    state: {
      state_code: stateCode,
      state_name: stateName,
      rule_version: 'fallback',
      is_verified: false,
      rules_payload: {}
    }
  };

  if (!supabase || !stateCode) return fallback;

  const [{ data: federalRows }, { data: stateRow }] = await Promise.all([
    supabase
      .from('widows_playbook_federal_rules')
      .select('*')
      .eq('is_active', true)
      .order('updated_at', { ascending: false }),
    supabase
      .from('widows_playbook_state_rules')
      .select('*')
      .eq('state_code', stateCode)
      .eq('is_active', true)
      .order('updated_at', { ascending: false })
      .limit(1)
      .maybeSingle()
  ]);

  const federal = (federalRows || []).reduce((acc, row) => {
    acc[row.rule_key] = row.rule_payload;
    return acc;
  }, {});

  return {
    federal: {
      ...DEFAULT_FEDERAL_RULES,
      ...federal
    },
    state: stateRow || fallback.state
  };
}

