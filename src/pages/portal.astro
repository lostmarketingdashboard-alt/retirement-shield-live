---
export const prerender = false;
export const ssr = false;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Client Portal</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
  <div id="app"></div>

  <script type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'

    const supabase = createClient(
      "https://nyiturqeotdxucfdurzu.supabase.co",
      "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im55aXR1cnFlb3RkeHVjZmR1cnp1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIxMzI0ODgsImV4cCI6MjA4NzcwODQ4OH0.CvYju6UTaCGD_Zd-8FVTcB-yW9YVG_jQtwkd0l7mIV0",
      {
        auth: {
          persistSession: true,
          autoRefreshToken: true,
          detectSessionInUrl: true,
          flowType: 'pkce'
        }
      }
    )

    document.addEventListener('DOMContentLoaded', async () => {
      const { data: { session } } = await supabase.auth.getSession()

      if (!session || !session.user) {
        window.location.href = '/login'
        return
      }

      const user = session.user

      const { data: profile, error } = await supabase
        .from('profiles')
        .select('*')
        .eq('id', user.id)
        .single()

      if (error || !profile) {
        window.location.href = '/login'
        return
      }

      if (profile.role === 'user' && !profile.paid) {
        await supabase.auth.signOut()
        window.location.href = '/login?payment=required'
        return
      }

      initializePortal(user, profile)
    })

    function initializePortal(user, profile) {
      const getInitials = (name) => name
        ? name.split(' ').map(n => n[0]).join('').slice(0,2).toUpperCase()
        : 'RS'

      const getFamilyPlanTitle = (name) => name
        ? `${name.split(' ').slice(-1)[0]} Family Plan`
        : 'Your Family Plan'

      const getPortalStateLabel = (value) => value || 'Not added yet'
      const getProfileEmail = () => profile.email || user.email || ''
      const initials = getInitials(profile.full_name)

      const app = document.getElementById('app')

      app.innerHTML = `
        <div class="portal-root">

          <nav class="portal-nav">
            <div class="nav-left" onclick="window.location.href='/'">
              <div class="shield-icon"></div>
              <span class="brand">Retirement <span>Shield</span></span>
            </div>

            <div class="nav-right">
              <span class="badge">${profile.role.toUpperCase()} PORTAL</span>

              <div class="user-menu">
                <div class="avatar">${initials}</div>
                <div class="user-info">
                  <span class="user-name" id="portalUserName">${profile.full_name}</span>
                  <span class="user-role">${profile.role}</span>
                </div>
                <button id="logoutBtn" class="logout-btn">Sign Out</button>
              </div>
            </div>
          </nav>
 ${profile.role === 'user' ? `
          <section class="hero">
            <div class="hero-inner">
              <div class="hero-label">
                <span class="line"></span>
                Your Retirement Action Plan
              </div>

              <div class="hero-card">
                <div class="progress-wrap">
                  <div class="progress-ring">
                    <div class="progress-value">65%</div>
                    <div class="progress-label">Complete</div>
                  </div>
                </div>
  
                <div class="hero-main">
                  <h1 id="portalFamilyPlanTitle">${getFamilyPlanTitle(profile.full_name)}</h1>
                  <p class="subtext">Prepared following your consultation with Lewis on February 18, 2026</p>

               
                  <div class="status-badges">
                    <span class="badge-complete">1 Completed</span>
                    <span class="badge-progress">2 In Progress</span>
                    <span class="badge-queued">2 Queued</span>
                  </div>
              
                </div>

                <div class="review-box">
                  <div class="review-label">Next Plan Review</div>
                  <div class="review-date">August 2026</div>
                  <div class="review-sub">6-month check-in</div>
                </div>
              </div>
            </div>
          </section>
    ` : ''}
          <div class="tabs-wrap">
            <div class="tabs">
              ${profile.role === 'admin' ? `
  <button class="tab active" data-tab="users">Users</button>
  <button class="tab" data-tab="tasks">Action Tasks</button>
  <button class="tab" data-tab="add-users">Add Users</button>
  <button class="tab" data-tab="assign-referrals">Assign Referral Members</button>
  <button class="tab" data-tab="team-members">Team Members</button>
  <button class="tab" data-tab="articles">Articles</button>
` : profile.role === 'referral' ? `
  <button class="tab active" data-tab="assigned-members">Assigned Members</button>
` : `
  <button class="tab active" data-tab="action">Action Plan</button>
 
  <button class="tab" data-tab="documents">Documents</button>
  <button class="tab" data-tab="tools">Tools</button>
   <button class="tab" data-tab="profile">Profile</button>
  <button class="tab" data-tab="team">Your Team</button>
  <button class="tab" data-tab="timeline">Timeline</button>
`}
            </div>
            <div class="tab-underline"></div>
          </div>

          <div class="content-wrap">
            <div id="portalContent"></div>
          </div>

          <footer class="portal-footer">
            © 2026 <strong>Retirement Shield</strong> · Educational use only
          </footer>

        </div>
      `

      document.getElementById('logoutBtn').addEventListener('click', async () => {
        await supabase.auth.signOut()
        window.location.href = '/'
      })

      const contentDiv = document.getElementById('portalContent')

      if (profile.role === 'user') {

        let actionPlan = [];
        let actionPlanLoaded = false;
        const userTabCache = {
          reports: null,
          reportsPromise: null,
          team: null,
          teamPromise: null,
          profileMarkup: null
        };
        const PROFILE_STATE_OPTIONS = [
          ['','Select your state'],
          ['Alabama','Alabama'],['Alaska','Alaska'],['Arizona','Arizona'],['Arkansas','Arkansas'],['California','California'],
          ['Colorado','Colorado'],['Connecticut','Connecticut'],['Delaware','Delaware'],['Florida','Florida'],['Georgia','Georgia'],
          ['Hawaii','Hawaii'],['Idaho','Idaho'],['Illinois','Illinois'],['Indiana','Indiana'],['Iowa','Iowa'],['Kansas','Kansas'],
          ['Kentucky','Kentucky'],['Louisiana','Louisiana'],['Maine','Maine'],['Maryland','Maryland'],['Massachusetts','Massachusetts'],
          ['Michigan','Michigan'],['Minnesota','Minnesota'],['Mississippi','Mississippi'],['Missouri','Missouri'],['Montana','Montana'],
          ['Nebraska','Nebraska'],['Nevada','Nevada'],['New Hampshire','New Hampshire'],['New Jersey','New Jersey'],['New Mexico','New Mexico'],
          ['New York','New York'],['North Carolina','North Carolina'],['North Dakota','North Dakota'],['Ohio','Ohio'],['Oklahoma','Oklahoma'],
          ['Oregon','Oregon'],['Pennsylvania','Pennsylvania'],['Rhode Island','Rhode Island'],['South Carolina','South Carolina'],
          ['South Dakota','South Dakota'],['Tennessee','Tennessee'],['Texas','Texas'],['Utah','Utah'],['Vermont','Vermont'],
          ['Virginia','Virginia'],['Washington','Washington'],['West Virginia','West Virginia'],['Wisconsin','Wisconsin'],['Wyoming','Wyoming'],
          ['District of Columbia','District of Columbia']
        ];

        function renderTabLoading(message = 'Loading...') {
          contentDiv.innerHTML = `
            <div class="doc-card">
              <div class="doc-body">
                <p>${message}</p>
              </div>
            </div>
          `;
        }

        async function getLatestSingle(table, selectFields) {
          const { data } = await supabase
            .from(table)
            .select(selectFields)
            .eq('user_id', user.id)
            .order('created_at', { ascending: false })
            .limit(1)
            .maybeSingle();

          return data ?? null;
        }

        async function getUserReportsSnapshot({ force = false } = {}) {
          if (!force && userTabCache.reports) return userTabCache.reports;
          if (!force && userTabCache.reportsPromise) return userTabCache.reportsPromise;

          userTabCache.reportsPromise = (async () => {
            const [
              familyPlanQuizReport,
              widowsPlaybookReport,
              legacyWidowsPlaybookResult,
              homeEquityReport,
              emergencyBinderReport,
              retirementPaycheckReport,
              retirementRunwayReport,
              incomeShieldReport,
              inflationErosionReport,
              irmaaGuardReport,
              rmdCalendarReport,
              annuityXrayReport,
              unclaimedPropertyReport,
              relocationReport,
              inheritanceCollisionReport,
              afterDeathChecklistReport,
              shieldBriefReport,
              dividendWatchReport,
              estateWatchReport
            ] = await Promise.all([
              getLatestSingle('family-plan-quiz-data', 'id, created_at'),
              getLatestSingle('widows_playbook_reports', 'id, created_at'),
              getLatestSingle('widows-playbook-data', 'id, created_at'),
              getLatestSingle('home_equity_reports', 'id, created_at, full_address'),
              getLatestSingle('emergency_binder_reports', 'id, created_at, report_title, household_label, state_name'),
              getLatestSingle('retirement_paycheck_reports', 'id, created_at, report_title, full_name, county_name, state_name'),
              getLatestSingle('retirement_runway_reports', 'id, created_at, report_title, full_name, county_name, state_name'),
              getLatestSingle('income_shield_reports', 'id, created_at, report_title, full_name, county_name, state_name'),
              getLatestSingle('inflation_erosion_reports', 'id, created_at, report_title, full_name, county_name, state_name'),
              getLatestSingle('irmaa_guard_reports', 'id, created_at, report_title, full_name, county_name, state_name'),
              getLatestSingle('rmd_calendar_reports', 'id, created_at, report_title, full_name, county_name, state_name'),
              getLatestSingle('annuity_xray_reports', 'id, created_at, report_title, full_name'),
              getLatestSingle('unclaimed_property_reports', 'id, created_at, report_title, full_name, state_name, proof_level'),
              getLatestSingle('retirement_relocation_reports', 'id, created_at, report_title, current_state_name, primary_destination_state_name'),
              getLatestSingle('inheritance_collision_reports', 'id, created_at, report_title, full_name, state_name'),
              getLatestSingle('after_death_checklist_reports', 'id, created_at, report_title, full_name, state_name'),
              getLatestSingle('shield_brief_reports', 'id, created_at, report_title, full_name, state_name, county_name, generated_month, segment_label'),
              getLatestSingle('dividend_watch_reports', 'id, created_at, report_title, full_name, portfolio_label, holdings_count'),
              getLatestSingle('estate_watch_reports', 'id, created_at, report_title, full_name, state_name, quiz_profile, tracked_change_count')
            ]);

            const snapshot = {
              familyPlanQuizReport,
              widowsReportResolved: widowsPlaybookReport || legacyWidowsPlaybookResult,
              homeEquityReport,
              emergencyBinderReport,
              retirementPaycheckReport,
              retirementRunwayReport,
              incomeShieldReport,
              inflationErosionReport,
              irmaaGuardReport,
              rmdCalendarReport,
              annuityXrayReport,
              unclaimedPropertyReport,
              relocationReport,
              inheritanceCollisionReport,
              afterDeathChecklistReport,
              shieldBriefReport,
              dividendWatchReport,
              estateWatchReport
            };

            userTabCache.reports = snapshot;
            userTabCache.reportsPromise = null;
            return snapshot;
          })();

          return userTabCache.reportsPromise;
        }

        async function getTeamSnapshot({ force = false } = {}) {
          if (!force && userTabCache.team) return userTabCache.team;
          if (!force && userTabCache.teamPromise) return userTabCache.teamPromise;

          userTabCache.teamPromise = (async () => {
            const { data: assignments } = await supabase
              .from('referral_assignments')
              .select('referral_id')
              .eq('user_id', user.id);

            if (!assignments || assignments.length === 0) {
              const emptyState = { assignments: [], consultants: [] };
              userTabCache.team = emptyState;
              userTabCache.teamPromise = null;
              return emptyState;
            }

            const referralIds = assignments.map(a => a.referral_id);
            const { data: consultants } = await supabase
              .from('profiles')
              .select('id, full_name, email')
              .in('id', referralIds);

            const teamState = { assignments, consultants: consultants || [] };
            userTabCache.team = teamState;
            userTabCache.teamPromise = null;
            return teamState;
          })();

          return userTabCache.teamPromise;
        }

        function prefetchUserPortalTabs() {
          getUserReportsSnapshot().catch(() => {});
          getTeamSnapshot().catch(() => {});
        }

        function refreshPortalIdentityUI() {
          const initialsValue = getInitials(profile.full_name);
          const userNameEl = document.getElementById('portalUserName');
          const familyPlanTitleEl = document.getElementById('portalFamilyPlanTitle');
          const avatarEl = document.querySelector('.avatar');

          if (userNameEl) userNameEl.textContent = profile.full_name || 'Retirement Shield Member';
          if (familyPlanTitleEl) familyPlanTitleEl.textContent = getFamilyPlanTitle(profile.full_name);
          if (avatarEl) avatarEl.textContent = initialsValue;
        }

        function renderProfile() {
          const memberSince = profile.created_at
            ? new Date(profile.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })
            : 'Recently joined';
          const stateLabel = getPortalStateLabel(profile.state);
          const saveStatusMarkup = userTabCache.profileMarkup || '';

          contentDiv.innerHTML = `
            <div class="profile-layout">
              <section class="profile-hero-card">
                <div class="profile-hero-copy">
                  <div class="profile-kicker">Member Profile</div>
                  <h2>Keep your portal details current.</h2>
                  <p>Your profile is what the portal uses to personalize saved tools, state-specific planning views, and household-facing documents. Update it here and the rest of the portal follows along.</p>
                  <div class="profile-pill-row">
                    <span class="profile-pill">Role: ${profile.role}</span>
                    <span class="profile-pill">State: ${stateLabel}</span>
                    <span class="profile-pill">Member since ${memberSince}</span>
                  </div>
                </div>
                <div class="profile-identity-card">
                  <div class="profile-avatar-lg">${getInitials(profile.full_name)}</div>
                  <div class="profile-identity-name">${profile.full_name || 'Retirement Shield Member'}</div>
                  <div class="profile-identity-email">${getProfileEmail() || 'No email on file'}</div>
                  <div class="profile-identity-meta">Household portal profile</div>
                </div>
              </section>

              <div class="profile-grid">
                <section class="doc-card profile-card">
                  <div class="doc-header profile-card-head">
                    <div class="doc-icon">👤</div>
                    <div>
                      <h3>Edit Your Details</h3>
                      <div class="doc-meta">These fields update your portal identity and state-based personalization.</div>
                    </div>
                  </div>

                  ${saveStatusMarkup}

                  <form id="profileForm" class="profile-form">
                    <div class="profile-form-grid">
                      <label class="profile-field">
                        <span class="profile-label">Full Name</span>
                        <input id="profileFullName" class="profile-input" type="text" value="${profile.full_name ?? ''}" placeholder="e.g. Margaret Thomas">
                      </label>
                      <label class="profile-field">
                        <span class="profile-label">Email Address</span>
                        <input id="profileEmail" class="profile-input" type="email" value="${getProfileEmail()}" placeholder="name@example.com">
                      </label>
                      <label class="profile-field profile-field-full">
                        <span class="profile-label">Primary State</span>
                        <select id="profileState" class="profile-input">
                          ${PROFILE_STATE_OPTIONS.map(([value, label]) => `<option value="${value}" ${profile.state === value ? 'selected' : ''}>${label}</option>`).join('')}
                        </select>
                      </label>
                    </div>

                    <div class="profile-actions">
                      <button type="submit" class="view-pdf-btn" id="saveProfileBtn">Save Profile</button>
                    </div>
                  </form>
                </section>

                <section class="doc-card profile-card">
                  <div class="doc-header profile-card-head">
                    <div class="doc-icon">🧭</div>
                    <div>
                      <h3>How Your Profile Is Used</h3>
                      <div class="doc-meta">A quick snapshot of what this information influences inside Retirement Shield.</div>
                    </div>
                  </div>
                  <div class="profile-usage-list">
                    <div class="profile-usage-item">
                      <strong>Portal identity</strong>
                      <span>Your name and email appear across the header, saved reports, and profile summary views.</span>
                    </div>
                    <div class="profile-usage-item">
                      <strong>State guidance</strong>
                      <span>Your state helps prefill state-driven tools and keeps legal or planning content pointed at the right jurisdiction.</span>
                    </div>
                    <div class="profile-usage-item">
                      <strong>Household continuity</strong>
                      <span>Keeping this current makes shared family documents and saved outputs easier for a spouse or adult child to understand later.</span>
                    </div>
                  </div>
                </section>
              </div>
            </div>
          `;

          const profileForm = document.getElementById('profileForm');
          if (profileForm) {
            profileForm.addEventListener('submit', async (event) => {
              event.preventDefault();

              const saveBtn = document.getElementById('saveProfileBtn');
              const fullName = document.getElementById('profileFullName')?.value.trim() || '';
              const email = document.getElementById('profileEmail')?.value.trim() || '';
              const state = document.getElementById('profileState')?.value || '';

              if (!fullName) {
                userTabCache.profileMarkup = `<div class="profile-alert error">Please enter your full name before saving.</div>`;
                renderProfile();
                return;
              }

              if (!email) {
                userTabCache.profileMarkup = `<div class="profile-alert error">Please enter an email address before saving.</div>`;
                renderProfile();
                return;
              }

              if (saveBtn) {
                saveBtn.disabled = true;
                saveBtn.textContent = 'Saving...';
              }

              const { error } = await supabase
                .from('profiles')
                .update({
                  full_name: fullName,
                  email,
                  state
                })
                .eq('id', user.id);

              if (error) {
                userTabCache.profileMarkup = `<div class="profile-alert error">We could not save your profile just now. Please try again.</div>`;
                renderProfile();
                return;
              }

              profile.full_name = fullName;
              profile.email = email;
              profile.state = state;
              userTabCache.profileMarkup = `<div class="profile-alert success">Your profile has been updated.</div>`;
              refreshPortalIdentityUI();
              renderProfile();
            });
          }
        }

        async function loadActionPlan() {

          // 1. Load global templates
          const { data: templates } = await supabase
            .from('action_plan_templates')
            .select('*')
            .order('created_at', { ascending: true });

          if (!templates) {
            actionPlan = [];
            return;
          }

          const enrichedPlans = [];

          for (const template of templates) {

            // 2. Load template subtasks
            const { data: subtasks } = await supabase
              .from('action_plan_template_subtasks')
              .select('*')
              .eq('template_id', template.id)
              .order('created_at', { ascending: true });

            // 3. Load user progress for those subtasks
            const { data: progress } = await supabase
              .from('user_subtask_progress')
              .select('*')
              .eq('user_id', user.id);

            const mergedSubtasks = (subtasks || []).map(st => {
              const match = progress?.find(p => p.subtask_id === st.id);
              return {
                id: st.id,
                label: st.label,
                done: match ? match.done : false
              };
            });

            // 4. Auto-calc status from subtasks
            let status = 'queued';
            if (mergedSubtasks.length) {
              if (mergedSubtasks.every(s => s.done)) status = 'complete';
              else if (mergedSubtasks.some(s => s.done)) status = 'progress';
            }

            enrichedPlans.push({
              id: template.id,
              title: template.title,
              category: template.category,
              details: template.details,
              status,
              subtasks: mergedSubtasks
            });
          }

          actionPlan = enrichedPlans;
          actionPlanLoaded = true;
        }

        function calculateStats() {
          const completed = actionPlan.filter(a => a.status === 'complete').length
          const inProgress = actionPlan.filter(a => a.status === 'progress').length
          const queued = actionPlan.filter(a => a.status === 'queued').length
          return { completed, inProgress, queued }
        }

        async function renderPlan() {
          const stats = calculateStats()

          document.querySelector('.badge-complete').innerText = `${stats.completed} Completed`
          document.querySelector('.badge-progress').innerText = `${stats.inProgress} In Progress`
          document.querySelector('.badge-queued').innerText = `${stats.queued} Queued`

          // Preserve which card is open
          const openCard = document.querySelector('.plan-card.open')
          const openId = openCard ? openCard.dataset.id : null

          contentDiv.innerHTML = actionPlan.map(item => `
            <div class="plan-card ${item.status}" data-id="${item.id}">
              <div class="plan-header">
                <div class="plan-left">
                  <div class="plan-number"></div>
                  <div>
                    <h3>${item.title}</h3>
                    <div class="plan-category">${item.category ?? ''}</div>
                  </div>
                </div>
                <div class="plan-status">${item.status.replace('_',' ')}</div>
              </div>
              <div class="plan-body">
                <p>${item.details ?? ''}</p>
                ${item.subtasks.length > 0 ? `
                  <div class="subtasks">
                    ${item.subtasks.map((s, i) => `
                      <label class="subtask ${s.done ? 'done' : ''}">
                        <input type="checkbox" data-parent="${item.id}" data-index="${i}" ${s.done ? 'checked' : ''}>
                        <span class="custom-check"></span>
                        <span class="task-label">${s.label}</span>
                      </label>
                    `).join('')}
                  </div>
                ` : ''}
              </div>
            </div>
          `).join('')

          attachEvents()

          if (openId) {
            const restored = document.querySelector(`.plan-card[data-id="${openId}"]`)
            if (restored) restored.classList.add('open')
          }
        }

        // --- DOCUMENTS TAB FUNCTIONALITY ---
        async function renderDocuments() {
          if (!userTabCache.reports) {
            renderTabLoading('Loading your saved documents...');
          }

          const {
            familyPlanQuizReport,
            widowsReportResolved,
            homeEquityReport,
            emergencyBinderReport,
            retirementPaycheckReport,
            retirementRunwayReport,
            incomeShieldReport,
            inflationErosionReport,
            irmaaGuardReport,
            rmdCalendarReport,
            annuityXrayReport,
            unclaimedPropertyReport,
            relocationReport,
            inheritanceCollisionReport,
            afterDeathChecklistReport,
            shieldBriefReport,
            dividendWatchReport,
            estateWatchReport
          } = await getUserReportsSnapshot();

          contentDiv.innerHTML = `
            <div class="documents-search-wrap">
             <input
                id="documentSearch"
                class="portal-search"
                type="text"
                placeholder="Search documents by title, type, or description..."
              />
            </div>

            <div id="documentSearchEmpty" class="doc-card" style="margin-top:24px;display:none;">
              <div class="doc-body">
                <p>No documents match that search yet.</p>
              </div>
            </div>

            <div class="doc-card document-search-item" data-doc-search="estate planning assessment personalized strategy report trust structure beneficiary designations asset protection retirement income coordination">
              <div class="doc-header">
                <div class="doc-icon">📄</div>
                <div>
                  <h3>Estate Planning Assessment</h3>
                  <div class="doc-meta">Generated March 4, 2026 · Personalized Strategy Report</div>
                </div>
              </div>

              <div class="doc-body">
                <p>
                  This comprehensive estate planning report outlines your trust structure,
                  beneficiary designations, asset protection positioning, and retirement
                  income coordination strategy.
                </p>
              </div>

              <div class="doc-actions">
                <button class="view-pdf-btn" id="viewPdfBtn">View My PDF</button>
              </div>
            </div>

            ${familyPlanQuizReport ? `
              <div class="doc-card document-search-item" data-doc-search="is your family's plan actually ready family readiness quiz results completed family plan quiz saved results" style="margin-top:24px;">
                <div class="doc-header">
                  <div class="doc-icon">🛡️</div>
                  <div>
                    <h3>Is Your Family's Plan Actually Ready?</h3>
                    <div class="doc-meta">Generated ${new Date(familyPlanQuizReport.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · Family Readiness Quiz Results</div>
                  </div>
                </div>

                <div class="doc-body">
                  <p>
                    Your completed Family Plan Quiz is saved and ready to review.
                    Open it to jump directly to the finished results.
                  </p>
