}
.testimonial-problem {
  font-family: 'DM Mono', monospace; font-size: 0.6rem; text-transform: uppercase;
  letter-spacing: 0.14em; color: var(--text-muted); margin-bottom: 9px; display: block;
}
.testimonial-problem-text {
  font-family: 'Playfair Display', serif; font-size: 1.02rem; font-style: italic; font-weight: 700;
  color: var(--navy); line-height: 1.3; margin-bottom: 18px;
  padding-bottom: 16px; border-bottom: 1px solid var(--rule);
}
.testimonial-discovery { font-size: 0.87rem; color: var(--text-secondary); line-height: 1.7; margin-bottom: 14px; }
.testimonial-discovery strong { color: var(--text-primary); }
.testimonial-action {
  font-size: 0.84rem; color: var(--text-secondary); line-height: 1.65; margin-bottom: 18px;
  padding: 14px 16px; background: rgba(200,130,26,0.07); border-left: 2px solid var(--amber);
}
.testimonial-attr {
  font-family: 'DM Mono', monospace; font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);
}

/* ══════════════════════════════════════════════════
   TRUST BAR
══════════════════════════════════════════════════ */
.trust-bar { background: var(--white); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); padding: 32px 48px; }
.trust-bar-inner { display: flex; align-items: center; gap: 36px; flex-wrap: wrap; }
.trust-label { font-family: 'DM Mono', monospace; font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--text-muted); white-space: nowrap; }
.trust-divider { width: 1px; height: 26px; background: var(--rule); flex-shrink: 0; }
.trust-item { display: flex; align-items: center; gap: 8px; font-size: 0.8rem; color: var(--text-secondary); }
.trust-item svg { color: var(--amber); flex-shrink: 0; }

/* ══════════════════════════════════════════════════
   NEWSLETTER
══════════════════════════════════════════════════ */
.newsletter-section {
  background: var(--amber); padding: 72px 48px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: start;
}
.newsletter-content h2 {
  font-family: 'Playfair Display', serif; font-size: clamp(1.7rem, 2.4vw, 2.3rem);
  font-weight: 900; line-height: 1.1; color: var(--navy); margin-bottom: 14px;
}
.newsletter-content h2 em { font-style: italic; }
.newsletter-lead { font-size: 0.93rem; color: var(--navy); opacity: 0.8; line-height: 1.72; margin-bottom: 20px; }
.newsletter-format {
  font-family: 'DM Mono', monospace; font-size: 0.62rem; text-transform: uppercase;
  letter-spacing: 0.12em; color: var(--navy); opacity: 0.55; line-height: 1.8;
  border-top: 1px solid rgba(13,27,42,0.2); padding-top: 16px;
}
.newsletter-format strong { opacity: 0.85; }
.email-preview {
  background: var(--white); border: 1px solid rgba(13,27,42,0.12);
  box-shadow: 0 4px 24px rgba(13,27,42,0.1); margin-bottom: 20px;
}
.email-preview-header {
  background: #f0f4f8; border-bottom: 1px solid rgba(13,27,42,0.1);
  padding: 12px 16px; display: flex; align-items: center; gap: 8px;
}
.email-dot { width: 10px; height: 10px; border-radius: 50%; }
.email-dot-red { background: #ff5f57; }
.email-dot-yellow { background: #ffbc2e; }
.email-dot-green { background: #28c840; }
.email-subject-row { padding: 14px 18px 0; }
.email-from { font-family: 'DM Mono', monospace; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 4px; }
.email-subject {
  font-family: 'Source Serif 4', serif; font-size: 0.95rem; font-weight: 600;
  color: var(--text-primary); line-height: 1.3; padding-bottom: 14px;
  border-bottom: 1px solid rgba(13,27,42,0.08); margin-bottom: 14px;
}
.email-body-preview { padding: 0 18px 18px; font-size: 0.8rem; color: var(--text-secondary); line-height: 1.7; }
.email-body-preview p { margin-bottom: 8px; }
.email-body-preview .read-more { font-family: 'DM Mono', monospace; font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--amber); }
.newsletter-form { display: flex; flex-direction: column; gap: 10px; }
.newsletter-form input {
  background: rgba(255,255,255,0.4); border: 1.5px solid rgba(13,27,42,0.22);
  padding: 14px 18px; font-family: 'Source Serif 4', serif; font-size: 1rem;
  color: var(--navy); outline: none; transition: background 0.2s, border-color 0.2s;
  min-height: var(--tap-min); border-radius: 0; -webkit-appearance: none;
}
.newsletter-form input::placeholder { color: rgba(13,27,42,0.4); }
.newsletter-form input:focus { background: rgba(255,255,255,0.6); border-color: var(--navy); }
.newsletter-form button {
  background: var(--navy); color: var(--amber-light); font-family: 'DM Mono', monospace;
  font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.14em;
  padding: 16px; border: none; cursor: pointer; transition: background 0.2s;
  min-height: var(--tap-min); -webkit-appearance: none; border-radius: 0;
}
.newsletter-form button:hover { background: var(--navy-light); }
.newsletter-legal {
  font-family: 'DM Mono', monospace; font-size: 0.56rem;
  color: rgba(13,27,42,0.42); text-transform: uppercase; letter-spacing: 0.08em; line-height: 1.7;
}

/* ══════════════════════════════════════════════════
   FOOTER
══════════════════════════════════════════════════ */
footer { background: var(--navy); padding: 60px 48px 40px; color: rgba(245,240,232,0.45); }
.footer-top {
  display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 44px; padding-bottom: 40px;
  border-bottom: 1px solid rgba(200,184,154,0.12); margin-bottom: 28px;
}
.footer-brand-name {
  font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700;
  color: var(--cream); margin-bottom: 12px; display: flex; align-items: center; gap: 10px;
}
.footer-mission { font-size: 0.8rem; line-height: 1.7; margin-bottom: 14px; }
.footer-col h5 {
  font-family: 'DM Mono', monospace; font-size: 0.58rem; text-transform: uppercase;
  letter-spacing: 0.16em; color: var(--amber-light); margin-bottom: 14px;
}
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.footer-col ul li a { color: rgba(245,240,232,0.45); text-decoration: none; font-size: 0.82rem; transition: color 0.2s; min-height: var(--tap-min); display: flex; align-items: center; }
.footer-col ul li a:hover { color: var(--cream); }
.footer-compliance {
  font-family: 'DM Mono', monospace; font-size: 0.56rem; line-height: 1.75;
  color: rgba(245,240,232,0.24); text-transform: uppercase; letter-spacing: 0.06em;
  border-top: 1px solid rgba(200,184,154,0.08); padding-top: 22px;
}

/* ══════════════════════════════════════════════════
   STICKY MOBILE CTA BAR
══════════════════════════════════════════════════ */
.sticky-cta-bar {
  display: none; /* shown only on mobile */
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--navy); border-top: 2px solid var(--amber);
  padding: 12px 20px; z-index: 150;
  flex-direction: column; gap: 4px;
  box-shadow: 0 -4px 20px rgba(13,27,42,0.35);
}
.sticky-cta-bar a {
  background: var(--amber); color: var(--navy);
  font-family: 'DM Mono', monospace; font-size: 0.72rem;
  text-transform: uppercase; letter-spacing: 0.12em;
  padding: 14px; text-align: center; text-decoration: none;
  display: block; font-weight: 400;
}
.sticky-cta-bar small {
  font-family: 'DM Mono', monospace; font-size: 0.52rem;
  color: rgba(245,240,232,0.4); text-transform: uppercase; letter-spacing: 0.1em;
  text-align: center; display: block;
}

/* ══════════════════════════════════════════════════
   SCROLL REVEAL
══════════════════════════════════════════════════ */
.reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.65s ease, transform 0.65s ease; }
.reveal.visible { opacity: 1; transform: none; }

/* ══════════════════════════════════════════════════
   ████ MOBILE RESPONSIVE — 768px and below ████
══════════════════════════════════════════════════ */
@media (max-width: 768px) {

  /* Base */
  body { font-size: 17px; } /* Never below 16px for this audience */

  /* ── Masthead ── */
  .masthead { padding: 0 20px; }
  nav.desktop-nav { display: none; }
  .hamburger { display: flex; }
  .brand-tagline { display: none; } /* keeps header tight on small screens */

  /* ── Ticker ── */
  .ticker-fact { font-size: 0.75rem; }

  /* ── Hero: single column, full-width ── */
  .hero {
    grid-template-columns: 1fr;
    padding: 48px 20px 0;
    gap: 0;
  }
  .hero::before { display: none; } /* remove heavy radial gradient on mobile */
  .hero-eyebrow { font-size: 0.6rem; margin-bottom: 16px; }
  .hero-headline {
    font-size: clamp(2.2rem, 10vw, 3rem);
    margin-bottom: 20px;
  }
  .hero-body { font-size: 1rem; max-width: 100%; margin-bottom: 20px; }
  .hero-body:last-of-type { margin-bottom: 28px; }
  .hero-actions {
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
    padding-bottom: 40px;
  }
  .btn-primary { width: 100%; text-align: center; padding: 18px 20px; font-size: 0.72rem; }
  .btn-ghost { width: 100%; justify-content: center; text-align: center; border: 1px solid rgba(245,240,232,0.28); border-bottom: 1px solid rgba(245,240,232,0.28); padding: 16px; }
  /* Hero aside: strip border, run horizontal scroll of stat cards */
  .hero-aside {
    border-left: none;
    border-top: 1px solid rgba(200,184,154,0.2);
    padding-left: 0;
    padding-top: 28px;
    padding-bottom: 40px;
    display: flex;
    gap: 12px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .hero-aside::-webkit-scrollbar { display: none; }
  .stat-card {
    flex-shrink: 0;
    width: 220px;
    margin-bottom: 0;
    padding: 20px 18px 18px;
  }
  .stat-number { font-size: 2.2rem; }

  /* ── Estate Gateway ── */
  .estate-gateway { padding: 44px 20px; }
  .estate-gateway-inner { grid-template-columns: 1fr; gap: 36px; }
  .estate-gateway h2 { font-size: clamp(1.6rem, 7vw, 2rem); }
  .estate-gateway p { font-size: 0.93rem; }
  .checklist-item { padding: 16px 14px; }
  .check-text { font-size: 0.9rem; }
  .check-text span { font-size: 0.8rem; }
  .estate-cta-row { flex-direction: column; align-items: flex-start; gap: 16px; }
  .estate-cta-row .btn-primary { width: 100%; }

  /* ── Section rules ── */
  .section-rule { margin-bottom: 32px; }

  /* ── Quiz Banner ── */
  .quiz-banner {
    grid-template-columns: 1fr;
    gap: 40px;
    padding: 48px 20px;
  }
  .quiz-banner::before { display: none; }
  .quiz-content h2 { font-size: clamp(1.6rem, 7vw, 2rem); }
  .quiz-preview { padding: 24px 20px; }
  .quiz-q { font-size: 0.97rem; }
  .quiz-option { font-size: 0.9rem; padding: 16px 14px; min-height: 52px; }

  /* ── Gap Section ── */
  .gap-section { padding: 56px 20px; }
  .gap-intro { margin-bottom: 36px; }
  .gap-intro h2 { font-size: clamp(1.7rem, 7.5vw, 2.2rem); }
  .gap-grid {
    grid-template-columns: 1fr; /* single column stack */
    gap: 1px;
  }
  .gap-card { padding: 28px 20px 24px; }
  .gap-card h3 { font-size: 1.1rem; }

  /* ── Buckets ── */
  .buckets-section { padding: 48px 20px; }
  .buckets-grid {
    grid-template-columns: 1fr 1fr; /* 2-col grid */
    gap: 1px;
  }
  /* Make featured bucket span full width */
  .bucket-card.featured {
    grid-column: 1 / -1;
    margin: -1px;
    flex-direction: row;
    align-items: center;
    gap: 16px;
    padding: 22px 20px;
  }
  .bucket-card.featured .bucket-icon { margin-bottom: 0; font-size: 1.8rem; }
  .bucket-card.featured .bucket-desc { display: none; } /* hide on mobile to keep it tight */
  .bucket-card { padding: 22px 16px 18px; }
  .bucket-name { font-size: 0.88rem; }
  .bucket-desc { font-size: 0.73rem; display: none; } /* hide descriptions on mobile for density */
  .bucket-count { display: block; }

  /* ── Articles ── */
  .articles-section { padding: 56px 20px; }
  .articles-layout { grid-template-columns: 1fr; gap: 0; }
  .articles-sidebar { border-left: none; border-top: 1px solid var(--rule); padding-left: 0; padding-top: 36px; margin-top: 36px; }
  .article-featured h3 { font-size: 1.25rem; }
  .article-featured p { font-size: 0.9rem; }

  /* ── Margaret ── */
  .margaret-section { padding: 56px 20px; }
  .margaret-section::after { font-size: 14rem; bottom: -20px; right: -10px; }
  .pullquote { font-size: clamp(1.1rem, 5vw, 1.5rem); padding-left: 18px; }
  .pullquote-attr { padding-left: 18px; font-size: 0.58rem; }
  .margaret-body { font-size: 0.92rem; max-width: 100%; }

  /* ── Social Proof ── */
  .social-proof { padding: 56px 20px; }
  .testimonial-grid { grid-template-columns: 1fr; gap: 28px; }
  .testimonial-card { padding: 28px 22px 24px; }
  .testimonial-problem-text { font-size: 0.98rem; }

  /* ── Trust Bar ── */
  .trust-bar { padding: 28px 20px; }
  .trust-bar-inner { gap: 0; flex-direction: column; align-items: flex-start; }
  .trust-label { margin-bottom: 16px; }
  .trust-divider { display: none; }
  .trust-item { padding: 10px 0; border-bottom: 1px solid var(--rule-light); width: 100%; font-size: 0.85rem; min-height: 44px; }
  .trust-item:last-child { border-bottom: none; }

  /* ── Newsletter ── */
  .newsletter-section { grid-template-columns: 1fr; gap: 36px; padding: 48px 20px; }
  .newsletter-content h2 { font-size: clamp(1.5rem, 7vw, 2rem); }
  .newsletter-form input { font-size: 1rem; padding: 16px 18px; }
  .newsletter-form button { font-size: 0.72rem; padding: 18px; }
  /* Collapse email preview on mobile — space is precious */
  .email-body-preview { display: none; }
  .email-subject-row { padding-bottom: 14px; }

  /* ── Footer ── */
  footer { padding: 44px 20px 100px; } /* extra bottom padding for sticky CTA bar */
  .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
  .footer-col ul li a { min-height: 40px; font-size: 0.88rem; }

  /* ── Sticky CTA bar ── */
  .sticky-cta-bar { display: flex; }

  /* ── Disable heavy desktop animations on mobile for performance ── */
  .margaret-section::after { display: none; }
  .quiz-banner::before { display: none; }
}

/* ══════════════════════════════════════════════════
   SMALL PHONES — 480px and below
══════════════════════════════════════════════════ */
@media (max-width: 480px) {
  .hero-headline { font-size: clamp(2rem, 11vw, 2.6rem); }
  .hero-aside { gap: 10px; }
  .stat-card { width: 190px; }
  .buckets-grid { grid-template-columns: 1fr; }
  .bucket-card.featured { flex-direction: column; }
  .bucket-card.featured .bucket-desc { display: block; }
  .footer-top { grid-template-columns: 1fr; gap: 28px; }
  .testimonial-card { padding: 24px 18px 20px; }
}

/* ══════════════════════════════════════════════════
   TABLET — 769px to 1024px
══════════════════════════════════════════════════ */
@media (min-width: 769px) and (max-width: 1024px) {
  .masthead { padding: 0 32px; }
  nav.desktop-nav { gap: 18px; }
  nav.desktop-nav a:not(.nav-cta) { display: none; } /* hide interior links, keep CTA */
  .hero { padding: 56px 32px 0; grid-template-columns: 1fr 300px; gap: 40px; }
  .estate-gateway { padding: 52px 32px; }
  .estate-gateway-inner { gap: 40px; }
  .gap-section, .articles-section, .margaret-section, .social-proof { padding: 64px 32px; }
  .buckets-section { padding: 56px 32px; }
  .buckets-grid { grid-template-columns: repeat(3, 1fr); }
  .bucket-card:nth-child(n+4) { grid-column: auto; }
  .newsletter-section { padding: 56px 32px; gap: 48px; }
  footer { padding: 52px 32px 40px; }
  .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
  .quiz-banner { padding: 56px 32px; gap: 48px; }
  .gap-grid { grid-template-columns: 1fr 1fr; }
  .trust-bar { padding: 28px 32px; }
}

</style>
  </head>

